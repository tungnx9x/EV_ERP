@model EV_ERP.Models.ViewModels.Stock.WarehouseListViewModel
@{
    ViewData["Title"] = "Quản lý kho";
    bool canEdit = ViewBag.CanEdit == true;
    bool canDelete = ViewBag.CanDelete == true;
    var paged = Model.Paged;
}

<div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
    <div>
        <p class="text-muted small mb-0">Tổng cộng @paged.TotalCount kho</p>
    </div>
    @if (canEdit)
    {
        <a href="/Warehouse/Create" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i> Thêm kho
        </a>
    }
</div>

<!-- Filter bar -->
<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-3">
        <form method="get" asp-action="Index" class="row g-2 align-items-end">
            <div class="col-12 col-sm-6 col-lg-6">
                <label class="form-label small fw-semibold mb-1">Tìm kiếm</label>
                <div class="input-group input-group-sm">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" name="keyword" class="form-control"
                           placeholder="Tên, mã kho, địa chỉ..."
                           value="@Model.SearchKeyword" />
                </div>
            </div>
            <div class="col-6 col-sm-3 col-lg-3">
                <label class="form-label small fw-semibold mb-1">Trạng thái</label>
                <select name="status" class="form-select form-select-sm">
                    <option value="">Đang hoạt động</option>
                    <option value="inactive" selected="@(Model.FilterStatus == "inactive")">Vô hiệu</option>
                </select>
            </div>
            <div class="col-6 col-sm-3 col-lg-3 d-flex gap-1">
                <button type="submit" class="btn btn-primary btn-sm flex-fill">
                    <i class="bi bi-funnel me-1"></i> Lọc
                </button>
                <a href="/Warehouse" class="btn btn-outline-secondary btn-sm" title="Xóa bộ lọc">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Table -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (!paged.Items.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-archive" style="font-size: 3rem; opacity: 0.3;"></i>
                <p class="mt-2 mb-0">Không tìm thấy kho nào</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" style="font-size:0.875rem;">
                    <thead class="table-light">
                        <tr>
                            <th style="width:40px;">#</th>
                            <th>Kho</th>
                            <th class="d-none d-md-table-cell">Địa chỉ</th>
                            <th class="d-none d-lg-table-cell">Quản lý</th>
                            <th class="text-center">Vị trí</th>
                            <th class="d-none d-lg-table-cell text-center">Loại</th>
                            <th>Trạng thái</th>
                            <th style="width:110px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int idx = (paged.PageIndex - 1) * paged.PageSize + 1; }
                        @foreach (var w in paged.Items)
                        {
                            <tr>
                                <td class="text-muted small">@(idx++)</td>
                                <td>
                                    <div>
                                        <a href="/Warehouse/Detail/@w.WarehouseId"
                                           class="fw-semibold text-decoration-none text-dark link-hover">
                                            @w.WarehouseName
                                        </a>
                                        <div class="text-muted small">@w.WarehouseCode</div>
                                    </div>
                                </td>
                                <td class="d-none d-md-table-cell text-muted small">@w.Address</td>
                                <td class="d-none d-lg-table-cell text-muted small">@(w.ManagerName ?? "—")</td>
                                <td class="text-center">
                                    <span class="badge bg-light text-dark border">@w.LocationCount</span>
                                </td>
                                <td class="d-none d-lg-table-cell text-center">
                                    @if (w.IsVirtual)
                                    {
                                        <span class="badge bg-info-subtle text-info-emphasis rounded-pill">Ảo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-dark border rounded-pill">Thực</span>
                                    }
                                </td>
                                <td>
                                    @if (w.IsActive)
                                    {
                                        <span class="badge bg-success-subtle text-success-emphasis rounded-pill">
                                            <i class="bi bi-circle-fill me-1" style="font-size:0.45rem;vertical-align:middle;"></i>
                                            Hoạt động
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary-emphasis rounded-pill">
                                            <i class="bi bi-circle-fill me-1" style="font-size:0.45rem;vertical-align:middle;"></i>
                                            Vô hiệu
                                        </span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a href="/Warehouse/Detail/@w.WarehouseId"
                                           class="btn btn-sm btn-outline-secondary" title="Xem chi tiết">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (canEdit)
                                        {
                                            <a href="/Warehouse/Edit/@w.WarehouseId"
                                               class="btn btn-sm btn-outline-primary" title="Chỉnh sửa">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                        }
                                        @if (canDelete)
                                        {
                                            <button class="btn btn-sm @(w.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                                    title="@(w.IsActive ? "Vô hiệu hóa" : "Kích hoạt lại")"
                                                    onclick="toggleActive(@w.WarehouseId, '@w.WarehouseName.Replace("'", "\\'")', @w.IsActive.ToString().ToLower())">
                                                <i class="bi @(w.IsActive ? "bi-slash-circle" : "bi-check-circle")"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (paged.TotalPages > 1)
            {
                <nav class="d-flex justify-content-center py-3">
                    <ul class="pagination pagination-sm mb-0">
                        @if (paged.HasPrevious)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@BuildPageUrl(paged.PageIndex - 1)">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                            </li>
                        }
                        @for (int pg = 1; pg <= paged.TotalPages; pg++)
                        {
                            <li class="page-item @(pg == paged.PageIndex ? "active" : "")">
                                <a class="page-link" href="@BuildPageUrl(pg)">@pg</a>
                            </li>
                        }
                        @if (paged.HasNext)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@BuildPageUrl(paged.PageIndex + 1)">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        }
    </div>
</div>

@functions {
    string BuildPageUrl(int page)
    {
        var qs = new Dictionary<string, string?> {
            ["keyword"] = Model.SearchKeyword,
            ["status"] = Model.FilterStatus,
            ["page"] = page.ToString()
        };
        return "/Warehouse?" + string.Join("&", qs.Where(kv => !string.IsNullOrEmpty(kv.Value)).Select(kv => $"{kv.Key}={kv.Value}"));
    }
}

<style>
    .link-hover:hover { color: #2563eb !important; }
    .bg-success-subtle { background-color: #dcfce7 !important; }
    .text-success-emphasis { color: #166534 !important; }
    .bg-secondary-subtle { background-color: #f1f5f9 !important; }
    .text-secondary-emphasis { color: #475569 !important; }
    .bg-info-subtle { background-color: #e0f2fe !important; }
    .text-info-emphasis { color: #075985 !important; }
</style>

<script>
    function toggleActive(id, name, isActive) {
        var action = isActive ? 'vô hiệu hóa' : 'kích hoạt lại';
        if (!confirm('Bạn có chắc muốn ' + action + ' kho "' + name + '"?')) return;

        var form = new FormData();
        form.append('__RequestVerificationToken', getAntiForgeryToken());

        fetch('/Warehouse/ToggleActive/' + id, { method: 'POST', body: form })
            .then(r => r.json())
            .then(data => {
                if (data.Success) location.reload();
                else alert('Lỗi: ' + data.Message);
            });
    }

    function getAntiForgeryToken() {
        return document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
    }
</script>
@Html.AntiForgeryToken()
