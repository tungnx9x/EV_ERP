@model EV_ERP.Models.ViewModels.RFQs.RfqDetailViewModel
@using EV_ERP.Models.ViewModels.Quotations
@{
    ViewData["Title"] = Model.RfqNo;
    ViewData["Breadcrumbs"] = new List<BreadcrumbItem>
    {
        new("Trang chủ", "/"),
        new("Yêu cầu báo giá", "/Rfq"),
        new(Model.RfqNo)
    };
    bool canCreate = ViewBag.CanCreate == true;
    bool isManager = ViewBag.IsManager == true;
    int currentUserId = (int)(ViewBag.CurrentUserId ?? 0);
    bool isOwner = Model.CreatedBy == currentUserId;
    bool canManage = isOwner || isManager;
    var salesPersons = (List<SalesPersonOptionViewModel>?)ViewBag.SalesPersons ?? new();
}

<!-- Header -->
<div class="d-flex align-items-start justify-content-between mb-3 flex-wrap gap-2">
    <div class="d-flex align-items-center gap-3">
       @*  <a href="/Rfq" class="btn btn-sm btn-light border">
            <i class="bi bi-arrow-left"></i>
        </a> *@
        <div>
            <h5 class="mb-0 fw-bold">@Model.RfqNo</h5>
            <div class="text-muted small">
                <span class="badge bg-@(Model.StatusBadge)-subtle text-@(Model.StatusBadge)-emphasis rounded-pill">
                    <i class="bi bi-circle-fill me-1" style="font-size:0.4rem;vertical-align:middle;"></i>
                    @Model.StatusText
                </span>
                <span class="badge bg-@(Model.PriorityBadge)-subtle text-@(Model.PriorityBadge)-emphasis rounded-pill ms-1">
                    @Model.PriorityText
                </span>
            </div>
        </div>
    </div>

    @if (Model.Status == "INPROGRESS")
    {
        <div class="d-flex gap-1 flex-wrap">
            @if (canManage)
            {
                <a href="/Rfq/Edit/@Model.RfqId" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-pencil me-1"></i> Sửa
                </a>
            }
            @if (canCreate || canManage)
            {
                <div class="dropdown">
                    <button class="btn btn-sm btn-primary dropdown-toggle" type="button"
                            data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="bi bi-lightning-charge me-1"></i> Xử lý yêu cầu
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                        @if (Model.Quotations.Count == 0)
                        {
                            <li>
                                <a href="/Quotation/Create?rfqId=@Model.RfqId" class="dropdown-item text-success">
                                    <i class="bi bi-file-earmark-plus me-1"></i> Tạo báo giá
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item text-success" href="#" data-bs-toggle="modal" data-bs-target="#importQuotationModal">
                                    <i class="bi bi-file-earmark-arrow-up me-1"></i> Import báo giá
                                </a>
                            </li>
                        }
                        @if (canManage)
                        {
                             <li>
                                <a class="dropdown-item text-danger" href="#" onclick="doCancel()">
                                    <i class="bi bi-x-circle me-1"></i> Hủy
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            }
            
            @* @if (canCreate && Model.Quotations.Count == 0)
            {
                <a href="/Quotation/Create?rfqId=@Model.RfqId" class="btn btn-sm btn-primary">
                    <i class="bi bi-file-earmark-plus me-1"></i> Tạo báo giá
                </a>
                <button type="button" class="btn btn-sm btn-outline-success" data-bs-toggle="modal" data-bs-target="#importQuotationModal">
                    <i class="bi bi-file-earmark-arrow-up me-1"></i> Import báo giá
                </button>
            }
            @if (canManage)
            {
                <button class="btn btn-sm btn-outline-danger" onclick="doCancel()">
                    <i class="bi bi-x-circle me-1"></i> Hủy
                </button>
            } *@
        </div>
    }
</div>

<div class="row g-3">
    <!-- LEFT: Info -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <h6 class="fw-semibold text-muted text-uppercase mb-3" style="font-size:0.72rem;letter-spacing:.06em;">
                    Thông tin khách hàng
                </h6>
                <div class="mb-2">
                    <div class="fw-semibold">@Model.CustomerName</div>
                    <div class="text-muted small">@Model.CustomerCode</div>
                </div>
                @if (Model.ContactName != null)
                {
                    <div class="d-flex align-items-center gap-2 mb-1 small">
                        <i class="bi bi-person text-muted" style="width:16px;"></i>
                        <span>@Model.ContactName</span>
                    </div>
                }
                @if (Model.ContactPhone != null)
                {
                    <div class="d-flex align-items-center gap-2 mb-1 small">
                        <i class="bi bi-telephone text-muted" style="width:16px;"></i>
                        <span>@Model.ContactPhone</span>
                    </div>
                }
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <h6 class="fw-semibold text-muted text-uppercase mb-3" style="font-size:0.72rem;letter-spacing:.06em;">
                    Thông tin RFQ
                </h6>
                <div class="row g-2 small">
                    <div class="col-6">
                        <div class="text-muted">Ngày yêu cầu</div>
                        <div class="fw-semibold">@Model.RequestDate.ToString("dd/MM/yyyy")</div>
                    </div>
                    <div class="col-6">
                        <div class="text-muted">Hạn xử lý</div>
                        <div class="fw-semibold @(Model.Deadline < DateTime.Now && Model.Status == "INPROGRESS" ? "text-danger" : "")">
                            @Model.Deadline.ToString("dd/MM/yyyy HH:mm")
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="text-muted">Phân công</div>
                        <div class="fw-semibold">@(Model.AssignedToName ?? "Chưa phân công")</div>
                    </div>
                    <div class="col-6">
                        <div class="text-muted">Người tạo</div>
                        <div class="fw-semibold">@Model.CreatedByName</div>
                    </div>
                    <div class="col-6">
                        <div class="text-muted">Ngày tạo</div>
                        <div class="fw-semibold">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                    </div>
                    @if (Model.CompletedAt.HasValue)
                    {
                        <div class="col-6">
                            <div class="text-muted">Hoàn tất lúc</div>
                            <div class="fw-semibold text-success">@Model.CompletedAt.Value.ToString("dd/MM HH:mm")</div>
                        </div>
                    }
                    @if (Model.CancelledAt.HasValue)
                    {
                        <div class="col-6">
                            <div class="text-muted">Hủy lúc</div>
                            <div class="fw-semibold text-danger">@Model.CancelledAt.Value.ToString("dd/MM HH:mm")</div>
                        </div>
                    }
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <h6 class="fw-semibold text-muted text-uppercase mb-2" style="font-size:0.72rem;letter-spacing:.06em;">
                        Mô tả yêu cầu
                    </h6>
                    <div class="small ck-content">@Html.Raw(Model.Description)</div>
                </div>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.Notes))
        {
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <h6 class="fw-semibold text-muted text-uppercase mb-2" style="font-size:0.72rem;letter-spacing:.06em;">
                        Ghi chú
                    </h6>
                    <p class="small mb-0" style="white-space:pre-wrap;">@Model.Notes</p>
                </div>
            </div>
        }
    </div>

    <!-- RIGHT: Linked Quotations -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom py-2 d-flex align-items-center justify-content-between">
                <h6 class="mb-0 fw-semibold small text-uppercase">
                    <i class="bi bi-file-earmark-text me-1"></i> Báo giá liên quan
                    <span class="badge bg-primary rounded-pill ms-1">@Model.Quotations.Count</span>
                </h6>
                @* @if (canEdit && Model.Status == "INPROGRESS")
                {
                    <a href="/Quotation/Create?rfqId=@Model.RfqId" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-plus-lg me-1"></i> Tạo báo giá
                    </a>
                } *@
            </div>
            <div class="card-body p-0">
                @if (!Model.Quotations.Any())
                {
                    <div class="text-center py-4 text-muted">
                        <i class="bi bi-file-earmark-text" style="font-size:2rem;opacity:.3;"></i>
                        <p class="small mt-1 mb-0">Chưa có báo giá nào cho yêu cầu này</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0" style="font-size:0.85rem;">
                            <thead class="table-light">
                                <tr>
                                    <th>Mã báo giá</th>
                                    <th>Ngày BG</th>
                                    <th class="text-end">Tổng tiền</th>
                                    <th>Trạng thái</th>
                                    <th style="width:60px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var q in Model.Quotations)
                                {
                                    <tr>
                                        <td>
                                            <a href="/Quotation/Detail/@q.QuotationId"
                                               class="fw-semibold text-decoration-none text-dark link-hover">
                                                @q.QuotationNo
                                            </a>
                                        </td>
                                        <td class="text-muted small">@q.QuotationDate.ToString("dd/MM/yyyy")</td>
                                        <td class="text-end fw-semibold">@q.TotalAmount.ToString("N0")</td>
                                        <td>
                                            <span class="badge bg-@(q.StatusBadge)-subtle text-@(q.StatusBadge)-emphasis rounded-pill">
                                                @q.StatusText
                                            </span>
                                        </td>
                                        <td>
                                            <a href="/Quotation/Detail/@q.QuotationId" class="btn btn-sm btn-outline-secondary">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Import Quotation Modal -->
@if (canCreate)
{
    <div class="modal fade" id="importQuotationModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-file-earmark-arrow-up me-2"></i>Import báo giá từ Excel
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="importQuotationForm">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Khách hàng</label>
                            <input type="text" class="form-control" value="@Model.CustomerName (@Model.CustomerCode)" disabled />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Nhân viên phụ trách <span class="text-danger">*</span></label>
                            <select id="rfqImportSalesPersonId" class="form-select" required>
                                <option value="">-- Chọn nhân viên --</option>
                                @foreach (var s in salesPersons)
                                {
                                    @if (s.UserId == currentUserId)
                                    {
                                        <option value="@s.UserId" selected>@s.FullName (@s.UserCode)</option>
                                    }
                                    else
                                    {
                                        <option value="@s.UserId">@s.FullName (@s.UserCode)</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Hạn xử lý nội bộ <span class="text-danger">*</span></label>
                            <input type="datetime-local" id="rfqImportDeadline" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">File Excel <span class="text-danger">*</span></label>
                            <input type="file" id="rfqImportFile" class="form-control" accept=".xlsx,.xls" required />
                            <div class="form-text">File Excel cùng định dạng với file xuất báo giá (Export)</div>
                        </div>
                    </form>
                    <div id="rfqImportResult" class="d-none mt-3"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                    <button type="button" class="btn btn-success" id="btnRfqImport" onclick="doRfqImport()">
                        <i class="bi bi-upload me-1"></i> Import
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Cancel Modal -->
<div class="modal fade" id="cancelModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title fw-bold">Hủy yêu cầu báo giá</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <label class="form-label small fw-semibold">Lý do hủy</label>
                <textarea id="cancelReason" class="form-control form-control-sm" rows="3"
                          placeholder="Nhập lý do..."></textarea>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Đóng</button>
                <button type="button" class="btn btn-sm btn-danger" onclick="confirmCancel()">
                    <i class="bi bi-x-circle me-1"></i> Hủy RFQ
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Comment Panel -->
@await Html.PartialAsync("_TaskComments", new ViewDataDictionary(ViewData) {
    { "EntityType", "RFQ" }, { "EntityId", Model.RfqId }
})

<style>
    .link-hover:hover { color: #2563eb !important; }
    .bg-secondary-subtle { background-color: #f1f5f9 !important; }
    .text-secondary-emphasis { color: #475569 !important; }
    .bg-info-subtle { background-color: #e0f2fe !important; }
    .text-info-emphasis { color: #0369a1 !important; }
    .bg-success-subtle { background-color: #dcfce7 !important; }
    .text-success-emphasis { color: #166534 !important; }
    .bg-danger-subtle { background-color: #fee2e2 !important; }
    .text-danger-emphasis { color: #991b1b !important; }
    .bg-warning-subtle { background-color: #fef9c3 !important; }
    .text-warning-emphasis { color: #854d0e !important; }
    .bg-primary-subtle { background-color: #dbeafe !important; }
    .text-primary-emphasis { color: #1e40af !important; }
    .bg-dark-subtle { background-color: #e2e8f0 !important; }
    .text-dark-emphasis { color: #1e293b !important; }

    .ck-content { word-wrap: break-word; overflow-wrap: anywhere; }
    .ck-content img { max-width: 100%; height: auto; }
    .ck-content figure { max-width: 100% !important; margin: 0.5rem 0; }
    .ck-content figure.image { display: block; }
    .ck-content figure.image img { width: 100%; height: auto; }
    .ck-content table { max-width: 100%; }
</style>

@section Scripts {
    <script>
        function doCancel() {
            document.getElementById('cancelReason').value = '';
            new bootstrap.Modal(document.getElementById('cancelModal')).show();
        }

        function doRfqImport() {
            var salesPersonId = document.getElementById('rfqImportSalesPersonId').value;
            var deadline = document.getElementById('rfqImportDeadline').value;
            var fileInput = document.getElementById('rfqImportFile');
            var resultDiv = document.getElementById('rfqImportResult');

            if (!salesPersonId) { alert('Vui lòng chọn nhân viên phụ trách'); return; }
            if (!deadline) { alert('Vui lòng chọn hạn xử lý'); return; }
            if (!fileInput.files.length) { alert('Vui lòng chọn file Excel'); return; }

            var formData = new FormData();
            formData.append('file', fileInput.files[0]);
            formData.append('customerId', '@Model.CustomerId');
            formData.append('salesPersonId', salesPersonId);
            formData.append('deadline', deadline);
            formData.append('rfqId', '@Model.RfqId');

            var btn = document.getElementById('btnRfqImport');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Đang xử lý...';
            resultDiv.classList.add('d-none');

            var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

            fetch('/Quotation/ImportFromExcel', {
                method: 'POST',
                headers: { 'RequestVerificationToken': token || '' },
                body: formData
            })
            .then(function(r) { return r.json(); })
            .then(function(res) {
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-upload me-1"></i> Import';
                resultDiv.classList.remove('d-none');
                if (res.Success) {
                    var msg = (res.Message || 'Import thành công').replace(/\n/g, '<br/>');
                    resultDiv.className = 'alert alert-success mt-3';
                    resultDiv.innerHTML = msg + '<br/><a href="/Quotation/Detail/' + res.Data.QuotationId +
                        '" class="btn btn-sm btn-primary mt-2"><i class="bi bi-eye me-1"></i>Xem báo giá</a>';
                } else {
                    var msg = (res.Message || 'Import thất bại').replace(/\n/g, '<br/>');
                    resultDiv.className = 'alert alert-danger mt-3';
                    resultDiv.innerHTML = msg;
                }
            })
            .catch(function(err) {
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-upload me-1"></i> Import';
                resultDiv.classList.remove('d-none');
                resultDiv.className = 'alert alert-danger mt-3';
                resultDiv.innerHTML = 'Lỗi: ' + err.message;
            });
        }

        function confirmCancel() {
            var reason = document.getElementById('cancelReason').value.trim();
            fetch('/Rfq/Cancel/@Model.RfqId', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? ''
                },
                body: JSON.stringify({ Reason: reason })
            })
            .then(function (r) { return r.json(); })
            .then(function (data) {
                if (data.Success) {
                    bootstrap.Modal.getInstance(document.getElementById('cancelModal')).hide();
                    location.reload();
                } else {
                    alert(data.Message || 'Lỗi');
                }
            });
        }
    </script>
    @Html.AntiForgeryToken()
}
