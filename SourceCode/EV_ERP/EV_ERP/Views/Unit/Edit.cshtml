@model EV_ERP.Models.ViewModels.Products.UnitFormViewModel
@{
    ViewData["Title"] = "Chỉnh sửa đơn vị tính";
    ViewData["Breadcrumbs"] = new List<BreadcrumbItem>
    {
        new("Trang chủ", "/"),
        new("Đơn vị tính", "/Unit"),
        new("Chỉnh sửa")
    };
}

<div class="row justify-content-center">
    <div class="col-xl-6 col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom py-3">
                <h5 class="mb-0 fw-semibold">
                    <i class="bi bi-pencil-square me-2 text-primary"></i>Chỉnh sửa đơn vị tính
                </h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit" asp-controller="Unit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="UnitId" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                    @await Html.PartialAsync("_UnitForm", Model)

                    <hr class="my-4" />
                    <div class="d-flex gap-2 justify-content-end">
                        <a href="/Unit" class="btn btn-outline-secondary">Hủy</a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i> Lưu thay đổi
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
