@model EV_ERP.Models.ViewModels.SalesOrders.SalesOrderDetailViewModel
@{
    ViewData["Title"] = Model.SalesOrderNo;
    ViewData["Breadcrumbs"] = new List<BreadcrumbItem>
    {
        new("Trang chủ", "/"),
        new("Đơn hàng", "/SalesOrder"),
        new(Model.SalesOrderNo)
    };
    bool canEdit = ViewBag.CanEdit == true;
    bool isManager = ViewBag.IsManager == true;
    int currentUserId = (int)(ViewBag.CurrentUserId ?? 0);
    bool canManageStatus = isManager || Model.SalesPersonId == currentUserId;
    bool showBuyingInfo = Model.Status is "BUYING" or "RECEIVED" or "DELIVERING" or "DELIVERED" or "RETURNED" or "COMPLETED" or "REPORTED";
    var productForm = ViewBag.ProductForm as EV_ERP.Models.ViewModels.Products.ProductFormViewModel;
}

<!-- Header -->
<div class="d-flex align-items-start justify-content-between mb-3 flex-wrap gap-2">
    <div class="d-flex align-items-center gap-3">
        @* <a href="/SalesOrder" class="btn btn-sm btn-light border">
            <i class="bi bi-arrow-left"></i>
        </a> *@
        <div>
            <div class="d-flex flex-wrap align-items-center gap-3">
                <h5 class="mb-0 fw-bold">@Model.SalesOrderNo</h5>
                @if (Model.Status == "DRAFT")
                {
                   <a href="/SalesOrder/ExportDntu/@Model.SalesOrderId"
                    class="text-success d-flex align-items-center"
                    style="text-decoration: none;">
                        <i class="bi bi-download me-1"></i>
                        Xuất DNTU
                   </a>
                }
                @if (Model.Status == "DELIVERED")
                {
                    <div class="dropdown">
                        <a class="text-success d-flex align-items-center dropdown-toggle"
                           href="#"
                           role="button"
                           data-bs-toggle="dropdown"
                           aria-expanded="false"
                           style="text-decoration: none;">
                            <i class="bi bi-download me-1"></i>
                            Xuất Excel
                        </a>

                        <ul class="dropdown-menu">
                            <li>
                                <a class="dropdown-item d-flex align-items-center"
                                   href="/SalesOrder/ExportDnhu/@Model.SalesOrderId">
                                    <i class="bi bi-download me-2 text-success"></i>
                                    Xuất DNHU
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item d-flex align-items-center"
                                   href="/SalesOrder/ExportDntt/@Model.SalesOrderId">
                                    <i class="bi bi-download me-2 text-success"></i>
                                    Xuất DNTT
                                </a>
                            </li>
                        </ul>
                    </div>
                }
            </div>
            <div class="text-muted small">
                <span class="badge bg-@(Model.StatusBadge)-subtle text-@(Model.StatusBadge)-emphasis rounded-pill">
                    <i class="bi bi-circle-fill me-1" style="font-size:0.4rem;vertical-align:middle;"></i>
                    @Model.StatusText
                </span>
                @if (Model.QuotationNo != null)
                {
                    <span class="ms-2">
                        <i class="bi bi-file-earmark-text me-1"></i>BG:
                        <a href="/Quotation/Detail/@Model.QuotationId">@Model.QuotationNo</a>
                    </span>
                }
                @if (Model.RfqNo != null)
                {
                    <span class="ms-2">
                        <i class="bi bi-clipboard-check me-1"></i>RFQ:
                        <a href="/Rfq/Detail/@Model.RfqId">@Model.RfqNo</a>
                    </span>
                }
            </div>
        </div>
    </div>

    <!-- Action buttons per status -->
    <div class="d-flex gap-1 flex-wrap">
        @if (canEdit)
        {
            @if (Model.Status == "DRAFT")
            {           
                @if (canManageStatus)
                {
                    <button class="btn btn-sm btn-primary" onclick="showSubmitWaitModal()">
                        <i class="bi bi-send me-1"></i> Gửi DNTU
                    </button>
                    <button class="btn btn-sm btn-outline-danger" onclick="doCancel()">
                        <i class="bi bi-x-circle me-1"></i> Hủy
                    </button>
                }
            }
            @if (Model.Status == "WAIT" && canManageStatus)
            {
                <button class="btn btn-sm btn-info text-white" onclick="showBuyingModal()">
                    <i class="bi bi-cart3 me-1"></i> Bắt đầu mua hàng
                </button>
                <button class="btn btn-sm btn-outline-danger" onclick="doCancel()">
                    <i class="bi bi-x-circle me-1"></i> Hủy
                </button>
            }
            @if (Model.Status is "BUYING" or "RECEIVED" or "DELIVERING" && canManageStatus)
            {
                @* Whole-order action removed — Nhận hàng / Giao hàng nay theo từng dòng (bảng bên dưới).
                   Chỉ giữ "Hủy đơn" và batch shortcut. Trạng thái SO tự roll-up khi xác nhận phiếu kho. *@
                if (Model.Items.Any(i => i.RemainingReceiveQty > 0))
                {
                    <button class="btn btn-sm btn-info text-white" onclick="showReceiveBatchModal()">
                        <i class="bi bi-box-arrow-in-down me-1"></i> Nhận lô (nhiều dòng)
                    </button>
                }
                if (Model.Items.Any(i => i.InStockQty > 0))
                {
                    <button class="btn btn-sm btn-warning" onclick="showDeliverBatchModal()">
                        <i class="bi bi-truck me-1"></i> Giao lô (nhiều dòng)
                    </button>
                }
                <button class="btn btn-sm btn-outline-danger" onclick="doCancel()">
                    <i class="bi bi-x-circle me-1"></i> Hủy đơn
                </button>
            }
            @if (Model.Status == "DELIVERED" && canManageStatus)
            {
                <button class="btn btn-sm btn-success" onclick="showCompleteModal()">
                    <i class="bi bi-check-all me-1"></i> Hoàn tất quyết toán
                </button>
                <button class="btn btn-sm btn-warning" onclick="showReturnModal()">
                    <i class="bi bi-arrow-return-left me-1"></i> Trả hàng
                </button>
            }
            @if (Model.Status == "RETURNED" && canManageStatus)
            {
                <button class="btn btn-sm btn-success" onclick="showCompleteModal()">
                    <i class="bi bi-check-all me-1"></i> Hoàn tất quyết toán
                </button>
            }
            @if (Model.Status == "COMPLETED" && canManageStatus)
            {
                <button class="btn btn-sm btn-primary" onclick="doSimpleAction('Report', 'Xác nhận nộp báo cáo KQKD?')">
                    <i class="bi bi-file-earmark-bar-graph me-1"></i> Nộp báo cáo KQKD
                </button>
            }
        }
    </div>
</div>

<!-- Unmapped products warning -->
@if (canEdit && Model.Status == "DRAFT" && Model.HasUnmappedProducts)
{
    <div class="alert alert-warning border-0 shadow-sm mb-3 py-2" role="alert">
        <div class="d-flex align-items-center gap-2 mb-2">
            <i class="bi bi-exclamation-triangle-fill fs-5"></i>
            <div class="small">
                <strong>@Model.UnmappedProductCount sản phẩm chưa được nhập vào hệ thống.</strong>
                Tạo từng sản phẩm hoặc import hàng loạt bằng Excel.
            </div>
        </div>
        <div class="d-flex gap-2 flex-wrap ms-4">
            <a href="/SalesOrder/ExportProductTemplate/@Model.SalesOrderId"
               class="btn btn-sm btn-outline-success">
                <i class="bi bi-download me-1"></i> Tải template Excel
            </a>
            <label class="btn btn-sm btn-outline-primary mb-0" for="importProductFile">
                <i class="bi bi-upload me-1"></i> Import từ Excel
            </label>
            <input type="file" id="importProductFile" class="d-none"
                   accept=".xlsx,.xls" onchange="importProducts(this)" />
        </div>
    </div>
}

<!-- Status timeline -->
<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2 px-3">
        <div class="d-flex align-items-center gap-1 flex-wrap" style="font-size:0.78rem;">
            @{
                var steps = new[] {
                    ("DRAFT", "Nháp"), ("WAIT", "Chờ tạm ứng"), ("BUYING", "Đang mua"),
                    ("RECEIVED", "Nhận hàng"), ("DELIVERING", "Đang giao"),
                    ("DELIVERED", "Đã giao"), ("COMPLETED", "Hoàn tất"),
                    ("REPORTED", "Báo cáo KQKD")
                };
                if (Model.Status == "RETURNED" || Model.ReturnedAt.HasValue)
                {
                    var list = steps.ToList();
                    var deliveredIdx = list.FindIndex(s => s.Item1 == "COMPLETED");
                    list.Insert(deliveredIdx, ("RETURNED", "Trả hàng"));
                    steps = list.ToArray();
                }
                var statusOrder = steps.Select(s => s.Item1).ToList();
                var currentIdx = statusOrder.IndexOf(Model.Status);
                bool isCancelled = Model.Status == "CANCELLED";
            }
            @for (int i = 0; i < steps.Length; i++)
            {
                var (code, label) = steps[i];
                var done = !isCancelled && currentIdx >= i;
                var active = !isCancelled && currentIdx == i;
                <div class="d-flex align-items-center gap-1">
                    <span class="badge @(active ? "bg-primary" : done ? "bg-success" : "bg-light text-muted border")">
                        @if (done && !active) { <i class="bi bi-check-lg"></i> }
                        @label
                    </span>
                    @if (i < steps.Length - 1)
                    {
                        <i class="bi bi-chevron-right text-muted" style="font-size:0.6rem;"></i>
                    }
                </div>
            }
            @if (isCancelled)
            {
                <span class="badge bg-danger ms-2">Đã hủy</span>
            }
        </div>
    </div>
</div>
<!-- Info cards -->
<div class="row g-3">
    <div class="col-lg-6">
        <!-- Order info -->
        <div class="card border-0 shadow-sm mb-3 border-start border-4 border-info">
            <div class="card-body">
                <h6 class="fw-semibold text-muted text-uppercase mb-3" style="font-size:0.72rem;letter-spacing:.06em;">
                    Thông tin đơn hàng
                </h6>
                <div class="row g-2 small">
                    <div class="col-6">
                        <div class="text-muted">Khách hàng</div>
                        <div class="fw-semibold">@Model.CustomerName</div>
                    </div>
                    <div class="col-6">
                        <div class="text-muted">Ngày tạo</div>
                        <div class="fw-semibold">@Model.OrderDate.ToString("dd/MM/yyyy")</div>
                    </div>
                    <div class="col-6">
                        <div class="text-muted">Phụ trách</div>
                        <div class="fw-semibold">@Model.SalesPersonName</div>
                    </div>
                    @if (Model.Status != "DRAFT" && Model.CustomerPoNo != null)
                    {
                        <div class="col-6">
                            <div class="text-muted">Mã PO KH</div>
                            <div class="fw-semibold">@Model.CustomerPoNo</div>
                        </div>
                    }
                    @if (Model.Status != "DRAFT" && Model.CustomerPoFile != null)
                    {
                        <div class="col-6">
                            <div class="text-muted">File PO KH</div>
                            <div><a href="@Model.CustomerPoFile" target="_blank" class="text-primary"><i class="bi bi-file-earmark-arrow-down me-1"></i>Tải xuống</a></div>
                        </div>
                    }
                    @if (Model.ExpectedDeliveryDate.HasValue)
                    {
                        <div class="col-6">
                            <div class="text-muted">Dự kiến giao</div>
                            <div class="fw-semibold">@Model.ExpectedDeliveryDate.Value.ToString("dd/MM/yyyy")</div>
                        </div>
                    }
                    @if (Model.PaymentDueDate.HasValue)
                    {
                        <div class="col-6">
                            <div class="text-muted">Hạn thanh toán</div>
                            <div class="fw-semibold">@Model.PaymentDueDate.Value.ToString("dd/MM/yyyy")</div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Advance info -->
        @if (Model.AdvanceAmount > 0)
        {
            <div class="card border-0 shadow-sm mb-3 border-start border-4 border-warning">
                <div class="card-body">
                    <h6 class="fw-semibold text-muted text-uppercase mb-3" style="font-size:0.72rem;letter-spacing:.06em;">
                        <i class="bi bi-cash-stack me-1"></i> Tạm ứng
                    </h6>
                    <div class="row g-2 small">
                        <div class="col-6">
                            <div class="text-muted">Số tiền</div>
                            <div class="fw-bold text-warning">@Model.AdvanceAmount?.ToString("N0") @Model.Currency</div>
                        </div>
                        <div class="col-6">
                            <div class="text-muted">Trạng thái</div>
                            <div class="fw-semibold">@(Model.AdvanceStatus ?? "—")</div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
    <div class="col-lg-6">
         <!-- PO KH editable (DRAFT only) -->
         @if (canEdit && Model.Status == "DRAFT")
         {
             <div class="card border-0 shadow-sm mb-3 border-start border-4 border-primary">
                 <div class="card-body">
                     <h6 class="fw-semibold text-muted text-uppercase mb-3" style="font-size:0.72rem;letter-spacing:.06em;">
                         <i class="bi bi-file-earmark-text me-1"></i> PO Khách hàng
                     </h6>
                     <form id="draftInfoForm" enctype="multipart/form-data">
                         <div class="mb-2">
                             <label class="form-label small fw-semibold mb-1">Mã PO khách hàng</label>
                             <input type="text" id="draftCustomerPoNo" class="form-control form-control-sm"
                                    placeholder="Nhập mã PO..." value="@Model.CustomerPoNo" />
                         </div>
                         <div class="mb-2">
                             <label class="form-label small fw-semibold mb-1">Dự kiến giao hàng</label>
                             <input type="date" id="draftExpectedDeliveryDate" class="form-control form-control-sm"
                                    value="@(Model.ExpectedDeliveryDate?.ToString("yyyy-MM-dd"))" />
                         </div>
                         <div class="mb-2">
                             <label class="form-label small fw-semibold mb-1">File PO khách hàng</label>
                             @if (Model.CustomerPoFile != null)
                             {
                                 <div class="mb-1">
                                     <a href="@Model.CustomerPoFile" target="_blank" class="text-primary small">
                                         <i class="bi bi-file-earmark-arrow-down me-1"></i>File hiện tại
                                     </a>
                                 </div>
                             }
                             <input type="file" id="draftCustomerPoFile" class="form-control form-control-sm"
                                    accept=".pdf,.jpg,.jpeg,.png,.doc,.docx,.xls,.xlsx" />
                             <div class="form-text" style="font-size:0.7rem;">PDF, ảnh, Word, Excel (tối đa 10MB)</div>
                         </div>
                         <button type="button" class="btn btn-sm btn-primary w-100" onclick="saveDraftInfo()">
                             <i class="bi bi-check-lg me-1"></i> Lưu thông tin PO
                         </button>
                     </form>
                 </div>
             </div>
         }
         <!-- Vendor / Buying info -->
           @if (showBuyingInfo)
           {
               <div class="card border-0 shadow-sm mb-3">
                   <div class="card-body">
                       <h6 class="fw-semibold text-muted text-uppercase mb-3" style="font-size:0.72rem;letter-spacing:.06em;">
                           <i class="bi bi-cart3 me-1"></i> Thông tin mua hàng
                       </h6>
                       <div class="row g-2 small">
                           <div class="col-12">
                               <div class="text-muted">Nhà cung cấp</div>
                               <div class="fw-semibold">@(Model.PurchaseSource ?? "—")</div>
                           </div>
                           @if (Model.ExpectedReceiveDate.HasValue)
                           {
                               <div class="col-6">
                                   <div class="text-muted">Dự kiến về kho</div>
                                   <div class="fw-semibold">@Model.ExpectedReceiveDate.Value.ToString("dd/MM/yyyy")</div>
                               </div>
                           }
                           @if (Model.BuyingAt.HasValue)
                           {
                               <div class="col-6">
                                   <div class="text-muted">Bắt đầu mua</div>
                                   <div class="fw-semibold">@Model.BuyingAt.Value.ToString("dd/MM HH:mm")</div>
                               </div>
                           }
                           @if (Model.ReceivedAt.HasValue)
                           {
                               <div class="col-6">
                                   <div class="text-muted">Nhận hàng</div>
                                   <div class="fw-semibold text-success">@Model.ReceivedAt.Value.ToString("dd/MM HH:mm")</div>
                               </div>
                           }
                           @if (!string.IsNullOrEmpty(Model.BuyingNotes))
                           {
                               <div class="col-12">
                                   <div class="text-muted">Ghi chú mua</div>
                                   <div style="white-space:pre-wrap;">@Model.BuyingNotes</div>
                               </div>
                           }
                       </div>
                   </div>
               </div>
           }

           <!-- Delivery timestamps -->
           @if (Model.DeliveringAt.HasValue || Model.DeliveredAt.HasValue || Model.ReturnedAt.HasValue || Model.CompletedAt.HasValue || Model.ReportedAt.HasValue)
           {
               <div class="card border-0 shadow-sm mb-3">
                   <div class="card-body">
                       <h6 class="fw-semibold text-muted text-uppercase mb-3" style="font-size:0.72rem;letter-spacing:.06em;">
                           <i class="bi bi-clock-history me-1"></i> Tiến trình
                       </h6>
                       <div class="row g-2 small">
                           @if (Model.DeliveringAt.HasValue)
                           {
                               <div class="col-6">
                                   <div class="text-muted">Giao vận chuyển</div>
                                   <div class="fw-semibold">@Model.DeliveringAt.Value.ToString("dd/MM HH:mm")</div>
                               </div>
                           }
                           @if (Model.DeliveredAt.HasValue)
                           {
                               <div class="col-6">
                                   <div class="text-muted">KH nhận hàng</div>
                                   <div class="fw-semibold text-success">@Model.DeliveredAt.Value.ToString("dd/MM HH:mm")</div>
                               </div>
                           }
                           @if (Model.ReturnedAt.HasValue)
                           {
                               <div class="col-6">
                                   <div class="text-muted">Trả hàng</div>
                                   <div class="fw-semibold text-warning">@Model.ReturnedAt.Value.ToString("dd/MM HH:mm")</div>
                               </div>
                           }
                           @if (Model.CompletedAt.HasValue)
                           {
                               <div class="col-6">
                                   <div class="text-muted">Hoàn tất</div>
                                   <div class="fw-semibold text-success">@Model.CompletedAt.Value.ToString("dd/MM HH:mm")</div>
                               </div>
                           }
                           @if (Model.ReportedAt.HasValue)
                           {
                               <div class="col-6">
                                   <div class="text-muted">Báo cáo KQKD</div>
                                   <div class="fw-semibold text-primary">@Model.ReportedAt.Value.ToString("dd/MM HH:mm")</div>
                               </div>
                           }
                       </div>
                   </div>
               </div>
           }

           <!-- Settlement -->
           @if (Model.Status is "COMPLETED" or "REPORTED" or "RETURNED" && Model.ActualCost.HasValue)
           {
               <div class="card border-0 shadow-sm mb-3 border-start border-4 border-success">
                   <div class="card-body">
                       <h6 class="fw-semibold text-muted text-uppercase mb-3" style="font-size:0.72rem;letter-spacing:.06em;">
                           <i class="bi bi-calculator me-1"></i> Quyết toán
                       </h6>
                       <div class="row g-2 small">
                           <div class="col-6">
                               <div class="text-muted">Chi phí thực tế</div>
                               <div class="fw-bold">@Model.ActualCost?.ToString("N0") @Model.Currency</div>
                           </div>
                           @if (!string.IsNullOrEmpty(Model.SettlementNotes))
                           {
                               <div class="col-12">
                                   <div class="text-muted">Ghi chú</div>
                                   <div>@Model.SettlementNotes</div>
                               </div>
                           }
                       </div>
                   </div>
               </div>
           }

           <!-- Cancel info -->
           @if (Model.Status == "CANCELLED")
           {
               <div class="card border-0 shadow-sm mb-3 border-start border-4 border-danger">
                   <div class="card-body">
                       <h6 class="fw-semibold text-muted text-uppercase mb-3" style="font-size:0.72rem;letter-spacing:.06em;">
                           <i class="bi bi-x-circle me-1"></i> Thông tin hủy
                       </h6>
                       <div class="small">
                           <div class="text-muted">Hủy lúc: @Model.CancelledAt?.ToString("dd/MM/yyyy HH:mm")</div>
                           @if (!string.IsNullOrEmpty(Model.CancelReason))
                           {
                               <div class="mt-1">Lý do: @Model.CancelReason</div>
                           }
                       </div>
                   </div>
               </div>
           }

           <!-- Return info -->
           @if (Model.Status == "RETURNED" || Model.ReturnedAt.HasValue)
           {
               <div class="card border-0 shadow-sm mb-3 border-start border-4 border-warning">
                   <div class="card-body">
                       <h6 class="fw-semibold text-muted text-uppercase mb-3" style="font-size:0.72rem;letter-spacing:.06em;">
                           <i class="bi bi-arrow-return-left me-1"></i> Trả hàng
                       </h6>
                       <div class="small">
                           <div class="text-muted">Trả hàng lúc: @Model.ReturnedAt?.ToString("dd/MM/yyyy HH:mm")</div>
                           @if (!string.IsNullOrEmpty(Model.ReturnReason))
                           {
                               <div class="mt-1">Lý do: @Model.ReturnReason</div>
                           }
                       </div>
                   </div>
               </div>
           }

           <!-- Notes -->
           @if (!string.IsNullOrEmpty(Model.Notes))
           {
               <div class="card border-0 shadow-sm mb-3">
                   <div class="card-body">
                       <h6 class="fw-semibold text-muted text-uppercase mb-2" style="font-size:0.72rem;letter-spacing:.06em;">
                           Ghi chú
                       </h6>
                       <p class="small mb-0" style="white-space:pre-wrap;">@Model.Notes</p>
                   </div>
               </div>
           }
           @if (!string.IsNullOrEmpty(Model.InternalNotes))
           {
               <div class="card border-0 shadow-sm mb-3 border-start border-4 border-warning">
                   <div class="card-body">
                       <h6 class="fw-semibold text-muted text-uppercase mb-2" style="font-size:0.72rem;letter-spacing:.06em;">
                           <i class="bi bi-lock me-1"></i> Ghi chú nội bộ
                       </h6>
                       <p class="small mb-0" style="white-space:pre-wrap;">@Model.InternalNotes</p>
                   </div>
               </div>
           }
        </div>
</div>
<!-- Items + Totals -->
<div class="row g-3">
    <div class="col-lg-12">
        @{
            bool showProgress = Model.Status is "BUYING" or "RECEIVED" or "DELIVERING" or "DELIVERED" or "COMPLETED" or "REPORTED" or "RETURNED";
            bool canAct = canManageStatus && Model.Status is "BUYING" or "RECEIVED" or "DELIVERING";
            int totalLines = Model.Items.Count;
            int doneRecv = Model.Items.Count(i => i.LineStatus is "RECEIVED_FULL" or "PARTIAL_DELIVERED" or "DELIVERED");
            int doneDeliv = Model.Items.Count(i => i.LineStatus == "DELIVERED");
            int partial = Model.Items.Count(i => i.LineStatus is "PARTIAL" or "PARTIAL_DELIVERED");
            int notStarted = Model.Items.Count(i => i.LineStatus is "NOT_STARTED" or "BUYING");
            int cancelledLines = Model.Items.Count(i => i.LineStatus == "CANCELLED");
        }

        @if (showProgress)
        {
            <!-- Per-line progress summary strip -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body py-2 px-3">
                    <div class="d-flex flex-wrap gap-3 align-items-center small">
                        <span class="text-muted">
                            <i class="bi bi-box-arrow-in-down text-info me-1"></i>
                            <strong>Mua/Nhận:</strong>
                            <span class="badge bg-success-subtle text-success-emphasis">@doneRecv / @totalLines đã đủ</span>
                            @if (partial > 0)
                            {
                                <span class="badge bg-warning-subtle text-warning-emphasis ms-1">@partial về 1 phần</span>
                            }
                            @if (notStarted > 0)
                            {
                                <span class="badge bg-light text-muted border ms-1">@notStarted chưa bắt đầu</span>
                            }
                        </span>
                        <span class="text-muted">
                            <i class="bi bi-truck text-warning me-1"></i>
                            <strong>Giao KH:</strong>
                            <span class="badge bg-success-subtle text-success-emphasis">@doneDeliv / @totalLines đã giao đủ</span>
                        </span>
                        @if (cancelledLines > 0)
                        {
                            <span class="text-muted">
                                <i class="bi bi-x-circle text-danger me-1"></i>
                                <span class="badge bg-danger-subtle text-danger-emphasis">@cancelledLines dòng đã hủy</span>
                            </span>
                        }
                    </div>
                </div>
            </div>
        }

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom py-2">
                <h6 class="mb-0 fw-semibold small text-uppercase">
                    <i class="bi bi-box-seam me-1"></i> Chi tiết sản phẩm
                    <span class="badge bg-primary rounded-pill ms-1">@Model.Items.Count</span>
                    @if (Model.Status == "DRAFT" && Model.HasUnmappedProducts)
                    {
                        <span class="badge bg-warning rounded-pill ms-1">
                            <i class="bi bi-exclamation-triangle me-1"></i>@Model.UnmappedProductCount chưa nhập SP
                        </span>
                    }
                </h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-bordered table-hover align-middle mb-0" style="font-size:0.8rem;">
                        <thead class="table-light">
                            <tr>
                                <th style="width:30px;" class="text-center">STT</th>
                                <th>Sản phẩm</th>
                                @if (canEdit && Model.Status == "DRAFT")
                                {
                                    <th style="width:80px;" class="text-center">Trạng thái</th>
                                }
                                <th>DVT</th>
                                <th class="text-end">SL</th>
                                @if (showProgress)
                                {
                                    <th class="text-center bg-info-subtle" style="min-width:140px;">Tiến độ mua/giao</th>
                                    <th class="text-center bg-info-subtle" style="min-width:110px;">Dự kiến</th>
                                }
                                <th class="text-end bg-success-subtle">Đơn giá bán</th>
                                <th class="text-end bg-success-subtle">Thành tiền</th>
                                @if (showBuyingInfo)
                                {
                                    <th class="text-end bg-warning-subtle">Giá mua</th>
                                    <th class="text-end bg-warning-subtle">Chi phí</th>
                                }
                                <th class="d-none d-md-table-cell">Ghi chú</th>
                                @if (canAct)
                                {
                                    <th class="text-center" style="width:130px;">Hành động</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @{ int idx = 1; }
                            @foreach (var item in Model.Items)
                            {
                                <tr class="@(!item.IsProductMapped && Model.Status == "DRAFT" ? "table-warning" : "") @(item.LineStatus == "CANCELLED" ? "text-decoration-line-through text-muted" : "")">
                                    <td class="text-center text-muted">@(idx++)</td>
                                    <td class="fw-semibold">
                                        @item.ProductName
                                        @if (showProgress)
                                        {
                                            <span class="badge @item.LineStatusBadge ms-1" style="font-size:0.65rem;">@item.LineStatusText</span>
                                            @if (item.CancelledQty > 0 && item.CancelledQty < item.Quantity)
                                            {
                                                <span class="badge bg-danger-subtle text-danger-emphasis ms-1" style="font-size:0.65rem;">Hủy @item.CancelledQty.ToString("N3")</span>
                                            }
                                        }
                                    </td>
                                    @if (canEdit && Model.Status == "DRAFT")
                                    {
                                        <td class="text-center">
                                            @if (item.IsProductMapped)
                                            {
                                                <span class="badge bg-success-subtle text-success-emphasis">
                                                    <i class="bi bi-check-circle-fill me-1"></i>OK
                                                </span>
                                            }
                                            else
                                            {
                                                <button type="button" class="btn btn-sm btn-outline-warning py-0 px-1"
                                                        onclick="openCreateProductModal(@item.SOItemId, '@System.Web.HttpUtility.JavaScriptStringEncode(item.ProductName)', @item.UnitPrice, @(item.PurchasePrice?.ToString() ?? "0"), '@System.Web.HttpUtility.JavaScriptStringEncode(item.SourceUrl ?? "")', '@System.Web.HttpUtility.JavaScriptStringEncode(item.ProductDescription ?? "")', '@System.Web.HttpUtility.JavaScriptStringEncode(item.ImageUrl ?? "")')">
                                                    <i class="bi bi-plus-circle me-1"></i>Tạo SP
                                                </button>
                                            }
                                        </td>
                                    }
                                    <td>@item.UnitName</td>
                                    <td class="text-end">@item.Quantity.ToString("N3")</td>
                                    @if (showProgress)
                                    {
                                        <td class="text-center small">
                                            <div>
                                                <span class="text-muted">Nhận:</span>
                                                <span class="fw-semibold @(item.RemainingReceiveQty > 0 ? "text-info-emphasis" : "text-success")">
                                                    @item.ReceivedQty.ToString("N3") / @item.EffectiveQty.ToString("N3")
                                                </span>
                                            </div>
                                            <div>
                                                <span class="text-muted">Giao:</span>
                                                <span class="fw-semibold @(item.RemainingDeliverQty > 0 ? "text-warning-emphasis" : "text-success")">
                                                    @item.DeliveredQty.ToString("N3") / @item.EffectiveQty.ToString("N3")
                                                </span>
                                            </div>
                                            @if (item.InStockQty > 0)
                                            {
                                                <div class="badge bg-secondary-subtle text-secondary-emphasis" style="font-size:0.65rem;">
                                                    Trong kho: @item.InStockQty.ToString("N3")
                                                </div>
                                            }
                                        </td>
                                        <td class="text-center small">
                                            @if (item.ExpectedReceiveDate.HasValue)
                                            {
                                                <div title="Dự kiến hàng về">
                                                    <i class="bi bi-box-arrow-in-down text-info"></i> @item.ExpectedReceiveDate.Value.ToString("dd/MM")
                                                </div>
                                            }
                                            @if (item.ExpectedDeliveryDate.HasValue)
                                            {
                                                <div title="Dự kiến giao KH">
                                                    <i class="bi bi-truck text-warning"></i> @item.ExpectedDeliveryDate.Value.ToString("dd/MM")
                                                </div>
                                            }
                                            @if (!item.ExpectedReceiveDate.HasValue && !item.ExpectedDeliveryDate.HasValue)
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                    }
                                    <td class="text-end">@item.UnitPrice.ToString("N0")</td>
                                    <td class="text-end fw-semibold text-success">@item.LineTotal.ToString("N0")</td>
                                    @if (showBuyingInfo)
                                    {
                                        <td class="text-end">@(item.PurchasePrice?.ToString("N0") ?? "—")</td>
                                        <td class="text-end text-warning-emphasis">@(item.LineCost?.ToString("N0") ?? "—")</td>
                                    }
                                    <td class="d-none d-md-table-cell text-muted small">@(item.Notes ?? "")</td>
                                    @if (canAct)
                                    {
                                        <td class="text-center">
                                            @if (item.LineStatus == "CANCELLED")
                                            {
                                                <span class="text-muted small">—</span>
                                            }
                                            else
                                            {
                                                <div class="btn-group btn-group-sm">
                                                    @if (item.RemainingReceiveQty > 0)
                                                    {
                                                        <button type="button" class="btn btn-outline-info py-0 px-1"
                                                                title="Nhận hàng cho dòng này"
                                                                onclick="openReceiveItemModal(@item.SOItemId)">
                                                            <i class="bi bi-box-arrow-in-down"></i>
                                                        </button>
                                                    }
                                                    @if (item.InStockQty > 0)
                                                    {
                                                        <button type="button" class="btn btn-outline-warning py-0 px-1"
                                                                title="Giao hàng dòng này"
                                                                onclick="openDeliverItemModal(@item.SOItemId)">
                                                            <i class="bi bi-truck"></i>
                                                        </button>
                                                    }
                                                    <button type="button" class="btn btn-outline-secondary py-0 px-1 dropdown-toggle"
                                                            data-bs-toggle="dropdown" aria-expanded="false" title="Khác">
                                                    </button>
                                                    <ul class="dropdown-menu dropdown-menu-end">
                                                        <li>
                                                            <a class="dropdown-item small" href="#"
                                                               onclick="openEditItemModal(@item.SOItemId); return false;">
                                                                <i class="bi bi-pencil me-1"></i> Sửa giá / nguồn / ngày
                                                            </a>
                                                        </li>
                                                        @if (item.RemainingReceiveQty > 0)
                                                        {
                                                            <li>
                                                                <a class="dropdown-item small text-danger" href="#"
                                                                   onclick="openCancelItemModal(@item.SOItemId); return false;">
                                                                    <i class="bi bi-x-circle me-1"></i> Hủy dòng
                                                                </a>
                                                            </li>
                                                        }
                                                    </ul>
                                                </div>
                                            }
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Financial summary -->
        <div class="card border-0 shadow-sm mt-3">
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <h6 class="fw-semibold text-muted text-uppercase mb-3" style="font-size:0.72rem;letter-spacing:.06em;">
                            <i class="bi bi-cash me-1"></i> Giá trị bán
                        </h6>
                        <table class="table table-sm table-borderless mb-0" style="font-size:0.85rem;">
                            <tr>
                                <td class="text-muted">Tạm tính</td>
                                <td class="text-end">@Model.SubTotal.ToString("N0")</td>
                            </tr>
                            @if (Model.DiscountAmount > 0)
                            {
                                <tr>
                                    <td class="text-muted">Chiết khấu</td>
                                    <td class="text-end text-danger">-@Model.DiscountAmount.ToString("N0")</td>
                                </tr>
                            }
                            <tr>
                                <td class="text-muted">Thuế (@Model.TaxRate%)</td>
                                <td class="text-end">@Model.TaxAmount.ToString("N0")</td>
                            </tr>
                            <tr class="fw-bold border-top">
                                <td>Tổng bán</td>
                                <td class="text-end text-primary fs-6">@Model.TotalAmount.ToString("N0") @Model.Currency</td>
                            </tr>
                        </table>
                    </div>
                    @if (showBuyingInfo)
                    {
                        <div class="col-md-6">
                            <h6 class="fw-semibold text-muted text-uppercase mb-3" style="font-size:0.72rem;letter-spacing:.06em;">
                                <i class="bi bi-calculator me-1"></i> Chi phí & Lợi nhuận
                            </h6>
                            <table class="table table-sm table-borderless mb-0" style="font-size:0.85rem;">
                                <tr>
                                    <td class="text-muted">Chi phí mua</td>
                                    <td class="text-end">@(Model.PurchaseCost?.ToString("N0") ?? "—")</td>
                                </tr>
                                <tr class="fw-bold border-top">
                                    <td>Lợi nhuận</td>
                                    <td class="text-end @(Model.ProfitAmount >= 0 ? "text-success" : "text-danger")">
                                        @Model.ProfitAmount.ToString("N0") @Model.Currency
                                    </td>
                                </tr>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Comment Panel -->
@await Html.PartialAsync("_TaskComments", new ViewDataDictionary(ViewData) {
    { "EntityType", "SALES_ORDER" }, { "EntityId", Model.SalesOrderId }
})

