@model EV_ERP.Models.ViewModels.Customers.CustomerFormViewModel
@{
    ViewData["Title"] = "Thêm khách hàng mới";
    ViewData["Breadcrumbs"] = new List<BreadcrumbItem>
    {
        new("Trang chủ", "/"),
        new("Khách hàng", "/Customer"),
        new("Tạo mới")
    };
}

<div class="row justify-content-center">
    <div class="col-xl-8 col-lg-10">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom py-3">
                <div class="d-flex align-items-center gap-2">
                    <a href="/Customer" class="btn btn-sm btn-light border">
                        <i class="bi bi-arrow-left"></i>
                    </a>
                    <h5 class="mb-0 fw-semibold">
                        <i class="bi bi-building-add me-2 text-primary"></i>Thêm khách hàng mới
                    </h5>
                </div>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" asp-controller="Customer" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                    <!-- Section: Thông tin cơ bản -->
                    <h6 class="fw-semibold text-muted text-uppercase mb-3" style="font-size:0.75rem;letter-spacing:.06em;">
                        <i class="bi bi-info-circle me-1"></i> Thông tin cơ bản
                    </h6>
                    <div class="row g-3 mb-4">
                        <div class="col-12">
                            <label asp-for="CustomerName" class="form-label fw-semibold small"></label>
                            <input asp-for="CustomerName" class="form-control"
                                   placeholder="VD: Khách sạn ABC" autofocus />
                            <span asp-validation-for="CustomerName" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="TaxCode" class="form-label fw-semibold small"></label>
                            <input asp-for="TaxCode" class="form-control" placeholder="0100000000" />
                            <span asp-validation-for="TaxCode" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="CustomerGroupId" class="form-label fw-semibold small"></label>
                            <select asp-for="CustomerGroupId" class="form-select">
                                <option value="">-- Chọn nhóm --</option>
                                @foreach (var g in Model.Groups)
                                {
                                    <option value="@g.CustomerGroupId">@g.GroupName</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Phone" class="form-label fw-semibold small"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-telephone"></i></span>
                                <input asp-for="Phone" class="form-control" placeholder="0901234567" />
                            </div>
                            <span asp-validation-for="Phone" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label fw-semibold small"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                                <input asp-for="Email" class="form-control" placeholder="info@hotel.com" />
                            </div>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Website" class="form-label fw-semibold small"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-globe"></i></span>
                                <input asp-for="Website" class="form-control" placeholder="https://hotel.com" />
                            </div>
                        </div>
                    </div>

                    <!-- Section: Địa chỉ -->
                    <h6 class="fw-semibold text-muted text-uppercase mb-3" style="font-size:0.75rem;letter-spacing:.06em;">
                        <i class="bi bi-geo-alt me-1"></i> Địa chỉ
                    </h6>
                    <div class="row g-3 mb-4">
                        <div class="col-12">
                            <label asp-for="Address" class="form-label fw-semibold small"></label>
                            <input asp-for="Address" class="form-control" placeholder="Số nhà, tên đường..." />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="City" class="form-label fw-semibold small"></label>
                            <select id="selCity" name="City" class="form-select">
                                <option value="">-- Chọn tỉnh/thành phố --</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="District" class="form-label fw-semibold small"></label>
                            <select id="selDistrict" name="District" class="form-select" disabled>
                                <option value="">-- Chọn quận/huyện --</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Ward" class="form-label fw-semibold small"></label>
                            <select id="selWard" name="Ward" class="form-select" disabled>
                                <option value="">-- Chọn phường/xã --</option>
                            </select>
                        </div>
                    </div>

                    <!-- Section: Thương mại -->
                    <h6 class="fw-semibold text-muted text-uppercase mb-3" style="font-size:0.75rem;letter-spacing:.06em;">
                        <i class="bi bi-cash-coin me-1"></i> Thông tin thương mại
                    </h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label asp-for="SalesPersonId" class="form-label fw-semibold small"></label>
                            <select asp-for="SalesPersonId" class="form-select">
                                <option value="">-- Chưa gán --</option>
                                @foreach (var sp in Model.SalesPersons)
                                {
                                    <option value="@sp.UserId">@sp.FullName (@sp.UserCode)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="PaymentTermDays" class="form-label fw-semibold small"></label>
                            <div class="input-group">
                                <input asp-for="PaymentTermDays" class="form-control" type="number" min="0" max="365" />
                                <span class="input-group-text">ngày</span>
                            </div>
                            <span asp-validation-for="PaymentTermDays" class="text-danger small"></span>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="CreditLimit" class="form-label fw-semibold small"></label>
                            <input asp-for="CreditLimit" class="form-control" type="number" min="0" step="1000000"
                                   placeholder="VD: 50000000" />
                            <span asp-validation-for="CreditLimit" class="text-danger small"></span>
                        </div>
                    </div>

                    <!-- Section: Ghi chú & Trạng thái -->
                    <div class="row g-3 mb-4">
                        <div class="col-12">
                            <label asp-for="InternalNotes" class="form-label fw-semibold small"></label>
                            <textarea asp-for="InternalNotes" class="form-control" rows="3"
                                      placeholder="Ghi chú nội bộ (không hiển thị ra ngoài)..."></textarea>
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox"
                                       role="switch" checked />
                                <label asp-for="IsActive" class="form-check-label small fw-semibold"></label>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4" />
                    <div class="d-flex gap-2 justify-content-end">
                        <a href="/Customer" class="btn btn-outline-secondary">Hủy</a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i> Tạo khách hàng
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        let _cities = [], _districts = [], _wardsCache = {};

        async function initRegion(initCity, initDistrict, initWard) {
            [_cities, _districts] = await Promise.all([
                fetch('/region/cities.json').then(r => r.json()),
                fetch('/region/districts.json').then(r => r.json())
            ]);

            const selCity = document.getElementById('selCity');
            [..._cities]
                .sort((a, b) => a.name.localeCompare(b.name, 'vi'))
                .forEach(c => selCity.add(new Option(c.name_with_type, c.name)));

            selCity.addEventListener('change', function () {
                const city = _cities.find(c => c.name === this.value);
                fillDistricts(city ? city.code : null, null, null);
            });
            document.getElementById('selDistrict').addEventListener('change', async function () {
                const dist = _districts.find(d => d.name === this.value);
                await fillWards(dist ? dist.code : null, null);
            });

            if (initCity) {
                const city = _cities.find(c => c.name === initCity || c.name_with_type === initCity);
                if (city) {
                    selCity.value = city.name;
                    await fillDistricts(city.code, initDistrict, initWard);
                }
            }
        }

        async function fillDistricts(cityCode, initDistrict, initWard) {
            const sel = document.getElementById('selDistrict');
            const selWard = document.getElementById('selWard');
            sel.innerHTML = '<option value="">-- Chọn quận/huyện --</option>';
            selWard.innerHTML = '<option value="">-- Chọn phường/xã --</option>';
            selWard.disabled = true;
            if (!cityCode) { sel.disabled = true; return; }
            sel.disabled = false;
            const items = _districts.filter(d => d.parent_code === cityCode)
                .sort((a, b) => a.name.localeCompare(b.name, 'vi'));
            items.forEach(d => sel.add(new Option(d.name_with_type, d.name)));
            if (initDistrict) {
                const dist = items.find(d => d.name === initDistrict || d.name_with_type === initDistrict);
                if (dist) { sel.value = dist.name; await fillWards(dist.code, initWard); }
            }
        }

        async function fillWards(distCode, initWard) {
            const sel = document.getElementById('selWard');
            sel.innerHTML = '<option value="">-- Chọn phường/xã --</option>';
            if (!distCode) { sel.disabled = true; return; }
            if (!_wardsCache[distCode]) {
                const all = await fetch('/region/wards.json').then(r => r.json());
                all.forEach(w => {
                    (_wardsCache[w.parent_code] = _wardsCache[w.parent_code] || []).push(w);
                });
            }
            sel.disabled = false;
            const items = (_wardsCache[distCode] || []).sort((a, b) => a.name.localeCompare(b.name, 'vi'));
            items.forEach(w => sel.add(new Option(w.name_with_type, w.name)));
            if (initWard) {
                const ward = items.find(w => w.name === initWard || w.name_with_type === initWard);
                if (ward) sel.value = ward.name;
            }
        }
    </script>
    <script>
        document.addEventListener('DOMContentLoaded', () => initRegion(null, null, null));
    </script>
}
