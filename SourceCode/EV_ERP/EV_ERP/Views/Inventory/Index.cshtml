@model EV_ERP.Models.ViewModels.Stock.InventoryListViewModel
@{
    ViewData["Title"] = "Tồn kho";
    ViewData["Breadcrumbs"] = new List<BreadcrumbItem>
    {
        new("Trang chủ", "/"),
        new("Tồn kho")
    };
}

<div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
    <div>
        <p class="text-muted small mb-0" id="productViewSummary">
            @Model.TotalProducts sản phẩm — Tổng tồn: <strong>@Model.TotalQuantity.ToString("N0")</strong>
        </p>
    </div>
    <div class="btn-group btn-group-sm" role="group" aria-label="Chọn cách tra cứu">
        <button type="button" class="btn btn-primary" id="viewBtnProduct" onclick="switchView('product')">
            <i class="bi bi-box-seam me-1"></i> Theo sản phẩm
        </button>
        <button type="button" class="btn btn-outline-primary" id="viewBtnOrder" onclick="switchView('order')">
            <i class="bi bi-receipt me-1"></i> Theo đơn hàng
        </button>
    </div>
</div>

<!-- ── PRODUCT VIEW ────────────────────────────────── -->
<div id="productView">

<!-- Barcode quick lookup -->
<div class="card border-1 border-primary mb-3" style="border-style:dashed !important;">
    <div class="card-body py-2">
        <div class="row g-2 align-items-center">
            <div class="col">
                <div class="input-group input-group-sm">
                    <span class="input-group-text bg-primary text-white"><i class="bi bi-upc-scan"></i></span>
                    <input type="text" id="quickBarcode" class="form-control"
                           placeholder="Quét barcode hoặc nhập mã SP để tra cứu tồn kho nhanh..."
                           autocomplete="off" />
                    <button class="btn btn-primary btn-sm" onclick="doQuickLookup()">
                        <i class="bi bi-search"></i>
                    </button>
                    <button class="btn btn-outline-primary btn-sm" type="button" onclick="openCameraScanner()" title="Quét bằng camera">
                        <i class="bi bi-camera"></i>
                    </button>
                </div>
            </div>
        </div>
        <div id="lookupResult" class="mt-2" style="display:none;"></div>
    </div>
</div>

<!-- Filter bar -->
<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-3">
        <form method="get" asp-action="Index" class="row g-2 align-items-end">
            <div class="col-12 col-sm-4 col-lg-4">
                <label class="form-label small fw-semibold mb-1">Tìm kiếm</label>
                <div class="input-group input-group-sm">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" name="keyword" class="form-control"
                           placeholder="Tên, mã SP, barcode..."
                           value="@Model.SearchKeyword" />
                </div>
            </div>
            <div class="col-6 col-sm-3 col-lg-3">
                <label class="form-label small fw-semibold mb-1">Kho</label>
                <select name="warehouseId" class="form-select form-select-sm">
                    <option value="">Tất cả kho</option>
                    @foreach (var w in Model.Warehouses)
                    {
                        <option value="@w.WarehouseId" selected="@(Model.FilterWarehouseId == w.WarehouseId)">
                            @w.WarehouseCode - @w.WarehouseName
                        </option>
                    }
                </select>
            </div>
            <div class="col-6 col-sm-3 col-lg-3">
                <label class="form-label small fw-semibold mb-1">Trạng thái</label>
                <select name="status" class="form-select form-select-sm">
                    <option value="">Tất cả</option>
                    <option value="low" selected="@(Model.FilterStatus == "low")">Dưới mức tối thiểu</option>
                    <option value="out" selected="@(Model.FilterStatus == "out")">Hết hàng</option>
                </select>
            </div>
            <div class="col-6 col-sm-2 col-lg-2 d-flex gap-1">
                <button type="submit" class="btn btn-primary btn-sm flex-fill">
                    <i class="bi bi-funnel me-1"></i> Lọc
                </button>
                <a href="/Inventory" class="btn btn-outline-secondary btn-sm" title="Xóa bộ lọc">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Inventory Table -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (!Model.Records.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-archive" style="font-size: 3rem; opacity: 0.3;"></i>
                <p class="mt-2 mb-0">Chưa có dữ liệu tồn kho</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" style="font-size:0.875rem;">
                    <thead class="table-light">
                        <tr>
                            <th style="width:40px;">#</th>
                            <th style="width:44px;"></th>
                            <th>Sản phẩm</th>
                            <th class="d-none d-md-table-cell">Barcode</th>
                            <th class="d-none d-lg-table-cell">Danh mục</th>
                            <th class="text-end">Tồn kho</th>
                            <th class="text-end d-none d-md-table-cell">Đã giữ</th>
                            <th class="text-end d-none d-md-table-cell">Khả dụng</th>
                            <th>ĐVT</th>
                            <th style="width:80px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int idx = 1; }
                        @foreach (var r in Model.Records)
                        {
                            <tr class="@(r.IsLowStock ? "table-warning" : "")">
                                <td class="text-muted small">@(idx++)</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(r.ImageUrl))
                                    {
                                        <img src="@r.ImageUrl" alt="" class="rounded"
                                             style="width:32px;height:32px;object-fit:cover;" />
                                    }
                                    else
                                    {
                                        <div class="bg-light rounded d-flex align-items-center justify-content-center"
                                             style="width:32px;height:32px;">
                                            <i class="bi bi-box text-muted"></i>
                                        </div>
                                    }
                                </td>
                                <td>
                                    <a href="/Inventory/ProductDetail/@r.ProductId"
                                       class="fw-semibold text-decoration-none text-dark link-hover">
                                        @r.ProductName
                                    </a>
                                    <div class="text-muted small">@r.ProductCode</div>
                                </td>
                                <td class="d-none d-md-table-cell">
                                    @if (!string.IsNullOrEmpty(r.Barcode))
                                    {
                                        <span class="font-monospace small bg-light px-2 py-1 rounded">
                                            <i class="bi bi-upc me-1"></i>@r.Barcode
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                                <td class="d-none d-lg-table-cell text-muted small">@(r.CategoryName ?? "—")</td>
                                <td class="text-end fw-bold @(r.IsLowStock ? "text-danger" : "")">
                                    @r.QuantityOnHand.ToString("N0")
                                    @if (r.IsLowStock)
                                    {
                                        <i class="bi bi-exclamation-triangle-fill text-danger ms-1" style="font-size:0.7rem;"
                                           title="Dưới mức tối thiểu (@r.MinStockLevel)"></i>
                                    }
                                </td>
                                <td class="text-end d-none d-md-table-cell text-muted">@r.QuantityReserved.ToString("N0")</td>
                                <td class="text-end d-none d-md-table-cell fw-semibold">@r.QuantityAvailable.ToString("N0")</td>
                                <td class="text-muted small">@r.UnitName</td>
                                <td>
                                    <a href="/Inventory/ProductDetail/@r.ProductId"
                                       class="btn btn-sm btn-outline-secondary" title="Chi tiết tồn kho">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

</div><!-- /#productView -->

<!-- ── ORDER VIEW ──────────────────────────────────── -->
<div id="orderView" style="display:none;">
    <div class="card border-1 border-success mb-3" style="border-style:dashed !important;">
        <div class="card-body py-2">
            <div class="row g-2 align-items-center">
                <div class="col">
                    <div class="input-group input-group-sm">
                        <span class="input-group-text bg-success text-white"><i class="bi bi-clipboard-check"></i></span>
                        <input type="text" id="soLookupInput" class="form-control"
                               placeholder="Nhập mã đơn hàng (vd: SO-202605-001) để xem tiến độ nhận hàng theo từng dòng..."
                               autocomplete="off" />
                        <button class="btn btn-success btn-sm" onclick="doSoLookup()">
                            <i class="bi bi-search me-1"></i> Tra cứu
                        </button>
                        <button class="btn btn-outline-secondary btn-sm" type="button" onclick="clearSoLookup()" title="Xóa kết quả">
                            <i class="bi bi-x-lg"></i>
                        </button>
                    </div>
                </div>
            </div>
            <div id="soLookupResult" class="mt-2" style="display:none;"></div>
        </div>
    </div>
</div><!-- /#orderView -->

<style>
    .link-hover:hover { color: #2563eb !important; }
    #quickBarcode:focus { box-shadow: 0 0 0 3px rgba(59,130,246,0.25); border-color: #3b82f6; }
    #soLookupInput:focus { box-shadow: 0 0 0 3px rgba(25,135,84,0.25); border-color: #198754; }
</style>

<script>
    // ── View Switcher (Product / Order) ─────────────────
    function switchView(mode) {
        var productView = document.getElementById('productView');
        var orderView = document.getElementById('orderView');
        var btnP = document.getElementById('viewBtnProduct');
        var btnO = document.getElementById('viewBtnOrder');
        var summary = document.getElementById('productViewSummary');

        if (mode === 'order') {
            productView.style.display = 'none';
            orderView.style.display = '';
            btnP.classList.remove('btn-primary'); btnP.classList.add('btn-outline-primary');
            btnO.classList.remove('btn-outline-primary'); btnO.classList.add('btn-primary');
            if (summary) summary.style.display = 'none';
            setTimeout(function () { document.getElementById('soLookupInput').focus(); }, 50);
        } else {
            productView.style.display = '';
            orderView.style.display = 'none';
            btnO.classList.remove('btn-primary'); btnO.classList.add('btn-outline-primary');
            btnP.classList.remove('btn-outline-primary'); btnP.classList.add('btn-primary');
            if (summary) summary.style.display = '';
        }
        try { localStorage.setItem('inventoryView', mode); } catch (e) { }
    }

    (function () {
        var saved = null;
        try { saved = localStorage.getItem('inventoryView'); } catch (e) { }
        if (saved === 'order') switchView('order');
    })();

    document.getElementById('quickBarcode').addEventListener('keydown', function (e) {
        if (e.key === 'Enter') { e.preventDefault(); doQuickLookup(); }
    });

    function doQuickLookup() {
        var input = document.getElementById('quickBarcode');
        var barcode = input.value.trim();
        if (!barcode) return;

        var resultDiv = document.getElementById('lookupResult');
        resultDiv.style.display = 'none';

        fetch('/Inventory/QuickLookup?barcode=' + encodeURIComponent(barcode))
            .then(r => r.json())
            .then(data => {
                if (!data.Success) {
                    resultDiv.innerHTML = '<div class="alert alert-warning py-2 small mb-0">' +
                        '<i class="bi bi-exclamation-triangle me-1"></i>' + data.Message + '</div>';
                    resultDiv.style.display = 'block';
                    return;
                }

                var p = data.Data;
                var imgHtml = p.ImageUrl
                    ? '<img src="' + p.ImageUrl + '" class="rounded me-2" style="width:40px;height:40px;object-fit:cover;" />'
                    : '';

                resultDiv.innerHTML =
                    '<div class="d-flex align-items-center justify-content-between bg-light rounded p-2">' +
                        '<div class="d-flex align-items-center">' +
                            imgHtml +
                            '<div>' +
                                '<div class="fw-semibold small">' + p.ProductName + '</div>' +
                                '<div class="text-muted" style="font-size:0.75rem;">' +
                                    p.ProductCode +
                                    (p.Barcode ? ' | <i class="bi bi-upc"></i> ' + p.Barcode : '') +
                                '</div>' +
                            '</div>' +
                        '</div>' +
                        '<div class="text-end">' +
                            '<div class="fw-bold">' + p.QuantityOnHand.toLocaleString('vi-VN') + ' ' + p.UnitName + '</div>' +
                            '<a href="/Inventory/ProductDetail/' + p.ProductId + '" class="small">Chi tiết &rarr;</a>' +
                        '</div>' +
                    '</div>';
                resultDiv.style.display = 'block';
                input.value = '';
                input.focus();
            });
    }

    // ── SO Receive Progress Lookup ──────────────────────
    document.getElementById('soLookupInput').addEventListener('keydown', function (e) {
        if (e.key === 'Enter') { e.preventDefault(); doSoLookup(); }
    });

    function clearSoLookup() {
        document.getElementById('soLookupInput').value = '';
        var r = document.getElementById('soLookupResult');
        r.innerHTML = '';
        r.style.display = 'none';
    }

    function doSoLookup() {
        var input = document.getElementById('soLookupInput');
        var code = input.value.trim();
        var resultDiv = document.getElementById('soLookupResult');
        if (!code) {
            resultDiv.style.display = 'none';
            return;
        }

        resultDiv.innerHTML = '<div class="text-muted small"><i class="bi bi-hourglass-split me-1"></i>Đang tra cứu...</div>';
        resultDiv.style.display = 'block';

        fetch('/Inventory/LookupSalesOrder?soCode=' + encodeURIComponent(code))
            .then(r => r.json())
            .then(data => {
                if (!data.Success) {
                    resultDiv.innerHTML = '<div class="alert alert-warning py-2 small mb-0">' +
                        '<i class="bi bi-exclamation-triangle me-1"></i>' + data.Message + '</div>';
                    return;
                }
                renderSoLookup(data.Data, resultDiv);
            })
            .catch(err => {
                resultDiv.innerHTML = '<div class="alert alert-danger py-2 small mb-0">' +
                    '<i class="bi bi-x-circle me-1"></i>Lỗi: ' + err + '</div>';
            });
    }

    function fmtNum(n) { return (n || 0).toLocaleString('vi-VN'); }
    function fmtDate(s) {
        if (!s) return '—';
        var d = new Date(s);
        if (isNaN(d.getTime())) return '—';
        return d.getDate().toString().padStart(2,'0') + '/' +
               (d.getMonth()+1).toString().padStart(2,'0') + '/' +
               d.getFullYear();
    }
    function lineStatusBadge(status, text) {
        var css = ({
            'RECEIVED': 'bg-success',
            'PARTIAL': 'bg-warning text-dark',
            'NOT_STARTED': 'bg-secondary',
            'CANCELLED': 'bg-dark'
        })[status] || 'bg-light text-dark';
        return '<span class="badge ' + css + '">' + text + '</span>';
    }
    function soStatusBadge(status, text) {
        var css = ({
            'DRAFT': 'bg-light text-dark border',
            'WAIT': 'bg-secondary',
            'BUYING': 'bg-info',
            'RECEIVED': 'bg-primary',
            'DELIVERING': 'bg-warning text-dark',
            'DELIVERED': 'bg-success',
            'COMPLETED': 'bg-success',
            'RETURNED': 'bg-secondary',
            'REPORTED': 'bg-primary',
            'CANCELLED': 'bg-danger'
        })[status] || 'bg-secondary';
        return '<span class="badge ' + css + '">' + text + '</span>';
    }

    function renderSoLookup(d, target) {
        var ratioPct = d.TotalLines > 0
            ? Math.round((d.FullyReceivedLines + d.CancelledLines) * 100 / d.TotalLines)
            : 0;
        var overallBadge = d.IsFullyReceived
            ? '<span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Đã nhận đủ toàn bộ</span>'
            : '<span class="badge bg-warning text-dark"><i class="bi bi-hourglass-split me-1"></i>Chưa nhận đủ</span>';

        var html =
            '<div class="card border-success shadow-sm">' +
              '<div class="card-header bg-success bg-opacity-10 py-2">' +
                '<div class="d-flex flex-wrap align-items-center gap-2 justify-content-between">' +
                  '<div>' +
                    '<a href="/SalesOrder/Detail/' + d.SalesOrderId + '" class="fw-bold text-decoration-none">' +
                       '<i class="bi bi-receipt me-1"></i>' + d.SalesOrderNo +
                    '</a>' +
                    ' &middot; <span class="text-muted small">' + (d.CustomerName || '—') + '</span>' +
                    ' &middot; <span class="text-muted small">Đặt: ' + fmtDate(d.OrderDate) + '</span>' +
                    (d.ExpectedReceiveDate ? ' &middot; <span class="text-muted small">Dự kiến nhận: ' + fmtDate(d.ExpectedReceiveDate) + '</span>' : '') +
                  '</div>' +
                  '<div class="d-flex gap-1">' +
                    soStatusBadge(d.Status, d.StatusText) +
                    overallBadge +
                  '</div>' +
                '</div>' +
              '</div>' +

              '<div class="card-body py-2">' +
                // summary row
                '<div class="row g-2 mb-2">' +
                  '<div class="col-6 col-md-3"><div class="border rounded p-2 text-center">' +
                    '<div class="text-muted small">Đã nhận đủ</div>' +
                    '<div class="fw-bold text-success">' + d.FullyReceivedLines + ' / ' + d.TotalLines + ' dòng</div>' +
                  '</div></div>' +
                  '<div class="col-6 col-md-3"><div class="border rounded p-2 text-center">' +
                    '<div class="text-muted small">Nhận một phần</div>' +
                    '<div class="fw-bold text-warning">' + d.PartialLines + ' dòng</div>' +
                  '</div></div>' +
                  '<div class="col-6 col-md-3"><div class="border rounded p-2 text-center">' +
                    '<div class="text-muted small">Chưa nhận</div>' +
                    '<div class="fw-bold text-secondary">' + d.NotStartedLines + ' dòng</div>' +
                  '</div></div>' +
                  '<div class="col-6 col-md-3"><div class="border rounded p-2 text-center">' +
                    '<div class="text-muted small">Đã hủy</div>' +
                    '<div class="fw-bold text-dark">' + d.CancelledLines + ' dòng</div>' +
                  '</div></div>' +
                '</div>' +

                // progress bar
                '<div class="progress mb-2" style="height:6px;">' +
                  '<div class="progress-bar bg-success" role="progressbar" style="width:' + ratioPct + '%"></div>' +
                '</div>' +
                '<div class="d-flex justify-content-between small text-muted mb-2">' +
                  '<div>Tổng SL đặt: <strong>' + fmtNum(d.TotalOrderedQty) + '</strong>' +
                  ' &middot; Đã nhận: <strong class="text-success">' + fmtNum(d.TotalReceivedQty) + '</strong>' +
                  ' &middot; Còn lại: <strong class="text-warning">' + fmtNum(d.TotalRemainingQty) + '</strong>' +
                  (d.TotalCancelledQty > 0 ? ' &middot; Đã hủy: <strong>' + fmtNum(d.TotalCancelledQty) + '</strong>' : '') +
                  '</div>' +
                  '<div>' + ratioPct + '% hoàn thành</div>' +
                '</div>' +

                // items table
                '<div class="table-responsive">' +
                  '<table class="table table-sm table-hover align-middle mb-0" style="font-size:0.825rem;">' +
                    '<thead class="table-light">' +
                      '<tr>' +
                        '<th style="width:40px;">#</th>' +
                        '<th style="width:44px;"></th>' +
                        '<th>Sản phẩm</th>' +
                        '<th class="text-end">SL đặt</th>' +
                        '<th class="text-end">Đã nhận</th>' +
                        '<th class="text-end">Còn lại</th>' +
                        '<th class="text-end">Đã hủy</th>' +
                        '<th class="text-end">Trong kho</th>' +
                        '<th class="d-none d-md-table-cell">Dự kiến</th>' +
                        '<th>Trạng thái</th>' +
                      '</tr>' +
                    '</thead>' +
                    '<tbody>';

        d.Lines.forEach(function (l, i) {
            var imgHtml = l.ImageUrl
                ? '<img src="' + l.ImageUrl + '" class="rounded" style="width:32px;height:32px;object-fit:cover;" />'
                : '<div class="bg-light rounded d-flex align-items-center justify-content-center" style="width:32px;height:32px;"><i class="bi bi-box text-muted"></i></div>';
            var prodLink = l.ProductId
                ? '<a href="/Inventory/ProductDetail/' + l.ProductId + '" class="fw-semibold text-decoration-none text-dark">' + l.ProductName + '</a>'
                : '<span class="fw-semibold">' + l.ProductName + '</span>';
            var codeStr = l.ProductCode ? '<div class="text-muted small">' + l.ProductCode + (l.Barcode ? ' · ' + l.Barcode : '') + '</div>' : '';
            var rowClass = l.LineStatus === 'CANCELLED' ? 'text-muted' :
                           l.LineStatus === 'RECEIVED' ? 'table-success' :
                           l.LineStatus === 'PARTIAL' ? 'table-warning' : '';

            html +=
                '<tr class="' + rowClass + '">' +
                  '<td class="text-muted small">' + (i + 1) + '</td>' +
                  '<td>' + imgHtml + '</td>' +
                  '<td>' + prodLink + codeStr + '</td>' +
                  '<td class="text-end">' + fmtNum(l.Quantity) + ' <span class="text-muted small">' + l.UnitName + '</span></td>' +
                  '<td class="text-end fw-semibold text-success">' + fmtNum(l.ReceivedQty) + '</td>' +
                  '<td class="text-end fw-semibold ' + (l.RemainingReceiveQty > 0 ? 'text-warning' : 'text-muted') + '">' + fmtNum(l.RemainingReceiveQty) + '</td>' +
                  '<td class="text-end ' + (l.CancelledQty > 0 ? 'text-dark fw-semibold' : 'text-muted') + '">' + fmtNum(l.CancelledQty) + '</td>' +
                  '<td class="text-end">' + fmtNum(l.InStockQty) + '</td>' +
                  '<td class="d-none d-md-table-cell text-muted small">' + fmtDate(l.ExpectedReceiveDate) + '</td>' +
                  '<td>' + lineStatusBadge(l.LineStatus, l.LineStatusText) + '</td>' +
                '</tr>';
        });

        html +=
                    '</tbody>' +
                  '</table>' +
                '</div>' +
              '</div>' +
            '</div>';

        target.innerHTML = html;
        target.style.display = 'block';
    }

    // ── Camera Barcode Scanner ──────────────────────────
    var html5QrCode = null;

    function openCameraScanner() {
        var modal = new bootstrap.Modal(document.getElementById('cameraScannerModal'));
        modal.show();
        document.getElementById('cameraScannerModal').addEventListener('shown.bs.modal', startCameraScanner, { once: true });
    }

    function startCameraScanner() {
        var readerEl = document.getElementById('cameraScannerReader');
        readerEl.innerHTML = '';
        document.getElementById('cameraScanStatus').textContent = 'Đang khởi động camera...';

        html5QrCode = new Html5Qrcode('cameraScannerReader');
        html5QrCode.start(
            { facingMode: 'environment' },
            { fps: 10, qrbox: { width: 280, height: 120 }, aspectRatio: 1.5 },
            function (decodedText) {
                document.getElementById('cameraScanStatus').innerHTML =
                    '<span class="text-success"><i class="bi bi-check-circle me-1"></i>Đã quét: ' + decodedText + '</span>';
                stopCameraScanner();
                bootstrap.Modal.getInstance(document.getElementById('cameraScannerModal')).hide();
                document.getElementById('quickBarcode').value = decodedText;
                doQuickLookup();
            },
            function () { }
        ).then(function () {
            document.getElementById('cameraScanStatus').textContent = 'Đưa barcode vào khung hình để quét...';
        }).catch(function (err) {
            document.getElementById('cameraScanStatus').innerHTML =
                '<span class="text-danger"><i class="bi bi-exclamation-triangle me-1"></i>Không thể mở camera: ' + err + '</span>';
        });
    }

    function stopCameraScanner() {
        if (html5QrCode && html5QrCode.isScanning) {
            html5QrCode.stop().catch(function () { });
        }
    }

    document.getElementById('cameraScannerModal').addEventListener('hidden.bs.modal', stopCameraScanner);
</script>

<!-- Camera Scanner Modal -->
<div class="modal fade" id="cameraScannerModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title"><i class="bi bi-camera me-1"></i> Quét Barcode bằng Camera</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-2">
                <div id="cameraScannerReader" style="width:100%;"></div>
                <div id="cameraScanStatus" class="text-center small text-muted mt-2">Đang khởi động camera...</div>
            </div>
            <div class="modal-footer py-1">
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>
