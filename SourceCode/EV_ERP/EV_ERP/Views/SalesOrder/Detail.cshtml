<!-- Giá nhập hiện tại — Calc Modal (ported from Quotation calcModal) -->
<div class="modal fade" id="calcModal" tabindex="-1" aria-labelledby="calcModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title fw-semibold" id="calcModalTitle">
                    <i class="bi bi-calculator me-1 text-primary"></i> Tính giá nhập — <span id="calcRowLabel" class="text-muted"></span>
                </h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="calcItemId" />
                <!-- Mode toggle -->
                <div class="mb-3">
                    <div class="d-flex gap-4">
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="calcMode" id="calcModeDomestic" value="DOMESTIC">
                            <label class="form-check-label" for="calcModeDomestic">Mua trong nước</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="calcMode" id="calcModeUnofficial" value="UNOFFICIAL">
                            <label class="form-check-label" for="calcModeUnofficial">Nhập tiểu ngạch</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="calcMode" id="calcModeOfficial" value="OFFICIAL">
                            <label class="form-check-label" for="calcModeOfficial">Nhập chính ngạch</label>
                        </div>
                    </div>
                </div>

                <!-- Currency/Rate + VAT (domestic) + Base price + Purchase quantity -->
                <div class="row g-2 mb-3">
                    <div class="col-md">
                        <label class="form-label small fw-semibold">Đơn giá gốc</label>
                        <input type="text" inputmode="decimal" class="form-control form-control-sm text-end"
                               id="calcBasePrice" oninput="formatMoneyInput(this); onCalcInput();" onfocus="this.select()" />
                    </div>
                    <div class="col-md">
                        <label class="form-label small fw-semibold d-flex align-items-center justify-content-between" style="gap:4px;">
                            <span id="calcCurrRateLabelText">Tỷ giá</span>
                            <button type="button" class="btn btn-sm btn-link p-0 text-danger" id="calcResetCurrBtn" onclick="resetCalcCurrency()" style="display:none;" title="Đổi lại VND">×</button>
                        </label>
                        <select class="form-select form-select-sm" id="calcCurrency"></select>
                        <input type="text" inputmode="decimal" class="form-control form-control-sm text-end"
                               id="calcRate" style="display:none;" oninput="formatMoneyInput(this); onCalcInput();" onfocus="this.select()" placeholder="Nhập tỷ giá" />
                    </div>
                    <!-- VAT — chỉ áp dụng cho "Mua trong nước" (DOMESTIC) -->
                    <div class="col-md" id="calcVatCol" style="display:none;">
                        <label class="form-label small fw-semibold">VAT (%)</label>
                        <input type="text" inputmode="decimal" class="form-control form-control-sm text-end"
                               id="calcVatPercent" oninput="onCalcInput();" onfocus="this.select()" placeholder="VAT %" />
                    </div>
                    <div class="col-md">
                        <label class="form-label small fw-semibold">Số lượng mua</label>
                        <input type="text" inputmode="decimal" class="form-control form-control-sm text-end"
                               id="calcQty" oninput="onCalcInput();" onfocus="this.select()" />
                    </div>
                </div>

                <!-- OFFICIAL / DOMESTIC panel — shipping only -->
                <div id="calcOfficialPanel">
                    <div class="card border-primary-subtle">
                        <div class="card-header bg-primary-subtle py-2 small fw-semibold">
                            <i class="bi bi-shield-check me-1"></i> Chi phí vận chuyển
                        </div>
                        <div class="card-body py-2">
                            <div class="row g-2">
                                <div class="col-md-12">
                                    <input type="text" inputmode="decimal" class="form-control form-control-sm text-end"
                                           id="calcOfficialShipping" oninput="formatMoneyInput(this); onCalcInput();" onfocus="this.select()" />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- UNOFFICIAL panel — shipping breakdown -->
                <div id="calcUnofficialPanel" style="display:none;">
                    <div class="card border-warning-subtle">
                        <div class="card-header bg-warning-subtle py-2 small fw-semibold">
                            <i class="bi bi-truck me-1"></i> Chi phí vận chuyển
                        </div>
                        <div class="card-body py-2">
                            <div class="row g-2">
                                <div class="col-md-6">
                                    <label class="form-label small">Phí vận chuyển nội địa <span class="text-muted">(VND)</span></label>
                                    <input type="text" inputmode="decimal" class="form-control form-control-sm text-end"
                                           id="calcDomesticShipping" oninput="formatMoneyInput(this); onCalcInput();" onfocus="this.select()" />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label small">Cân nặng (kg)</label>
                                    <input type="text" inputmode="decimal" class="form-control form-control-sm text-end"
                                           id="calcWeight" onchange="onCalcInput()" onfocus="this.select()" />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label small">Phí / kg (VND)</label>
                                    <input type="text" inputmode="decimal" class="form-control form-control-sm text-end"
                                           id="calcCostPerKg" oninput="formatMoneyInput(this); onCalcInput();" onfocus="this.select()" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label small">Phí xách tay (VND)</label>
                                    <input type="text" inputmode="decimal" class="form-control form-control-sm text-end"
                                           id="calcHandCarry" oninput="formatMoneyInput(this); onCalcInput();" onfocus="this.select()" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label small">Kho trung gian → kho công ty (VND)</label>
                                    <input type="text" inputmode="decimal" class="form-control form-control-sm text-end"
                                           id="calcW2W" oninput="formatMoneyInput(this); onCalcInput();" onfocus="this.select()" />
                                </div>

                                <!-- Thể tích (CBM): Dài × Rộng × Cao (m) × Phí/CBM -->
                                <div class="col-12">
                                    <hr class="my-1" />
                                    <span class="small fw-semibold text-muted"><i class="bi bi-box me-1"></i>Thể tích (CBM)</span>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label small">Dài (m)</label>
                                    <input type="text" inputmode="decimal" class="form-control form-control-sm text-end"
                                           id="calcLength" oninput="onCalcInput()" onfocus="this.select()" />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label small">Rộng (m)</label>
                                    <input type="text" inputmode="decimal" class="form-control form-control-sm text-end"
                                           id="calcWidth" oninput="onCalcInput()" onfocus="this.select()" />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label small">Cao (m)</label>
                                    <input type="text" inputmode="decimal" class="form-control form-control-sm text-end"
                                           id="calcHeight" oninput="onCalcInput()" onfocus="this.select()" />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label small">Phí / CBM (VND)</label>
                                    <input type="text" inputmode="decimal" class="form-control form-control-sm text-end"
                                           id="calcCostPerCbm" oninput="formatMoneyInput(this); onCalcInput();" onfocus="this.select()" />
                                </div>
                                <div class="col-12">
                                    <div class="small text-muted text-end">CBM = Dài × Rộng × Cao = <span id="calcCbmValue" class="fw-semibold">0</span> m³</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Common cost components -->
                <div class="card border-secondary-subtle mt-3" id="calcCommonCostCard">
                    <div class="card-header bg-light py-2 small fw-semibold">
                        <i class="bi bi-receipt me-1"></i> Chi phí khác (VND)
                    </div>
                    <div class="card-body py-2">
                        <div class="row g-2">
                            <div class="col-md-3">
                                <label class="form-label small">Thuế</label>
                                <input type="text" inputmode="decimal" class="form-control form-control-sm text-end"
                                       id="calcTax" oninput="formatMoneyInput(this); onCalcInput();" onfocus="this.select()" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small">Phí kiểm định</label>
                                <input type="text" inputmode="decimal" class="form-control form-control-sm text-end"
                                       id="calcInspection" oninput="formatMoneyInput(this); onCalcInput();" onfocus="this.select()" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small">Phí ngân hàng</label>
                                <input type="text" inputmode="decimal" class="form-control form-control-sm text-end"
                                       id="calcBanking" oninput="formatMoneyInput(this); onCalcInput();" onfocus="this.select()" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small">Chi phí khác</label>
                                <input type="text" inputmode="decimal" class="form-control form-control-sm text-end"
                                       id="calcOther" oninput="formatMoneyInput(this); onCalcInput();" onfocus="this.select()" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Live preview -->
                <div class="card mt-3 border-0 bg-light">
                    <div class="card-body py-2">
                        <div class="row text-end">
                            <div class="col-md-6">
                                <div class="small text-muted">Tổng chi phí dòng (VND)</div>
                                <div class="fw-semibold" id="calcLineTotal">0</div>
                            </div>
                            <div class="col-md-6">
                                <div class="small text-muted">Giá nhập / đơn vị (VND)</div>
                                <div class="fw-bold text-primary fs-5" id="calcPerUnit">0</div>
                            </div>
                        </div>
                        <div class="small text-muted mt-1" id="calcFormulaHint"></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer py-2">
                <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-sm btn-primary" id="calcConfirmBtn" onclick="confirmItemCalc()">
                    <i class="bi bi-check-lg me-1"></i> Xác nhận
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Receive Batch Modal -->
<div class="modal fade" id="receiveBatchModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title fw-bold"><i class="bi bi-box-arrow-in-down text-info me-1"></i> Nhận hàng</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-info py-2 px-3 small mb-3">
                    Tạo phiếu Nhập kho (Nháp) chứa các dòng đã chọn. Bộ phận Kho sẽ vào module Kho để xác nhận.
                </div>
                <div class="row g-2 mb-3 small">
                    <div class="col-md-5">
                        <label class="form-label fw-semibold mb-1">Ngày phiếu</label>
                        <input type="date" id="recvBatchDate" class="form-control form-control-sm" />
                    </div>
                    <div class="col-md-7">
                        <label class="form-label fw-semibold mb-1">Ghi chú</label>
                        <input type="text" id="recvBatchNotes" class="form-control form-control-sm" placeholder="Ghi chú phiếu..." />
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-sm table-bordered align-middle mb-0" style="font-size:0.82rem;">
                        <thead class="table-light">
                            <tr>
                                <th style="width:36px;" class="text-center">
                                    <input type="checkbox" id="recvBatchCheckAll" title="Chọn/bỏ tất cả" />
                                </th>
                                <th>Sản phẩm</th>
                                <th class="text-end" style="width:110px;">Còn cần nhập</th>
                                <th class="text-end" style="width:110px;" title="Số lượng đã có trong phiếu nhập kho nháp chưa xác nhận">Đã có phiếu nháp</th>
                                <th class="text-end" style="width:130px;">SL nhập đợt này</th>
                            </tr>
                        </thead>
                        <tbody id="recvBatchBody">
                            @foreach (var item in Model.Items.Where(i => i.RemainingReceiveQty > 0))
                            {
                                var pendingRecv = item.PendingReceiveQty;
                                var availableRecv = item.RemainingReceiveQty - pendingRecv;
                                if (availableRecv < 0) { availableRecv = 0; }
                                var availStr = availableRecv.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture);
                                <tr data-item-id="@item.SOItemId" data-max="@availStr">
                                    <td class="text-center">
                                        <input type="checkbox" class="recv-include" @(availableRecv <= 0 ? "disabled" : "") />
                                    </td>
                                    <td>@item.ProductName <span class="text-muted small">(@item.UnitName)</span></td>
                                    <td class="text-end text-info-emphasis fw-semibold">@item.RemainingReceiveQty.ToString("0.###")</td>
                                    <td class="text-end">
                                        @if (pendingRecv > 0)
                                        {
                                            <span class="badge bg-warning-subtle text-warning-emphasis border"
                                                  title="Đã có trong phiếu nhập kho nháp chưa xác nhận">@pendingRecv.ToString("0.###")</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">—</span>
                                        }
                                    </td>
                                    <td>
                                        <input type="number" class="form-control form-control-sm text-end recv-qty"
                                               min="0" max="@availStr" step="0.001"
                                               value="@availStr" @(availableRecv <= 0 ? "disabled" : "") />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-sm btn-info text-white" onclick="confirmReceiveBatch()">
                    <i class="bi bi-box-arrow-in-down me-1"></i> Tạo phiếu nhập
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Create Advance Request Modal -->
@if (canManageAdvance)
{
    <div class="modal fade" id="createAdvanceModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header border-0 pb-0">
                    <h6 class="modal-title fw-bold">
                        <i class="bi bi-cash-stack text-warning me-1"></i>
                        <span id="advModalTitle">Tạm ứng mới</span>
                    </h6>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="advEditId" value="" />
                    <div class="row g-2 mb-3 small">
                        <div class="col-md-4">
                            <label class="form-label fw-semibold mb-1">Ngày yêu cầu</label>
                            <input type="date" id="advDate" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold mb-1" title="% tạm ứng tổng hợp = Σ tạm ứng SP / Σ chi phí mua SP">% tạm ứng (tổng hợp)</label>
                            <div class="input-group input-group-sm">
                                <input type="text" id="advPercent" class="form-control text-end fw-bold" readonly value="0" />
                                <span class="input-group-text">%</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold mb-1">Tổng cộng</label>
                            <input type="text" id="advTotalDisplay" class="form-control form-control-sm text-end fw-bold" readonly value="0" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold mb-1">Mục đích</label>
                            <input type="text" id="advPurpose" class="form-control form-control-sm" placeholder="VD: Tạm ứng mua hàng đợt 1..." />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold mb-1">Ghi chú</label>
                            <textarea id="advNotes" class="form-control form-control-sm" rows="2"></textarea>
                        </div>
                        <div class="col-12" id="advSelfPaidWrap">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="advSelfPaid" />
                                <label class="form-check-label small" for="advSelfPaid">
                                    <i class="bi bi-person-check me-1 text-dark"></i>
                                    <strong>Người tạo đã tự thanh toán khoản này</strong>
                                    <span class="text-muted">— ghi nhận "Đã tự thanh toán", không qua quy trình duyệt (kế toán / giám đốc).</span>
                                </label>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="small text-muted">
                                Chi phí mua dự kiến (cơ sở tính %): <strong class="text-dark">@((adv?.PurchaseCost ?? 0).ToString("N0")) @(adv?.Currency ?? "VND")</strong>
                            </div>
                        </div>
                    </div>

                    <div class="small fw-semibold mb-1">Phân bổ theo dòng sản phẩm</div>
                    <div class="text-muted small mb-2">
                        Nhập <strong>% tạm ứng</strong> cho từng dòng — mỗi sản phẩm tách riêng <strong>Hàng hóa</strong>, <strong>Vận chuyển</strong> (mua) và <strong>Vận chuyển KH</strong>. Số tiền tự tính theo Chi phí × %.
                    </div>
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered align-middle mb-0" style="font-size:0.82rem;">
                            <thead class="table-light">
                                <tr>
                                    <th>Sản phẩm</th>
                                    <th style="width:110px;">Khoản</th>
                                    <th class="text-end" style="width:120px;">Chi phí</th>
                                    <th class="text-end" style="width:110px;">Đã yêu cầu</th>
                                    <th class="text-end" style="width:90px;">% tạm ứng</th>
                                    <th class="text-end" style="width:150px;">Số tiền tạm ứng</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Items.Where(i => i.LineStatus != "CANCELLED"))
                                {
                                    decimal lineCost = item.PurchasePrice.HasValue && item.PurchasePrice > 0
                                        ? item.EffectiveQty * item.PurchasePrice.Value : 0;
                                    decimal shippingTotal = item.PurchaseMode == "UNOFFICIAL"
                                        ? (item.UnofficialDomesticShipping ?? 0) + (item.UnofficialWeightKg ?? 0) * (item.UnofficialCostPerKg ?? 0) + (item.UnofficialHandCarryFee ?? 0) + (item.UnofficialW2WShipping ?? 0) + (item.UnofficialLength ?? 0) * (item.UnofficialWidth ?? 0) * (item.UnofficialHeight ?? 0) * (item.UnofficialCostPerCbm ?? 0)
                                        : (item.OfficialShipping ?? 0);
                                    decimal pqty = item.PurchaseQuantity ?? 0;
                                    decimal shippingBasis = (pqty > 0 && shippingTotal > 0) ? Math.Round(shippingTotal / pqty * item.EffectiveQty) : 0;
                                    if (shippingBasis > lineCost) { shippingBasis = lineCost; }
                                    decimal productBasis = lineCost - shippingBasis;
                                    decimal customerShipBasis = item.ShippingFee ?? 0;
                                    <tr data-so-item-id="@item.SOItemId">
                                        <td rowspan="3">
                                            <div class="fw-semibold">@item.ProductName</div>
                                            <div class="text-muted small">
                                                @item.UnitName · SL @item.EffectiveQty.ToString("0.###")
                                                @if (item.CancelledQty > 0)
                                                {
                                                    <span class="text-danger-emphasis">(đã hủy @item.CancelledQty.ToString("0.###"))</span>
                                                }
                                            </div>
                                        </td>
                                        <td class="small"><i class="bi bi-box-seam me-1 text-success"></i>Hàng hóa</td>
                                        <td class="text-end small text-muted">@(productBasis > 0 ? productBasis.ToString("N0") : "—")</td>
                                        <td class="text-end small @(item.AdvancedProductAmount > 0 ? "text-warning-emphasis fw-semibold" : "text-muted")">@(item.AdvancedProductAmount > 0 ? item.AdvancedProductAmount.ToString("N0") : "—")</td>
                                        <td>
                                            <input type="number" min="0" max="100" step="0.01"
                                                   class="form-control form-control-sm text-end adv-line-percent"
                                                   data-so-item-id="@item.SOItemId"
                                                   data-line-cost="@productBasis.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                                   placeholder="0" @(productBasis <= 0 ? "disabled" : "") />
                                        </td>
                                        <td>
                                            <input type="number" min="0" step="1" class="form-control form-control-sm text-end adv-line-amount"
                                                   data-so-item-id="@item.SOItemId"
                                                   data-line-cost="@productBasis.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                                   data-adv-kind="product" placeholder="0" @(productBasis <= 0 ? "disabled" : "") />
                                        </td>
                                    </tr>
                                    <tr data-so-item-id="@item.SOItemId">
                                        <td class="small"><i class="bi bi-truck me-1 text-primary"></i>Vận chuyển</td>
                                        <td class="text-end small text-muted">@(shippingBasis > 0 ? shippingBasis.ToString("N0") : "—")</td>
                                        <td class="text-end small @(item.AdvancedShippingAmount > 0 ? "text-warning-emphasis fw-semibold" : "text-muted")">@(item.AdvancedShippingAmount > 0 ? item.AdvancedShippingAmount.ToString("N0") : "—")</td>
                                        <td>
                                            <input type="number" min="0" max="100" step="0.01"
                                                   class="form-control form-control-sm text-end adv-line-percent"
                                                   data-so-item-id="@item.SOItemId"
                                                   data-line-cost="@shippingBasis.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                                   placeholder="0" @(shippingBasis <= 0 ? "disabled" : "") />
                                        </td>
                                        <td>
                                            <input type="number" min="0" step="1" class="form-control form-control-sm text-end adv-line-amount"
                                                   data-so-item-id="@item.SOItemId"
                                                   data-line-cost="@shippingBasis.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                                   data-adv-kind="shipping" placeholder="0" @(shippingBasis <= 0 ? "disabled" : "") />
                                        </td>
                                    </tr>
                                    <tr data-so-item-id="@item.SOItemId">
                                        <td class="small"><i class="bi bi-truck me-1 text-info"></i>Vận chuyển KH</td>
                                        <td class="text-end small text-muted">@(customerShipBasis > 0 ? customerShipBasis.ToString("N0") : "—")</td>
                                        <td class="text-end small @(item.AdvancedCustomerShippingAmount > 0 ? "text-warning-emphasis fw-semibold" : "text-muted")">@(item.AdvancedCustomerShippingAmount > 0 ? item.AdvancedCustomerShippingAmount.ToString("N0") : "—")</td>
                                        <td>
                                            <input type="number" min="0" max="100" step="0.01"
                                                   class="form-control form-control-sm text-end adv-line-percent"
                                                   data-so-item-id="@item.SOItemId"
                                                   data-line-cost="@customerShipBasis.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                                   placeholder="0" @(customerShipBasis <= 0 ? "disabled" : "") />
                                        </td>
                                        <td>
                                            <input type="number" min="0" step="1" class="form-control form-control-sm text-end adv-line-amount"
                                                   data-so-item-id="@item.SOItemId"
                                                   data-line-cost="@customerShipBasis.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                                   data-adv-kind="customer_shipping" placeholder="0" @(customerShipBasis <= 0 ? "disabled" : "") />
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Đóng</button>
                    <button type="button" class="btn btn-sm btn-warning" id="advSubmitBtn" onclick="confirmCreateAdvance()">
                        <i class="bi bi-check-circle me-1"></i>
                        <span id="advSubmitBtnLabel">Tạo phiếu tạm ứng</span>
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Deliver Batch Modal -->
<div class="modal fade" id="deliverBatchModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title fw-bold"><i class="bi bi-truck text-warning me-1"></i> Giao hàng</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-warning py-2 px-3 small mb-3">
                    Tạo phiếu Xuất kho (Nháp) chứa các dòng đã chọn. Bộ phận Kho sẽ vào module Kho để xuất giao.
                </div>
                <div class="row g-2 mb-3 small">
                    <div class="col-md-5">
                        <label class="form-label fw-semibold mb-1">Ngày phiếu</label>
                        <input type="date" id="delivBatchDate" class="form-control form-control-sm" />
                    </div>
                    <div class="col-md-7">
                        <label class="form-label fw-semibold mb-1">Người nhận</label>
                        <input type="text" id="delivBatchReceiver" class="form-control form-control-sm"
                               value="@Model.CustomerName" />
                    </div>
                    <div class="col-md-5">
                        <label class="form-label fw-semibold mb-1">SĐT người nhận</label>
                        <input type="text" id="delivBatchReceiverPhone" class="form-control form-control-sm" />
                    </div>
                    <div class="col-md-7">
                        <label class="form-label fw-semibold mb-1">Ghi chú</label>
                        <input type="text" id="delivBatchNotes" class="form-control form-control-sm" />
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-sm table-bordered align-middle mb-0" style="font-size:0.82rem;">
                        <thead class="table-light">
                            <tr>
                                <th style="width:36px;" class="text-center">
                                    <input type="checkbox" id="delivBatchCheckAll" title="Chọn/bỏ tất cả" />
                                </th>
                                <th>Sản phẩm</th>
                                <th class="text-end" style="width:90px;">Trong kho</th>
                                <th class="text-end" style="width:110px;" title="Số lượng đã có trong phiếu xuất kho nháp chưa xác nhận">Đã có phiếu nháp</th>
                                <th class="text-end" style="width:120px;">SL giao đợt này</th>
                            </tr>
                        </thead>
                        <tbody id="delivBatchBody">
                            @foreach (var item in Model.Items.Where(i => i.InStockQty > 0))
                            {
                                var pendingDel = item.PendingDeliverQty;
                                var availableDel = item.InStockQty - pendingDel;
                                if (availableDel < 0) { availableDel = 0; }
                                var availDelStr = availableDel.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture);
                                <tr data-item-id="@item.SOItemId" data-max="@availDelStr">
                                    <td class="text-center">
                                        <input type="checkbox" class="deliv-include" @(availableDel <= 0 ? "disabled" : "") />
                                    </td>
                                    <td>@item.ProductName <span class="text-muted small">(@item.UnitName)</span></td>
                                    <td class="text-end text-warning-emphasis fw-semibold">@item.InStockQty.ToString("0.###")</td>
                                    <td class="text-end">
                                        @if (pendingDel > 0)
                                        {
                                            <span class="badge bg-warning-subtle text-warning-emphasis border"
                                                  title="Đã có trong phiếu xuất kho nháp chưa xác nhận">@pendingDel.ToString("0.###")</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">—</span>
                                        }
                                    </td>
                                    <td>
                                        <input type="number" class="form-control form-control-sm text-end deliv-qty"
                                               min="0" max="@availDelStr" step="0.001"
                                               value="@availDelStr" @(availableDel <= 0 ? "disabled" : "") />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-sm btn-warning" onclick="confirmDeliverBatch()">
                    <i class="bi bi-truck me-1"></i> Tạo phiếu xuất
                </button>
            </div>
        </div>
    </div>
</div>

