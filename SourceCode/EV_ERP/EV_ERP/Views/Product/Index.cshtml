@model EV_ERP.Models.ViewModels.Products.ProductListViewModel
@{
    ViewData["Title"] = "Quản lý sản phẩm";
    ViewData["Breadcrumbs"] = new List<BreadcrumbItem>
    {
        new("Trang chủ", "/"),
        new("Sản phẩm")
    };
    bool canEdit = ViewBag.CanEdit == true;
    bool canDelete = ViewBag.CanDelete == true;
    var paged = Model.Paged;
}

<div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
    <div>
        <p class="text-muted small mb-0">Tổng cộng @paged.TotalCount sản phẩm</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        @if (canEdit)
        {
            <a href="/Product/Create" class="btn btn-primary">
                <i class="bi bi-plus-circle me-1"></i> Thêm sản phẩm
            </a>
        }
    </div>
</div>

<!-- Filter bar -->
<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-3">
        <form method="get" asp-action="Index" class="row g-2 align-items-end">
            <div class="col-12 col-sm-5 col-lg-5">
                <label class="form-label small fw-semibold mb-1">Tìm kiếm</label>
                <div class="input-group input-group-sm">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" name="keyword" class="form-control"
                           placeholder="Tên, mã SP, barcode..."
                           value="@Model.SearchKeyword" />
                </div>
            </div>
            <div class="col-6 col-sm-3 col-lg-3">
                <label class="form-label small fw-semibold mb-1">Danh mục</label>
                <input type="hidden" name="categoryId" id="filterCategoryId" value="@(Model.FilterCategoryId?.ToString() ?? "")" />
                <div class="ts-wrap position-relative" id="filterTreeSelectWrap">
                    <div class="ts-trigger form-select form-select-sm d-flex align-items-center" onclick="ftsToggle()" id="ftsTrigger">
                        <span class="ts-selected-text flex-grow-1" id="ftsSelectedText">Tất cả danh mục</span>
                        @* <i class="bi bi-chevron-down ts-arrow" style="font-size:0.65rem;transition:transform .2s;"></i> *@
                    </div>
                    <div class="ts-dropdown" id="ftsDropdown" style="display:none;">
                        <div class="ts-search-box">
                            <input type="text" class="form-control form-control-sm" id="ftsSearch"
                                   placeholder="Tìm danh mục..." autocomplete="off" />
                        </div>
                        <div class="ts-tree" id="ftsTree"></div>
                        <div class="ts-empty text-muted text-center py-2 small" id="ftsEmpty" style="display:none;">
                            Không tìm thấy
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-sm-2 col-lg-2">
                <label class="form-label small fw-semibold mb-1">Trạng thái</label>
                <select name="status" class="form-select form-select-sm">
                    <option value="">Đang hoạt động</option>
                    <option value="inactive" selected="@(Model.FilterStatus == "inactive")">Vô hiệu</option>
                </select>
            </div>
            <div class="col-12 col-sm-2 col-lg-2 d-flex gap-1">
                <button type="submit" class="btn btn-primary btn-sm flex-fill">
                    <i class="bi bi-funnel me-1"></i> Lọc
                </button>
                <a href="/Product" class="btn btn-outline-secondary btn-sm" title="Xóa bộ lọc">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Table -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (!paged.Items.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-box-seam" style="font-size: 3rem; opacity: 0.3;"></i>
                <p class="mt-2 mb-0">Không tìm thấy sản phẩm nào</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" style="font-size:0.875rem;">
                    <thead class="table-light">
                        <tr>
                            <th style="width:40px;">#</th>
                            <th style="width:80px;">Ảnh</th>
                            <th>Sản phẩm</th>
                            <th class="d-none d-md-table-cell">Danh mục</th>
                            <th class="d-none d-md-table-cell">SKU</th>
                            <th>Trạng thái</th>
                            <th style="width:120px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int idx = (paged.PageIndex - 1) * paged.PageSize + 1; }
                        @foreach (var p in paged.Items)
                        {
                            <tr>
                                <td class="text-muted small">@(idx++)</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(p.ImageUrl))
                                    {
                                        <img src="@p.ImageUrl" alt="@p.ProductName"
                                             style="width:60px;height:60px;object-fit:cover;border-radius:6px;" />
                                    }
                                    else
                                    {
                                        <div style="width:44px;height:44px;border-radius:6px;background:#f1f5f9;display:flex;align-items:center;justify-content:center;">
                                            <i class="bi bi-image text-muted" style="font-size:1.1rem;opacity:.4;"></i>
                                        </div>
                                    }
                                </td>
                                <td>
                                    <div>
                                        <a href="/Product/Detail/@p.ProductId"
                                           class="fw-semibold text-decoration-none text-dark link-hover">
                                            @p.ProductName
                                        </a>
                                        <div class="text-muted small">
                                            @p.ProductCode
@*                                             @if (!string.IsNullOrEmpty(p.SKU))
                                            {
                                                <span class="ms-1 font-monospace text-primary-emphasis">@p.SKU</span>
                                            } *@
                                        </div>
                                    </div>
                                </td>
                                <td class="d-none d-md-table-cell">
                                    @if (!string.IsNullOrEmpty(p.CategoryName))
                                    {
                                        <span class="badge bg-info-subtle text-info-emphasis rounded-pill">
                                            @p.CategoryName
                                        </span>
                                    }
                                </td>
                                <td class="d-none d-md-table-cell">
                                    @if (!string.IsNullOrEmpty(p.SKU))
                                    {
                                        @p.SKU
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge bg-@(p.StatusBadge)-subtle text-@(p.StatusBadge)-emphasis rounded-pill">
                                        <i class="bi bi-circle-fill me-1" style="font-size:0.45rem;vertical-align:middle;"></i>
                                        @p.StatusText
                                    </span>
                                </td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a href="/Product/Detail/@p.ProductId"
                                           class="btn btn-sm btn-outline-secondary" title="Xem chi tiết">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (canEdit)
                                        {
                                            <a href="/Product/Edit/@p.ProductId"
                                               class="btn btn-sm btn-outline-primary" title="Chỉnh sửa">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                        }
                                        @if (canDelete)
                                        {
                                            <button class="btn btn-sm @(p.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                                    title="@(p.IsActive ? "Vô hiệu hóa" : "Kích hoạt lại")"
                                                    onclick="toggleActive(@p.ProductId, '@p.ProductName.Replace("'", "\\'")', @p.IsActive.ToString().ToLower())">
                                                <i class="bi @(p.IsActive ? "bi-slash-circle" : "bi-check-circle")"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (paged.TotalPages > 1)
            {
                <nav class="d-flex justify-content-center py-3">
                    <ul class="pagination pagination-sm mb-0">
                        @if (paged.HasPrevious)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@BuildPageUrl(paged.PageIndex - 1)">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                            </li>
                        }
                        @for (int pg = 1; pg <= paged.TotalPages; pg++)
                        {
                            <li class="page-item @(pg == paged.PageIndex ? "active" : "")">
                                <a class="page-link" href="@BuildPageUrl(pg)">@pg</a>
                            </li>
                        }
                        @if (paged.HasNext)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@BuildPageUrl(paged.PageIndex + 1)">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        }
    </div>
</div>

@functions {
    string BuildPageUrl(int page)
    {
        var qs = new Dictionary<string, string?> {
            ["keyword"] = Model.SearchKeyword,
            ["categoryId"] = Model.FilterCategoryId?.ToString(),
            ["status"] = Model.FilterStatus,
            ["page"] = page.ToString()
        };
        return "/Product?" + string.Join("&", qs.Where(kv => kv.Value != null).Select(kv => $"{kv.Key}={kv.Value}"));
    }
}

<style>
    .link-hover:hover { color: #2563eb !important; }
    .btn-xs { padding: .15rem .45rem; font-size: .75rem; }
    .bg-success-subtle { background-color: #dcfce7 !important; }
    .text-success-emphasis { color: #166534 !important; }
    .bg-secondary-subtle { background-color: #f1f5f9 !important; }
    .text-secondary-emphasis { color: #475569 !important; }
    .bg-warning-subtle { background-color: #fef9c3 !important; }
    .text-warning-emphasis { color: #854d0e !important; }
    .bg-info-subtle { background-color: #e0f2fe !important; }
    .text-info-emphasis { color: #0369a1 !important; }
    /* TreeSelect */
    .ts-wrap { position: relative; }
    .ts-trigger { cursor: pointer; user-select: none; }
    .ts-trigger:hover { border-color: #86b7fe; }
    .ts-trigger.ts-open { border-color: #86b7fe; box-shadow: 0 0 0 .25rem rgba(13,110,253,.25); }
    .ts-trigger.ts-open .ts-arrow { transform: rotate(180deg); }
    .ts-selected-text { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .ts-selected-text.ts-placeholder { color: #6c757d; }
    .ts-dropdown {
        position: absolute; top: 100%; left: 0; right: 0;
        background: #fff; border: 1px solid #dee2e6;
        border-radius: 0 0 8px 8px; box-shadow: 0 6px 16px rgba(0,0,0,.12);
        z-index: 1060; margin-top: -1px;
    }
    .ts-search-box { padding: 6px; border-bottom: 1px solid #f0f0f0; }
    .ts-search-box input { border-radius: 6px; }
    .ts-tree { max-height: 260px; overflow-y: auto; padding: 4px 0; }
    .ts-node {
        display: flex; align-items: center; padding: 5px 10px;
        cursor: pointer; font-size: 0.82rem; color: #1c1e21; transition: background .1s;
    }
    .ts-node:hover { background: #f5f5f5; }
    .ts-node.ts-active { background: #e6f4ff; color: #1677ff; }
    .ts-node.ts-highlighted { background: #f0f0f0; }
    .ts-node-indent { display: inline-block; width: 18px; flex-shrink: 0; }
    .ts-node-toggle {
        width: 18px; height: 18px; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer; border-radius: 3px; font-size: 0.6rem; color: #8c8c8c;
    }
    .ts-node-toggle:hover { background: #e0e0e0; }
    .ts-node-toggle.ts-expanded i { transform: rotate(90deg); }
    .ts-node-toggle i { transition: transform .2s; }
    .ts-node-leaf { width: 18px; flex-shrink: 0; }
    .ts-node-icon { margin-right: 5px; font-size: 0.75rem; }
    .ts-node-icon.ts-folder { color: #faad14; }
    .ts-node-icon.ts-leaf-icon { color: #1677ff; }
    .ts-node-label { flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .ts-node-code { font-size: 0.68rem; color: #8c8c8c; margin-left: 5px; font-family: monospace; flex-shrink: 0; }
    .ts-highlight { background: #fff3cd; border-radius: 2px; padding: 0 1px; }
    .ts-all-node { border-bottom: 1px solid #f0f0f0; color: #595959; }
</style>

@section Scripts {
    <script>
        function toggleActive(id, name, isActive) {
            var action = isActive ? 'vô hiệu hóa' : 'kích hoạt lại';
            if (!confirm('Bạn có chắc muốn ' + action + ' sản phẩm "' + name + '"?')) return;

            var form = new FormData();
            form.append('__RequestVerificationToken', getAntiForgeryToken());

            fetch('/Product/ToggleActive/' + id, { method: 'POST', body: form })
                .then(r => r.json())
                .then(data => {
                    if (data.Success) location.reload();
                    else alert('Lỗi: ' + data.Message);
                });
        }

        function getAntiForgeryToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
        }

        // ════════════════════════════════════════════════
        // Filter TreeSelect
        // ════════════════════════════════════════════════
        (function () {
            var ftsData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Categories, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = null }));
            var ftsSelectedId = @(Model.FilterCategoryId.HasValue ? Model.FilterCategoryId.Value.ToString() : "null");
            var ftsOpen = false;
            var ftsExpandedIds = {};
            var ftsHighlightIdx = -1;
            var ftsVisibleNodes = [];

            var ftsChildrenMap = {};
            ftsData.forEach(function (n) {
                var pid = n.ParentCategoryId || 0;
                if (!ftsChildrenMap[pid]) ftsChildrenMap[pid] = [];
                ftsChildrenMap[pid].push(n);
            });

            // Expand all root categories by default
            (ftsChildrenMap[0] || []).forEach(function (root) {
                ftsExpandedIds[root.CategoryId] = true;
            });

            // Expand path to selected
            if (ftsSelectedId) {
                var sel = ftsData.find(function (n) { return n.CategoryId === ftsSelectedId; });
                if (sel) {
                    ftsExpandPath(sel);
                    ftsUpdateTrigger(sel);
                }
            }

            function ftsExpandPath(node) {
                var cur = node;
                while (cur && cur.ParentCategoryId) {
                    ftsExpandedIds[cur.ParentCategoryId] = true;
                    cur = ftsData.find(function (n) { return n.CategoryId === cur.ParentCategoryId; });
                }
            }

            function ftsUpdateTrigger(node) {
                var el = document.getElementById('ftsSelectedText');
                if (node) {
                    var path = [];
                    var cur = node;
                    while (cur) {
                        path.unshift(cur.CategoryName);
                        cur = cur.ParentCategoryId ? ftsData.find(function (n) { return n.CategoryId === cur.ParentCategoryId; }) : null;
                    }
                    el.textContent = path.join(' / ');
                    el.classList.remove('ts-placeholder');
                } else {
                    el.textContent = 'Tất cả danh mục';
                    el.classList.add('ts-placeholder');
                }
            }

            function ftsRenderTree(searchQuery) {
                var tree = document.getElementById('ftsTree');
                var empty = document.getElementById('ftsEmpty');
                var q = (searchQuery || '').trim().toLowerCase();

                var matchIds = {};
                var visibleIds = {};
                if (q) {
                    ftsData.forEach(function (n) {
                        if (n.CategoryName.toLowerCase().indexOf(q) >= 0 || n.CategoryCode.toLowerCase().indexOf(q) >= 0) {
                            matchIds[n.CategoryId] = true;
                            var cur = n;
                            while (cur) {
                                visibleIds[cur.CategoryId] = true;
                                cur = cur.ParentCategoryId ? ftsData.find(function (x) { return x.CategoryId === cur.ParentCategoryId; }) : null;
                            }
                        }
                    });
                }

                ftsVisibleNodes = [];
                // "All" option
                ftsVisibleNodes.push({ CategoryId: null, CategoryName: 'Tất cả danh mục', CategoryCode: '', _isAll: true });

                var html = '<div class="ts-node ts-all-node' + (ftsSelectedId === null ? ' ts-active' : '') + '" data-id="">' +
                    '<i class="bi bi-grid-fill ts-node-icon" style="color:#8c8c8c;"></i>' +
                    '<span class="ts-node-label">Tất cả danh mục</span></div>';

                function renderNode(node, depth) {
                    if (q && !visibleIds[node.CategoryId]) return;

                    ftsVisibleNodes.push(node);
                    var isActive = node.CategoryId === ftsSelectedId;
                    var isExpanded = q ? true : !!ftsExpandedIds[node.CategoryId];
                    var children = ftsChildrenMap[node.CategoryId] || [];
                    var hasVisibleChildren = q ? children.some(function (c) { return visibleIds[c.CategoryId]; }) : children.length > 0;

                    html += '<div class="ts-node' + (isActive ? ' ts-active' : '') + '" data-id="' + node.CategoryId + '">';
                    for (var i = 0; i < depth; i++) html += '<span class="ts-node-indent"></span>';

                    if (hasVisibleChildren) {
                        html += '<span class="ts-node-toggle' + (isExpanded ? ' ts-expanded' : '') + '" data-toggle="' + node.CategoryId + '">';
                        html += '<i class="bi bi-caret-right-fill"></i></span>';
                    } else {
                        html += '<span class="ts-node-leaf"></span>';
                    }

                    html += '<i class="bi ' + (node.HasChildren ? 'bi-folder-fill ts-folder' : 'bi-tag-fill ts-leaf-icon') + ' ts-node-icon"></i>';

                    var label = node.CategoryName;
                    if (q && matchIds[node.CategoryId]) {
                        var regex = new RegExp('(' + q.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
                        label = label.replace(regex, '<span class="ts-highlight">$1</span>');
                    }
                    html += '<span class="ts-node-label">' + label + '</span>';
                    html += '<span class="ts-node-code">' + node.CategoryCode + '</span>';
                    html += '</div>';

                    if (isExpanded && hasVisibleChildren) {
                        children.forEach(function (child) { renderNode(child, depth + 1); });
                    }
                }

                (ftsChildrenMap[0] || []).forEach(function (root) { renderNode(root, 0); });

                tree.innerHTML = html;
                empty.style.display = ftsVisibleNodes.length <= 1 && q ? '' : 'none';
                ftsHighlightIdx = -1;

                // Bind clicks
                tree.querySelectorAll('.ts-node').forEach(function (el) {
                    el.addEventListener('click', function (e) {
                        if (e.target.closest('.ts-node-toggle')) return;
                        var idStr = el.dataset.id;
                        ftsSelect(idStr ? parseInt(idStr) : null);
                    });
                });
                tree.querySelectorAll('.ts-node-toggle').forEach(function (el) {
                    el.addEventListener('click', function (e) {
                        e.stopPropagation();
                        var id = parseInt(el.dataset.toggle);
                        ftsExpandedIds[id] = !ftsExpandedIds[id];
                        ftsRenderTree(searchQuery);
                    });
                });
            }

            function ftsSelect(id) {
                ftsSelectedId = id;
                document.getElementById('filterCategoryId').value = id !== null ? id : '';
                var node = id !== null ? ftsData.find(function (n) { return n.CategoryId === id; }) : null;
                ftsUpdateTrigger(node);
                ftsClose();
            }

            window.ftsToggle = function () {
                if (ftsOpen) ftsClose();
                else ftsOpenDropdown();
            };

            function ftsOpenDropdown() {
                ftsOpen = true;
                document.getElementById('ftsDropdown').style.display = '';
                document.getElementById('ftsTrigger').classList.add('ts-open');
                var searchInput = document.getElementById('ftsSearch');
                searchInput.value = '';
                ftsRenderTree('');
                setTimeout(function () { searchInput.focus(); }, 50);
                setTimeout(function () {
                    var active = document.querySelector('#ftsTree .ts-node.ts-active');
                    if (active) active.scrollIntoView({ block: 'nearest' });
                }, 60);
            }

            function ftsClose() {
                ftsOpen = false;
                document.getElementById('ftsDropdown').style.display = 'none';
                document.getElementById('ftsTrigger').classList.remove('ts-open');
            }

            document.addEventListener('mousedown', function (e) {
                if (ftsOpen && !e.target.closest('#filterTreeSelectWrap')) ftsClose();
            });

            document.getElementById('ftsSearch').addEventListener('input', function () {
                ftsRenderTree(this.value);
            });

            document.getElementById('ftsSearch').addEventListener('keydown', function (e) {
                if (!ftsOpen) return;
                var nodes = document.querySelectorAll('#ftsTree .ts-node');
                if (e.key === 'ArrowDown') {
                    e.preventDefault();
                    ftsHighlightIdx = Math.min(ftsHighlightIdx + 1, nodes.length - 1);
                    ftsUpdateHighlight(nodes);
                } else if (e.key === 'ArrowUp') {
                    e.preventDefault();
                    ftsHighlightIdx = Math.max(ftsHighlightIdx - 1, 0);
                    ftsUpdateHighlight(nodes);
                } else if (e.key === 'Enter') {
                    e.preventDefault();
                    if (ftsHighlightIdx >= 0 && ftsHighlightIdx < ftsVisibleNodes.length) {
                        var n = ftsVisibleNodes[ftsHighlightIdx];
                        ftsSelect(n._isAll ? null : n.CategoryId);
                    }
                } else if (e.key === 'Escape') {
                    ftsClose();
                }
            });

            function ftsUpdateHighlight(nodes) {
                nodes.forEach(function (n) { n.classList.remove('ts-highlighted'); });
                if (ftsHighlightIdx >= 0 && ftsHighlightIdx < nodes.length) {
                    nodes[ftsHighlightIdx].classList.add('ts-highlighted');
                    nodes[ftsHighlightIdx].scrollIntoView({ block: 'nearest' });
                }
            }
        })();
    </script>
    @Html.AntiForgeryToken()
}
