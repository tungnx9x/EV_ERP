@model EV_ERP.Models.ViewModels.Quotations.QuotationDetailViewModel
@{
    ViewData["Title"] = Model.QuotationNo;
    ViewData["Breadcrumbs"] = new List<BreadcrumbItem>
    {
        new("Trang chủ", "/"),
        new("Báo giá", "/Quotation"),
        new(Model.QuotationNo)
    };
    bool canEdit = ViewBag.CanEdit == true;
    bool isManager = ViewBag.IsManager == true;
    int currentUserId = (int)(ViewBag.CurrentUserId ?? 0);
    bool canEditThis = canEdit && (isManager || Model.CreatedBy == currentUserId);
    bool canManageStatus = isManager || Model.SalesPersonId == currentUserId;
}

<!-- Header -->
<div class="d-flex align-items-start justify-content-between mb-3 flex-wrap gap-2">
    <div class="d-flex align-items-center gap-3">
        @* <a href="/Quotation" class="btn btn-sm btn-light border">
            <i class="bi bi-arrow-left"></i>
        </a> *@
        <div>
            <div class="d-flex flex-wrap align-items-center gap-3">
                <h5 class="mb-0 fw-bold">@Model.QuotationNo</h5>
                <a href="/Quotation/ExportExcelById/@Model.QuotationId"
                    class="text-success d-flex align-items-center"
                    style="text-decoration: none;">
                    <i class="bi bi-download me-1"></i>
                    Xuất Excel
                </a>
            </div>
            <div class="text-muted small">
                <span class="badge bg-@(Model.StatusBadge)-subtle text-@(Model.StatusBadge)-emphasis rounded-pill">
                    <i class="bi bi-circle-fill me-1" style="font-size:0.4rem;vertical-align:middle;"></i>
                    @Model.StatusText
                </span>
                @if (Model.AmendFromNo != null)
                {
                    <span class="ms-2 text-muted">
                        <i class="bi bi-arrow-return-left me-1"></i>Chỉnh sửa từ
                        <a href="/Quotation/Detail/@Model.AmendFromId">@Model.AmendFromNo</a>
                    </span>
                }
                @if (Model.RfqNo != null)
                {
                    <span class="ms-2 text-muted">
                        <i class="bi bi-link-45deg me-1"></i>RFQ: @Model.RfqNo
                    </span>
                }
            </div>   
        </div>
    </div>

    <div class="d-flex gap-1 flex-wrap">       
        @if (canEdit)
        {
            @if (Model.Status == "DRAFT")
            {
                @if (canEditThis)
                {
                    <a href="/Quotation/Edit/@Model.QuotationId" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-pencil me-1"></i> Sửa
                    </a>
                }
                @if (canManageStatus)
                {
                     <div class="dropdown">
                        <button class="btn btn-sm btn-primary dropdown-toggle" type="button"
                                data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-lightning-charge me-1"></i> Xử lý báo giá
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                            <li>
                                <a class="dropdown-item text-success" href="#"
                                   onclick="doAction('Send', @Model.QuotationId)">
                                    <i class="bi bi-send me-1"></i> Gửi báo giá
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item text-danger" href="#"
                                   onclick="doCancel(@Model.QuotationId)">
                                    <i class="bi bi-x-circle me-1"></i> Hủy
                                </a>
                            </li>
                        </ul>
                    </div>
                }
            }
            @if (Model.Status == "SENT" && canManageStatus)
            {
                <div class="dropdown">
                    <button class="btn btn-sm btn-primary dropdown-toggle" type="button"
                            data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="bi bi-lightning-charge me-1"></i> Xử lý báo giá
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                        <li>
                            <a class="dropdown-item text-success" href="#"
                               onclick="event.preventDefault(); doAction('Approve', @Model.QuotationId);">
                                <i class="bi bi-check-circle me-2"></i> Duyệt (KH đồng ý)
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item text-danger" href="#"
                               onclick="event.preventDefault(); doReject(@Model.QuotationId);">
                                <i class="bi bi-x-circle me-2"></i> Từ chối
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item text-warning-emphasis" href="#"
                               onclick="event.preventDefault(); doAction('Amend', @Model.QuotationId);">
                                <i class="bi bi-pencil-square me-2"></i> Chỉnh sửa (Amend)
                            </a>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <a class="dropdown-item text-secondary" href="#"
                               onclick="event.preventDefault(); doAction('Expire', @Model.QuotationId);">
                                <i class="bi bi-clock-history me-2"></i> Hết hạn
                            </a>
                        </li>
                    </ul>
                </div>
            }
            @if (Model.Status == "REJECTED" && canManageStatus)
            {
                <button class="btn btn-sm btn-outline-warning" onclick="doAction('Amend', @Model.QuotationId)">
                    <i class="bi bi-pencil-square me-1"></i> Tạo bản chỉnh sửa
                </button>
            }
            @if (Model.SalesOrderNo != null)
            {
                <a href="/SalesOrder/Detail/@Model.SalesOrderId" class="btn btn-sm btn-outline-success">
                    <i class="bi bi-receipt me-1"></i> SO: @Model.SalesOrderNo
                </a>
            }
        }
    </div>
</div>

<div class="row">
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            <h6 class="fw-semibold text-muted text-uppercase mb-3" style="font-size:0.72rem;letter-spacing:.06em;">
                Thông tin báo giá
            </h6>
            <div class="row g-2 small">
                <div class="col-6">
                <div class="text-muted">Khách hàng</div>
                <div class="fw-semibold">@Model.CustomerName - @Model.CustomerCode</div>
            </div>
            <div class="col-6">
                <div class="text-muted">Ngày BG</div>
                <div class="fw-semibold">@Model.QuotationDate.ToString("dd/MM/yyyy")</div>
            </div>
            <div class="col-6">
                <div class="text-muted">Hết hạn</div>
                <div class="fw-semibold @(Model.ExpiryDate < DateTime.Today ? "text-danger" : "")">
                    @(Model.ExpiryDate?.ToString("dd/MM/yyyy") ?? "—")
                </div>
            </div>
            <div class="col-6">
                <div class="text-muted">Hạn xử lý</div>
                <div class="fw-semibold @(Model.Deadline < DateTime.Now && Model.Status is "DRAFT" or "SENT" ? "text-danger" : "")">
                    @Model.Deadline.ToString("dd/MM/yyyy HH:mm")
                </div>
            </div>
            <div class="col-6">
                <div class="text-muted">Phụ trách</div>
                <div class="fw-semibold">@Model.SalesPersonName</div>
            </div>
            <div class="col-6">
                <div class="text-muted">Người tạo</div>
                <div class="fw-semibold">@(Model.CreatedByName ?? "—")</div>
            </div>
            @if (Model.SentAt.HasValue)
            {
                <div class="col-6">
                    <div class="text-muted">Gửi lúc</div>
                    <div class="fw-semibold">@Model.SentAt.Value.ToString("dd/MM HH:mm")</div>
                </div>
            }
            @if (Model.ApprovedAt.HasValue)
            {
                <div class="col-6">
                    <div class="text-muted">Duyệt lúc</div>
                    <div class="fw-semibold text-success">@Model.ApprovedAt.Value.ToString("dd/MM HH:mm")</div>
                </div>
            }
            @if (Model.RejectedAt.HasValue)
            {
                <div class="col-12">
                    <div class="text-muted">Từ chối lúc</div>
                    <div class="fw-semibold text-danger">@Model.RejectedAt.Value.ToString("dd/MM HH:mm")</div>
                    @if (Model.RejectReason != null)
                    {
                        <div class="text-muted small mt-1">Lý do: @Model.RejectReason</div>
                    }
                </div>
            }
            </div>
        </div>              
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.PaymentTerms))
{
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            <h6 class="fw-semibold text-muted text-uppercase mb-2" style="font-size:0.72rem;letter-spacing:.06em;">
                Điều khoản thanh toán
            </h6>
            <p class="small mb-0">@Model.PaymentTerms</p>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(Model.Notes))
{
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            <h6 class="fw-semibold text-muted text-uppercase mb-2" style="font-size:0.72rem;letter-spacing:.06em;">
                Ghi chú
            </h6>
            <p class="small mb-0" style="white-space:pre-wrap;">@Model.Notes</p>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(Model.InternalNotes))
{
    <div class="card border-0 shadow-sm mb-3 border-start border-4 border-warning">
        <div class="card-body">
            <h6 class="fw-semibold text-muted text-uppercase mb-2" style="font-size:0.72rem;letter-spacing:.06em;">
                <i class="bi bi-lock me-1"></i> Ghi chú nội bộ
            </h6>
            <p class="small mb-0" style="white-space:pre-wrap;">@Model.InternalNotes</p>
        </div>
    </div>
}

<div class="row">
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-bottom py-2">
            <h6 class="mb-0 fw-semibold small text-uppercase">
                <i class="bi bi-box-seam me-1"></i> Chi tiết sản phẩm
                <span class="badge bg-primary rounded-pill ms-1">@Model.Items.Count</span>
            </h6>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm table-bordered table-hover align-middle mb-0" style="font-size:0.8rem;">
                    <thead class="table-light">
                        <tr>
                            <th rowspan="2" style="width:30px;" class="text-center align-middle">STT</th>
                            <th colspan="4" class="text-center bg-primary-subtle">Thông tin sản phẩm</th>
                            <th colspan="5" class="text-center bg-success-subtle">Báo giá khách hàng</th>
                            <th colspan="5" class="text-center bg-warning-subtle">Thông tin nội bộ</th>
                        </tr>
                        <tr>
                            <th>Yêu cầu</th>
                            <th>Đề xuất</th>
                            <th style="width:60px;">Ảnh</th>
                            <th>DVT</th>
                            <th class="text-end">SL</th>
                            <th class="text-end">Đơn giá</th>
                            <th class="text-end">Trước VAT</th>
                            <th class="text-center">VAT</th>
                            <th class="text-end">Sau VAT</th>
                            <th>Link</th>
                            <th class="text-end">Giá nhập</th>
                            <th class="text-end">Shipping</th>
                            <th class="text-center">Hệ số</th>
                        </tr>
                    </thead>
                    <tbody id="quotItemsTbody">
                        @{ int idx = 0; }
                        @foreach (var item in Model.Items)
                        {
                            idx++;
                            <tr>
                                <td class="text-center text-muted">@idx</td>
                                <td class="fw-semibold">
                                    @item.ProductName
                                    @if (!item.IsProductMapped)
                                    {
                                        <span class="badge bg-warning-subtle text-warning ms-1" style="font-size:0.6rem;"
                                              title="SP nhập tay - chưa có trong hệ thống">SP mới</span>
                                    }
                                </td>
                                <td class="text-muted small">@(item.Proposal ?? "—")</td>
                                <td class="text-center">
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl" alt="" style="width:36px;height:36px;object-fit:cover;border-radius:4px;" />
                                    }
                                    else
                                    {
                                        <span class="text-muted" style="font-size:0.7rem;">N/A</span>
                                    }
                                </td>
                                <td>@item.UnitName</td>
                                <td class="text-end">@item.Quantity.ToString("0.###")</td>
                                <td class="text-end">@item.UnitPrice.ToString("N0")</td>
                                <td class="text-end">@item.AmountExclVat.ToString("N0")</td>
                                <td class="text-center">@item.VatRate.ToString("0.###")%</td>
                                <td class="text-end fw-bold text-primary">@item.AmountInclVat.ToString("N0")</td>
                                <td class="small">
                                    @if (!string.IsNullOrEmpty(item.SourceUrl))
                                    {
                                        <a href="@item.SourceUrl" target="_blank" class="text-truncate d-inline-block" style="max-width:150px;" title="@item.SourceUrl">
                                            <i class="bi bi-link-45deg"></i> Link
                                        </a>
                                    }
                                    else
                                    {
                                        <span>—</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <a href="#" class="text-decoration-none fw-semibold calc-view-link"
                                       title="Xem chi tiết tính giá nhập"
                                       data-calc="@System.Text.Json.JsonSerializer.Serialize(new {
                                           no = idx,
                                           mode = item.PurchaseMode,
                                           currency = item.PurchaseCurrency ?? "VND",
                                           rate = item.ExchangeRate,
                                           qty = item.PurchaseQuantity,
                                           basePrice = item.BasePrice,
                                           offShipping = item.OfficialShipping,
                                           domShipping = item.UnofficialDomesticShipping,
                                           weight = item.UnofficialWeightKg,
                                           costPerKg = item.UnofficialCostPerKg,
                                           handCarry = item.UnofficialHandCarryFee,
                                           w2w = item.UnofficialW2WShipping,
                                           length = item.UnofficialLength,
                                           width = item.UnofficialWidth,
                                           height = item.UnofficialHeight,
                                           costPerCbm = item.UnofficialCostPerCbm,
                                           vatPercent = item.PurchaseVatPercent,
                                           tax = item.PurchaseTax,
                                           inspection = item.InspectionFee,
                                           banking = item.BankingFee,
                                           other = item.OtherCosts,
                                           importPrice = item.ImportPrice
                                       })"
                                       onclick="openCalcView(this); return false;">
                                        @item.ImportPrice.ToString("N0")
                                    </a>
                                </td>
                                <td class="text-end">@item.Shipping.ToString("N0")</td>
                                <td class="text-center">@item.Coefficient.ToString("0.###")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr class="fw-semibold">
                            <td colspan="7" class="text-end">Tong cong:</td>
                            <td class="text-end">@Model.SubTotal.ToString("N0")</td>
                            <td></td>
                            <td class="text-end text-primary fs-6">
                                @Model.TotalAmount.ToString("N0")
                                <span class="small fw-normal text-muted">@Model.Currency</span>
                            </td>
                            <td colspan="5"></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
            <!-- Pager (client-side) -->
            <div id="quotItemsPager" class="d-flex justify-content-between align-items-center px-3 py-2 border-top small" style="display:none !important;">
                <div class="d-flex align-items-center gap-2">
                    <span class="text-muted">Hiển thị</span>
                    <select id="quotItemsPageSize" class="form-select form-select-sm" style="width:auto;">
                        <option value="10" selected>10</option>
                        <option value="20">20</option>
                        <option value="50">50</option>
                        <option value="9999">Tất cả</option>
                    </select>
                    <span class="text-muted">/ tổng @Model.Items.Count dòng</span>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <button type="button" id="quotItemsPrev" class="btn btn-sm btn-outline-secondary py-0 px-2" title="Trang trước">
                        <i class="bi bi-chevron-left"></i>
                    </button>
                    <span class="text-muted" id="quotItemsPageInfo"></span>
                    <button type="button" id="quotItemsNext" class="btn btn-sm btn-outline-secondary py-0 px-2" title="Trang sau">
                        <i class="bi bi-chevron-right"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Reject Modal -->
<div class="modal fade" id="rejectModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title fw-bold">Từ chối báo giá</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <label class="form-label small fw-semibold">Lý do từ chối</label>
                <textarea id="rejectReason" class="form-control form-control-sm" rows="3"
                          placeholder="Nhập lý do..."></textarea>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-sm btn-danger" onclick="confirmReject()">
                    <i class="bi bi-x-circle me-1"></i> Từ chối
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Cancel Modal -->
<div class="modal fade" id="cancelModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title fw-bold">Hủy báo giá</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <label class="form-label small fw-semibold">Lý do hủy</label>
                <textarea id="cancelReason" class="form-control form-control-sm" rows="3"
                          placeholder="Nhập lý do..."></textarea>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Đóng</button>
                <button type="button" class="btn btn-sm btn-danger" onclick="confirmCancel()">
                    <i class="bi bi-x-circle me-1"></i> Hủy báo giá
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Purchase Price Calc — View-only Modal -->
<div class="modal fade" id="calcViewModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title fw-semibold">
                    <i class="bi bi-calculator me-1 text-primary"></i> Chi tiết giá nhập — Sản phẩm <span id="cvRowNo">#</span>
                </h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <!-- Mode (read-only badge) -->
                <div class="mb-3">
                    <span class="form-label small fw-semibold me-2 mb-0">Hình thức nhập:</span>
                    <span id="cvModeBadge" class="badge"></span>
                </div>

                <!-- Currency/Rate + Base price + Purchase quantity -->
                <div class="row g-2 mb-3">
                    <div class="col-md-4">
                        <label class="form-label small fw-semibold">Đơn giá gốc <span class="text-muted">(ngoại tệ)</span></label>
                        <input type="text" class="form-control form-control-sm text-end" id="cvBasePrice" disabled />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-semibold" id="cvRateLabel">Tỷ giá</label>
                        <input type="text" class="form-control form-control-sm text-end" id="cvRate" disabled />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-semibold">Số lượng mua</label>
                        <input type="text" class="form-control form-control-sm text-end" id="cvQty" disabled />
                    </div>
                </div>

                <!-- OFFICIAL / DOMESTIC panel — shipping only -->
                <div id="cvOfficialPanel">
                    <div class="card border-primary-subtle">
                        <div class="card-header bg-primary-subtle py-2 small fw-semibold">
                            <i class="bi bi-shield-check me-1"></i> Chi phí vận chuyển
                        </div>
                        <div class="card-body py-2">
                            <input type="text" class="form-control form-control-sm text-end" id="cvOfficialShipping" disabled />
                        </div>
                    </div>
                    <!-- VAT — chỉ áp dụng cho "Mua trong nước" (DOMESTIC) -->
                    <div class="card border-info-subtle mt-2" id="cvVatCard" style="display:none;">
                        <div class="card-header bg-info-subtle py-2 small fw-semibold">
                            <i class="bi bi-percent me-1"></i> Thuế VAT (%)
                        </div>
                        <div class="card-body py-2">
                            <input type="text" class="form-control form-control-sm text-end" id="cvVatPercent" disabled />
                        </div>
                    </div>
                </div>

                <!-- UNOFFICIAL panel — shipping breakdown -->
                <div id="cvUnofficialPanel" style="display:none;">
                    <div class="card border-warning-subtle">
                        <div class="card-header bg-warning-subtle py-2 small fw-semibold">
                            <i class="bi bi-truck me-1"></i> Chi phí vận chuyển
                        </div>
                        <div class="card-body py-2">
                            <div class="row g-2">
                                <div class="col-md-6">
                                    <label class="form-label small">Phí vận chuyển nội địa <span class="text-muted">(VND)</span></label>
                                    <input type="text" class="form-control form-control-sm text-end" id="cvDomesticShipping" disabled />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label small">Cân nặng (kg)</label>
                                    <input type="text" class="form-control form-control-sm text-end" id="cvWeight" disabled />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label small">Phí / kg (VND)</label>
                                    <input type="text" class="form-control form-control-sm text-end" id="cvCostPerKg" disabled />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label small">Phí xách tay (VND)</label>
                                    <input type="text" class="form-control form-control-sm text-end" id="cvHandCarry" disabled />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label small">Kho trung gian → kho công ty (VND)</label>
                                    <input type="text" class="form-control form-control-sm text-end" id="cvW2W" disabled />
                                </div>

                                <!-- Thể tích (CBM): Dài × Rộng × Cao (m) × Phí/CBM -->
                                <div class="col-12">
                                    <hr class="my-1" />
                                    <span class="small fw-semibold text-muted"><i class="bi bi-box me-1"></i>Thể tích (CBM)</span>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label small">Dài (m)</label>
                                    <input type="text" class="form-control form-control-sm text-end" id="cvLength" disabled />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label small">Rộng (m)</label>
                                    <input type="text" class="form-control form-control-sm text-end" id="cvWidth" disabled />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label small">Cao (m)</label>
                                    <input type="text" class="form-control form-control-sm text-end" id="cvHeight" disabled />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label small">Phí / CBM (VND)</label>
                                    <input type="text" class="form-control form-control-sm text-end" id="cvCostPerCbm" disabled />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Common cost components (both modes) -->
                <div class="card border-secondary-subtle mt-3">
                    <div class="card-header bg-light py-2 small fw-semibold">
                        <i class="bi bi-receipt me-1"></i> Chi phí khác (VND)
                    </div>
                    <div class="card-body py-2">
                        <div class="row g-2">
                            <div class="col-md-3">
                                <label class="form-label small">Thuế</label>
                                <input type="text" class="form-control form-control-sm text-end" id="cvTax" disabled />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small">Phí kiểm định</label>
                                <input type="text" class="form-control form-control-sm text-end" id="cvInspection" disabled />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small">Phí ngân hàng</label>
                                <input type="text" class="form-control form-control-sm text-end" id="cvBanking" disabled />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small">Chi phí khác</label>
                                <input type="text" class="form-control form-control-sm text-end" id="cvOther" disabled />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Live preview -->
                <div class="card mt-3 border-0 bg-light">
                    <div class="card-body py-2">
                        <div class="row text-end">
                            <div class="col-md-6">
                                <div class="small text-muted">Tổng chi phí dòng (VND)</div>
                                <div class="fw-semibold" id="cvLineTotal">0</div>
                            </div>
                            <div class="col-md-6">
                                <div class="small text-muted">Giá nhập / đơn vị (VND)</div>
                                <div class="fw-bold text-primary fs-5" id="cvPerUnit">0</div>
                            </div>
                        </div>
                        <div class="small text-muted mt-1" id="cvFormulaHint"></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer py-2">
                <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

<!-- Comment Panel -->
@await Html.PartialAsync("_TaskComments", new ViewDataDictionary(ViewData) {
    { "EntityType", "QUOTATION" }, { "EntityId", Model.QuotationId }
})

<style>
    .bg-secondary-subtle { background-color: #f1f5f9 !important; }
    .text-secondary-emphasis { color: #475569 !important; }
    .bg-info-subtle { background-color: #e0f2fe !important; }
    .text-info-emphasis { color: #0369a1 !important; }
    .bg-success-subtle { background-color: #dcfce7 !important; }
    .text-success-emphasis { color: #166534 !important; }
    .bg-danger-subtle { background-color: #fee2e2 !important; }
    .text-danger-emphasis { color: #991b1b !important; }
    .bg-warning-subtle { background-color: #fef9c3 !important; }
    .text-warning-emphasis { color: #854d0e !important; }
    .bg-dark-subtle { background-color: #e2e8f0 !important; }
    .text-dark-emphasis { color: #1e293b !important; }
</style>

@section Scripts {
    <script>
        var quotationId = @Model.QuotationId;

        async function doAction(action, id) {
            var msg = {
                'Send': 'Bạn có chắc muốn gửi báo giá này cho khách hàng?',
                'Approve': 'Xác nhận khách hàng đã duyệt báo giá?',
                'Amend': 'Tạo bản chỉnh sửa mới từ báo giá này?',
                'Expire': 'Đánh dấu báo giá này đã hết hạn?'
            };
            if (!await appConfirm(msg[action] || 'Bạn có chắc?')) return;

            postAction('/Quotation/' + action + '/' + id, null, function (data) {
                if (data.Success) {
                    if (action === 'Amend' && data.Data && data.Data.QuotationId) {
                        window.location.href = '/Quotation/Edit/' + data.Data.QuotationId;
                    } else {
                        location.reload();
                    }
                } else {
                    appAlert(data.Message || 'Lỗi');
                }
            });
        }

        function doReject(id) {
            document.getElementById('rejectReason').value = '';
            new bootstrap.Modal(document.getElementById('rejectModal')).show();
        }

        function confirmReject() {
            var reason = document.getElementById('rejectReason').value.trim();
            postAction('/Quotation/Reject/' + quotationId, { Reason: reason }, function (data) {
                if (data.Success) {
                    bootstrap.Modal.getInstance(document.getElementById('rejectModal')).hide();
                    location.reload();
                } else {
                    appAlert(data.Message || 'Lỗi');
                }
            });
        }

        function doCancel(id) {
            document.getElementById('cancelReason').value = '';
            new bootstrap.Modal(document.getElementById('cancelModal')).show();
        }

        function confirmCancel() {
            var reason = document.getElementById('cancelReason').value.trim();
            postAction('/Quotation/Cancel/' + quotationId, { Reason: reason }, function (data) {
                if (data.Success) {
                    bootstrap.Modal.getInstance(document.getElementById('cancelModal')).hide();
                    location.reload();
                } else {
                    appAlert(data.Message || 'Lỗi');
                }
            });
        }

        function postAction(url, body, callback) {
            fetch(url, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': getAntiForgeryToken()
                },
                body: body ? JSON.stringify(body) : null
            })
            .then(r => r.json())
            .then(callback);
        }

        function getAntiForgeryToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
        }

        // ── Purchase price calc — view-only popup ───────────
        var calcViewInstance = null;

        function cvFmt(n) {
            return Math.round(Number(n) || 0).toLocaleString('vi-VN');
        }

        function openCalcView(el) {
            var d;
            try { d = JSON.parse(el.getAttribute('data-calc')); } catch (e) { return; }

            var mode = (d.mode || 'OFFICIAL').toString().toUpperCase();
            var currency = d.currency || 'VND';
            var rate = Number(d.rate) || 1;
            var qty = Number(d.qty) > 0 ? Number(d.qty) : 1;
            var basePrice = Number(d.basePrice) || 0;
            var offShipping = Number(d.offShipping) || 0;
            var domShipping = Number(d.domShipping) || 0;
            var weight = Number(d.weight) || 0;
            var costPerKg = Number(d.costPerKg) || 0;
            var handCarry = Number(d.handCarry) || 0;
            var w2w = Number(d.w2w) || 0;
            var length = Number(d.length) || 0;
            var width = Number(d.width) || 0;
            var height = Number(d.height) || 0;
            var costPerCbm = Number(d.costPerCbm) || 0;
            var tax = Number(d.tax) || 0;
            var inspection = Number(d.inspection) || 0;
            var banking = Number(d.banking) || 0;
            var other = Number(d.other) || 0;
            var vatPercent = Number(d.vatPercent) || 0;

            document.getElementById('cvRowNo').textContent = (d.no != null ? d.no : '');

            // Mode badge
            var badge = document.getElementById('cvModeBadge');
            if (mode === 'UNOFFICIAL') {
                badge.className = 'badge bg-warning-subtle text-warning-emphasis';
                badge.textContent = 'Nhập tiểu ngạch';
            } else if (mode === 'DOMESTIC') {
                badge.className = 'badge bg-success-subtle text-success-emphasis';
                badge.textContent = 'Mua trong nước';
            } else {
                badge.className = 'badge bg-primary-subtle text-primary-emphasis';
                badge.textContent = 'Nhập chính ngạch';
            }

            // Currency / rate label
            var rateLabel = document.getElementById('cvRateLabel');
            rateLabel.textContent = (currency && currency !== 'VND') ? ('Tỷ giá - ' + currency) : 'Tỷ giá';

            document.getElementById('cvBasePrice').value = basePrice ? cvFmt(basePrice) : '';
            document.getElementById('cvRate').value = cvFmt(rate);
            document.getElementById('cvQty').value = qty;
            document.getElementById('cvOfficialShipping').value = offShipping ? cvFmt(offShipping) : '';
            document.getElementById('cvDomesticShipping').value = domShipping ? cvFmt(domShipping) : '';
            document.getElementById('cvWeight').value = weight ? weight : '';
            document.getElementById('cvCostPerKg').value = costPerKg ? cvFmt(costPerKg) : '';
            document.getElementById('cvHandCarry').value = handCarry ? cvFmt(handCarry) : '';
            document.getElementById('cvW2W').value = w2w ? cvFmt(w2w) : '';
            document.getElementById('cvLength').value = length ? length : '';
            document.getElementById('cvWidth').value = width ? width : '';
            document.getElementById('cvHeight').value = height ? height : '';
            document.getElementById('cvCostPerCbm').value = costPerCbm ? cvFmt(costPerCbm) : '';
            document.getElementById('cvTax').value = tax ? cvFmt(tax) : '';
            document.getElementById('cvInspection').value = inspection ? cvFmt(inspection) : '';
            document.getElementById('cvBanking').value = banking ? cvFmt(banking) : '';
            document.getElementById('cvOther').value = other ? cvFmt(other) : '';
            document.getElementById('cvVatPercent').value = vatPercent ? vatPercent : '';

            document.getElementById('cvOfficialPanel').style.display = (mode === 'OFFICIAL' || mode === 'DOMESTIC') ? '' : 'none';
            document.getElementById('cvUnofficialPanel').style.display = (mode === 'UNOFFICIAL') ? '' : 'none';
            document.getElementById('cvVatCard').style.display = (mode === 'DOMESTIC') ? '' : 'none';

            // Same formula as the calc popup
            var perUnit, lineVnd, hint;
            if (mode === 'DOMESTIC') {
                // Domestic: priced in VND (rate = 1), VAT on base price, no extra fees.
                perUnit = Math.round(basePrice * (1 + vatPercent / 100) + offShipping / qty);
                hint = 'Giá nhập = Đơn giá gốc × (1 + VAT%) + (Phí vận chuyển / SL mua)';
            } else {
                var shippingVnd;
                if (mode === 'OFFICIAL') {
                    shippingVnd = offShipping;
                    hint = 'Giá nhập = (Đơn giá gốc × Tỷ giá) + ((Vận chuyển CT + Thuế + Kiểm định + Ngân hàng + Khác) / SL mua)';
                } else {
                    var cbmCost = (length * width * height) * costPerCbm;
                    shippingVnd = domShipping + weight * costPerKg + handCarry + w2w + cbmCost;
                    hint = 'Giá nhập = (Đơn giá gốc × Tỷ giá) + ((Nội địa + Kg×Phí/kg + CBM×Phí/CBM + Xách tay + Kho→Kho + Thuế + Kiểm định + Ngân hàng + Khác) / SL mua)';
                }
                var feesVnd = shippingVnd + tax + inspection + banking + other;
                perUnit = Math.round(basePrice * rate + feesVnd / qty);
            }
            lineVnd = perUnit * qty;

            document.getElementById('cvLineTotal').textContent = cvFmt(lineVnd);
            document.getElementById('cvPerUnit').textContent = cvFmt(perUnit);
            document.getElementById('cvFormulaHint').textContent = hint;

            if (!calcViewInstance) {
                calcViewInstance = new bootstrap.Modal(document.getElementById('calcViewModal'));
            }
            calcViewInstance.show();
        }

        // ── Items table client-side pagination ──────────────
        (function () {
            var tbody = document.getElementById('quotItemsTbody');
            var pager = document.getElementById('quotItemsPager');
            if (!tbody || !pager) return;
            var rows = Array.from(tbody.querySelectorAll(':scope > tr'));
            if (rows.length === 0) return;

            // Hide pager when the smallest page size already shows everything.
            if (rows.length <= 10) return;
            pager.style.removeProperty('display');

            var pageSize = 10;
            var page = 0;
            var sizeEl = document.getElementById('quotItemsPageSize');
            var prevEl = document.getElementById('quotItemsPrev');
            var nextEl = document.getElementById('quotItemsNext');
            var infoEl = document.getElementById('quotItemsPageInfo');

            function render() {
                var pages = Math.max(1, Math.ceil(rows.length / pageSize));
                if (page >= pages) page = pages - 1;
                if (page < 0) page = 0;
                var start = page * pageSize, end = start + pageSize;
                rows.forEach(function (tr, i) {
                    tr.style.display = (i >= start && i < end) ? '' : 'none';
                });
                if (infoEl) {
                    var from = (start + 1);
                    var to = Math.min(end, rows.length);
                    infoEl.textContent = from + '–' + to + ' / ' + rows.length;
                }
                if (prevEl) prevEl.disabled = (page === 0);
                if (nextEl) nextEl.disabled = (page >= pages - 1);
            }

            sizeEl && sizeEl.addEventListener('change', function (e) {
                pageSize = parseInt(e.target.value) || 10;
                page = 0;
                render();
            });
            prevEl && prevEl.addEventListener('click', function () { page--; render(); });
            nextEl && nextEl.addEventListener('click', function () { page++; render(); });

            render();
        })();
    </script>
    @Html.AntiForgeryToken()
}
