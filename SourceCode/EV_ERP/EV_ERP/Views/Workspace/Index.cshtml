@model EV_ERP.Models.ViewModels.Workspace.WorkspaceViewModel
@using EV_ERP.Helpers
@{
    ViewData["Title"] = "Workspace";
    var me = Context.Session.GetObject<CurrentUser>(SessionKeys.CurrentUser)!;
    var isViewingOther = Model.CanViewOthers && !Model.IsManagerOverview && Model.ViewingUserId != me.UserId;
}

<div class="mb-4 d-flex align-items-center justify-content-between flex-wrap gap-2">
    <div>
        <h5 class="fw-bold mb-0">
            @if (Model.IsManagerOverview)
            {
                <i class="bi bi-people me-2 text-primary"></i>@:Tổng quan
            }
            else
            {
                @:Công việc cần làm
                @if (isViewingOther)
                {
                    <span class="badge bg-info fw-normal ms-2" style="font-size:0.75rem;">
                        <i class="bi bi-eye me-1"></i>@Model.ViewingUserName
                    </span>
                }
            }
        </h5>
    </div>
    @if (Model.CanViewOthers)
    {
        <div class="d-flex align-items-center gap-2">
            @if (!Model.IsManagerOverview)
            {
                <a href="/Workspace" class="btn btn-sm btn-outline-primary" title="Về tổng quan">
                    <i class="bi bi-people me-1"></i> Tổng quan
                </a>
            }
            else
            {
                <a href="/Workspace?viewUserId=@me.UserId" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-person me-1"></i> Workspace của tôi
                </a>
            }
        </div>
    }
</div>

<!-- Flow arrow connector -->
<div class="workspace-flow">
    @foreach (var card in Model.Cards)
    {
        var hasContent = Model.IsManagerOverview ? card.EmployeeSummaries.Count > 0 : card.Tasks.Count > 0;
        var totalCount = Model.IsManagerOverview ? card.TotalTasks : card.Tasks.Count;

        <div class="workspace-step">
            <div class="card border-0 shadow-sm workspace-card h-100 @(hasContent ? "" : "opacity-50")">
                <!-- Card header -->
                <div class="card-header bg-white border-bottom py-2 px-3 d-flex align-items-center justify-content-between">
                    <div class="d-flex align-items-center gap-2">
                        <span class="step-number">@card.StepNumber</span>
                        <div>
                            <div class="fw-semibold" style="font-size:0.82rem;">
                                <i class="bi @card.Icon me-1 text-@card.BadgeColor"></i>@card.Title
                            </div>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-1">
                        @if (Model.IsManagerOverview && card.TotalSlaViolations > 0)
                        {
                            <span class="badge bg-danger rounded-pill" style="font-size:0.65rem;" title="Vi phạm SLA">
                                <i class="bi bi-exclamation-triangle-fill me-1"></i>@card.TotalSlaViolations
                            </span>
                        }
                        <span class="badge bg-@(totalCount > 0 ? card.BadgeColor : "light text-muted border") rounded-pill">
                            @totalCount
                        </span>
                    </div>
                </div>

                <!-- Card body -->
                <div class="card-body p-0">
                    @if (!hasContent)
                    {
                        <div class="text-center text-muted py-4" style="font-size:0.8rem;">
                            <i class="bi bi-check-circle d-block mb-1" style="font-size:1.2rem;"></i>
                            Không có công việc
                        </div>
                    }
                    else if (Model.IsManagerOverview)
                    {
                        @* ── Manager Overview: Employee list per card ── *@
                        <div class="task-list" style="max-height:320px; overflow-y:auto;">
                            @foreach (var emp in card.EmployeeSummaries)
                            {
                                var hasSla = emp.SlaViolationCount > 0;
                                var empClass = hasSla ? "sla-danger" : "";
                                <a href="/Workspace?viewUserId=@emp.UserId"
                                   class="task-item d-block text-decoration-none @empClass"
                                   title="Xem workspace của @emp.FullName">
                                    <div class="d-flex align-items-center justify-content-between">
                                        <div class="d-flex align-items-center gap-2" style="min-width:0;">
                                            <div class="emp-avatar">@emp.FullName[0]</div>
                                            <span class="fw-semibold text-dark text-truncate" style="font-size:0.82rem;">
                                                @emp.FullName
                                            </span>
                                        </div>
                                        <div class="d-flex align-items-center gap-1 flex-shrink-0 ms-2">
                                            @if (hasSla)
                                            {
                                                <span class="badge bg-danger text-white" style="font-size:0.65rem;" title="Vi phạm SLA">
                                                    <i class="bi bi-exclamation-triangle-fill me-1"></i>@emp.SlaViolationCount
                                                </span>
                                            }
                                            <span class="badge bg-light text-muted border" style="font-size:0.68rem;">
                                                @emp.TaskCount @(emp.TaskCount == 1 ? "task" : "tasks")
                                            </span>
                                        </div>
                                    </div>
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        @* ── Individual Workspace: Task list ── *@
                        <div class="task-list" style="max-height:320px; overflow-y:auto;">
                            @foreach (var task in card.Tasks)
                            {
                                var slaClass = task.SlaSeverity switch
                                {
                                    "DANGER" => "sla-danger",
                                    "WARNING" => "sla-warning",
                                    _ => ""
                                };
                                <div class="task-item @slaClass">
                                    <div class="d-flex align-items-start justify-content-between">
                                        <a href="@task.DetailUrl" class="text-decoration-none flex-grow-1" style="min-width:0;">
                                            <div class="fw-semibold text-dark" style="font-size:0.8rem;">
                                                @task.RfqNo
                                                @if (task.SalesOrderNo != null)
                                                {
                                                    <span class="text-muted fw-normal">/ @task.SalesOrderNo</span>
                                                }
                                            </div>
                                            <div class="text-muted text-truncate" style="font-size:0.75rem;">
                                                @task.CustomerName
                                            </div>
                                        </a>
                                        <div class="d-flex align-items-center gap-1 flex-shrink-0 ms-2">
                                            @if (!string.IsNullOrEmpty(task.Notes))
                                            {
                                                <a href="javascript:;" class="btn-note has-note"
                                                   data-entity-type="@task.EntityType"
                                                   data-entity-id="@task.EntityId"
                                                   data-notes="@Html.Raw(System.Web.HttpUtility.HtmlAttributeEncode(task.Notes))"
                                                   data-bs-toggle="tooltip"
                                                   data-bs-placement="top"
                                                   data-bs-custom-class="note-tooltip"
                                                   data-bs-title="@task.Notes">
                                                    <i class="bi bi-sticky-fill"></i>
                                                </a>
                                            }
                                            else
                                            {
                                                <a href="javascript:;" class="btn-note no-note"
                                                   data-entity-type="@task.EntityType"
                                                   data-entity-id="@task.EntityId"
                                                   data-notes="">
                                                    <i class="bi bi-pencil-square"></i>
                                                </a>
                                            }
                                            @if (task.SlaTimeRemaining != null)
                                            {
                                                var slaBadge = task.SlaSeverity == "DANGER" ? "bg-danger text-white"
                                                             : task.SlaSeverity == "WARNING" ? "bg-warning text-dark"
                                                             : "bg-light text-muted border";
                                                <span class="badge @slaBadge" style="font-size:0.65rem;" title="SLA">
                                                    <i class="bi bi-clock me-1"></i>@task.SlaTimeRemaining
                                                </span>
                                            }
                                            @if (task.ExtraInfo != null)
                                            {
                                                <span class="badge bg-light text-muted border" style="font-size:0.68rem;">
                                                    @task.ExtraInfo
                                                </span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- Arrow connector (not on last item, not on 5th which ends a row) -->
            @if (card.StepNumber < Model.Cards.Count && card.StepNumber % 5 != 0)
            {
                <div class="step-arrow d-none d-xl-flex">
                    <span class="arrow-line"></span>
                    <i class="bi bi-chevron-right arrow-head"></i>
                </div>
            }
        </div>
    }
</div>

<!-- Quick Note Modal -->
<div class="modal fade" id="noteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-header py-2 px-3">
                <h6 class="modal-title mb-0"><i class="bi bi-sticky me-2"></i>Ghi chú nhanh</h6>
                <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-3">
                <input type="hidden" id="noteEntityType" />
                <input type="hidden" id="noteEntityId" />
                <textarea id="noteContent" class="form-control" rows="4" placeholder="Nhập ghi chú..." style="font-size:0.85rem;"></textarea>
            </div>
            <div class="modal-footer py-2 px-3">
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Đóng</button>
                <button type="button" class="btn btn-sm btn-primary" id="btnSaveNote">
                    <i class="bi bi-check-lg me-1"></i>Lưu
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    .workspace-flow {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 0.75rem 2rem;
        align-items: stretch;
    }

    .workspace-step {
        position: relative;
    }

    .workspace-card {
        border-radius: 8px;
        transition: box-shadow 0.15s;
    }
    .workspace-card:hover {
        box-shadow: 0 4px 16px rgba(0,0,0,0.1) !important;
    }

    .step-number {
        width: 22px; height: 22px;
        border-radius: 50%;
        background: #e2e8f0;
        color: #475569;
        font-size: 0.7rem;
        font-weight: 700;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }

    .step-arrow {
        position: absolute;
        right: -2rem;
        width: 2rem;
        top: 50%;
        transform: translateY(-50%);
        z-index: 5;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .arrow-line {
        flex: 1;
        height: 0;
        border-top: 2px dashed #94a3b8;
    }

    .arrow-head {
        color: #64748b;
        font-size: 0.85rem;
        margin-left: -2px;
        line-height: 1;
    }

    .task-list {
        scrollbar-width: thin;
    }
    .task-list::-webkit-scrollbar { width: 4px; }
    .task-list::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 2px; }

    .task-item {
        padding: 0.5rem 0.75rem;
        border-bottom: 1px solid #f1f5f9;
        transition: background 0.15s;
    }
    .task-item:last-child { border-bottom: none; }
    .task-item:hover { background: #f8fafc; }

    /* Employee avatar in manager overview */
    .emp-avatar {
        width: 26px; height: 26px;
        border-radius: 50%;
        background: #2563eb; color: #fff;
        font-weight: 600; font-size: 0.7rem;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }

    /* SLA highlighting */
    .task-item.sla-warning {
        background: #fefce8;
        border-left: 3px solid #eab308;
    }
    .task-item.sla-warning:hover { background: #fef9c3; }
    .task-item.sla-danger {
        background: #fef2f2;
        border-left: 3px solid #ef4444;
    }
    .task-item.sla-danger:hover { background: #fee2e2; }

    /* Quick note button */
    .btn-note {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 22px; height: 22px;
        border-radius: 4px;
        font-size: 0.78rem;
        transition: all 0.15s;
        text-decoration: none;
    }
    .btn-note.has-note {
        color: #d97706;
    }
    .btn-note.has-note:hover {
        color: #b45309;
        background: #fef3c7;
    }
    .btn-note.no-note {
        color: #94a3b8;
        opacity: 0;
    }
    .task-item:hover .btn-note.no-note {
        opacity: 1;
    }
    .btn-note.no-note:hover {
        color: #2563eb;
        background: #eff6ff;
    }

    /* Note tooltip: allow full content, wrap text */
    .note-tooltip .tooltip-inner {
        max-width: 300px;
        white-space: pre-wrap;
        text-align: left;
        font-size: 0.8rem;
        padding: 0.5rem 0.65rem;
    }

    @@media (max-width: 1199.98px) {
        .workspace-flow {
            grid-template-columns: repeat(3, 1fr);
            gap: 0.75rem 1.5rem;
        }
        .step-arrow { display: none !important; }
    }

    @@media (max-width: 767.98px) {
        .workspace-flow {
            grid-template-columns: repeat(2, 1fr);
            gap: 0.5rem;
        }
    }

    @@media (max-width: 575.98px) {
        .workspace-flow {
            grid-template-columns: 1fr;
            gap: 0.5rem;
        }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var noteModal = new bootstrap.Modal(document.getElementById('noteModal'));

        // Open note modal on click
        document.querySelectorAll('.btn-note').forEach(function (btn) {
            btn.addEventListener('click', function (e) {
                e.preventDefault();
                e.stopPropagation();
                document.getElementById('noteEntityType').value = this.dataset.entityType;
                document.getElementById('noteEntityId').value = this.dataset.entityId;
                document.getElementById('noteContent').value = this.dataset.notes || '';
                noteModal.show();
            });
        });

        // Save note
        document.getElementById('btnSaveNote').addEventListener('click', function () {
            var btn = this;
            btn.disabled = true;

            var entityType = document.getElementById('noteEntityType').value;
            var entityId = parseInt(document.getElementById('noteEntityId').value);
            var notes = document.getElementById('noteContent').value.trim();

            fetch('/Workspace/SaveNote', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ entityType: entityType, entityId: entityId, notes: notes || null })
            })
            .then(function (r) { return r.json(); })
            .then(function (res) {
                btn.disabled = false;
                if (res.Success) {
                    noteModal.hide();
                    // Update the icon in-place
                    var noteBtn = document.querySelector('.btn-note[data-entity-type="' + entityType + '"][data-entity-id="' + entityId + '"]');
                    if (noteBtn) {
                        noteBtn.dataset.notes = notes;
                        // Dispose old tooltip if any
                        var oldTip = bootstrap.Tooltip.getInstance(noteBtn);
                        if (oldTip) oldTip.dispose();
                        if (notes) {
                            noteBtn.className = 'btn-note has-note';
                            noteBtn.setAttribute('data-bs-title', notes);
                            noteBtn.setAttribute('data-bs-toggle', 'tooltip');
                            noteBtn.setAttribute('data-bs-placement', 'top');
                            noteBtn.setAttribute('data-bs-custom-class', 'note-tooltip');
                            noteBtn.querySelector('i').className = 'bi bi-sticky-fill';
                            new bootstrap.Tooltip(noteBtn);
                        } else {
                            noteBtn.className = 'btn-note no-note';
                            noteBtn.removeAttribute('data-bs-title');
                            noteBtn.removeAttribute('data-bs-toggle');
                            noteBtn.querySelector('i').className = 'bi bi-pencil-square';
                        }
                    }
                } else {
                    alert(res.Message || 'Có lỗi xảy ra');
                }
            })
            .catch(function () {
                btn.disabled = false;
                alert('Có lỗi xảy ra');
            });
        });

        // Initialize Bootstrap tooltips for note buttons
        document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
            new bootstrap.Tooltip(el);
        });
    });
</script>
