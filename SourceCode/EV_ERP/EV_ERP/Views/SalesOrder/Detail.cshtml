<style>
    .bg-secondary-subtle { background-color: #f1f5f9 !important; }
    .text-secondary-emphasis { color: #475569 !important; }
    .bg-info-subtle { background-color: #e0f2fe !important; }
    .text-info-emphasis { color: #0369a1 !important; }
    .bg-success-subtle { background-color: #dcfce7 !important; }
    .text-success-emphasis { color: #166534 !important; }
    .bg-danger-subtle { background-color: #fee2e2 !important; }
    .text-danger-emphasis { color: #991b1b !important; }
    .bg-warning-subtle { background-color: #fef9c3 !important; }
    .text-warning-emphasis { color: #854d0e !important; }
    .bg-primary-subtle { background-color: #dbeafe !important; }
    .text-primary-emphasis { color: #1e40af !important; }
</style>

@Html.AntiForgeryToken()

<script>
    var soId = @Model.SalesOrderId;
    var hasUnmappedProducts = @(Model.HasUnmappedProducts ? "true" : "false");

    // Re-init dropdowns inside .table-responsive with Popper's `fixed` strategy
    // so the menu escapes the table's overflow clipping.
    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('[data-portal="fixed"][data-bs-toggle="dropdown"]').forEach(function (el) {
            var existing = bootstrap.Dropdown.getInstance(el);
            if (existing) existing.dispose();
            new bootstrap.Dropdown(el, {
                popperConfig: function (defaultBsPopperConfig) {
                    return Object.assign({}, defaultBsPopperConfig, { strategy: 'fixed' });
                }
            });
        });
    });

    // ── Helpers ──────────────────────────────────────
    function postAction(url, body, callback) {
        fetch(url, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? ''
            },
            body: body ? JSON.stringify(body) : null
        })
        .then(function(r) { return r.json(); })
        .then(callback);
    }

    async function doSimpleAction(action, msg) {
        if (!await appConfirm(msg)) return;
        postAction('/SalesOrder/' + action + '/' + soId, null, function (data) {
            if (data.Success) location.reload();
            else appAlert(data.Message || 'Lỗi');
        });
    }

    // ══════════════════════════════════════════════════
    // ẢNH HÓA ĐƠN theo từng sản phẩm (lazy-load, gom theo SOItem)
    // ══════════════════════════════════════════════════
    var canManageBills = @(canManageStatus ? "true" : "false");

    // Chỉ tải ảnh khi card được MỞ (lần đầu) — tránh tải hàng loạt khi đơn nhiều dòng.
    function onBillToggle(soItemId) {
        var col = document.getElementById('billCollapse-' + soItemId);
        if (!col) return;
        var opening = !col.classList.contains('show');
        if (opening && col.dataset.loaded !== 'true') loadItemBills(soItemId);
    }

    function loadItemBills(soItemId) {
        var grid = document.getElementById('billGrid-' + soItemId);
        if (!grid) return;
        grid.innerHTML = '<div class="text-muted small">Đang tải...</div>';
        fetch('/SalesOrder/GetItemBills/' + soId + '?soItemId=' + soItemId)
            .then(function (r) { return r.json(); })
            .then(function (res) {
                if (!res.Success) { grid.innerHTML = '<div class="text-danger small">' + (res.Message || 'Lỗi tải ảnh') + '</div>'; return; }
                document.getElementById('billCollapse-' + soItemId).dataset.loaded = 'true';
                renderBillGrid(soItemId, res.Data || []);
            })
            .catch(function () { grid.innerHTML = '<div class="text-danger small">Lỗi tải ảnh</div>'; });
    }

    function renderBillGrid(soItemId, images) {
        var grid = document.getElementById('billGrid-' + soItemId);
        if (!grid) return;
        if (!images.length) {
            grid.innerHTML = '<div class="text-muted small">Chưa có ảnh hóa đơn</div>';
            updateBillCount(soItemId, 0);
            return;
        }
        var html = '';
        images.forEach(function (img) {
            html += '<div class="position-relative" style="width:90px;">'
                + '<a href="' + img.FileUrl + '" target="_blank" title="' + (img.FileName || '') + '">'
                + '<img src="' + img.FileUrl + '" style="width:90px;height:90px;object-fit:cover;border-radius:6px;border:1px solid #e2e8f0;" /></a>';
            if (canManageBills) {
                html += '<button type="button" class="btn btn-sm btn-danger position-absolute top-0 end-0 py-0 px-1" '
                    + 'style="line-height:1;font-size:0.7rem;" title="Xóa" '
                    + 'onclick="deleteItemBill(' + img.AttachmentId + ',' + soItemId + ')">&times;</button>';
            }
            html += '</div>';
        });
        grid.innerHTML = html;
        updateBillCount(soItemId, images.length);
    }

    function uploadItemBills(soItemId, input) {
        var files = Array.from(input.files || []);
        input.value = '';
        if (!files.length) return;
        var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
        var grid = document.getElementById('billGrid-' + soItemId);
        if (grid) grid.insertAdjacentHTML('beforeend', '<div class="text-muted small">Đang tải lên ' + files.length + ' ảnh...</div>');

        var uploads = files.map(function (f) {
            var fd = new FormData();
            fd.append('file', f);
            fd.append('soItemId', soItemId);
            return fetch('/SalesOrder/UploadItemBill/' + soId, {
                method: 'POST',
                headers: { 'RequestVerificationToken': token },
                body: fd
            }).then(function (r) { return r.json(); });
        });

        Promise.all(uploads).then(function (results) {
            var failed = results.filter(function (x) { return !x.Success; });
            if (failed.length) appAlert(failed[0].Message || 'Một số ảnh tải lên thất bại');
            loadItemBills(soItemId);
        }).catch(function () {
            appAlert('Lỗi tải ảnh lên');
            loadItemBills(soItemId);
        });
    }

    async function deleteItemBill(attachmentId, soItemId) {
        if (!await appConfirm('Xóa ảnh hóa đơn này?')) return;
        postAction('/SalesOrder/DeleteItemBill/' + soId + '?attachmentId=' + attachmentId, null, function (data) {
            if (data.Success) loadItemBills(soItemId);
            else appAlert(data.Message || 'Lỗi');
        });
    }

    function updateBillCount(soItemId, n) {
        var badge = document.getElementById('billCount-' + soItemId);
        if (badge) badge.textContent = n;
        var total = 0;
        document.querySelectorAll('[id^="billCount-"]').forEach(function (b) { total += parseInt(b.textContent) || 0; });
        var tb = document.getElementById('billTotalBadge');
        if (tb) tb.textContent = total;
    }

    function filterBillCards() {
        var q = (document.getElementById('billFilter').value || '').trim().toLowerCase();
        var any = false;
        document.querySelectorAll('#billCardGrid .bill-card').forEach(function (c) {
            var match = !q || (c.dataset.name || '').indexOf(q) !== -1;
            c.classList.toggle('d-none', !match);
            if (match) any = true;
        });
        var nm = document.getElementById('billNoMatch');
        if (nm) nm.classList.toggle('d-none', any);
    }

    function toggleAllBills(show) {
        document.querySelectorAll('#billCardGrid .collapse').forEach(function (el) {
            var inst = bootstrap.Collapse.getOrCreateInstance(el, { toggle: false });
            if (show) {
                var soItemId = parseInt(el.id.replace('billCollapse-', ''));
                if (el.dataset.loaded !== 'true') loadItemBills(soItemId);
                inst.show();
            } else {
                inst.hide();
            }
        });
    }

    // ── Inline edit Phí vận chuyển (Shipping Cost) ────
    function startEditShipFee(spanEl) {
        var td = spanEl.closest('td');
        var input = td.querySelector('.ship-fee-input');
        if (!input) return;
        spanEl.classList.add('d-none');
        input.classList.remove('d-none');
        input.focus();
        input.select();
    }
    function shipFeeKey(e, input) {
        if (e.key === 'Enter') { e.preventDefault(); input.blur(); }
        else if (e.key === 'Escape') { input.dataset.cancelled = '1'; input.blur(); }
    }
    function saveShipFee(input) {
        var td = input.closest('td');
        var span = td.querySelector('.ship-fee-display');
        if (input.dataset.cancelled === '1') {
            input.dataset.cancelled = '';
            input.classList.add('d-none');
            if (span) span.classList.remove('d-none');
            return;
        }
        var soItemId = parseInt(input.getAttribute('data-so-item-id'));
        var raw = (input.value || '').trim();
        var val = raw === '' ? null : parseFloat(raw);
        if (val !== null && (isNaN(val) || val < 0)) { appAlert('Phí vận chuyển không hợp lệ'); input.focus(); return; }
        input.disabled = true;
        postAction('/SalesOrder/UpdateItemShippingFee/' + soId + '?soItemId=' + soItemId, { ShippingFee: val }, function (data) {
            if (data.Success) { location.reload(); }
            else { appAlert(data.Message || 'Lỗi'); input.disabled = false; }
        });
    }

    // ── Save Draft Info (PO KH + file) ────────────────
    function saveDraftInfo() {
        var formData = new FormData();
        formData.append('customerPoNo', document.getElementById('draftCustomerPoNo').value.trim());
        var poDate = document.getElementById('draftCustomerPoDate').value;
        if (poDate) {
            formData.append('customerPoDate', poDate);
        }
        var expectedDate = document.getElementById('draftExpectedDeliveryDate').value;
        if (expectedDate) {
            formData.append('expectedDeliveryDate', expectedDate);
        }
        var fileInput = document.getElementById('draftCustomerPoFile');
        if (fileInput.files.length > 0) {
            formData.append('customerPoFile', fileInput.files[0]);
        }

        var btn = event.target.closest('button');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Đang lưu...';

        fetch('/SalesOrder/UpdateDraftInfo/' + soId, {
            method: 'POST',
            headers: {
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? ''
            },
            body: formData
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.Success) location.reload();
            else { appAlert(data.Message || 'Loi'); btn.disabled = false; btn.innerHTML = '<i class="bi bi-check-lg me-1"></i> Lưu thông tin PO'; }
        })
        .catch(function() { btn.disabled = false; btn.innerHTML = '<i class="bi bi-check-lg me-1"></i> Lưu thông tin PO'; });
    }

    // ── Import Products from Excel ──────────────────
    async function importProducts(input) {
        if (!input.files || input.files.length === 0) return;

        var file = input.files[0];
        if (!file.name.match(/\.xlsx?$/i)) {
            appAlert('Vui lòng chọn file Excel (.xlsx)');
            input.value = '';
            return;
        }

        if (!await appConfirm('Import sản phẩm từ file "' + file.name + '"?\n\nSản phẩm sẽ được tạo và gắn tự động vào đơn hàng.'))
        {
            input.value = '';
            return;
        }

        var formData = new FormData();
        formData.append('file', file);

        // Show loading state on the label
        var label = document.querySelector('label[for="importProductFile"]');
        var origHtml = label.innerHTML;
        label.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Đang import...';
        label.classList.add('disabled');

        fetch('/SalesOrder/ImportProducts/' + soId, {
            method: 'POST',
            headers: {
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? ''
            },
            body: formData
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.Success) {
                appAlert(data.Message || ('Đã import ' + (data.Data?.created || 0) + ' sản phẩm'));
                location.reload();
            } else {
                appAlert(data.Message || 'Import thất bại');
                label.innerHTML = origHtml;
                label.classList.remove('disabled');
            }
            input.value = '';
        })
        .catch(function() {
            appAlert('Lỗi hệ thống khi import');
            label.innerHTML = origHtml;
            label.classList.remove('disabled');
            input.value = '';
        });
    }

    // ── DRAFT → WAIT ────────────────────────────────
    async function showSubmitWaitModal() {
        if (hasUnmappedProducts) {
            appAlert('Còn sản phẩm chưa được nhập vào hệ thống. Vui lòng tạo sản phẩm cho tất cả các dòng trước khi gửi DNTU.');
            return;
        }

        var customerPoNo = document.getElementById('draftCustomerPoNo')?.value.trim();
        if (!customerPoNo) {
            appAlert('Vui lòng nhập Mã PO khách hàng trước khi gửi DNTU.');
            document.getElementById('draftCustomerPoNo')?.focus();
            return;
        }

        var hasExistingFile = @(Model.CustomerPoFile != null ? "true" : "false");
        var hasNewFile = document.getElementById('draftCustomerPoFile')?.files.length > 0;
        if (!hasExistingFile && !hasNewFile) {
            appAlert('Vui lòng upload File PO khách hàng trước khi gửi DNTU.');
            return;
        }

        var activeAdvanceCount = @(Model.AdvanceSummary?.Requests.Count(r => r.Status != "REJECTED") ?? 0);
        if (activeAdvanceCount === 0) {
            appAlert('Vui lòng tạo ít nhất 1 đề nghị tạm ứng trong mục "Tạm ứng" trước khi gửi DNTU.');
            return;
        }

        if (!await appConfirm('Xác nhận gửi đề nghị tạm ứng?')) return;

        postAction('/SalesOrder/SubmitWait/' + soId, null, function (data) {
            if (data.Success) location.reload();
            else appAlert(data.Message || 'Lỗi');
        });
    }

    // ── Create Product Modal ────────────────────────
    function openCreateProductModal(soItemId, productName, salePrice, purchasePrice, sourceUrl, description, imageUrl, unitId, unitName) {
        document.getElementById('cpSoItemId').value = soItemId;
        document.getElementById('cpItemLabel').textContent = '(cho: ' + productName + ')';

        // Pre-fill form fields
        document.getElementById('ProductName').value = productName;

        // Bind unit of measure from the SO line: prefer the resolved UnitId,
        // otherwise fall back to matching the option text against the unit name.
        var unitSel = document.getElementById('UnitId');
        if (unitSel) {
            var bound = false;
            if (unitId && Number(unitId) > 0) {
                unitSel.value = String(unitId);
                bound = unitSel.value === String(unitId);
            }
            if (!bound && unitName) {
                var target = unitName.trim().toLowerCase();
                for (var i = 0; i < unitSel.options.length; i++) {
                    var txt = (unitSel.options[i].text || '').split('(')[0].trim().toLowerCase();
                    if (txt === target) { unitSel.selectedIndex = i; bound = true; break; }
                }
            }
            if (!bound) unitSel.value = '';
        }
        //document.getElementById('DefaultSalePrice').value = salePrice || '';
        var dppEl = document.getElementById('DefaultPurchasePrice');
        dppEl.value = (purchasePrice && Number(purchasePrice) > 0)
            ? Number(purchasePrice).toLocaleString('vi-VN')
            : '';
        document.getElementById('SourceUrl').value = sourceUrl || '';

        var descEl = document.getElementById('Description');
        if (descEl) descEl.value = description || '';

        // Reset upload state
        var galleryInput = document.getElementById('cp-gallery-input');
        if (galleryInput) galleryInput.value = '';
        document.getElementById('cp-gallery-preview').innerHTML = '';
        document.getElementById('cp-avatar-index').value = '0';

        // Render existing image preview (carried over from quotation snapshot)
        renderCpExistingImage(imageUrl || '');

        new bootstrap.Modal(document.getElementById('createProductModal')).show();
    }

    function renderCpExistingImage(url) {
        document.getElementById('cp-existing-image-url').value = url || '';
        var box = document.getElementById('cp-existing-image-preview');
        box.innerHTML = '';
        if (!url) return;

        var wrap = document.createElement('div');
        wrap.className = 'position-relative';
        wrap.style.cssText = 'width:80px;height:80px;';
        wrap.title = 'Ảnh từ báo giá — sẽ được dùng làm ảnh đại diện nếu bạn không tải ảnh mới';

        var img = document.createElement('img');
        img.src = url;
        img.style.cssText = 'width:100%;height:100%;object-fit:cover;border-radius:6px;border:2px solid #2563eb;';
        wrap.appendChild(img);

        var badge = document.createElement('span');
        badge.className = 'position-absolute top-0 start-0 badge bg-primary';
        badge.style.cssText = 'font-size:0.55rem;border-radius:6px 0 4px 0!important;pointer-events:none;';
        badge.textContent = 'Sẵn có';
        wrap.appendChild(badge);

        var removeBtn = document.createElement('button');
        removeBtn.type = 'button';
        removeBtn.className = 'btn btn-sm btn-danger position-absolute top-0 end-0 p-0';
        removeBtn.style.cssText = 'width:18px;height:18px;font-size:0.6rem;line-height:1;border-radius:0 6px 0 4px;';
        removeBtn.innerHTML = '&times;';
        removeBtn.title = 'Bỏ ảnh sẵn có';
        removeBtn.onclick = function () { renderCpExistingImage(''); };
        wrap.appendChild(removeBtn);

        box.appendChild(wrap);
    }

    function submitCreateProduct() {
        var productName = document.getElementById('ProductName').value.trim();
        var unitId = document.getElementById('UnitId').value;

        if (!productName) { appAlert('Tên sản phẩm là bắt buộc'); return; }
        if (!unitId || unitId === '0') { appAlert('Vui lòng chọn đơn vị tính'); return; }

        var formData = new FormData();
        formData.append('SoItemId', document.getElementById('cpSoItemId').value);
        formData.append('ProductName', productName);
        formData.append('Description', document.getElementById('Description')?.value || '');
        formData.append('CategoryId', document.getElementById('CategoryId')?.value || '');
        formData.append('UnitId', unitId);
        formData.append('DefaultSalePrice', document.getElementById('DefaultSalePrice')?.value || '');
        formData.append('DefaultPurchasePrice', (document.getElementById('DefaultPurchasePrice')?.value || '').replace(/\./g, '').replace(/,/g, ''));
        formData.append('MinStockLevel', document.getElementById('MinStockLevel')?.value || '0');
        formData.append('Barcode', document.getElementById('Barcode')?.value || '');
        formData.append('BarcodeType', document.getElementById('BarcodeType')?.value || 'CODE128');
        formData.append('SourceUrl', document.getElementById('SourceUrl')?.value || '');
        formData.append('Weight', document.getElementById('Weight')?.value || '');
        formData.append('WeightUnit', document.getElementById('WeightUnit')?.value || '');
        formData.append('IsActive', document.getElementById('IsActive')?.checked ? 'true' : 'false');
        formData.append('AvatarIndex', document.getElementById('cp-avatar-index')?.value || '0');
        formData.append('ExistingImageUrl', document.getElementById('cp-existing-image-url')?.value || '');

        // SKU attribute values
        document.querySelectorAll('[name^="AttributeValues["]').forEach(function (el) {
            if (el.value) formData.append(el.name, el.value);
        });

        // Gallery files
        var galleryInput = document.getElementById('cp-gallery-input');
        if (galleryInput && galleryInput.files) {
            for (var i = 0; i < galleryInput.files.length; i++) {
                formData.append('GalleryFiles', galleryInput.files[i]);
            }
        }

        var btn = document.getElementById('cpSubmitBtn');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Đang tạo...';

        fetch('/SalesOrder/CreateProduct/' + soId, {
            method: 'POST',
            headers: {
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? ''
            },
            body: formData
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.Success) {
                bootstrap.Modal.getInstance(document.getElementById('createProductModal')).hide();
                location.reload();
            } else {
                appAlert(data.Message || 'Lỗi tạo sản phẩm');
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-check-lg me-1"></i> Tạo sản phẩm';
            }
        })
        .catch(function(err) {
            appAlert('Lỗi hệ thống');
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-check-lg me-1"></i> Tạo sản phẩm';
        });
    }

    // ── Assign Existing Product Modal ───────────────
    var apSearchTimer = null;
    var apActiveQuery = '';

    function openAssignProductModal(soItemId, productName) {
        document.getElementById('apSoItemId').value = soItemId;
        document.getElementById('apProductId').value = '';
        document.getElementById('apItemLabel').textContent = '(cho: ' + productName + ')';
        document.getElementById('apSearchInput').value = productName || '';
        document.getElementById('apResults').innerHTML = '<div class="p-3 text-muted small text-center">Nhập từ khoá để tìm sản phẩm</div>';
        document.getElementById('apSelectedBox').classList.add('d-none');
        document.getElementById('apSubmitBtn').disabled = true;
        new bootstrap.Modal(document.getElementById('assignProductModal')).show();
        // Auto-search if pre-filled name >= 2 chars
        if ((productName || '').trim().length >= 2) {
            runAssignSearch(productName.trim());
        }
        setTimeout(function () { document.getElementById('apSearchInput').focus(); }, 200);
    }

    function onAssignSearchInput(inputEl) {
        var kw = inputEl.value.trim();
        clearTimeout(apSearchTimer);
        if (kw.length < 2) {
            document.getElementById('apResults').innerHTML = '<div class="p-3 text-muted small text-center">Nhập tối thiểu 2 ký tự</div>';
            return;
        }
        apSearchTimer = setTimeout(function () { runAssignSearch(kw); }, 300);
    }

    function runAssignSearch(kw) {
        apActiveQuery = kw;
        var box = document.getElementById('apResults');
        box.innerHTML = '<div class="p-3 text-muted small text-center"><span class="spinner-border spinner-border-sm me-1"></span> Đang tìm...</div>';
        fetch('/Quotation/SearchProducts?keyword=' + encodeURIComponent(kw))
            .then(function (r) { return r.json(); })
            .then(function (data) {
                if (apActiveQuery !== kw) return;
                if (!data || data.length === 0) {
                    box.innerHTML = '<div class="p-3 text-muted small text-center">Không tìm thấy sản phẩm</div>';
                    return;
                }
                box.innerHTML = data.map(function (p) {
                    var img = p.ImageUrl
                        ? '<img src="' + escapeHtmlAp(p.ImageUrl) + '" style="width:40px;height:40px;object-fit:cover;border-radius:4px;margin-right:8px;" />'
                        : '<div style="width:40px;height:40px;background:#f1f5f9;border-radius:4px;margin-right:8px;display:flex;align-items:center;justify-content:center;"><i class="bi bi-image text-muted"></i></div>';
                    var meta = escapeHtmlAp(p.ProductCode) + ' &bull; ' + escapeHtmlAp(p.UnitName || '');
                    return '<div class="ap-result-item d-flex align-items-center p-2 border-bottom" ' +
                           'style="cursor:pointer;" ' +
                           'onclick="selectAssignProduct(' + p.ProductId + ', ' +
                                JSON.stringify(p.ProductName).replace(/"/g, '&quot;') + ', ' +
                                JSON.stringify(meta).replace(/"/g, '&quot;') + ')">' +
                           img +
                           '<div class="flex-grow-1">' +
                                '<div class="fw-semibold small">' + escapeHtmlAp(p.ProductName) + '</div>' +
                                '<div class="text-muted" style="font-size:0.72rem;">' + meta + '</div>' +
                           '</div>' +
                           '</div>';
                }).join('');
            })
            .catch(function () {
                box.innerHTML = '<div class="p-3 text-danger small text-center">Lỗi tìm kiếm</div>';
            });
    }

    function selectAssignProduct(productId, productName, meta) {
        document.getElementById('apProductId').value = productId;
        document.getElementById('apSelectedName').textContent = productName;
        document.getElementById('apSelectedMeta').innerHTML = meta;
        document.getElementById('apSelectedBox').classList.remove('d-none');
        document.getElementById('apSubmitBtn').disabled = false;
        // Highlight selected row
        document.querySelectorAll('.ap-result-item').forEach(function (el) { el.classList.remove('bg-primary-subtle'); });
        if (window.event && window.event.currentTarget) {
            window.event.currentTarget.classList.add('bg-primary-subtle');
        }
    }

    function submitAssignProduct() {
        var soItemId = parseInt(document.getElementById('apSoItemId').value);
        var productId = parseInt(document.getElementById('apProductId').value);
        if (!productId) { appAlert('Vui lòng chọn sản phẩm'); return; }

        var btn = document.getElementById('apSubmitBtn');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Đang gán...';

        postAction('/SalesOrder/AssignProduct/' + soId, { SOItemId: soItemId, ProductId: productId }, function (data) {
            if (data.Success) {
                bootstrap.Modal.getInstance(document.getElementById('assignProductModal')).hide();
                location.reload();
            } else {
                appAlert(data.Message || 'Lỗi gán sản phẩm');
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-check-lg me-1"></i> Gán sản phẩm';
            }
        });
    }

    function escapeHtmlAp(s) {
        if (s == null) return '';
        return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    // ── Gallery preview for product modal ─────────────
    function previewCpGallery(input) {
        var container = document.getElementById('cp-gallery-preview');
        container.innerHTML = '';
        document.getElementById('cp-avatar-index').value = '0';
        if (!input.files || input.files.length === 0) return;

        Array.from(input.files).forEach(function (file, idx) {
            var reader = new FileReader();
            reader.onload = function (e) {
                var wrap = document.createElement('div');
                wrap.className = 'position-relative';
                wrap.dataset.idx = idx;
                wrap.style.cssText = 'width:80px;height:80px;cursor:pointer;';
                wrap.title = 'Nhấn để đặt làm ảnh đại diện';
                wrap.onclick = function () { setCpAvatar(idx); };

                var img = document.createElement('img');
                img.src = e.target.result;
                img.style.cssText = 'width:100%;height:100%;object-fit:cover;border-radius:6px;border:2px solid ' + (idx === 0 ? '#2563eb' : '#e2e8f0') + ';';
                img.dataset.idx = idx;
                wrap.appendChild(img);

                if (idx === 0) {
                    var badge = document.createElement('span');
                    badge.className = 'position-absolute top-0 start-0 badge bg-primary cp-avatar-badge';
                    badge.style.cssText = 'font-size:0.55rem;border-radius:6px 0 4px 0!important;pointer-events:none;';
                    badge.textContent = 'Avatar';
                    wrap.appendChild(badge);
                }
                container.appendChild(wrap);
            };
            reader.readAsDataURL(file);
        });
    }

    function setCpAvatar(idx) {
        document.getElementById('cp-avatar-index').value = idx;
        document.querySelectorAll('.cp-avatar-badge').forEach(function(b) { b.remove(); });
        document.querySelectorAll('#cp-gallery-preview img').forEach(function (img) {
            img.style.border = img.dataset.idx == idx ? '2px solid #2563eb' : '2px solid #e2e8f0';
        });
        var target = document.querySelector('#cp-gallery-preview [data-idx="' + idx + '"]');
        if (target) {
            var badge = document.createElement('span');
            badge.className = 'position-absolute top-0 start-0 badge bg-primary cp-avatar-badge';
            badge.style.cssText = 'font-size:0.55rem;border-radius:6px 0 4px 0!important;pointer-events:none;';
            badge.textContent = 'Avatar';
            target.appendChild(badge);
        }
    }

    // ── WAIT → BUYING ───────────────────────────────
    function showBuyingModal() {
        recalcBuying();
        new bootstrap.Modal(document.getElementById('buyingModal')).show();
    }

    function recalcBuying() {
        var total = 0;
        document.querySelectorAll('#buyingItemsBody .purchase-price-cell').forEach(function (cell) {
            var price = parseFloat(cell.dataset.price) || 0;
            var qty = parseFloat(cell.dataset.qty) || 0;
            var cost = price * qty;
            total += cost;
            cell.closest('tr').querySelector('.line-cost-cell').textContent = cost.toLocaleString('vi-VN');
        });
        document.getElementById('totalPurchaseCost').textContent = total.toLocaleString('vi-VN');
    }

    // Check-all toggle for buying modal
    document.getElementById('buyingCheckAll')?.addEventListener('change', function (e) {
        document.querySelectorAll('#buyingItemsBody .buying-include').forEach(function (cb) { cb.checked = e.target.checked; });
    });

    function confirmBuying() {
        var items = [];
        var checkedAny = false;
        var missingDate = false;
        document.querySelectorAll('#buyingItemsBody tr').forEach(function (tr) {
            var itemId = parseInt(tr.dataset.itemId);
            var include = tr.querySelector('.buying-include').checked;
            if (include) checkedAny = true;
            var priceCell = tr.querySelector('.purchase-price-cell');
            var sourceUrlEl = tr.querySelector('.source-url-input');
            var expRecvEl = tr.querySelector('.expected-receive-input');
            if (include && (!expRecvEl || !expRecvEl.value)) {
                missingDate = true;
                if (expRecvEl) expRecvEl.classList.add('is-invalid');
            } else if (expRecvEl) {
                expRecvEl.classList.remove('is-invalid');
            }
            items.push({
                SOItemId: itemId,
                IncludeInBatch: include,
                PurchasePrice: priceCell ? (parseFloat(priceCell.dataset.price) || 0) : 0,
                SourceName: null,
                SourceUrl: sourceUrlEl ? sourceUrlEl.value.trim() : null,
                ExpectedReceiveDate: expRecvEl && expRecvEl.value ? expRecvEl.value : null
            });
        });

        if (!checkedAny) { appAlert('Tích chọn ít nhất 1 dòng để bắt đầu mua'); return; }

        if (missingDate) { appAlert('Vui lòng nhập "Dự kiến về" cho các dòng đã chọn'); return; }

        var body = {
            PurchaseSource: null,
            BuyingNotes: document.getElementById('inputBuyingNotes').value.trim(),
            Items: items
        };

        postAction('/SalesOrder/StartBuying/' + soId, body, function (data) {
            if (data.Success) location.reload();
            else appAlert(data.Message || 'Lỗi');
        });
    }

    // ══════════════════════════════════════════════════
    // PER-LINE: Edit / Cancel / Receive (single + batch) / Deliver (single + batch)
    // ══════════════════════════════════════════════════
    var soItemsCache = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        Model.Items.Select(i => new {
            id = i.SOItemId,
            name = i.ProductName,
            qty = i.Quantity,
            cancelledQty = i.CancelledQty,
            receivedQty = i.ReceivedQty,
            deliveredQty = i.DeliveredQty,
            remainingReceive = i.RemainingReceiveQty,
            inStock = i.InStockQty,
            price = i.PurchasePrice,
            sourceName = i.SourceName,
            sourceUrl = i.SourceUrl,
            expReceive = i.ExpectedReceiveDate?.ToString("yyyy-MM-dd"),
            expDeliver = i.ExpectedDeliveryDate?.ToString("yyyy-MM-dd"),
            notes = i.Notes
        })));
    function findItem(id) { return soItemsCache.find(function (i) { return i.id === id; }); }

    // ── Edit purchase info ───────────────────────────
    function openEditItemModal(soItemId) {
        var it = findItem(soItemId); if (!it) return;
        document.getElementById('editItemId').value = soItemId;
        document.getElementById('editItemLabel').textContent = '— ' + it.name;
        document.getElementById('editItemExpReceive').value = it.expReceive ?? '';
        document.getElementById('editItemExpDeliver').value = it.expDeliver ?? '';
        new bootstrap.Modal(document.getElementById('editItemModal')).show();
    }
    function confirmEditItem() {
        var id = parseInt(document.getElementById('editItemId').value);
        var body = {
            ExpectedReceiveDate: document.getElementById('editItemExpReceive').value || null,
            ExpectedDeliveryDate: document.getElementById('editItemExpDeliver').value || null
        };
        postAction('/SalesOrder/UpdateItemPurchase/' + soId + '?soItemId=' + id, body, function (data) {
            if (data.Success) location.reload(); else appAlert(data.Message || 'Lỗi');
        });
    }

    // ── Cancel line ──────────────────────────────────
    function openCancelItemModal(soItemId) {
        var it = findItem(soItemId); if (!it) return;
        var maxCancel = it.qty - it.cancelledQty - it.receivedQty;
        document.getElementById('cancelItemId').value = soItemId;
        document.getElementById('cancelItemLabel').textContent = '— ' + it.name;
        document.getElementById('cancelItemQty').value = '';
        document.getElementById('cancelItemQty').max = maxCancel;
        document.getElementById('cancelItemMax').textContent = '/ tối đa ' + maxCancel.toLocaleString('vi-VN');
        document.getElementById('cancelItemReason').value = '';
        new bootstrap.Modal(document.getElementById('cancelItemModal')).show();
    }
    function confirmCancelItem() {
        var id = parseInt(document.getElementById('cancelItemId').value);
        var qtyVal = document.getElementById('cancelItemQty').value;
        var body = {
            CancelQty: qtyVal ? parseFloat(qtyVal) : null,
            Reason: document.getElementById('cancelItemReason').value.trim()
        };
        postAction('/SalesOrder/CancelItem/' + soId + '?soItemId=' + id, body, function (data) {
            if (data.Success) location.reload(); else appAlert(data.Message || 'Lỗi');
        });
    }

    // ── Receive (single line) — opens batch modal with only this row checked ─
    function openReceiveItemModal(soItemId) {
        var modal = document.getElementById('receiveBatchModal');
        modal.querySelectorAll('.recv-include').forEach(function (cb) {
            cb.checked = (!cb.disabled && parseInt(cb.closest('tr').dataset.itemId) === soItemId);
        });
        document.getElementById('recvBatchDate').value = new Date().toISOString().slice(0, 10);
        new bootstrap.Modal(modal).show();
    }
    function showReceiveBatchModal() {
        var modal = document.getElementById('receiveBatchModal');
        modal.querySelectorAll('.recv-include').forEach(function (cb) { if (!cb.disabled) cb.checked = true; });
        document.getElementById('recvBatchDate').value = new Date().toISOString().slice(0, 10);
        new bootstrap.Modal(modal).show();
    }
    document.getElementById('recvBatchCheckAll')?.addEventListener('change', function (e) {
        document.querySelectorAll('#recvBatchBody .recv-include').forEach(function (cb) { if (!cb.disabled) cb.checked = e.target.checked; });
    });
    function confirmReceiveBatch() {
        var rows = document.querySelectorAll('#recvBatchBody tr');
        var items = [];
        var bad = null;
        rows.forEach(function (tr) {
            var inc = tr.querySelector('.recv-include');
            if (!inc.checked || inc.disabled) return;
            var soItemId = parseInt(tr.dataset.itemId);
            var max = parseFloat(tr.dataset.max);
            var qty = parseFloat(tr.querySelector('.recv-qty').value);
            if (!qty || qty <= 0) { bad = 'Số lượng phải > 0'; return; }
            if (qty > max) { bad = 'SL nhập (' + qty + ') vượt quá còn cần nhận (' + max + ')'; return; }
            items.push({ SOItemId: soItemId, Quantity: qty });
        });
        if (bad) { appAlert(bad); return; }
        if (items.length === 0) { appAlert('Chưa chọn dòng nào'); return; }

        var body = {
            WarehouseId: 0,
            TransactionDate: document.getElementById('recvBatchDate').value || null,
            Notes: document.getElementById('recvBatchNotes').value.trim(),
            Items: items
        };
        postAction('/SalesOrder/ReceiveBatch/' + soId, body, function (data) {
            if (data.Success) {
                appAlert(data.Message || 'Đã tạo phiếu nhập').then(function () { location.reload(); });
            } else appAlert(data.Message || 'Lỗi');
        });
    }

    // ── Deliver (single line) — opens batch modal with only this row checked ─
    function openDeliverItemModal(soItemId) {
        var modal = document.getElementById('deliverBatchModal');
        modal.querySelectorAll('.deliv-include').forEach(function (cb) {
            cb.checked = (!cb.disabled && parseInt(cb.closest('tr').dataset.itemId) === soItemId);
        });
        document.getElementById('delivBatchDate').value = new Date().toISOString().slice(0, 10);
        new bootstrap.Modal(modal).show();
    }
    function showDeliverBatchModal() {
        var modal = document.getElementById('deliverBatchModal');
        modal.querySelectorAll('.deliv-include').forEach(function (cb) { if (!cb.disabled) cb.checked = true; });
        document.getElementById('delivBatchDate').value = new Date().toISOString().slice(0, 10);
        new bootstrap.Modal(modal).show();
    }
    document.getElementById('delivBatchCheckAll')?.addEventListener('change', function (e) {
        document.querySelectorAll('#delivBatchBody .deliv-include').forEach(function (cb) { if (!cb.disabled) cb.checked = e.target.checked; });
    });
    function confirmDeliverBatch() {
        var rows = document.querySelectorAll('#delivBatchBody tr');
        var items = [];
        var bad = null;
        rows.forEach(function (tr) {
            var inc = tr.querySelector('.deliv-include');
            if (!inc.checked || inc.disabled) return;
            var soItemId = parseInt(tr.dataset.itemId);
            var max = parseFloat(tr.dataset.max);
            var qty = parseFloat(tr.querySelector('.deliv-qty').value);
            if (!qty || qty <= 0) { bad = 'Số lượng phải > 0'; return; }
            if (qty > max) { bad = 'SL giao (' + qty + ') vượt quá SL có thể giao (' + max + ')'; return; }
            items.push({ SOItemId: soItemId, Quantity: qty });
        });
        if (bad) { appAlert(bad); return; }
        if (items.length === 0) { appAlert('Chưa chọn dòng nào'); return; }

        var body = {
            WarehouseId: 0,
            TransactionDate: document.getElementById('delivBatchDate').value || null,
            ReceiverName: document.getElementById('delivBatchReceiver').value.trim(),
            ReceiverPhone: document.getElementById('delivBatchReceiverPhone').value.trim(),
            DeliveryNote: document.getElementById('delivBatchNotes').value.trim(),
            Notes: document.getElementById('delivBatchNotes').value.trim(),
            Items: items
        };
        postAction('/SalesOrder/DeliverBatch/' + soId, body, function (data) {
            if (data.Success) {
                appAlert(data.Message || 'Đã tạo phiếu xuất').then(function () { location.reload(); });
            } else appAlert(data.Message || 'Lỗi');
        });
    }

    // ── DELIVERED|RETURNED → COMPLETED (Kế toán duyệt quyết toán + nhập số HĐ đầu ra) ──
    function openCompleteModal() {
        document.getElementById('completeOutputInvoiceNo').value = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.OutputInvoiceNo ?? ""));
        document.getElementById('completeSettlementNotes').value = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SettlementNotes ?? ""));
