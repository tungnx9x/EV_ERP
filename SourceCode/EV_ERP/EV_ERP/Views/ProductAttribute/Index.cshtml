@model EV_ERP.Models.ViewModels.Products.ProductAttributeListViewModel
@{
    ViewData["Title"] = "Thuộc tính sản phẩm";
    ViewData["Breadcrumbs"] = new List<BreadcrumbItem>
    {
        new("Trang chủ", "/"),
        new("Sản phẩm", "/Product"),
        new("Thuộc tính")
    };
    var paged = Model.Paged;
}

<div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
    <h5 class="mb-0 fw-bold">
        <i class="bi bi-tags me-2"></i>Thuộc tính sản phẩm
        <span class="badge bg-secondary-subtle text-secondary-emphasis ms-1" style="font-size:0.7rem;">@paged.TotalCount</span>
    </h5>
    <a href="/ProductAttribute/Create" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i> Thêm thuộc tính
    </a>
</div>

<!-- Search -->
<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-6">
                <input name="keyword" value="@Model.SearchKeyword" class="form-control form-control-sm"
                       placeholder="Tìm theo tên hoặc mã..." />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-search me-1"></i> Tìm
                </button>
                @if (!string.IsNullOrEmpty(Model.SearchKeyword))
                {
                    <a href="/ProductAttribute" class="btn btn-sm btn-outline-secondary ms-1">Xóa lọc</a>
                }
            </div>
        </form>
    </div>
</div>

<!-- Table -->
<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0" style="font-size:0.85rem;">
            <thead class="table-light">
                <tr>
                    <th>Mã</th>
                    <th>Tên thuộc tính</th>
                    <th class="text-center">Kiểu</th>
                    <th class="text-center">Trạng thái</th>
                    <th class="text-end"></th>
                </tr>
            </thead>
            <tbody>
                @if (!paged.Items.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center py-4 text-muted">
                            <i class="bi bi-tags" style="font-size:2rem;opacity:.3;"></i>
                            <p class="small mt-2 mb-0">Chưa có thuộc tính nào</p>
                        </td>
                    </tr>
                }
                @foreach (var attr in paged.Items)
                {
                    <tr id="attr-row-@attr.AttributeId">
                        <td><span class="font-monospace fw-semibold">@attr.AttrCode</span></td>
                        <td>
                            <a href="/ProductAttribute/Edit/@attr.AttributeId" class="text-decoration-none fw-semibold">
                                @attr.AttributeName
                            </a>
                        </td>
                        <td class="text-center">
                            <span class="@(attr.DataType == "LIST" ? "bg-primary-subtle text-primary-emphasis" : "bg-warning-subtle text-warning-emphasis")">
                                @attr.DataType
                            </span>
                        </td>
                        <td class="text-center">
                            <span class="@(attr.IsActive ? "bg-success-subtle text-success-emphasis" : "bg-secondary-subtle text-secondary-emphasis") rounded-pill">
                                @(attr.IsActive ? "Hoạt động" : "Vô hiệu")
                            </span>
                        </td>
                        <td class="text-end">
                            <a href="/ProductAttribute/Edit/@attr.AttributeId" class="btn btn-sm btn-outline-primary me-1" title="Chỉnh sửa">
                                <i class="bi bi-pencil"></i>
                            </a>
                            @* <button class="btn btn-sm @(attr.IsActive ? "btn-outline-secondary" : "btn-outline-success")"
                                    onclick="toggleAttrActive(@attr.AttributeId)" title="@(attr.IsActive ? "Vô hiệu hóa" : "Kích hoạt")">
                                <i class="bi @(attr.IsActive ? "bi-toggle-on" : "bi-toggle-off")"></i>
                            </button> *@
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (paged.TotalPages > 1)
    {
        <nav class="d-flex justify-content-center py-3 border-top">
            <ul class="pagination pagination-sm mb-0">
                @if (paged.HasPrevious)
                {
                    <li class="page-item">
                        <a class="page-link" href="@BuildPageUrl(paged.PageIndex - 1)">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                }
                @for (int pg = 1; pg <= paged.TotalPages; pg++)
                {
                    <li class="page-item @(pg == paged.PageIndex ? "active" : "")">
                        <a class="page-link" href="@BuildPageUrl(pg)">@pg</a>
                    </li>
                }
                @if (paged.HasNext)
                {
                    <li class="page-item">
                        <a class="page-link" href="@BuildPageUrl(paged.PageIndex + 1)">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>

@functions {
    string BuildPageUrl(int page)
    {
        var qs = new Dictionary<string, string?> {
            ["keyword"] = Model.SearchKeyword,
            ["page"] = page.ToString()
        };
        return "/ProductAttribute?" + string.Join("&", qs.Where(kv => kv.Value != null).Select(kv => $"{kv.Key}={kv.Value}"));
    }
}

