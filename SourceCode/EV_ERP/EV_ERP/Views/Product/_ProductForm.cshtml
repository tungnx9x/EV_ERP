@model EV_ERP.Models.ViewModels.Products.ProductFormViewModel

<!-- Section: Thông tin cơ bản -->
<h6 class="fw-semibold text-muted text-uppercase mb-3" style="font-size:0.75rem;letter-spacing:.06em;">
    <i class="bi bi-info-circle me-1"></i> Thông tin cơ bản
</h6>
<div class="row g-3 mb-4">
    <div class="col-12">
        <label asp-for="ProductName" class="form-label fw-semibold small"></label>
        <input asp-for="ProductName" class="form-control"
               placeholder="VD: Khăn tắm cotton 500g" autofocus />
        <span asp-validation-for="ProductName" class="text-danger small"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="CategoryId" class="form-label fw-semibold small"></label>
        <input type="hidden" asp-for="CategoryId" id="CategoryId" />
        <div class="ts-wrap position-relative" id="treeSelectWrap">
            <div class="ts-trigger form-select d-flex align-items-center" onclick="tsToggle()" id="tsTrigger">
                <span class="ts-selected-text flex-grow-1" id="tsSelectedText">-- Chọn danh mục --</span>
                <i class="bi bi-chevron-down ts-arrow" id="tsArrow" style="font-size:0.7rem;transition:transform .2s;"></i>
            </div>
            <div class="ts-dropdown" id="tsDropdown" style="display:none;">
                <div class="ts-search-box">
                    <input type="text" class="form-control form-control-sm" id="tsSearch"
                           placeholder="Tìm danh mục..." autocomplete="off" />
                </div>
                <div class="ts-tree" id="tsTree"></div>
                <div class="ts-empty text-muted text-center py-2 small" id="tsEmpty" style="display:none;">
                    Không tìm thấy danh mục
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <label asp-for="UnitId" class="form-label fw-semibold small"></label>
        <select asp-for="UnitId" class="form-select">
            <option value="">-- Chọn ĐVT --</option>
            @foreach (var u in Model.Units)
            {
                <option value="@u.UnitId">@u.UnitName (@u.UnitCode)</option>
            }
        </select>
        <span asp-validation-for="UnitId" class="text-danger small"></span>
    </div>

    <div class="col-12">
        <label asp-for="Description" class="form-label fw-semibold small"></label>
        <textarea asp-for="Description" class="form-control" rows="3"
                  placeholder="Mô tả chi tiết sản phẩm..."></textarea>
    </div>
</div>

<!-- Section: Giá & Kho -->
<h6 class="fw-semibold text-muted text-uppercase mb-3" style="font-size:0.75rem;letter-spacing:.06em;">
    <i class="bi bi-cash-coin me-1"></i> Giá & Tồn kho
</h6>
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <label asp-for="DefaultSalePrice" class="form-label fw-semibold small"></label>
        <div class="input-group">
            <input asp-for="DefaultSalePrice" class="form-control" type="number" min="0"
                   placeholder="VD: 150000" />
            <span class="input-group-text">₫</span>
        </div>
        <span asp-validation-for="DefaultSalePrice" class="text-danger small"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="DefaultPurchasePrice" class="form-label fw-semibold small"></label>
        <div class="input-group">
            <input asp-for="DefaultPurchasePrice" class="form-control" type="number" min="0" 
                   placeholder="VD: 100000" />
            <span class="input-group-text">₫</span>
        </div>
        <span asp-validation-for="DefaultPurchasePrice" class="text-danger small"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="MinStockLevel" class="form-label fw-semibold small"></label>
        <input asp-for="MinStockLevel" class="form-control" type="number" min="0"
               placeholder="VD: 10" />
        <span asp-validation-for="MinStockLevel" class="text-danger small"></span>
    </div>
</div>

<!-- Section: Barcode -->
<h6 class="fw-semibold text-muted text-uppercase mb-3" style="font-size:0.75rem;letter-spacing:.06em;">
    <i class="bi bi-upc-scan me-1"></i> Barcode
</h6>
<div class="row g-3 mb-4">
    <div class="col-md-6">
        <label asp-for="Barcode" class="form-label fw-semibold small"></label>
        <input asp-for="Barcode" class="form-control font-monospace"
               placeholder="Để trống để tự động tạo từ SKU" />
        <div class="form-text small">Để trống — hệ thống tự tạo Code 128 từ mã SKU</div>
    </div>
    <div class="col-md-6">
        <label asp-for="BarcodeType" class="form-label fw-semibold small"></label>
        <input type="hidden" asp-for="BarcodeType" value="CODE128" />
        <input type="text" class="form-control" value="Code 128" disabled />
        <div class="form-text small">Mặc định Code 128</div>
    </div>
</div>

<!-- Section: SKU & Thuộc tính -->
<h6 class="fw-semibold text-muted text-uppercase mb-3" style="font-size:0.75rem;letter-spacing:.06em;">
    <i class="bi bi-tags me-1"></i> Thuộc tính & SKU
</h6>
@if (Model.IsEditMode && !string.IsNullOrEmpty(Model.SKU))
{
    <div class="alert alert-info py-2 small mb-3">
        <i class="bi bi-key me-1"></i> <strong>SKU:</strong>
        <span class="font-monospace fw-semibold">@Model.SKU</span>
        <span class="text-muted ms-2">(tự động tạo từ danh mục + thuộc tính)</span>
    </div>
}
<div id="sku-attributes-container" class="row g-3 mb-3">
    @if (Model.SkuAttributes.Any())
    {
        foreach (var attr in Model.SkuAttributes)
        {
            <div class="col-md-4">
                <label class="form-label fw-semibold small">
                    @attr.AttributeName
                    @if (attr.IsRequired) { <span class="text-danger">*</span> }
                    <span class="text-muted font-monospace" style="font-size:0.7rem;">(@attr.AttrCode)</span>
                </label>
                @if (attr.DataType == "LIST")
                {
                    <select name="AttributeValues[@attr.AttributeId]" class="form-select form-select-sm sku-attr-select">
                        <option value="">-- Chọn --</option>
                        @foreach (var val in attr.Values)
                        {
                            <option value="@val.ValueId"
                                    data-skucode="@val.SkuCode"
                                    selected="@(val.ValueId == attr.SelectedValueId)">
                                @val.ValueName (@val.SkuCode)
                            </option>
                        }
                    </select>
                }
                else
                {
                    <input type="text" name="AttributeValues[@attr.AttributeId]"
                           value="@attr.TextValue"
                           class="form-control form-control-sm"
                           placeholder="Nhập giá trị..." />
                }
            </div>
        }
    }
    else if (!Model.IsEditMode)
    {
        <div class="col-12 text-muted small" id="sku-attr-placeholder">
            <i class="bi bi-info-circle me-1"></i> Chọn danh mục để hiển thị thuộc tính SKU
        </div>
    }
</div>
<div id="sku-preview" class="mb-4" style="display:none;">
    <span class="text-muted small">SKU Preview: </span>
    <span class="font-monospace fw-semibold text-primary" id="sku-preview-text"></span>
</div>

<!-- Section: Thông tin bổ sung -->
<h6 class="fw-semibold text-muted text-uppercase mb-3" style="font-size:0.75rem;letter-spacing:.06em;">
    <i class="bi bi-box me-1"></i> Thông tin bổ sung
</h6>
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <label asp-for="SourceUrl" class="form-label fw-semibold small"></label>
        <input asp-for="SourceUrl" class="form-control" placeholder="https://shopee.vn/..." />
    </div>
    <div class="col-md-4">
        <label asp-for="Weight" class="form-label fw-semibold small"></label>
        <input asp-for="Weight" class="form-control" type="number" min="0" step="0.001"
               placeholder="VD: 0.5" />
    </div>
    <div class="col-md-4">
        <label asp-for="WeightUnit" class="form-label fw-semibold small"></label>
        <select asp-for="WeightUnit" class="form-select">
            <option value="">-- Chọn --</option>
            <option value="kg">Kilogram (kg)</option>
            <option value="g">Gram (g)</option>
        </select>
    </div>
    <div class="col-md-4 d-flex align-items-end">
        <div class="form-check form-switch mb-2">
            <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" />
            <label asp-for="IsActive" class="form-check-label small fw-semibold"></label>
        </div>
    </div>
</div>

<!-- TreeSelect Styles -->
<style>
    .ts-wrap { position: relative; }
    .ts-trigger {
        cursor: pointer;
        background: #fff;
        min-height: 38px;
        font-size: 0.875rem;
        user-select: none;
    }
    .ts-trigger:hover { border-color: #86b7fe; }
    .ts-trigger.ts-open { border-color: #86b7fe; box-shadow: 0 0 0 .25rem rgba(13,110,253,.25); }
    .ts-trigger.ts-open .ts-arrow { transform: rotate(180deg); }
    .ts-selected-text { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .ts-selected-text.ts-placeholder { color: #6c757d; }
    .ts-dropdown {
        position: absolute; top: 100%; left: 0; right: 0;
        background: #fff; border: 1px solid #dee2e6;
        border-radius: 0 0 8px 8px; box-shadow: 0 6px 16px rgba(0,0,0,.12);
        z-index: 1060; margin-top: -1px;
    }
    .ts-search-box { padding: 8px; border-bottom: 1px solid #f0f0f0; }
    .ts-search-box input { border-radius: 6px; }
    .ts-tree {
        max-height: 280px; overflow-y: auto; padding: 4px 0;
    }
    .ts-node {
        display: flex; align-items: center; padding: 6px 12px;
        cursor: pointer; font-size: 0.84rem; color: #1c1e21;
        transition: background .1s;
    }
    .ts-node:hover { background: #f5f5f5; }
    .ts-node.ts-active { background: #e6f4ff; color: #1677ff; }
    .ts-node.ts-highlighted { background: #f0f0f0; }
    .ts-node-indent { display: inline-block; width: 20px; flex-shrink: 0; }
    .ts-node-toggle {
        width: 20px; height: 20px; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer; border-radius: 4px; font-size: 0.65rem; color: #8c8c8c;
        transition: background .1s;
    }
    .ts-node-toggle:hover { background: #e0e0e0; }
    .ts-node-toggle.ts-expanded i { transform: rotate(90deg); }
    .ts-node-toggle i { transition: transform .2s; }
    .ts-node-leaf { width: 20px; flex-shrink: 0; }
    .ts-node-icon { margin-right: 6px; color: #faad14; font-size: 0.8rem; }
    .ts-node-icon.ts-folder { color: #faad14; }
    .ts-node-icon.ts-leaf-icon { color: #1677ff; }
    .ts-node-label { flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .ts-node-code {
        font-size: 0.7rem; color: #8c8c8c; margin-left: 6px;
        font-family: monospace; flex-shrink: 0;
    }
    .ts-highlight { background: #fff3cd; border-radius: 2px; padding: 0 1px; }
    .ts-clear {
        cursor: pointer; color: #bfbfbf; font-size: 0.8rem;
        margin-right: 6px; display: none;
    }
    .ts-clear:hover { color: #595959; }
</style>

<script>
(function () {
    // ── TreeSelect Data ──
    var tsData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Categories, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = null }));
    var tsSelectedId = @(Model.CategoryId.HasValue ? Model.CategoryId.Value.ToString() : "null");
    var tsOpen = false;
    var tsExpandedIds = {};
    var tsHighlightIdx = -1;
    var tsVisibleNodes = [];

    // Build parent-child lookup
    var tsChildrenMap = {};
    tsData.forEach(function (n) {
        var pid = n.ParentCategoryId || 0;
        if (!tsChildrenMap[pid]) tsChildrenMap[pid] = [];
        tsChildrenMap[pid].push(n);
    });

    // Auto-expand path to selected node
    if (tsSelectedId) {
        var sel = tsData.find(function (n) { return n.CategoryId === tsSelectedId; });
        if (sel) {
            expandPathTo(sel);
            updateTriggerText(sel);
        }
    }

    function expandPathTo(node) {
        var cur = node;
        while (cur && cur.ParentCategoryId) {
            tsExpandedIds[cur.ParentCategoryId] = true;
            cur = tsData.find(function (n) { return n.CategoryId === cur.ParentCategoryId; });
        }
    }

    function updateTriggerText(node) {
        var textEl = document.getElementById('tsSelectedText');
        if (node) {
            // Build full path
            var path = [];
            var cur = node;
            while (cur) {
                path.unshift(cur.CategoryName);
                cur = cur.ParentCategoryId ? tsData.find(function (n) { return n.CategoryId === cur.ParentCategoryId; }) : null;
            }
            textEl.textContent = path.join(' / ');
            textEl.classList.remove('ts-placeholder');
        } else {
            textEl.textContent = '-- Chọn danh mục --';
            textEl.classList.add('ts-placeholder');
        }
    }

    // ── Render tree ──
    function renderTree(searchQuery) {
        var tree = document.getElementById('tsTree');
        var empty = document.getElementById('tsEmpty');
        var q = (searchQuery || '').trim().toLowerCase();

        // Determine visible node IDs based on search
        var matchIds = {};
        var visibleIds = {};

        if (q) {
            tsData.forEach(function (n) {
                var nameMatch = n.CategoryName.toLowerCase().indexOf(q) >= 0;
                var codeMatch = n.CategoryCode.toLowerCase().indexOf(q) >= 0;
                if (nameMatch || codeMatch) {
                    matchIds[n.CategoryId] = true;
                    // Make all ancestors visible
                    var cur = n;
                    while (cur) {
                        visibleIds[cur.CategoryId] = true;
                        cur = cur.ParentCategoryId ? tsData.find(function (x) { return x.CategoryId === cur.ParentCategoryId; }) : null;
                    }
                }
            });
        }

        tsVisibleNodes = [];
        var html = '';

        function renderNode(node, depth) {
            if (q && !visibleIds[node.CategoryId]) return;

            tsVisibleNodes.push(node);
            var isActive = node.CategoryId === tsSelectedId;
            var isMatch = matchIds[node.CategoryId];
            var isExpanded = q ? true : !!tsExpandedIds[node.CategoryId];
            var children = tsChildrenMap[node.CategoryId] || [];
            var hasVisibleChildren = q ? children.some(function (c) { return visibleIds[c.CategoryId]; }) : children.length > 0;

            html += '<div class="ts-node' + (isActive ? ' ts-active' : '') + '" data-id="' + node.CategoryId + '">';

            // Indentation
            for (var i = 0; i < depth; i++) {
                html += '<span class="ts-node-indent"></span>';
            }

            // Toggle or leaf spacer
            if (hasVisibleChildren) {
                html += '<span class="ts-node-toggle' + (isExpanded ? ' ts-expanded' : '') + '" data-toggle="' + node.CategoryId + '">';
                html += '<i class="bi bi-caret-right-fill"></i>';
                html += '</span>';
            } else {
                html += '<span class="ts-node-leaf"></span>';
            }

            // Icon
            if (node.HasChildren) {
                html += '<i class="bi bi-folder-fill ts-node-icon ts-folder"></i>';
            } else {
                html += '<i class="bi bi-tag-fill ts-node-icon ts-leaf-icon"></i>';
            }

            // Label
            var label = node.CategoryName;
            if (q && isMatch) {
                var regex = new RegExp('(' + escapeRegex(q) + ')', 'gi');
                label = label.replace(regex, '<span class="ts-highlight">$1</span>');
            }
            html += '<span class="ts-node-label">' + label + '</span>';
            html += '<span class="ts-node-code">' + node.CategoryCode + '</span>';
            html += '</div>';

            // Children
            if (isExpanded && hasVisibleChildren) {
                children.forEach(function (child) {
                    renderNode(child, depth + 1);
                });
            }
        }

        (tsChildrenMap[0] || []).forEach(function (root) {
            renderNode(root, 0);
        });

        tree.innerHTML = html;
        empty.style.display = tsVisibleNodes.length === 0 ? '' : 'none';
        tsHighlightIdx = -1;

        // Bind click events
        tree.querySelectorAll('.ts-node').forEach(function (el) {
            el.addEventListener('click', function (e) {
                if (e.target.closest('.ts-node-toggle')) return;
                var id = parseInt(el.dataset.id);
                tsSelect(id);
            });
        });
        tree.querySelectorAll('.ts-node-toggle').forEach(function (el) {
            el.addEventListener('click', function (e) {
                e.stopPropagation();
                var id = parseInt(el.dataset.toggle);
                tsExpandedIds[id] = !tsExpandedIds[id];
                renderTree(searchQuery);
            });
        });
    }

    function tsSelect(id) {
        tsSelectedId = id;
        document.getElementById('CategoryId').value = id;
        var node = tsData.find(function (n) { return n.CategoryId === id; });
        updateTriggerText(node);
        tsClose();
        // Trigger category change for SKU attributes
        loadSkuAttributes(id);
    }

    // ── Open/Close ──
    window.tsToggle = function () {
        if (tsOpen) tsClose();
        else tsOpenDropdown();
    };

    function tsOpenDropdown() {
        tsOpen = true;
        document.getElementById('tsDropdown').style.display = '';
        document.getElementById('tsTrigger').classList.add('ts-open');
        var searchInput = document.getElementById('tsSearch');
        searchInput.value = '';
        renderTree('');
        setTimeout(function () { searchInput.focus(); }, 50);

        // Scroll to active node
        setTimeout(function () {
            var active = document.querySelector('.ts-node.ts-active');
            if (active) active.scrollIntoView({ block: 'nearest' });
        }, 60);
    }

    function tsClose() {
        tsOpen = false;
        document.getElementById('tsDropdown').style.display = 'none';
        document.getElementById('tsTrigger').classList.remove('ts-open');
    }

    // Close on outside click
    document.addEventListener('mousedown', function (e) {
        if (tsOpen && !e.target.closest('#treeSelectWrap')) {
            tsClose();
        }
    });

    // ── Search ──
    document.getElementById('tsSearch').addEventListener('input', function () {
        renderTree(this.value);
    });

    // ── Keyboard navigation ──
    document.getElementById('tsSearch').addEventListener('keydown', function (e) {
        if (!tsOpen) return;
        var nodes = document.querySelectorAll('.ts-node');

        if (e.key === 'ArrowDown') {
            e.preventDefault();
            tsHighlightIdx = Math.min(tsHighlightIdx + 1, nodes.length - 1);
            updateHighlight(nodes);
        } else if (e.key === 'ArrowUp') {
            e.preventDefault();
            tsHighlightIdx = Math.max(tsHighlightIdx - 1, 0);
            updateHighlight(nodes);
        } else if (e.key === 'Enter') {
            e.preventDefault();
            if (tsHighlightIdx >= 0 && tsHighlightIdx < tsVisibleNodes.length) {
                tsSelect(tsVisibleNodes[tsHighlightIdx].CategoryId);
            }
        } else if (e.key === 'Escape') {
            tsClose();
        }
    });

    function updateHighlight(nodes) {
        nodes.forEach(function (n) { n.classList.remove('ts-highlighted'); });
        if (tsHighlightIdx >= 0 && tsHighlightIdx < nodes.length) {
            nodes[tsHighlightIdx].classList.add('ts-highlighted');
            nodes[tsHighlightIdx].scrollIntoView({ block: 'nearest' });
        }
    }

    function escapeRegex(str) {
        return str.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    }

    // ── Init trigger text on page load ──
    document.addEventListener('DOMContentLoaded', function () {
        if (tsSelectedId) {
            var sel = tsData.find(function (n) { return n.CategoryId === tsSelectedId; });
            if (sel) updateTriggerText(sel);
        }
    });

    // ════════════════════════════════════════════════════
    // SKU ATTRIBUTES (existing logic, unchanged)
    // ════════════════════════════════════════════════════

    function loadSkuAttributes(categoryId) {
        var container = document.getElementById('sku-attributes-container');
        var preview = document.getElementById('sku-preview');

        if (!categoryId) {
            container.innerHTML = '<div class="col-12 text-muted small" id="sku-attr-placeholder"><i class="bi bi-info-circle me-1"></i> Chọn danh mục để hiển thị thuộc tính SKU</div>';
            preview.style.display = 'none';
            return;
        }

        var productId = @(Model.ProductId.HasValue ? Model.ProductId.Value.ToString() : "null");
        var url = '/ProductAttribute/GetAttributesByCategory?categoryId=' + categoryId;
        if (productId) url += '&productId=' + productId;

        fetch(url)
            .then(function (r) { return r.json(); })
            .then(function (result) {
                if (!result.Success || !result.Data || result.Data.length === 0) {
                    container.innerHTML = '<div class="col-12 text-muted small"><i class="bi bi-info-circle me-1"></i> Danh mục này chưa cấu hình thuộc tính SKU</div>';
                    preview.style.display = 'none';
                    return;
                }

                var html = '';
                result.Data.forEach(function (attr) {
                    html += '<div class="col-md-4">';
                    html += '<label class="form-label fw-semibold small">' + attr.AttributeName;
                    if (attr.IsRequired) html += ' <span class="text-danger">*</span>';
                    html += ' <span class="text-muted font-monospace" style="font-size:0.7rem;">(' + attr.AttrCode + ')</span>';
                    html += '</label>';

                    if (attr.DataType === 'LIST') {
                        html += '<select name="AttributeValues[' + attr.AttributeId + ']" class="form-select form-select-sm sku-attr-select" onchange="updateSkuPreview()">';
                        html += '<option value="">-- Chọn --</option>';
                        attr.Values.forEach(function (val) {
                            var sel = val.ValueId === attr.SelectedValueId ? ' selected' : '';
                            html += '<option value="' + val.ValueId + '" data-skucode="' + val.SkuCode + '"' + sel + '>' + val.ValueName + ' (' + val.SkuCode + ')</option>';
                        });
                        html += '</select>';
                    } else {
                        html += '<input type="text" name="AttributeValues[' + attr.AttributeId + ']" class="form-control form-control-sm" placeholder="Nhập giá trị..." value="' + (attr.TextValue || '') + '" />';
                    }

                    html += '</div>';
                });

                container.innerHTML = html;
                updateSkuPreview();
            });
    }

    function updateSkuPreview() {
        var preview = document.getElementById('sku-preview');
        var previewText = document.getElementById('sku-preview-text');
        if (!preview || !previewText) return;

        var selects = document.querySelectorAll('.sku-attr-select');
        if (selects.length === 0) { preview.style.display = 'none'; return; }

        var parts = [];
        selects.forEach(function (sel) {
            var opt = sel.options[sel.selectedIndex];
            if (opt && opt.value) {
                parts.push(opt.dataset.skucode || '??');
            }
        });

        if (parts.length > 0) {
            previewText.textContent = '??-' + parts.join('-') + '-0001';
            preview.style.display = '';
        } else {
            preview.style.display = 'none';
        }
    }

    // Initialize preview on page load for edit mode
    document.addEventListener('DOMContentLoaded', function () {
        var selects = document.querySelectorAll('.sku-attr-select');
        if (selects.length > 0) {
            selects.forEach(function (sel) {
                sel.addEventListener('change', updateSkuPreview);
            });
        }
    });
})();
</script>

