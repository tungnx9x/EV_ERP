@model EV_ERP.Models.ViewModels.Vendors.VendorFormViewModel
@{
    ViewData["Title"] = "Thêm nhà cung cấp mới";
}

<div class="row justify-content-center">
    <div class="col-xl-8 col-lg-10">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom py-3">
                <div class="d-flex align-items-center gap-2">
                    <a href="/Vendor" class="btn btn-sm btn-light border">
                        <i class="bi bi-arrow-left"></i>
                    </a>
                    <h5 class="mb-0 fw-semibold">
                        <i class="bi bi-truck me-2 text-primary"></i>Thêm nhà cung cấp mới
                    </h5>
                </div>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" asp-controller="Vendor" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                    <partial name="_VendorForm" model="Model" />

                    <hr class="my-4" />
                    <div class="d-flex gap-2 justify-content-end">
                        <a href="/Vendor" class="btn btn-outline-secondary">Hủy</a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i> Tạo nhà cung cấp
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
