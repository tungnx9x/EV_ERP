<!-- Create Product Modal (full form) -->
@if (canEdit && Model.Status == "DRAFT" && Model.HasUnmappedProducts && productForm != null)
{
    <div class="modal fade" id="createProductModal" tabindex="-1">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header border-0 pb-0">
                    <h6 class="modal-title fw-bold">
                        <i class="bi bi-plus-circle me-1 text-primary"></i> Tạo sản phẩm mới
                        <span class="text-muted small ms-2" id="cpItemLabel"></span>
                    </h6>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="cpSoItemId" />

                    @await Html.PartialAsync("~/Views/Product/_ProductForm.cshtml", productForm)

                    <hr class="my-4" />

                    <!-- Section: Hình ảnh sản phẩm -->
                    <h6 class="fw-semibold text-muted text-uppercase mb-3" style="font-size:0.75rem;letter-spacing:.06em;">
                        <i class="bi bi-images me-1"></i> Hình ảnh sản phẩm
                    </h6>
                    <div class="mb-3">
                        <input type="file" id="cp-gallery-input"
                               class="form-control form-control-sm"
                               accept="image/jpeg,image/png,image/webp,image/gif"
                               multiple onchange="previewCpGallery(this)" />
                        <div class="form-text small">JPG, PNG, WebP — tối đa 5 MB mỗi ảnh. Ảnh đầu tiên mặc định là ảnh đại diện — nhấn vào ảnh khác để thay đổi.</div>
                    </div>
                    <input type="hidden" id="cp-avatar-index" value="0" />
                    <input type="hidden" id="cp-existing-image-url" value="" />
                    <div id="cp-existing-image-preview" class="d-flex flex-wrap gap-2 mb-2"></div>
                    <div id="cp-gallery-preview" class="d-flex flex-wrap gap-2 mb-3"></div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="button" class="btn btn-sm btn-primary" id="cpSubmitBtn" onclick="submitCreateProduct()">
                        <i class="bi bi-check-lg me-1"></i> Tạo sản phẩm
                    </button>
                </div>
            </div>
        </div>
    </div>
}


<!-- Buying Modal (WAIT → BUYING) — v2.2 per-line -->
<div class="modal fade" id="buyingModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title fw-bold">Bắt đầu mua hàng</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-info py-2 px-3 small mb-3">
                    <i class="bi bi-info-circle me-1"></i>
                    Tích chọn các dòng muốn bắt đầu mua. Có thể đặt <strong>ngày dự kiến về</strong> riêng cho từng dòng.
                    Các dòng chưa tích vẫn lưu giá/nguồn nhưng giữ trạng thái <em>chưa bắt đầu</em>.
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-12">
                        <label class="form-label small fw-semibold">Ghi chú mua hàng (chung)</label>
                        <textarea id="inputBuyingNotes" class="form-control form-control-sm" rows="2"
                                  placeholder="Ghi chú..."></textarea>
                    </div>
                </div>

                <h6 class="fw-semibold small mb-2">Thông tin mua từng dòng</h6>
                <div class="table-responsive">
                    <table class="table table-sm table-bordered align-middle mb-0" style="font-size:0.82rem;">
                        <thead class="table-light">
                            <tr>
                                <th style="width:36px;" class="text-center">
                                    <input type="checkbox" id="buyingCheckAll" checked title="Chọn/bỏ tất cả" />
                                </th>
                                <th>Sản phẩm</th>
                                <th class="text-end" style="width:70px;">SL</th>
                                <th class="text-end" style="width:130px;">Giá mua</th>
                                <th class="text-end" style="width:110px;">Chi phí</th>
                                <th style="width:140px;">Dự kiến về</th>
                                <th style="width:160px;">Nguồn</th>
                            </tr>
                        </thead>
                        <tbody id="buyingItemsBody">
                            @foreach (var item in Model.Items)
                            {
                                <tr data-item-id="@item.SOItemId">
                                    <td class="text-center">
                                        <input type="checkbox" class="buying-include" checked />
                                    </td>
                                    <td>@item.ProductName</td>
                                    <td class="text-end">@item.Quantity.ToString("N3")</td>
                                    <td>
                                        <input type="number" class="form-control form-control-sm text-end purchase-price-input"
                                               data-item-id="@item.SOItemId" data-qty="@item.Quantity"
                                               value="@(item.PurchasePrice ?? 0)" min="0" />
                                    </td>
                                    <td class="text-end line-cost-cell">0</td>
                                    <td>
                                        <input type="date" class="form-control form-control-sm expected-receive-input"
                                               data-item-id="@item.SOItemId" />
                                    </td>
                                    <td>
                                        <input type="text" class="form-control form-control-sm source-url-input"
                                               data-item-id="@item.SOItemId"
                                               placeholder="URL" value="@item.SourceUrl" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr class="fw-bold">
                                <td colspan="4" class="text-end">Tổng chi phí mua:</td>
                                <td class="text-end" id="totalPurchaseCost">0</td>
                                <td colspan="2"></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-sm btn-info text-white" onclick="confirmBuying()">
                    <i class="bi bi-cart3 me-1"></i> Xác nhận mua hàng
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ═══════════════════════════════════════════════════ -->
<!-- v2.2 PER-LINE MODALS                                -->
<!-- ═══════════════════════════════════════════════════ -->

<!-- Edit Item (purchase info) Modal -->
<div class="modal fade" id="editItemModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title fw-bold">Sửa thông tin mua dòng <span id="editItemLabel" class="text-muted small ms-1"></span></h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editItemId" />
                <div class="row g-2 small">
                    <div class="col-6">
                        <label class="form-label small fw-semibold mb-1">Giá mua</label>
                        <input type="number" id="editItemPrice" class="form-control form-control-sm text-end" min="0" />
                    </div>
                    <div class="col-6">
                        <label class="form-label small fw-semibold mb-1">Dự kiến về</label>
                        <input type="date" id="editItemExpReceive" class="form-control form-control-sm" />
                    </div>
                    <div class="col-6">
                        <label class="form-label small fw-semibold mb-1">Dự kiến giao</label>
                        <input type="date" id="editItemExpDeliver" class="form-control form-control-sm" />
                    </div>
                    <div class="col-6">
                        <label class="form-label small fw-semibold mb-1">Tên nguồn</label>
                        <input type="text" id="editItemSourceName" class="form-control form-control-sm" />
                    </div>
                    <div class="col-12">
                        <label class="form-label small fw-semibold mb-1">URL nguồn</label>
                        <input type="text" id="editItemSourceUrl" class="form-control form-control-sm" />
                    </div>
                    <div class="col-12">
                        <label class="form-label small fw-semibold mb-1">Ghi chú</label>
                        <textarea id="editItemNotes" class="form-control form-control-sm" rows="2"></textarea>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-sm btn-primary" onclick="confirmEditItem()">
                    <i class="bi bi-check-lg me-1"></i> Lưu
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Cancel Item Modal -->
<div class="modal fade" id="cancelItemModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title fw-bold">Hủy dòng <span id="cancelItemLabel" class="text-muted small ms-1"></span></h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body small">
                <input type="hidden" id="cancelItemId" />
                <div class="alert alert-warning py-2 px-3 mb-2">
                    Hủy phần SL chưa nhập về. Phần đã nhập về phải đi luồng trả hàng.
                </div>
                <div class="mb-2">
                    <label class="form-label fw-semibold mb-1">SL cần hủy (để trống = hủy toàn bộ phần còn lại)</label>
                    <div class="input-group input-group-sm">
                        <input type="number" id="cancelItemQty" class="form-control text-end" min="0" step="0.001" />
                        <span class="input-group-text" id="cancelItemMax"></span>
                    </div>
                </div>
                <div>
                    <label class="form-label fw-semibold mb-1">Lý do</label>
                    <textarea id="cancelItemReason" class="form-control form-control-sm" rows="2"></textarea>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Đóng</button>
                <button type="button" class="btn btn-sm btn-danger" onclick="confirmCancelItem()">
                    <i class="bi bi-x-circle me-1"></i> Xác nhận hủy
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Receive Batch Modal -->
<div class="modal fade" id="receiveBatchModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title fw-bold"><i class="bi bi-box-arrow-in-down text-info me-1"></i> Nhận hàng</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-info py-2 px-3 small mb-3">
                    Tạo phiếu Nhập kho (Nháp) chứa các dòng đã chọn. Bộ phận Kho sẽ vào module Kho để xác nhận.
                </div>
                <div class="row g-2 mb-3 small">
                    <div class="col-md-5">
                        <label class="form-label fw-semibold mb-1">Ngày phiếu</label>
                        <input type="date" id="recvBatchDate" class="form-control form-control-sm" />
                    </div>
                    <div class="col-md-7">
                        <label class="form-label fw-semibold mb-1">Ghi chú</label>
                        <input type="text" id="recvBatchNotes" class="form-control form-control-sm" placeholder="Ghi chú phiếu..." />
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-sm table-bordered align-middle mb-0" style="font-size:0.82rem;">
                        <thead class="table-light">
                            <tr>
                                <th style="width:36px;" class="text-center">
                                    <input type="checkbox" id="recvBatchCheckAll" title="Chọn/bỏ tất cả" />
                                </th>
                                <th>Sản phẩm</th>
                                <th class="text-end" style="width:110px;">Còn cần nhập</th>
                                <th class="text-end" style="width:130px;">SL nhập đợt này</th>
                            </tr>
                        </thead>
                        <tbody id="recvBatchBody">
                            @foreach (var item in Model.Items.Where(i => i.RemainingReceiveQty > 0))
                            {
                                <tr data-item-id="@item.SOItemId" data-max="@item.RemainingReceiveQty">
                                    <td class="text-center">
                                        <input type="checkbox" class="recv-include" />
                                    </td>
                                    <td>@item.ProductName <span class="text-muted small">(@item.UnitName)</span></td>
                                    <td class="text-end text-info-emphasis fw-semibold">@item.RemainingReceiveQty.ToString("N3")</td>
                                    <td>
                                        <input type="number" class="form-control form-control-sm text-end recv-qty"
                                               min="0" max="@item.RemainingReceiveQty" step="0.001"
                                               value="@item.RemainingReceiveQty.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture)" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-sm btn-info text-white" onclick="confirmReceiveBatch()">
                    <i class="bi bi-box-arrow-in-down me-1"></i> Tạo phiếu nhập
                </button>
            </div>
        </div>
    </div>
</div>

