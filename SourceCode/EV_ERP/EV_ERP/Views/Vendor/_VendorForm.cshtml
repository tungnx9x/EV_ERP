@model EV_ERP.Models.ViewModels.Vendors.VendorFormViewModel

<!-- Section: Thông tin cơ bản -->
<h6 class="fw-semibold text-muted text-uppercase mb-3" style="font-size:0.75rem;letter-spacing:.06em;">
    <i class="bi bi-info-circle me-1"></i> Thông tin cơ bản
</h6>
<div class="row g-3 mb-4">
    <div class="col-12">
        <label asp-for="VendorName" class="form-label fw-semibold small"></label>
        <input asp-for="VendorName" class="form-control"
               placeholder="VD: Công ty TNHH ABC" autofocus />
        <span asp-validation-for="VendorName" class="text-danger small"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="TaxCode" class="form-label fw-semibold small"></label>
        <input asp-for="TaxCode" class="form-control" placeholder="0100000000" />
        <span asp-validation-for="TaxCode" class="text-danger small"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Phone" class="form-label fw-semibold small"></label>
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-telephone"></i></span>
            <input asp-for="Phone" class="form-control" placeholder="0901234567" />
        </div>
        <span asp-validation-for="Phone" class="text-danger small"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Email" class="form-label fw-semibold small"></label>
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
            <input asp-for="Email" class="form-control" placeholder="info@supplier.com" />
        </div>
        <span asp-validation-for="Email" class="text-danger small"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Website" class="form-label fw-semibold small"></label>
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-globe"></i></span>
            <input asp-for="Website" class="form-control" placeholder="https://supplier.com" />
        </div>
    </div>

    <div class="col-12">
        <label asp-for="Address" class="form-label fw-semibold small"></label>
        <input asp-for="Address" class="form-control" placeholder="Số nhà, tên đường..." />
    </div>

    <div class="col-md-6">
        <label asp-for="City" class="form-label fw-semibold small"></label>
        <input asp-for="City" class="form-control" placeholder="VD: Hà Nội" />
    </div>

    <div class="col-md-6">
        <label asp-for="District" class="form-label fw-semibold small"></label>
        <input asp-for="District" class="form-control" placeholder="VD: Hoàn Kiếm" />
    </div>
</div>

<!-- Section: Người liên hệ chính -->
<h6 class="fw-semibold text-muted text-uppercase mb-3" style="font-size:0.75rem;letter-spacing:.06em;">
    <i class="bi bi-person me-1"></i> Người liên hệ chính
</h6>
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <label asp-for="ContactPerson" class="form-label fw-semibold small"></label>
        <input asp-for="ContactPerson" class="form-control" placeholder="VD: Nguyễn Văn A" />
    </div>
    <div class="col-md-4">
        <label asp-for="ContactPhone" class="form-label fw-semibold small"></label>
        <input asp-for="ContactPhone" class="form-control" placeholder="0901234567" />
        <span asp-validation-for="ContactPhone" class="text-danger small"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="ContactEmail" class="form-label fw-semibold small"></label>
        <input asp-for="ContactEmail" class="form-control" placeholder="contact@supplier.com" />
        <span asp-validation-for="ContactEmail" class="text-danger small"></span>
    </div>
</div>

<!-- Section: Thông tin ngân hàng -->
<h6 class="fw-semibold text-muted text-uppercase mb-3" style="font-size:0.75rem;letter-spacing:.06em;">
    <i class="bi bi-bank me-1"></i> Thông tin ngân hàng
</h6>
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <label asp-for="BankAccountNo" class="form-label fw-semibold small"></label>
        <input asp-for="BankAccountNo" class="form-control" placeholder="VD: 0123456789" />
    </div>
    <div class="col-md-4">
        <label asp-for="BankName" class="form-label fw-semibold small"></label>
        <input asp-for="BankName" class="form-control" placeholder="VD: Vietcombank" />
    </div>
    <div class="col-md-4">
        <label asp-for="BankBranch" class="form-label fw-semibold small"></label>
        <input asp-for="BankBranch" class="form-control" placeholder="VD: Chi nhánh Hà Nội" />
    </div>
</div>

<!-- Section: Thương mại -->
<h6 class="fw-semibold text-muted text-uppercase mb-3" style="font-size:0.75rem;letter-spacing:.06em;">
    <i class="bi bi-cash-coin me-1"></i> Điều khoản thương mại
</h6>
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <label asp-for="PaymentTermDays" class="form-label fw-semibold small"></label>
        <div class="input-group">
            <input asp-for="PaymentTermDays" class="form-control" type="number" min="0" max="365" />
            <span class="input-group-text">ngày</span>
        </div>
        <span asp-validation-for="PaymentTermDays" class="text-danger small"></span>
    </div>
    <div class="col-12">
        <label asp-for="InternalNotes" class="form-label fw-semibold small"></label>
        <textarea asp-for="InternalNotes" class="form-control" rows="3"
                  placeholder="Ghi chú nội bộ (không hiển thị ra ngoài)..."></textarea>
    </div>
    <div class="col-12">
        <div class="form-check form-switch">
            <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" />
            <label asp-for="IsActive" class="form-check-label small fw-semibold"></label>
        </div>
    </div>
</div>
