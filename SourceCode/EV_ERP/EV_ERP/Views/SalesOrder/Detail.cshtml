    function rejectAdvance(advId, advNo) {
        var reason = prompt('Lý do từ chối đề nghị ' + advNo + ' (tùy chọn):', '');
        if (reason === null) return; // user cancelled
        postAction('/AdvanceRequest/Reject?id=' + advId, { Reason: reason }, function (data) {
            if (data.Success) location.reload();
            else appAlert(data.Message || 'Lỗi');
        });
    }

    // ── Items table client-side pagination ──────────────
    (function () {
        var tbody = document.getElementById('soItemsTbody');
        var pager = document.getElementById('soItemsPager');
        if (!tbody || !pager) return;
        var rows = Array.from(tbody.querySelectorAll(':scope > tr'));
        if (rows.length === 0) return;

        // Hide pager when the smallest page size already shows everything.
        if (rows.length <= 10) return;
        pager.style.removeProperty('display');

        var pageSize = 10;
        var page = 0;
        var sizeEl = document.getElementById('soItemsPageSize');
        var prevEl = document.getElementById('soItemsPrev');
        var nextEl = document.getElementById('soItemsNext');
        var infoEl = document.getElementById('soItemsPageInfo');

        function render() {
            var pages = Math.max(1, Math.ceil(rows.length / pageSize));
            if (page >= pages) page = pages - 1;
            if (page < 0) page = 0;
            var start = page * pageSize, end = start + pageSize;
            rows.forEach(function (tr, i) {
                tr.style.display = (i >= start && i < end) ? '' : 'none';
            });
            if (infoEl) {
                var from = (start + 1);
                var to = Math.min(end, rows.length);
                infoEl.textContent = from + '–' + to + ' / ' + rows.length;
            }
            if (prevEl) prevEl.disabled = (page === 0);
            if (nextEl) nextEl.disabled = (page >= pages - 1);
        }

        sizeEl && sizeEl.addEventListener('change', function (e) {
            pageSize = parseInt(e.target.value) || 10;
            page = 0;
            render();
        });
        prevEl && prevEl.addEventListener('click', function () { page--; render(); });
        nextEl && nextEl.addEventListener('click', function () { page++; render(); });

        render();
    })();
</script>

<!-- Flatpickr: force dd/mm/yyyy display while keeping yyyy-MM-dd as the submitted value -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr@4.6.13/dist/flatpickr.min.css" />
<script src="https://cdn.jsdelivr.net/npm/flatpickr@4.6.13/dist/flatpickr.min.js"></script>
<script>
    (function () {
        if (typeof flatpickr === 'undefined') return;
        document.querySelectorAll('.js-flatpickr').forEach(function (el) {
            flatpickr(el, {
                dateFormat: 'Y-m-d',   // value kept ISO -> server parses unchanged
                altInput: true,
                altFormat: 'd/m/Y',    // what the user sees
                allowInput: true
            });
        });
    })();
</script>

<!-- ============ Giá nhập hiện tại — calc popup (ported from Quotation) ============ -->
<script>
    var soCalcCurrencies = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        Model.Currencies.Select(c => new { c.CurrencyCode, c.CurrencyName })));
    var soItemCalc = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        Model.Items.Select(i => new {
            id = i.SOItemId,
            name = i.ProductName,
            purchasePrice = i.PurchasePrice,
            mode = i.PurchaseMode,
            currency = i.PurchaseCurrency,
            rate = i.PurchaseExchangeRate,
            pqty = i.PurchaseQuantity,
            basePrice = i.BasePrice,
            tax = i.PurchaseTax,
            inspection = i.InspectionFee,
            banking = i.BankingFee,
            other = i.OtherCosts,
            offShip = i.OfficialShipping,
            domShip = i.UnofficialDomesticShipping,
            weight = i.UnofficialWeightKg,
            costPerKg = i.UnofficialCostPerKg,
            handCarry = i.UnofficialHandCarryFee,
            w2w = i.UnofficialW2WShipping,
            length = i.UnofficialLength,
            width = i.UnofficialWidth,
            height = i.UnofficialHeight,
            costPerCbm = i.UnofficialCostPerCbm,
            vatPercent = i.PurchaseVatPercent
        })));

    var calcItemId = -1;
    var soCalcModalInstance = null;

    // ── numeric helpers (ported) ──
    function formatNumber(n) { return Math.round(n).toLocaleString('vi-VN'); }
    function evalArithmetic(str) {
        if (!/^[\d.+\-*/()\s]+$/.test(str)) return NaN;
        try { var r = Function('"use strict"; return (' + str + ')')(); return isFinite(r) ? r : NaN; }
        catch (e) { return NaN; }
    }
    function parseMoney(s) {
        if (s === null || s === undefined || s === '') return 0;
        if (typeof s === 'number') return s;
        var str = String(s).trim().replace(/\s/g, '');
        if (str === '') return 0;
        var hasOp = /[+\-*/()]/.test(str);
        str = str.replace(/\./g, '');
        if (!hasOp) { var n = parseInt(str, 10); return isNaN(n) ? 0 : n; }
        var r = evalArithmetic(str); return isNaN(r) ? 0 : Math.round(r);
    }
    function parseDecimal(s) {
        if (s === null || s === undefined || s === '') return 0;
        if (typeof s === 'number') return s;
        var str = String(s).trim().replace(/\s/g, '');
        if (str === '') return 0;
        if (!/[+\-*/()]/.test(str)) { var n = parseFloat(str); return isNaN(n) ? 0 : n; }
        var r = evalArithmetic(str); return isNaN(r) ? 0 : r;
    }
    function formatMoneyInput(input) {
        var oldVal = input.value;
        if (/[+\-*/()]/.test(oldVal)) return;
        var caret = input.selectionStart;
        if (caret === null || caret === undefined) caret = oldVal.length;
        var digitsLeft = 0;
        for (var i = 0; i < caret; i++) { var c = oldVal.charCodeAt(i); if (c >= 48 && c <= 57) digitsLeft++; }
        var rawDigits = oldVal.replace(/\D/g, '');
        if (rawDigits === '') { input.value = ''; return; }
        var formatted = parseInt(rawDigits, 10).toLocaleString('vi-VN');
        input.value = formatted;
        var newPos = 0, seen = 0;
        if (digitsLeft > 0) {
            for (newPos = 0; newPos < formatted.length; newPos++) {
                var c2 = formatted.charCodeAt(newPos);
                if (c2 >= 48 && c2 <= 57) { seen++; if (seen === digitsLeft) { newPos++; break; } }
            }
        }
        try { input.setSelectionRange(newPos, newPos); } catch (e) { }
    }

    // ── open popup for a SO item ──
    function openItemCalcModal(soItemId) {
        var it = soItemCalc.find(function (x) { return x.id === soItemId; });
        if (!it) return;
        calcItemId = soItemId;

        var sel = document.getElementById('calcCurrency');
        var opts = '';
        for (var i = 0; i < soCalcCurrencies.length; i++) {
            var c = soCalcCurrencies[i];
            opts += '<option value="' + escapeHtmlAp(c.CurrencyCode) + '">' + escapeHtmlAp(c.CurrencyCode) + ' - ' + escapeHtmlAp(c.CurrencyName) + '</option>';
        }
        sel.innerHTML = opts;
        sel.value = it.currency || 'VND';
        sel.onchange = onCalcCurrencyChange;

        document.getElementById('calcItemId').value = soItemId;
        document.getElementById('calcRowLabel').textContent = it.name || '';
        document.getElementById('calcRate').value = formatNumber(it.rate || 1);
        document.getElementById('calcQty').value = (it.pqty != null && it.pqty > 0) ? it.pqty : '';

        updateCalcCurrRateUI();

        var mode = (it.mode || 'OFFICIAL').toUpperCase();
        document.getElementById('calcModeDomestic').checked = (mode === 'DOMESTIC');
        document.getElementById('calcModeOfficial').checked = (mode === 'OFFICIAL');
        document.getElementById('calcModeUnofficial').checked = (mode === 'UNOFFICIAL');

        document.getElementById('calcBasePrice').value = it.basePrice ? formatNumber(it.basePrice) : '';
        document.getElementById('calcOfficialShipping').value = it.offShip ? formatNumber(it.offShip) : '';
        document.getElementById('calcDomesticShipping').value = it.domShip ? formatNumber(it.domShip) : '';
        document.getElementById('calcWeight').value = it.weight ? it.weight : '';
        document.getElementById('calcCostPerKg').value = it.costPerKg ? formatNumber(it.costPerKg) : '';
        document.getElementById('calcHandCarry').value = it.handCarry ? formatNumber(it.handCarry) : '';
        document.getElementById('calcW2W').value = it.w2w ? formatNumber(it.w2w) : '';
        document.getElementById('calcLength').value = it.length ? it.length : '';
        document.getElementById('calcWidth').value = it.width ? it.width : '';
        document.getElementById('calcHeight').value = it.height ? it.height : '';
        document.getElementById('calcCostPerCbm').value = it.costPerCbm ? formatNumber(it.costPerCbm) : '';
        document.getElementById('calcTax').value = it.tax ? formatNumber(it.tax) : '';
        document.getElementById('calcInspection').value = it.inspection ? formatNumber(it.inspection) : '';
        document.getElementById('calcBanking').value = it.banking ? formatNumber(it.banking) : '';
        document.getElementById('calcOther').value = it.other ? formatNumber(it.other) : '';
        document.getElementById('calcVatPercent').value = it.vatPercent ? it.vatPercent : '';

        document.querySelectorAll('input[name="calcMode"]').forEach(function (r) { r.onchange = onCalcModeChange; });
        updateCalcPanels();
        onCalcInput();

        if (!soCalcModalInstance) soCalcModalInstance = new bootstrap.Modal(document.getElementById('calcModal'));
        soCalcModalInstance.show();
    }

    function onCalcModeChange() { updateCalcPanels(); onCalcInput(); }

    function updateCalcPanels() {
        var mode = document.querySelector('input[name="calcMode"]:checked')?.value || 'OFFICIAL';
        document.getElementById('calcOfficialPanel').style.display = (mode === 'OFFICIAL' || mode === 'DOMESTIC') ? '' : 'none';
        document.getElementById('calcUnofficialPanel').style.display = (mode === 'UNOFFICIAL') ? '' : 'none';
        var commonCard = document.getElementById('calcCommonCostCard');
        if (commonCard) commonCard.style.display = (mode === 'DOMESTIC') ? 'none' : '';
        var vatCol = document.getElementById('calcVatCol');
        if (vatCol) vatCol.style.display = (mode === 'DOMESTIC') ? '' : 'none';
        var currSel = document.getElementById('calcCurrency');
        if (mode === 'DOMESTIC') {
            if (currSel.value !== 'VND') { currSel.value = 'VND'; document.getElementById('calcRate').value = formatNumber(1); }
            currSel.disabled = true;
            updateCalcCurrRateUI();
        } else { currSel.disabled = false; }
    }

    function onCalcCurrencyChange() {
        var code = document.getElementById('calcCurrency').value || 'VND';
        if (code === 'VND') {
            document.getElementById('calcRate').value = formatNumber(1);
            updateCalcCurrRateUI(); onCalcInput(); return;
        }
        fetch('/Quotation/GetCurrencyRate?code=' + encodeURIComponent(code), { cache: 'no-store' })
            .then(function (r) { return r.json(); })
            .then(function (res) {
                var rate = (res && res.Success && res.Data && res.Data.rate) ? Number(res.Data.rate) : 1;
                document.getElementById('calcRate').value = formatNumber(rate > 0 ? rate : 1);
                updateCalcCurrRateUI(); onCalcInput();
            })
            .catch(function () {
                document.getElementById('calcRate').value = formatNumber(1);
                updateCalcCurrRateUI(); onCalcInput();
            });
    }

    function updateCalcCurrRateUI() {
        var code = document.getElementById('calcCurrency').value || 'VND';
        var sel = document.getElementById('calcCurrency');
        var rateInp = document.getElementById('calcRate');
        var resetBtn = document.getElementById('calcResetCurrBtn');
        var lblTxt = document.getElementById('calcCurrRateLabelText');
        if (code === 'VND') {
            sel.style.display = ''; rateInp.style.display = 'none';
            resetBtn.style.display = 'none'; lblTxt.textContent = 'Tỷ giá';
        } else {
            sel.style.display = 'none'; rateInp.style.display = '';
            resetBtn.style.display = ''; lblTxt.textContent = 'Tỷ giá - ' + code;
        }
    }

    function resetCalcCurrency() {
        document.getElementById('calcCurrency').value = 'VND';
        document.getElementById('calcRate').value = formatNumber(1);
        updateCalcCurrRateUI(); onCalcInput();
    }

    function calcReadFields() {
        return {
            mode: document.querySelector('input[name="calcMode"]:checked')?.value || 'OFFICIAL',
            currency: document.getElementById('calcCurrency').value || 'VND',
            rate: parseMoney(document.getElementById('calcRate').value) || 1,
            qty: Math.max(parseDecimal(document.getElementById('calcQty').value) || 1, 1),
            basePrice: parseMoney(document.getElementById('calcBasePrice').value),
            offShipping: parseMoney(document.getElementById('calcOfficialShipping').value),
            domShipping: parseMoney(document.getElementById('calcDomesticShipping').value),
            weight: parseDecimal(document.getElementById('calcWeight').value),
            costPerKg: parseMoney(document.getElementById('calcCostPerKg').value),
            handCarry: parseMoney(document.getElementById('calcHandCarry').value),
            w2w: parseMoney(document.getElementById('calcW2W').value),
            length: parseDecimal(document.getElementById('calcLength').value),
            width: parseDecimal(document.getElementById('calcWidth').value),
            height: parseDecimal(document.getElementById('calcHeight').value),
            costPerCbm: parseMoney(document.getElementById('calcCostPerCbm').value),
            tax: parseMoney(document.getElementById('calcTax').value),
            inspection: parseMoney(document.getElementById('calcInspection').value),
            banking: parseMoney(document.getElementById('calcBanking').value),
            other: parseMoney(document.getElementById('calcOther').value),
            vatPercent: parseDecimal(document.getElementById('calcVatPercent').value)
        };
    }

    function calcComputePreview() {
        var f = calcReadFields();
        var qty = f.qty > 0 ? f.qty : 1;
        if (f.mode === 'DOMESTIC') {
            var vatMult = 1 + (f.vatPercent || 0) / 100;
            var domPerUnit = Math.round(f.basePrice * vatMult + f.offShipping / qty);
            return { lineVnd: domPerUnit * qty, perUnit: domPerUnit,
                hint: 'Giá nhập = Đơn giá gốc × (1 + VAT%) + (Phí vận chuyển / SL mua)', fields: f };
        }
        var shippingVnd, hint;
        if (f.mode === 'OFFICIAL') {
            shippingVnd = f.offShipping;
            hint = 'Giá nhập = (Đơn giá gốc × Tỷ giá) + ((Vận chuyển CT + Thuế + Kiểm định + Ngân hàng + Khác) / SL mua)';
        } else {
            var cbm = (f.length || 0) * (f.width || 0) * (f.height || 0);
            shippingVnd = f.domShipping + f.weight * f.costPerKg + f.handCarry + f.w2w + cbm * f.costPerCbm;
            hint = 'Giá nhập = (Đơn giá gốc × Tỷ giá) + ((Nội địa + Kg×Phí/kg + CBM×Phí/CBM + Xách tay + Kho→Kho + Thuế + Kiểm định + Ngân hàng + Khác) / SL mua)';
        }
        var feesVnd = shippingVnd + f.tax + f.inspection + f.banking + f.other;
        var perUnit = Math.round(f.basePrice * f.rate + feesVnd / qty);
        return { lineVnd: Math.round(perUnit * qty), perUnit: perUnit, hint: hint, fields: f };
    }

    function onCalcInput() {
        var r = calcComputePreview();
        document.getElementById('calcLineTotal').textContent = formatNumber(r.lineVnd);
        document.getElementById('calcPerUnit').textContent = formatNumber(r.perUnit);
        document.getElementById('calcFormulaHint').textContent = r.hint;
        var cbmEl = document.getElementById('calcCbmValue');
        if (cbmEl) {
            var f = r.fields;
            var cbm = (f.length || 0) * (f.width || 0) * (f.height || 0);
            cbmEl.textContent = cbm ? cbm.toLocaleString('en-US', { maximumFractionDigits: 4 }) : '0';
        }
    }

    function confirmItemCalc() {
        if (calcItemId < 0) return;
        var r = calcComputePreview();
        var f = r.fields;

        var isDom = f.mode === 'DOMESTIC';
        var isOffOrDom = (f.mode === 'OFFICIAL' || f.mode === 'DOMESTIC');
        var body = {
            PurchasePrice: r.perUnit,
            PurchaseMode: f.mode,
            PurchaseCurrency: isDom ? 'VND' : f.currency,
            PurchaseExchangeRate: isDom ? 1 : (f.rate > 0 ? f.rate : 1),
            PurchaseQuantity: f.qty,
            BasePrice: f.basePrice || null,
            PurchaseTax: isDom ? null : (f.tax || null),
            InspectionFee: isDom ? null : (f.inspection || null),
            BankingFee: isDom ? null : (f.banking || null),
            OtherCosts: isDom ? null : (f.other || null),
            OfficialShipping: isOffOrDom ? (f.offShipping || null) : null,
            UnofficialDomesticShipping: isOffOrDom ? null : (f.domShipping || null),
            UnofficialWeightKg: isOffOrDom ? null : (f.weight || null),
            UnofficialCostPerKg: isOffOrDom ? null : (f.costPerKg || null),
            UnofficialHandCarryFee: isOffOrDom ? null : (f.handCarry || null),
            UnofficialW2WShipping: isOffOrDom ? null : (f.w2w || null),
            UnofficialLength: isOffOrDom ? null : (f.length || null),
            UnofficialWidth: isOffOrDom ? null : (f.width || null),
            UnofficialHeight: isOffOrDom ? null : (f.height || null),
            UnofficialCostPerCbm: isOffOrDom ? null : (f.costPerCbm || null),
            PurchaseVatPercent: isDom ? (f.vatPercent || null) : null
        };

        var btn = document.getElementById('calcConfirmBtn');
        btn.disabled = true;
        postAction('/SalesOrder/UpdateItemPurchasePrice/' + soId + '?soItemId=' + calcItemId, body, function (data) {
            if (data.Success) { location.reload(); }
            else { appAlert(data.Message || 'Lỗi'); btn.disabled = false; }
        });
    }

    // blur-commit arithmetic expressions inside the calc modal
    (function wireCalcExprInputs() {
        function commitCalcExpr(input, kind) {
            var raw = (input.value || '').trim();
            if (raw === '') return;
            if (kind === 'decimal') { var d = parseDecimal(raw); input.value = d ? String(Math.round(d * 1000) / 1000) : ''; }
            else { var m = parseMoney(raw); input.value = m ? formatNumber(m) : ''; }
            onCalcInput();
        }
        var moneyIds = ['calcBasePrice', 'calcRate', 'calcOfficialShipping', 'calcDomesticShipping',
                        'calcCostPerKg', 'calcHandCarry', 'calcW2W', 'calcCostPerCbm', 'calcTax', 'calcInspection', 'calcBanking', 'calcOther'];
        var decimalIds = ['calcQty', 'calcWeight', 'calcLength', 'calcWidth', 'calcHeight', 'calcVatPercent'];
        moneyIds.forEach(function (id) { var el = document.getElementById(id); if (el) el.addEventListener('blur', function () { commitCalcExpr(el, 'money'); }); });
        decimalIds.forEach(function (id) { var el = document.getElementById(id); if (el) el.addEventListener('blur', function () { commitCalcExpr(el, 'decimal'); }); });
    })();
</script>
