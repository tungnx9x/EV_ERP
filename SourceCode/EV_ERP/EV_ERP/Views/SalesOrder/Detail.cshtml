                                    <td>
                                        <input type="date" class="form-control form-control-sm expected-receive-input"
                                               data-item-id="@item.SOItemId" required />
                                    </td>
                                    <td>
                                        <input type="text" class="form-control form-control-sm source-url-input"
                                               data-item-id="@item.SOItemId"
                                               placeholder="URL" value="@item.SourceUrl" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr class="fw-bold">
                                <td colspan="4" class="text-end">Tổng chi phí mua:</td>
                                <td class="text-end" id="totalPurchaseCost">0</td>
                                <td colspan="2"></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-sm btn-info text-white" onclick="confirmBuying()">
                    <i class="bi bi-cart3 me-1"></i> Xác nhận mua hàng
                </button>
            </div>
        </div>
    </div>
</div>

