@model EV_ERP.Models.ViewModels.Customers.CustomerListViewModel
@{
    ViewData["Title"] = "Quản lý khách hàng";
    bool canEdit = ViewBag.CanEdit == true;
    bool canDelete = ViewBag.CanDelete == true;
}

<div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
    <div>
        <p class="text-muted small mb-0">Tổng cộng @Model.TotalCount khách hàng</p>
    </div>
    @if (canEdit)
    {
        <a href="/Customer/Create" class="btn btn-primary">
            <i class="bi bi-building-add me-1"></i> Thêm khách hàng
        </a>
    }
</div>

<!-- Filter bar -->
<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-3">
        <form method="get" asp-action="Index" class="row g-2 align-items-end">
            <div class="col-12 col-sm-5 col-lg-5">
                <label class="form-label small fw-semibold mb-1">Tìm kiếm</label>
                <div class="input-group input-group-sm">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" name="keyword" class="form-control"
                           placeholder="Tên, mã KH, SĐT, email..."
                           value="@Model.SearchKeyword" />
                </div>
            </div>
            <div class="col-6 col-sm-3 col-lg-3">
                <label class="form-label small fw-semibold mb-1">Nhóm KH</label>
                <select name="groupId" class="form-select form-select-sm">
                    <option value="">Tất cả nhóm</option>
                    @foreach (var g in Model.Groups)
                    {
                        <option value="@g.CustomerGroupId"
                                selected="@(Model.FilterGroupId == g.CustomerGroupId)">
                            @g.GroupName
                        </option>
                    }
                </select>
            </div>
            <div class="col-6 col-sm-2 col-lg-2">
                <label class="form-label small fw-semibold mb-1">Trạng thái</label>
                <select name="status" class="form-select form-select-sm">
                    <option value="">Đang hoạt động</option>
                    <option value="inactive" selected="@(Model.FilterStatus == "inactive")">Vô hiệu</option>
                </select>
            </div>
            <div class="col-12 col-sm-2 col-lg-2 d-flex gap-1">
                <button type="submit" class="btn btn-primary btn-sm flex-fill">
                    <i class="bi bi-funnel me-1"></i> Lọc
                </button>
                <a href="/Customer" class="btn btn-outline-secondary btn-sm" title="Xóa bộ lọc">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Table -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (!Model.Customers.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-building" style="font-size: 3rem; opacity: 0.3;"></i>
                <p class="mt-2 mb-0">Không tìm thấy khách hàng nào</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" style="font-size:0.875rem;">
                    <thead class="table-light">
                        <tr>
                            <th style="width:40px;">#</th>
                            <th>Khách hàng</th>
                            <th class="d-none d-md-table-cell">SĐT / Email</th>
                            <th class="d-none d-lg-table-cell">Địa chỉ</th>
                            <th class="d-none d-md-table-cell">Nhóm</th>
                            <th class="d-none d-lg-table-cell">Phụ trách</th>
                            <th>Trạng thái</th>
                            <th style="width:100px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int idx = 1; }
                        @foreach (var c in Model.Customers)
                        {
                            <tr>
                                <td class="text-muted small">@(idx++)</td>
                                <td>
                                    <div>
                                        <a href="/Customer/Detail/@c.CustomerId"
                                           class="fw-semibold text-decoration-none text-dark link-hover">
                                            @c.CustomerName
                                        </a>
                                        <div class="text-muted small">@c.CustomerCode</div>
                                    </div>
                                </td>
                                <td class="d-none d-md-table-cell text-muted small">
                                    @if (!string.IsNullOrEmpty(c.Phone))
                                    {
                                        <div><i class="bi bi-telephone me-1"></i>@c.Phone</div>
                                    }
                                    @if (!string.IsNullOrEmpty(c.Email))
                                    {
                                        <div><i class="bi bi-envelope me-1"></i>@c.Email</div>
                                    }
                                </td>
                                <td class="d-none d-lg-table-cell text-muted small">@c.City</td>
                                <td class="d-none d-md-table-cell">
                                    @if (!string.IsNullOrEmpty(c.GroupName))
                                    {
                                        <span class="badge @GroupBadge(c.GroupCode) rounded-pill">
                                            @c.GroupName
                                        </span>
                                    }
                                </td>
                                <td class="d-none d-lg-table-cell text-muted small">@c.SalesPersonName</td>
                                <td>
                                    <span class="badge bg-@c.StatusBadge-subtle text-@c.StatusBadge-emphasis rounded-pill">
                                        <i class="bi bi-circle-fill me-1" style="font-size:0.45rem;vertical-align:middle;"></i>
                                        @c.StatusText
                                    </span>
                                </td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a href="/Customer/Detail/@c.CustomerId"
                                           class="btn btn-sm btn-outline-secondary" title="Xem chi tiết">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (canEdit)
                                        {
                                            <a href="/Customer/Edit/@c.CustomerId"
                                               class="btn btn-sm btn-outline-primary" title="Chỉnh sửa">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                        }
                                        @if (canDelete)
                                        {
                                            <button class="btn btn-sm @(c.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                                    title="@(c.IsActive ? "Vô hiệu hóa" : "Kích hoạt lại")"
                                                    onclick="toggleActive(@c.CustomerId, '@c.CustomerName', @c.IsActive.ToString().ToLower())">
                                                <i class="bi @(c.IsActive ? "bi-slash-circle" : "bi-check-circle")"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@functions {
    string GroupBadge(string? code) => code switch
    {
        "VIP" => "bg-warning-subtle text-warning-emphasis",
        "NEW" or "MOI" => "bg-info-subtle text-info-emphasis",
        _ => "bg-secondary-subtle text-secondary-emphasis"
    };
}

<style>
    .link-hover:hover { color: #2563eb !important; }
    .bg-success-subtle { background-color: #dcfce7 !important; }
    .text-success-emphasis { color: #166534 !important; }
    .bg-secondary-subtle { background-color: #f1f5f9 !important; }
    .text-secondary-emphasis { color: #475569 !important; }
    .bg-warning-subtle { background-color: #fef9c3 !important; }
    .text-warning-emphasis { color: #854d0e !important; }
    .bg-info-subtle { background-color: #e0f2fe !important; }
    .text-info-emphasis { color: #0369a1 !important; }
</style>

@section Scripts {
    <script>
        function toggleActive(id, name, isActive) {
            var action = isActive ? 'vô hiệu hóa' : 'kích hoạt lại';
            if (!confirm('Bạn có chắc muốn ' + action + ' khách hàng "' + name + '"?')) return;

            var form = new FormData();
            form.append('__RequestVerificationToken', getAntiForgeryToken());

            fetch('/Customer/ToggleActive/' + id, { method: 'POST', body: form })
                .then(r => r.json())
                .then(data => {
                    if (data.Success) location.reload();
                    else alert('Lỗi: ' + data.Message);
                });
        }

        function getAntiForgeryToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
        }
    </script>
    @Html.AntiForgeryToken()
}
