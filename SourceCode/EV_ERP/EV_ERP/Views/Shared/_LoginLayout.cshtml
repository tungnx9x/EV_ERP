<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ERP Eastern Vision</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        :root {
            --brand-primary: #1a2d4e;
            --brand-accent: #2563eb;
        }
        html, body {
            height: 100%;
            margin: 0;
        }
        body {
            background: linear-gradient(135deg, #1a2d4e 0%, #2563eb 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            font-family: 'Segoe UI', sans-serif;
        }
        .login-wrapper {
            width: 100%;
            max-width: 440px;
            padding: 1rem;
        }
        .login-card {
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 25px 60px rgba(0,0,0,0.25);
            padding: 2.5rem 2.5rem 2rem;
        }
        .brand-logo {
            font-size: 2rem;
            font-weight: 800;
            color: var(--brand-primary);
            letter-spacing: -1px;
        }
        .brand-logo span { color: var(--brand-accent); }
        .brand-tagline {
            color: #6b7280;
            font-size: 0.85rem;
            margin-top: 0.25rem;
        }
        .form-control:focus {
            border-color: var(--brand-accent);
            box-shadow: 0 0 0 0.2rem rgba(37,99,235,0.15);
        }
        .btn-login {
            background: var(--brand-accent);
            border: none;
            border-radius: 8px;
            font-weight: 600;
            font-size: 1rem;
            padding: 0.65rem;
            transition: background 0.2s;
        }
        .btn-login:hover { background: #1d4ed8; }
        .input-group-text {
            background: #f9fafb;
            border-color: #d1d5db;
            color: #6b7280;
        }
        .form-control { border-color: #d1d5db; }
        .footer-text {
            color: rgba(255,255,255,0.6);
            font-size: 0.8rem;
            text-align: center;
            margin-top: 1.5rem;
        }
    </style>
</head>
<body>
    <div class="login-wrapper">
        <div class="login-card">
            @RenderBody()
        </div>
        <p class="footer-text">&copy; 2026 ERP EasternVision v1.0</p>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
