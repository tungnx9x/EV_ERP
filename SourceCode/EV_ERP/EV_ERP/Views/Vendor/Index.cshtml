@model EV_ERP.Models.ViewModels.Vendors.VendorListViewModel
@{
    ViewData["Title"] = "Quản lý nhà cung cấp";
    bool canEdit = ViewBag.CanEdit == true;
    bool canDelete = ViewBag.CanDelete == true;
}

<div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
    <div>
        <p class="text-muted small mb-0">Tổng cộng @Model.TotalCount nhà cung cấp</p>
    </div>
    @if (canEdit)
    {
        <a href="/Vendor/Create" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i> Thêm nhà cung cấp
        </a>
    }
</div>

<!-- Filter bar -->
<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-3">
        <form method="get" asp-action="Index" class="row g-2 align-items-end">
            <div class="col-12 col-sm-6 col-lg-6">
                <label class="form-label small fw-semibold mb-1">Tìm kiếm</label>
                <div class="input-group input-group-sm">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" name="keyword" class="form-control"
                           placeholder="Tên, mã NCC, MST, SĐT, email..."
                           value="@Model.SearchKeyword" />
                </div>
            </div>
            <div class="col-6 col-sm-3 col-lg-3">
                <label class="form-label small fw-semibold mb-1">Trạng thái</label>
                <select name="status" class="form-select form-select-sm">
                    <option value="">Đang hoạt động</option>
                    <option value="inactive" selected="@(Model.FilterStatus == "inactive")">Vô hiệu</option>
                </select>
            </div>
            <div class="col-6 col-sm-3 col-lg-3 d-flex gap-1">
                <button type="submit" class="btn btn-primary btn-sm flex-fill">
                    <i class="bi bi-funnel me-1"></i> Lọc
                </button>
                <a href="/Vendor" class="btn btn-outline-secondary btn-sm" title="Xóa bộ lọc">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Table -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (!Model.Vendors.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-truck" style="font-size: 3rem; opacity: 0.3;"></i>
                <p class="mt-2 mb-0">Không tìm thấy nhà cung cấp nào</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" style="font-size:0.875rem;">
                    <thead class="table-light">
                        <tr>
                            <th style="width:40px;">#</th>
                            <th>Nhà cung cấp</th>
                            <th class="d-none d-md-table-cell">SĐT / Email</th>
                            <th class="d-none d-lg-table-cell">Thành phố</th>
                            <th class="d-none d-md-table-cell">Liên hệ chính</th>
                            <th class="d-none d-lg-table-cell">Hạn TT</th>
                            <th>Trạng thái</th>
                            <th style="width:110px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int idx = 1; }
                        @foreach (var v in Model.Vendors)
                        {
                            <tr>
                                <td class="text-muted small">@(idx++)</td>
                                <td>
                                    <div>
                                        <a href="/Vendor/Detail/@v.VendorId"
                                           class="fw-semibold text-decoration-none text-dark link-hover">
                                            @v.VendorName
                                        </a>
                                        <div class="text-muted small">@v.VendorCode</div>
                                    </div>
                                </td>
                                <td class="d-none d-md-table-cell text-muted small">
                                    @if (!string.IsNullOrEmpty(v.Phone))
                                    {
                                        <div><i class="bi bi-telephone me-1"></i>@v.Phone</div>
                                    }
                                    @if (!string.IsNullOrEmpty(v.Email))
                                    {
                                        <div><i class="bi bi-envelope me-1"></i>@v.Email</div>
                                    }
                                </td>
                                <td class="d-none d-lg-table-cell text-muted small">@v.City</td>
                                <td class="d-none d-md-table-cell text-muted small">@v.ContactPerson</td>
                                <td class="d-none d-lg-table-cell text-muted small">
                                    @v.PaymentTermDays ngày
                                </td>
                                <td>
                                    @if (v.IsActive)
                                    {
                                        <span class="badge bg-success-subtle text-success-emphasis rounded-pill">
                                            <i class="bi bi-circle-fill me-1" style="font-size:0.45rem;vertical-align:middle;"></i>
                                            Hoạt động
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary-emphasis rounded-pill">
                                            <i class="bi bi-circle-fill me-1" style="font-size:0.45rem;vertical-align:middle;"></i>
                                            Vô hiệu
                                        </span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a href="/Vendor/Detail/@v.VendorId"
                                           class="btn btn-sm btn-outline-secondary" title="Xem chi tiết">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (canEdit)
                                        {
                                            <a href="/Vendor/Edit/@v.VendorId"
                                               class="btn btn-sm btn-outline-primary" title="Chỉnh sửa">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                        }
                                        @if (canDelete)
                                        {
                                            <button class="btn btn-sm @(v.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                                    title="@(v.IsActive ? "Vô hiệu hóa" : "Kích hoạt lại")"
                                                    onclick="toggleActive(@v.VendorId, '@v.VendorName.Replace("'", "\\'")', @v.IsActive.ToString().ToLower())">
                                                <i class="bi @(v.IsActive ? "bi-slash-circle" : "bi-check-circle")"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<style>
    .link-hover:hover { color: #2563eb !important; }
    .bg-success-subtle { background-color: #dcfce7 !important; }
    .text-success-emphasis { color: #166534 !important; }
    .bg-secondary-subtle { background-color: #f1f5f9 !important; }
    .text-secondary-emphasis { color: #475569 !important; }
</style>

@section Scripts {
    <script>
        function toggleActive(id, name, isActive) {
            var action = isActive ? 'vô hiệu hóa' : 'kích hoạt lại';
            if (!confirm('Bạn có chắc muốn ' + action + ' nhà cung cấp "' + name + '"?')) return;

            var form = new FormData();
            form.append('__RequestVerificationToken', getAntiForgeryToken());

            fetch('/Vendor/ToggleActive/' + id, { method: 'POST', body: form })
                .then(r => r.json())
                .then(data => {
                    if (data.Success) location.reload();
                    else alert('Lỗi: ' + data.Message);
                });
        }

        function getAntiForgeryToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
        }
    </script>
    @Html.AntiForgeryToken()
}
