@model EV_ERP.Models.ViewModels.SalesOrders.SalesOrderListViewModel
@{
    ViewData["Title"] = "Đơn hàng";
    bool canEdit = ViewBag.CanEdit == true;
    var p = Model.Paged;
}

<div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
    <div>
        <p class="text-muted small mb-0">Tổng cộng @p.TotalCount đơn hàng</p>
    </div>
</div>

<!-- Filter bar -->
<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-3">
        <form method="get" asp-action="Index" class="row g-2 align-items-end">
            <div class="col-12 col-sm-3 col-lg-3">
                <label class="form-label small fw-semibold mb-1">Tìm kiếm</label>
                <div class="input-group input-group-sm">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" name="keyword" class="form-control"
                           placeholder="Mã SO, khách hàng, PO KH..."
                           value="@Model.SearchKeyword" />
                </div>
            </div>
            <div class="col-6 col-sm-2 col-lg-2">
                <label class="form-label small fw-semibold mb-1">Trạng thái</label>
                <select name="status" class="form-select form-select-sm">
                    <option value="">Tất cả</option>
                    @foreach (var s in new[] {
                        ("DRAFT","Nháp"), ("WAIT","Chờ tạm ứng"), ("BUYING","Đang mua"),
                        ("RECEIVED","Đã nhận hàng"), ("DELIVERING","Đang giao"), ("DELIVERED","Đã giao"), ("RETURNED","Trả hàng"),
                        ("COMPLETED","Hoàn tất"), ("REPORTED","Đã báo cáo KQKD"), ("CANCELLED","Đã hủy") })
                    {
                        <option value="@s.Item1" selected="@(Model.FilterStatus == s.Item1)">@s.Item2</option>
                    }
                </select>
            </div>
            <div class="col-6 col-sm-2 col-lg-2">
                <label class="form-label small fw-semibold mb-1">Khách hàng</label>
                <div class="position-relative" id="customerFilterWrapper">
                    <input type="hidden" name="customerId" id="filterCustomerId" value="@Model.FilterCustomerId" />
                    <input type="text" class="form-control form-control-sm" id="customerSearchInput"
                           placeholder="Tìm khách hàng..."
                           autocomplete="off"
                           value="@(Model.FilterCustomerId.HasValue ? Model.Customers.FirstOrDefault(c => c.CustomerId == Model.FilterCustomerId)?.CustomerName : "")" />
                    <div id="customerDropdown" class="position-absolute w-100 bg-white border rounded shadow-sm d-none"
                         style="z-index:1050;max-height:200px;overflow-y:auto;top:100%;left:0;">
                    </div>
                </div>
            </div>
            <div class="col-6 col-sm-2 col-lg-2">
                <label class="form-label small fw-semibold mb-1">Phụ trách</label>
                <select name="salesPersonId" class="form-select form-select-sm">
                    <option value="">Tất cả</option>
                    @foreach (var sp in Model.SalesPersons)
                    {
                        <option value="@sp.UserId" selected="@(Model.FilterSalesPersonId == sp.UserId)">@sp.FullName</option>
                    }
                </select>
            </div>
            <div class="col-6 col-sm-3 col-lg-2 d-flex gap-1">
                <button type="submit" class="btn btn-primary btn-sm flex-fill">
                    <i class="bi bi-funnel me-1"></i> Lọc
                </button>
                <a href="/SalesOrder" class="btn btn-outline-secondary btn-sm" title="Reset (mặc định: do tôi phụ trách)">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Table -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (!p.Items.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-inbox" style="font-size: 3rem; opacity: 0.3;"></i>
                <p class="mt-2 mb-0">Không tìm thấy đơn hàng nào</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" style="font-size:0.875rem;">
                    <thead class="table-light">
                        <tr>
                            <th style="width:40px;">#</th>
                            <th>Mã SO</th>
                            <th>Khách hàng</th>
                            <th class="d-none d-md-table-cell">PO KH</th>
                            <th class="d-none d-md-table-cell">Ngày tạo</th>
                            <th>Trạng thái</th>
                            @* <th class="d-none d-lg-table-cell">Nguồn mua</th> *@
                            <th class="text-end">Tổng bán</th>
                            @* <th class="text-end d-none d-lg-table-cell">Chi phí mua</th> *@
                            <th style="width:70px;">Xem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int idx = (p.PageIndex - 1) * p.PageSize + 1; }
                        @foreach (var r in p.Items)
                        {
                            <tr>
                                <td class="text-muted small">@(idx++)</td>
                                <td>
                                    <a href="/SalesOrder/Detail/@r.SalesOrderId"
                                       class="fw-semibold text-decoration-none text-dark link-hover">
                                        @r.SalesOrderNo
                                    </a>
                                </td>
                                <td>
                                    <div>@r.CustomerName</div>
                                    <div class="text-muted small">@r.CustomerCode</div>
                                </td>
                                <td class="d-none d-md-table-cell text-muted small">
                                    @(r.CustomerPoNo ?? "—")
                                </td>
                                <td class="d-none d-md-table-cell text-muted small">
                                    @r.OrderDate.ToString("dd/MM/yyyy")
                                </td>
                                <td>
                                    <span class="badge bg-@(r.StatusBadge)-subtle text-@(r.StatusBadge)-emphasis rounded-pill">
                                        <i class="bi bi-circle-fill me-1" style="font-size:0.4rem;vertical-align:middle;"></i>
                                        @r.StatusText
                                    </span>
                                </td>
                                @* <td class="d-none d-lg-table-cell text-muted small">
                                    @(r.PurchaseSource ?? "—")
                                </td> *@
                                <td class="text-end fw-semibold">
                                    @r.TotalAmount.ToString("N0")
                                </td>
                               @*  <td class="text-end d-none d-lg-table-cell text-muted small">
                                    @(r.PurchaseCost?.ToString("N0") ?? "—")
                                </td> *@
                                <td>
                                    <a href="/SalesOrder/Detail/@r.SalesOrderId"
                                       class="btn btn-sm btn-outline-secondary" title="Xem">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (p.TotalPages > 1)
            {
                <nav class="d-flex justify-content-center py-3">
                    <ul class="pagination pagination-sm mb-0">
                        @if (p.HasPrevious)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@BuildPageUrl(p.PageIndex - 1)">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                            </li>
                        }
                        @for (int pg = 1; pg <= p.TotalPages; pg++)
                        {
                            <li class="page-item @(pg == p.PageIndex ? "active" : "")">
                                <a class="page-link" href="@BuildPageUrl(pg)">@pg</a>
                            </li>
                        }
                        @if (p.HasNext)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@BuildPageUrl(p.PageIndex + 1)">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        }
    </div>
</div>

@functions {
    string BuildPageUrl(int page)
    {
        // Always emit salesPersonId (even when empty) so the controller's "no querystring → default to me"
        // logic doesn't re-apply on pagination after the user clears the assignee filter.
        var qs = new Dictionary<string, string?> {
            ["keyword"] = Model.SearchKeyword,
            ["status"] = Model.FilterStatus,
            ["customerId"] = Model.FilterCustomerId?.ToString(),
            ["salesPersonId"] = Model.FilterSalesPersonId?.ToString() ?? "",
            ["page"] = page.ToString()
        };
        return "/SalesOrder?" + string.Join("&", qs.Where(kv => kv.Value != null).Select(kv => $"{kv.Key}={kv.Value}"));
    }
}

<style>
    .link-hover:hover { color: #2563eb !important; }
    .bg-secondary-subtle { background-color: #f1f5f9 !important; }
    .text-secondary-emphasis { color: #475569 !important; }
    .bg-info-subtle { background-color: #e0f2fe !important; }
    .text-info-emphasis { color: #0369a1 !important; }
    .bg-success-subtle { background-color: #dcfce7 !important; }
    .text-success-emphasis { color: #166534 !important; }
    .bg-danger-subtle { background-color: #fee2e2 !important; }
    .text-danger-emphasis { color: #991b1b !important; }
    .bg-warning-subtle { background-color: #fef9c3 !important; }
    .text-warning-emphasis { color: #854d0e !important; }
    .bg-primary-subtle { background-color: #dbeafe !important; }
    .text-primary-emphasis { color: #1e40af !important; }
    #customerDropdown .cs-item { padding: 6px 10px; cursor: pointer; font-size: 0.82rem; }
    #customerDropdown .cs-item:hover, #customerDropdown .cs-item.active { background: #e0f2fe; }
</style>

<script>
(function () {
    var customers = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Customers.Select(c => new { c.CustomerId, c.CustomerName, c.CustomerCode })));
    var input = document.getElementById('customerSearchInput');
    var hidden = document.getElementById('filterCustomerId');
    var dd = document.getElementById('customerDropdown');

    function render(filter) {
        var kw = (filter || '').toLowerCase();
        var items = customers.filter(function (c) {
            return !kw || c.CustomerName.toLowerCase().indexOf(kw) >= 0 || c.CustomerCode.toLowerCase().indexOf(kw) >= 0;
        });

        var html = '<div class="cs-item" data-id="">Tất cả KH</div>';
        items.forEach(function (c) {
            html += '<div class="cs-item" data-id="' + c.CustomerId + '">' + c.CustomerName + ' <span class="text-muted">(' + c.CustomerCode + ')</span></div>';
        });
        dd.innerHTML = html;
        dd.classList.remove('d-none');
    }

    input.addEventListener('focus', function () { render(input.value); });
    input.addEventListener('input', function () {
        hidden.value = '';
        render(input.value);
    });

    dd.addEventListener('click', function (e) {
        var item = e.target.closest('.cs-item');
        if (!item) return;
        var id = item.getAttribute('data-id');
        hidden.value = id;
        input.value = id ? item.textContent.trim() : '';
        dd.classList.add('d-none');
    });

    document.addEventListener('click', function (e) {
        if (!document.getElementById('customerFilterWrapper').contains(e.target)) {
            dd.classList.add('d-none');
        }
    });
})();
</script>
