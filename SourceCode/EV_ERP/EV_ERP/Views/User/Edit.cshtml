@model EV_ERP.Models.ViewModels.Users.UserFormViewModel
@{
    ViewData["Title"] = "Chỉnh sửa tài khoản";
    ViewData["Breadcrumbs"] = new List<BreadcrumbItem>
    {
        new("Trang chủ", "/"),
        new("Quản lý tài khoản", "/User"),
        new("Chỉnh sửa")
    };
}

<div class="row justify-content-center">
    <div class="col-lg-6 col-md-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom py-3">
                <div class="d-flex align-items-center gap-2">
                    @* <a href="/User" class="btn btn-sm btn-light border">
                        <i class="bi bi-arrow-left"></i>
                    </a> *@
                    <h5 class="mb-0 fw-semibold">
                        <i class="bi bi-person-gear me-2 text-primary"></i>Chỉnh sửa tài khoản
                    </h5>
                </div>
            </div>
            <div class="card-body p-4">

                <form asp-action="Edit" asp-controller="User" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="UserId" />

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="UserName" class="form-label fw-semibold small"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-at"></i></span>
                                <input asp-for="UserName" class="form-control" autofocus />
                            </div>
                            <span asp-validation-for="UserName" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="FullName" class="form-label fw-semibold small"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-person"></i></span>
                                <input asp-for="FullName" class="form-control" />
                            </div>
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Email" class="form-label fw-semibold small"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                                <input asp-for="Email" class="form-control" />
                            </div>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Phone" class="form-label fw-semibold small"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-telephone"></i></span>
                                <input asp-for="Phone" class="form-control" placeholder="0901234567" />
                            </div>
                            <span asp-validation-for="Phone" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="RoleId" class="form-label fw-semibold small"></label>
                            <select asp-for="RoleId" class="form-select">
                                <option value="">-- Chọn vai trò --</option>
                                @foreach (var role in Model.Roles)
                                {
                                    <option value="@role.RoleId"
                                            selected="@(Model.RoleId == role.RoleId)">
                                        @role.RoleName
                                    </option>
                                }
                            </select>
                            <span asp-validation-for="RoleId" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" />
                                <label asp-for="IsActive" class="form-check-label small fw-semibold"></label>
                            </div>
                            <small class="text-muted">Để đặt lại mật khẩu, dùng nút <i class="bi bi-key"></i> ở danh sách tài khoản</small>
                        </div>
                    </div>

                    <hr class="my-4" />

                    <div class="d-flex gap-2 justify-content-end">
                        <a href="/User" class="btn btn-outline-secondary">Hủy</a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i> Lưu thay đổi
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
