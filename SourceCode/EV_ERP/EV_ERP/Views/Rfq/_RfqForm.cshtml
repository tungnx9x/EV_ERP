@model EV_ERP.Models.ViewModels.RFQs.RfqFormViewModel
@{
    var action = Model.IsEditMode ? "Edit" : "Create";
    var title = Model.RfqNo;
    var icon = Model.IsEditMode ? "bi-pencil-square" : "bi-file-earmark-plus";
}

<div class="row">
    <div class="col-lg-8 mx-auto">
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-white border-bottom py-3">
                <div class="d-flex align-items-center gap-2">
                    @* <a href="/Rfq" class="btn btn-sm btn-light border">
                        <i class="bi bi-arrow-left"></i>
                    </a> *@
                    <h5 class="mb-0 fw-semibold">
                        <i class="bi @icon me-2 text-primary"></i>@title
                    </h5>
                </div>
            </div>
            <div class="card-body">
                @if (Model.IsEditMode)
                {
                    <input type="hidden" id="frm_rfqId" value="@Model.RfqId" />
                }

                <div class="row g-3">
                    <!-- Khách hàng -->
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Khách hàng <span class="text-danger">*</span></label>
                        <div class="position-relative" id="customerWrapper">
                            <input type="hidden" id="frm_customerId" value="@Model.CustomerId" />
                            <input type="text" class="form-control form-control-sm" id="customerSearchInput"
                                   placeholder="Tìm khách hàng..."
                                   autocomplete="off"
                                   value="@(Model.CustomerId > 0 ? Model.Customers.FirstOrDefault(c => c.CustomerId == Model.CustomerId)?.CustomerName : "")" />
                            <div id="customerDropdown" class="position-absolute w-100 bg-white border rounded shadow-sm d-none"
                                 style="z-index:1050;max-height:200px;overflow-y:auto;top:100%;left:0;">
                            </div>
                        </div>
                    </div>

                    <!-- Ưu tiên -->
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Độ ưu tiên</label>
                        <select id="frm_priority" class="form-select form-select-sm">
                            @foreach (var pr in new[] { ("LOW","Thấp"), ("NORMAL","Bình thường"), ("HIGH","Cao"), ("URGENT","Khẩn cấp") })
                            {
                                <option value="@pr.Item1" selected="@(Model.Priority == pr.Item1)">@pr.Item2</option>
                            }
                        </select>
                    </div>

                    <!-- Ngày yêu cầu -->
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Ngày yêu cầu</label>
                        <input type="date" id="frm_requestDate" class="form-control form-control-sm"
                               value="@Model.RequestDate.ToString("yyyy-MM-dd")" />
                    </div>

                    <!-- Hạn xử lý -->
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Hạn xử lý <span class="text-danger">*</span></label>
                        <input type="datetime-local" id="frm_deadline" class="form-control form-control-sm"
                               value="@(Model.Deadline?.ToString("yyyy-MM-ddTHH:mm"))" />
                    </div>

                    <!-- Phân công -->
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Phân công cho</label>
                        <div class="position-relative" id="assignedToWrapper">
                            <input type="hidden" id="frm_assignedTo" value="@Model.AssignedTo" />
                            <input type="text" class="form-control form-control-sm" id="assignedToSearchInput"
                                   placeholder="Tìm nhân viên..."
                                   autocomplete="off"
                                   value="@(Model.AssignedTo.HasValue ? Model.Users.FirstOrDefault(u => u.UserId == Model.AssignedTo)?.FullName : "")" />
                            <div id="assignedToDropdown" class="position-absolute w-100 bg-white border rounded shadow-sm d-none"
                                 style="z-index:1050;max-height:200px;overflow-y:auto;top:100%;left:0;">
                            </div>
                        </div>
                    </div>

                    <!-- Mô tả -->
                    <div class="col-12">
                        <label class="form-label small fw-semibold">Mô tả yêu cầu</label>
                        <div id="frm_description_editor">@Html.Raw(Model.Description)</div>
                    </div>

                    <!-- Ghi chú -->
                    <div class="col-12">
                        <label class="form-label small fw-semibold">Ghi chú</label>
                        <textarea id="frm_notes" class="form-control form-control-sm" rows="2"
                                  placeholder="Ghi chú nội bộ...">@Model.Notes</textarea>
                    </div>

                    <!-- Tệp yêu cầu khách hàng -->
                    <div class="col-12">
                        <label class="form-label small fw-semibold">
                            <i class="bi bi-paperclip me-1"></i>Tệp yêu cầu khách hàng
                        </label>
                        <div class="border rounded p-3 bg-light-subtle">
                            <input type="file" id="frm_attachmentInput" class="d-none" multiple
                                   accept=".pdf,.doc,.docx,.xls,.xlsx,.csv,.txt,.jpg,.jpeg,.png,.gif,.webp" />
                            <button type="button" class="btn btn-sm btn-outline-primary"
                                    onclick="document.getElementById('frm_attachmentInput').click()">
                                <i class="bi bi-upload me-1"></i>Chọn tệp
                            </button>
                            <span class="text-muted small ms-2">PDF, Word, Excel, CSV, TXT, ảnh — tối đa 20MB/tệp</span>
                            <div id="frm_attachmentList" class="mt-2 d-flex flex-column gap-1"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Actions -->
        <div class="d-flex gap-2 justify-content-end mb-4">
            <a href="/Rfq" class="btn btn-outline-secondary">Hủy</a>
            <button type="button" class="btn btn-primary" onclick="submitForm()" id="btnSubmit">
                <i class="bi bi-check-lg me-1"></i>
                @(Model.IsEditMode ? "Cập nhật" : "Tạo yêu cầu")
            </button>
        </div>
    </div>
</div>

<script src="https://cdn.ckeditor.com/ckeditor5/41.4.2/classic/ckeditor.js"></script>
<script>
    function RfqImageUploadAdapter(loader) {
        this.loader = loader;
    }
    RfqImageUploadAdapter.prototype.upload = function () {
        var loader = this.loader;
        return loader.file.then(function (file) {
            return new Promise(function (resolve, reject) {
                var data = new FormData();
                data.append('file', file);
                data.append('__RequestVerificationToken',
                    document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '');
                fetch('/Rfq/UploadImage', { method: 'POST', body: data })
                    .then(function (r) { return r.json(); })
                    .then(function (res) {
                        if (res.Success) resolve({ default: res.Data.url });
                        else reject(res.Message);
                    })
                    .catch(reject);
            });
        });
    };
    RfqImageUploadAdapter.prototype.abort = function () {};

    function RfqImageUploadAdapterPlugin(editor) {
        editor.plugins.get('FileRepository').createUploadAdapter = function (loader) {
            return new RfqImageUploadAdapter(loader);
        };
    }

    var descriptionEditor;
    ClassicEditor.create(document.getElementById('frm_description_editor'), {
        extraPlugins: [RfqImageUploadAdapterPlugin],
        toolbar: ['heading', '|', 'bold', 'italic', 'underline', '|',
                  'bulletedList', 'numberedList', '|', 'link', 'imageUpload', 'blockQuote', '|', 'undo', 'redo'],
        placeholder: 'Mô tả chi tiết yêu cầu từ khách hàng...',
        image: {
            toolbar: ['imageStyle:inline', 'imageStyle:block', '|', 'imageTextAlternative']
        }
    }).then(function (editor) {
        descriptionEditor = editor;
    });

    function submitForm() {
        var customerId = parseInt(document.getElementById('frm_customerId').value);
        if (!customerId) {
            appAlert('Vui lòng chọn khách hàng');
            return;
        }

        var deadlineVal = document.getElementById('frm_deadline').value;
        if (!deadlineVal) {
            appAlert('Vui lòng chọn hạn xử lý');
            return;
        }

        var rfqIdEl = document.getElementById('frm_rfqId');
        var isEdit = !!rfqIdEl;
        var assignedTo = parseInt(document.getElementById('frm_assignedTo').value) || null;

        var payload = {
            RfqId: isEdit ? parseInt(rfqIdEl.value) : null,
            CustomerId: customerId,
            RequestDate: document.getElementById('frm_requestDate').value,
            Deadline: document.getElementById('frm_deadline').value,
            Priority: document.getElementById('frm_priority').value,
            AssignedTo: assignedTo,
            Description: descriptionEditor ? (descriptionEditor.getData().trim() || null) : null,
            Notes: document.getElementById('frm_notes').value.trim() || null,
            AttachmentIds: window.rfqAttachmentIds || []
        };

        if (window.rfqAttachmentUploading) {
            appAlert('Đang tải tệp lên, vui lòng đợi hoàn tất');
            return;
        }

        var btn = document.getElementById('btnSubmit');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Đang xử lý...';

        var url = isEdit ? '/Rfq/Edit' : '/Rfq/Create';

        fetch(url, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? ''
            },
            body: JSON.stringify(payload)
        })
        .then(function (r) { return r.json(); })
        .then(function (data) {
            if (data.Success) {
                window.location.href = '/Rfq/Detail/' + data.Data.RfqId;
            } else {
                appAlert(data.Message || 'Có lỗi xảy ra');
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-check-lg me-1"></i>' + (isEdit ? 'Cập nhật' : 'Tạo yêu cầu');
            }
        })
        .catch(function () {
            appAlert('Lỗi kết nối');
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-check-lg me-1"></i>' + (isEdit ? 'Cập nhật' : 'Tạo yêu cầu');
        });
    }
    // ── Searchable assigned-to dropdown ─────────────────
    (function () {
        var users = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Users.Select(u => new { u.UserId, u.FullName, u.UserCode })));
        var input = document.getElementById('assignedToSearchInput');
        var hidden = document.getElementById('frm_assignedTo');
        var dd = document.getElementById('assignedToDropdown');

        function render(filter) {
            var kw = (filter || '').toLowerCase();
            var items = users.filter(function (u) {
                return !kw || u.FullName.toLowerCase().indexOf(kw) >= 0 || u.UserCode.toLowerCase().indexOf(kw) >= 0;
            });
            var html = '<div class="cs-item" data-id="" style="padding:6px 10px;cursor:pointer;font-size:0.82rem;">-- Chưa phân công --</div>';
            items.forEach(function (u) {
                html += '<div class="cs-item" data-id="' + u.UserId + '" style="padding:6px 10px;cursor:pointer;font-size:0.82rem;">'
                    + u.FullName + ' <span class="text-muted">(' + u.UserCode + ')</span></div>';
            });
            dd.innerHTML = html;
            dd.classList.remove('d-none');
        }

        input.addEventListener('focus', function () { render(input.value); });
        input.addEventListener('input', function () { hidden.value = ''; render(input.value); });

        dd.addEventListener('mouseover', function (e) {
            dd.querySelectorAll('.cs-item').forEach(function (el) { el.style.background = ''; });
            var item = e.target.closest('.cs-item');
            if (item) item.style.background = '#e0f2fe';
        });
        dd.addEventListener('click', function (e) {
            var item = e.target.closest('.cs-item');
            if (!item) return;
            var id = item.getAttribute('data-id');
            hidden.value = id;
            input.value = id ? item.textContent.trim() : '';
            dd.classList.add('d-none');
        });

        document.addEventListener('click', function (e) {
            if (!document.getElementById('assignedToWrapper').contains(e.target))
                dd.classList.add('d-none');
        });
    })();

    // ── Searchable customer dropdown ────────────────────
    (function () {
        var customers = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Customers.Select(c => new { c.CustomerId, c.CustomerName, c.CustomerCode })));
        var input = document.getElementById('customerSearchInput');
        var hidden = document.getElementById('frm_customerId');
        var dd = document.getElementById('customerDropdown');

        function render(filter) {
            var kw = (filter || '').toLowerCase();
            var items = customers.filter(function (c) {
                return !kw || c.CustomerName.toLowerCase().indexOf(kw) >= 0 || c.CustomerCode.toLowerCase().indexOf(kw) >= 0;
            });
            var html = '';
            if (items.length === 0) {
                html = '<div class="text-muted small text-center py-2">Không tìm thấy khách hàng</div>';
            } else {
                items.forEach(function (c) {
                    html += '<div class="cs-item" data-id="' + c.CustomerId + '" style="padding:6px 10px;cursor:pointer;font-size:0.82rem;">'
                        + c.CustomerName + ' <span class="text-muted">(' + c.CustomerCode + ')</span></div>';
                });
            }
            dd.innerHTML = html;
            dd.classList.remove('d-none');
        }

        input.addEventListener('focus', function () { render(input.value); });
        input.addEventListener('input', function () { hidden.value = ''; render(input.value); });

        dd.addEventListener('mouseover', function (e) {
            dd.querySelectorAll('.cs-item').forEach(function (el) { el.style.background = ''; });
            var item = e.target.closest('.cs-item');
            if (item) item.style.background = '#e0f2fe';
        });
        dd.addEventListener('click', function (e) {
            var item = e.target.closest('.cs-item');
            if (!item) return;
            var id = item.getAttribute('data-id');
            hidden.value = id;
            input.value = item.textContent.trim();
            dd.classList.add('d-none');
        });

        document.addEventListener('click', function (e) {
            if (!document.getElementById('customerWrapper').contains(e.target))
                dd.classList.add('d-none');
        });
    })();

    // ── Customer requirement attachments ────────────────
    (function () {
        var rfqIdEl = document.getElementById('frm_rfqId');
        var isEdit = !!rfqIdEl;
        var rfqId = isEdit ? parseInt(rfqIdEl.value) : 0;
        var input = document.getElementById('frm_attachmentInput');
        var listEl = document.getElementById('frm_attachmentList');
        var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';

        window.rfqAttachmentIds = [];          // ids of files belonging to this form
        window.rfqAttachmentUploading = false;
        var files = {};                         // attachmentId -> { fileName, fileUrl }

        function fmtSize(bytes) {
            if (!bytes && bytes !== 0) return '';
            if (bytes < 1024) return bytes + ' B';
            if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(0) + ' KB';
            return (bytes / 1024 / 1024).toFixed(1) + ' MB';
        }
        function iconFor(name) {
            var ext = (name.split('.').pop() || '').toLowerCase();
            if (['jpg', 'jpeg', 'png', 'gif', 'webp'].indexOf(ext) >= 0) return 'bi-file-earmark-image text-info';
            if (ext === 'pdf') return 'bi-file-earmark-pdf text-danger';
            if (['doc', 'docx'].indexOf(ext) >= 0) return 'bi-file-earmark-word text-primary';
            if (['xls', 'xlsx', 'csv'].indexOf(ext) >= 0) return 'bi-file-earmark-excel text-success';
            return 'bi-file-earmark-text text-secondary';
        }
        function render() {
            var ids = window.rfqAttachmentIds;
            if (ids.length === 0) {
                listEl.innerHTML = '<div class="text-muted small fst-italic">Chưa có tệp nào</div>';
                return;
            }
            listEl.innerHTML = ids.map(function (id) {
                var f = files[id];
                return '<div class="d-flex align-items-center gap-2 bg-white border rounded px-2 py-1">'
                    + '<i class="bi ' + iconFor(f.fileName) + '"></i>'
                    + '<a href="' + f.fileUrl + '" target="_blank" class="text-decoration-none small text-truncate flex-grow-1" title="' + f.fileName + '">' + f.fileName + '</a>'
                    + (f.fileSize != null ? '<span class="text-muted small">' + fmtSize(f.fileSize) + '</span>' : '')
                    + '<button type="button" class="btn btn-sm btn-link text-danger p-0" title="Xóa" data-del="' + id + '"><i class="bi bi-x-lg"></i></button>'
                    + '</div>';
            }).join('');
        }

        // Load existing files in edit mode
        if (isEdit && rfqId > 0) {
            fetch('/Rfq/GetAttachments?rfqId=' + rfqId)
                .then(function (r) { return r.json(); })
                .then(function (res) {
                    if (res.Success && res.Data) {
                        res.Data.forEach(function (a) {
                            files[a.AttachmentId] = { fileName: a.FileName, fileUrl: a.FileUrl, fileSize: a.FileSize };
                            window.rfqAttachmentIds.push(a.AttachmentId);
                        });
                    }
                    render();
                })
                .catch(render);
        } else {
            render();
        }

        input.addEventListener('change', function () {
            var selected = Array.prototype.slice.call(input.files);
            input.value = '';
            if (selected.length === 0) return;

            window.rfqAttachmentUploading = true;
            var url = (isEdit && rfqId > 0) ? '/Rfq/UploadAttachment' : '/Rfq/UploadTempAttachment';

            var chain = Promise.resolve();
            selected.forEach(function (file) {
                chain = chain.then(function () {
                    var data = new FormData();
                    data.append('file', file);
                    if (isEdit && rfqId > 0) data.append('rfqId', rfqId);
                    data.append('__RequestVerificationToken', token);
                    return fetch(url, { method: 'POST', body: data })
                        .then(function (r) { return r.json(); })
                        .then(function (res) {
                            if (res.Success && res.Data) {
                                files[res.Data.AttachmentId] = {
                                    fileName: res.Data.FileName, fileUrl: res.Data.FileUrl, fileSize: file.size
                                };
                                window.rfqAttachmentIds.push(res.Data.AttachmentId);
                                render();
                            } else {
                                appToast(res.Message || ('Tải lên thất bại: ' + file.name), 'error');
                            }
                        })
                        .catch(function () { appToast('Lỗi tải lên: ' + file.name, 'error'); });
                });
            });
            chain.finally(function () { window.rfqAttachmentUploading = false; });
        });

        listEl.addEventListener('click', function (e) {
            var btn = e.target.closest('[data-del]');
            if (!btn) return;
            var id = parseInt(btn.getAttribute('data-del'));
            appConfirm('Xóa tệp này?').then(function (ok) {
                if (!ok) return;
                var data = new FormData();
                data.append('attachmentId', id);
                data.append('__RequestVerificationToken', token);
                fetch('/Rfq/DeleteAttachment', { method: 'POST', body: data })
                    .then(function (r) { return r.json(); })
                    .then(function (res) {
                        if (res.Success) {
                            delete files[id];
                            window.rfqAttachmentIds = window.rfqAttachmentIds.filter(function (x) { return x !== id; });
                            render();
                        } else {
                            appToast(res.Message || 'Xóa thất bại', 'error');
                        }
                    })
                    .catch(function () { appToast('Lỗi xóa tệp', 'error'); });
            });
        });
    })();
</script>
@Html.AntiForgeryToken()
