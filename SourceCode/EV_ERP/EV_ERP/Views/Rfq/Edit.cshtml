@model EV_ERP.Models.ViewModels.RFQs.RfqFormViewModel
@{
    ViewData["Title"] = "Chỉnh sửa yêu cầu báo giá";
    ViewData["Breadcrumbs"] = new List<BreadcrumbItem>
    {
        new("Trang chủ", "/"),
        new("Yêu cầu báo giá", "/Rfq"),
        new(string.IsNullOrEmpty(Model.RfqNo) ? "Chỉnh sửa" : Model.RfqNo, $"/Rfq/Detail/{Model.RfqId}"),
        new("Chỉnh sửa")
    };
}
<partial name="_RfqForm" model="Model" />
