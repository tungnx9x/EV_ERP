@model EV_ERP.Models.ViewModels.Dashboard.DashboardViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Dashboard";

    var groupLabels  = JsonSerializer.Serialize(Model.CustomerGroupLabels);
    var groupCounts  = JsonSerializer.Serialize(Model.CustomerGroupCounts);
    var monthLabels  = JsonSerializer.Serialize(Model.MonthLabels);
    var monthCounts  = JsonSerializer.Serialize(Model.NewCustomerCounts);
    var roleLabels   = JsonSerializer.Serialize(Model.RoleLabels);
    var roleCounts   = JsonSerializer.Serialize(Model.RoleCounts);
}

<!-- Welcome banner -->
<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm"
             style="background: linear-gradient(135deg, #1a2d4e, #2563eb); color:#fff;">
            <div class="card-body py-4 px-4">
                <div class="d-flex align-items-center gap-3">
                    <div style="width:52px;height:52px;border-radius:50%;
                                background:rgba(255,255,255,0.2);
                                display:flex;align-items:center;justify-content:center;
                                font-size:1.5rem;font-weight:700;flex-shrink:0;">
                        @Model.CurrentUser.FullName[0].ToString().ToUpper()
                    </div>
                    <div>
                        <h5 class="mb-0 fw-bold">Xin chào, @Model.CurrentUser.FullName!</h5>
                        <small style="opacity:.8;">
                            @Model.CurrentUser.RoleName &bull; @Model.CurrentUser.UserCode
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Summary cards -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon" style="background:#eff6ff;">
                    <i class="bi bi-building" style="color:#2563eb;"></i>
                </div>
                <div>
                    <div class="stat-value">@Model.TotalCustomers</div>
                    <div class="text-muted small">Khách hàng</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon" style="background:#f0fdf4;">
                    <i class="bi bi-people" style="color:#16a34a;"></i>
                </div>
                <div>
                    <div class="stat-value">@Model.TotalUsers</div>
                    <div class="text-muted small">Nhân viên</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon" style="background:#fffbeb;">
                    <i class="bi bi-file-earmark-text" style="color:#d97706;"></i>
                </div>
                <div>
                    <div class="stat-value text-muted">--</div>
                    <div class="text-muted small">Báo giá chờ</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon" style="background:#fef2f2;">
                    <i class="bi bi-archive" style="color:#dc2626;"></i>
                </div>
                <div>
                    <div class="stat-value text-muted">--</div>
                    <div class="text-muted small">Sắp hết kho</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Charts row -->
<div class="row g-3 mb-3">
    <!-- Bar: New customers per month -->
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-bottom py-3 d-flex align-items-center justify-content-between">
                <h6 class="mb-0 fw-semibold">
                    <i class="bi bi-building me-2 text-primary"></i>Khách hàng mới theo tháng
                </h6>
                <span class="badge bg-primary-subtle text-primary rounded-pill" style="font-size:.7rem;">
                    6 tháng gần nhất
                </span>
            </div>
            <div class="card-body d-flex align-items-center justify-content-center" style="min-height:260px;">
                @if (Model.TotalCustomers == 0)
                {
                    <div class="text-center text-muted">
                        <i class="bi bi-building" style="font-size:2.5rem;opacity:.2;"></i>
                        <p class="small mt-2 mb-0">Chưa có dữ liệu khách hàng</p>
                    </div>
                }
                else
                {
                    <canvas id="chartNewCustomers" style="max-height:240px;width:100%;"></canvas>
                }
            </div>
        </div>
    </div>

    <!-- Doughnut: Customers by group -->
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-bottom py-3">
                <h6 class="mb-0 fw-semibold">
                    <i class="bi bi-pie-chart me-2 text-warning"></i>Phân loại khách hàng
                </h6>
            </div>
            <div class="card-body d-flex align-items-center justify-content-center" style="min-height:260px;">
                @if (Model.TotalCustomers == 0)
                {
                    <div class="text-center text-muted">
                        <i class="bi bi-pie-chart" style="font-size:2.5rem;opacity:.2;"></i>
                        <p class="small mt-2 mb-0">Chưa có dữ liệu</p>
                    </div>
                }
                else
                {
                    <canvas id="chartCustomerGroups" style="max-height:220px;"></canvas>
                }
            </div>
        </div>
    </div>
</div>

<!-- Second charts row -->
<div class="row g-3">
    <!-- Doughnut: Users by role -->
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-bottom py-3">
                <h6 class="mb-0 fw-semibold">
                    <i class="bi bi-people me-2 text-success"></i>Nhân viên theo vai trò
                </h6>
            </div>
            <div class="card-body d-flex align-items-center justify-content-center" style="min-height:220px;">
                @if (Model.TotalUsers == 0)
                {
                    <div class="text-center text-muted">
                        <i class="bi bi-people" style="font-size:2.5rem;opacity:.2;"></i>
                        <p class="small mt-2 mb-0">Chưa có dữ liệu</p>
                    </div>
                }
                else
                {
                    <canvas id="chartUserRoles" style="max-height:200px;"></canvas>
                }
            </div>
        </div>
    </div>

    <!-- Placeholder: Revenue (future) -->
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-bottom py-3 d-flex align-items-center justify-content-between">
                <h6 class="mb-0 fw-semibold">
                    <i class="bi bi-bar-chart-line me-2 text-secondary"></i>Doanh thu theo tháng
                </h6>
                <span class="badge bg-secondary-subtle text-secondary rounded-pill" style="font-size:.7rem;">
                    Sắp có
                </span>
            </div>
            <div class="card-body d-flex align-items-center justify-content-center"
                 style="min-height:220px;">
                <div class="text-center text-muted">
                    <i class="bi bi-bar-chart-line" style="font-size:3rem;opacity:.15;"></i>
                    <p class="mt-2 mb-1 fw-semibold small" style="color:#94a3b8;">
                        Dữ liệu doanh thu sẽ hiển thị khi module Bán hàng được kích hoạt
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .stat-icon {
        width: 46px; height: 46px; border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }
    .stat-icon i { font-size: 1.3rem; }
    .stat-value { font-size: 1.5rem; font-weight: 700; color: #1e293b; line-height: 1.2; }
    .bg-primary-subtle { background-color: #dbeafe !important; }
    .text-primary { color: #2563eb !important; }
    .bg-secondary-subtle { background-color: #f1f5f9 !important; }
    .text-secondary { color: #64748b !important; }
</style>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script>
    Chart.defaults.font.family = "'Segoe UI', sans-serif";
    Chart.defaults.font.size = 12;
    Chart.defaults.color = '#64748b';

    var palette = ['#2563eb','#16a34a','#d97706','#dc2626','#7c3aed','#0891b2','#db2777'];

    // ── Bar: new customers per month ─────────────
    var ctxBar = document.getElementById('chartNewCustomers');
    if (ctxBar) {
        new Chart(ctxBar, {
            type: 'bar',
            data: {
                labels: @Html.Raw(monthLabels),
                datasets: [{
                    label: 'Khách hàng mới',
                    data: @Html.Raw(monthCounts),
                    backgroundColor: 'rgba(37,99,235,0.15)',
                    borderColor: '#2563eb',
                    borderWidth: 2,
                    borderRadius: 6,
                    borderSkipped: false
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: ctx => ' ' + ctx.parsed.y + ' khách hàng'
                        }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: { stepSize: 1, precision: 0 },
                        grid: { color: 'rgba(0,0,0,0.05)' }
                    },
                    x: { grid: { display: false } }
                }
            }
        });
    }

    // ── Doughnut: customers by group ─────────────
    var ctxGroup = document.getElementById('chartCustomerGroups');
    if (ctxGroup) {
        var gLabels = @Html.Raw(groupLabels);
        var gCounts = @Html.Raw(groupCounts);
        new Chart(ctxGroup, {
            type: 'doughnut',
            data: {
                labels: gLabels,
                datasets: [{
                    data: gCounts,
                    backgroundColor: palette.slice(0, gLabels.length),
                    borderWidth: 2,
                    borderColor: '#fff'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                cutout: '65%',
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: { boxWidth: 12, padding: 12, font: { size: 11 } }
                    },
                    tooltip: {
                        callbacks: {
                            label: ctx => ' ' + ctx.label + ': ' + ctx.parsed + ' KH'
                        }
                    }
                }
            }
        });
    }

    // ── Doughnut: users by role ───────────────────
    var ctxRole = document.getElementById('chartUserRoles');
    if (ctxRole) {
        var rLabels = @Html.Raw(roleLabels);
        var rCounts = @Html.Raw(roleCounts);
        var roleColors = ['#7c3aed','#2563eb','#16a34a','#d97706','#0891b2'];
        new Chart(ctxRole, {
            type: 'doughnut',
            data: {
                labels: rLabels,
                datasets: [{
                    data: rCounts,
                    backgroundColor: roleColors.slice(0, rLabels.length),
                    borderWidth: 2,
                    borderColor: '#fff'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                cutout: '65%',
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: { boxWidth: 12, padding: 12, font: { size: 11 } }
                    },
                    tooltip: {
                        callbacks: {
                            label: ctx => ' ' + ctx.label + ': ' + ctx.parsed + ' người'
                        }
                    }
                }
            }
        });
    }
</script>
}
