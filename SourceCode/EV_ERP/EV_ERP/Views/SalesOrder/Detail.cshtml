    // Bước 3→4: Kế toán xác nhận chi tiền
    async function disburseAdvance(advId, advNo) {
        if (!await appConfirm('Xác nhận đã chi tiền cho đề nghị ' + advNo + '?')) return;
        postAction('/AdvanceRequest/Disburse?id=' + advId, null, function (data) {
