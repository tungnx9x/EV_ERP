@model EV_ERP.Models.ViewModels.Products.ProductCategoryFormViewModel
@{
    ViewData["Title"] = "Chỉnh sửa danh mục";
}

<div class="row justify-content-center">
    <div class="col-xl-6 col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom py-3">
                <div class="d-flex align-items-center gap-2">
                    <a href="/ProductCategory" class="btn btn-sm btn-light border">
                        <i class="bi bi-arrow-left"></i>
                    </a>
                    <div>
                        <h5 class="mb-0 fw-semibold">
                            <i class="bi bi-pencil me-2 text-primary"></i>Chỉnh sửa danh mục
                        </h5>
                        <div class="text-muted small font-monospace">@Model.CategoryCode</div>
                    </div>
                </div>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit" asp-controller="ProductCategory" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="CategoryId" />
                    <input type="hidden" asp-for="CategoryCode" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                    @await Html.PartialAsync("_CategoryForm", Model)

                    <hr class="my-4" />
                    <div class="d-flex gap-2 justify-content-end">
                        <a href="/ProductCategory" class="btn btn-outline-secondary">Hủy</a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i> Cập nhật
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
