@model EV_ERP.Models.ViewModels.Stock.WarehouseDetailViewModel
@{
    ViewData["Title"] = Model.WarehouseName;
    ViewData["Breadcrumbs"] = new List<BreadcrumbItem>
    {
        new("Trang chủ", "/"),
        new("Tồn kho", "/Inventory"),
        new("Kho hàng", "/Warehouse"),
        new(Model.WarehouseName)
    };
    bool canEdit = ViewBag.CanEdit == true;
    bool canDelete = ViewBag.CanDelete == true;
}

<!-- Header -->
<div class="d-flex align-items-start justify-content-between mb-3 flex-wrap gap-2">
    <div class="d-flex align-items-center gap-3">
        <a href="/Warehouse" class="btn btn-sm btn-light border">
            <i class="bi bi-arrow-left"></i>
        </a>
        <div>
            <h5 class="mb-0 fw-bold">@Model.WarehouseName</h5>
            <div class="text-muted small">
                @Model.WarehouseCode
                @if (Model.IsVirtual)
                {
                    <span class="ms-1 badge bg-info-subtle text-info-emphasis rounded-pill">Kho ảo</span>
                }
                @if (Model.IsActive)
                {
                    <span class="ms-1 badge bg-success-subtle text-success-emphasis rounded-pill">
                        <i class="bi bi-circle-fill me-1" style="font-size:0.4rem;vertical-align:middle;"></i>Hoạt động
                    </span>
                }
                else
                {
                    <span class="ms-1 badge bg-secondary-subtle text-secondary-emphasis rounded-pill">Vô hiệu</span>
                }
            </div>
        </div>
    </div>
    @if (canEdit)
    {
        <a href="/Warehouse/Edit/@Model.WarehouseId" class="btn btn-primary btn-sm">
            <i class="bi bi-pencil me-1"></i> Chỉnh sửa
        </a>
    }
</div>

<!-- Content -->
<div class="row g-3">
    <!-- Left: Info cards -->
    <div class="col-lg-4">
        <!-- General info -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <h6 class="fw-semibold text-muted text-uppercase mb-3" style="font-size:0.72rem;letter-spacing:.06em;">
                    Thông tin kho
                </h6>
                @if (!string.IsNullOrEmpty(Model.Address))
                {
                    <div class="d-flex align-items-start gap-2 mb-2 small">
                        <i class="bi bi-geo-alt text-muted mt-1" style="width:16px;flex-shrink:0;"></i>
                        <span>@Model.Address</span>
                    </div>
                }
                <div class="d-flex align-items-center gap-2 mb-2 small">
                    <i class="bi bi-person text-muted" style="width:16px;"></i>
                    <span>Quản lý: <strong>@(Model.ManagerName ?? "Chưa phân công")</strong></span>
                </div>
                <div class="d-flex align-items-center gap-2 mb-2 small">
                    <i class="bi bi-calendar text-muted" style="width:16px;"></i>
                    <span>Ngày tạo: @Model.CreatedAt.ToString("dd/MM/yyyy")</span>
                </div>
            </div>
        </div>

        <!-- Inventory summary -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <h6 class="fw-semibold text-muted text-uppercase mb-3" style="font-size:0.72rem;letter-spacing:.06em;">
                    Tồn kho
                </h6>
                <div class="row g-2 small">
                    <div class="col-6">
                        <div class="text-muted">Sản phẩm</div>
                        <div class="fw-semibold fs-5">@Model.TotalProductCount</div>
                    </div>
                    <div class="col-6">
                        <div class="text-muted">Tổng SL tồn</div>
                        <div class="fw-semibold fs-5">@Model.TotalQuantityOnHand.ToString("N0")</div>
                    </div>
                    <div class="col-6">
                        <div class="text-muted">Vị trí</div>
                        <div class="fw-semibold fs-5">@Model.Locations.Count(l => l.IsActive)</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Right: Locations tab -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center">
                <h6 class="mb-0 fw-semibold">
                    <i class="bi bi-pin-map me-1"></i>
                    Vị trí kho
                    <span class="badge bg-secondary-subtle text-secondary-emphasis ms-1">@Model.Locations.Count</span>
                </h6>
                @if (canEdit)
                {
                    <button class="btn btn-sm btn-outline-primary" onclick="openLocationModal(null)">
                        <i class="bi bi-plus-lg me-1"></i> Thêm vị trí
                    </button>
                }
            </div>
            <div class="card-body p-0">
                @if (!Model.Locations.Any())
                {
                    <div class="text-center py-4 text-muted">
                        <i class="bi bi-pin-map" style="font-size:2rem;opacity:.3;"></i>
                        <p class="small mt-2 mb-0">Chưa có vị trí nào</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-hover align-middle mb-0" style="font-size:0.82rem;">
                            <thead class="table-light">
                                <tr>
                                    <th>Mã vị trí</th>
                                    <th>Tên</th>
                                    <th class="d-none d-md-table-cell">Khu</th>
                                    <th class="d-none d-lg-table-cell">Dãy</th>
                                    <th class="d-none d-lg-table-cell">Kệ</th>
                                    <th class="d-none d-lg-table-cell">Tầng</th>
                                    <th class="d-none d-lg-table-cell">Ô</th>
                                    <th>Trạng thái</th>
                                    @if (canEdit)
                                    {
                                        <th style="width:80px;"></th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var loc in Model.Locations)
                                {
                                    <tr class="@(!loc.IsActive ? "table-secondary" : "")">
                                        <td class="fw-semibold font-monospace">@loc.LocationCode</td>
                                        <td>@loc.LocationName</td>
                                        <td class="d-none d-md-table-cell text-muted">@(loc.Zone ?? "—")</td>
                                        <td class="d-none d-lg-table-cell text-muted">@(loc.Aisle ?? "—")</td>
                                        <td class="d-none d-lg-table-cell text-muted">@(loc.Rack ?? "—")</td>
                                        <td class="d-none d-lg-table-cell text-muted">@(loc.Shelf ?? "—")</td>
                                        <td class="d-none d-lg-table-cell text-muted">@(loc.Bin ?? "—")</td>
                                        <td>
                                            @if (loc.IsActive)
                                            {
                                                <span class="badge bg-success-subtle text-success-emphasis rounded-pill" style="font-size:0.7rem;">
                                                    Hoạt động
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary-subtle text-secondary-emphasis rounded-pill" style="font-size:0.7rem;">
                                                    Vô hiệu
                                                </span>
                                            }
                                        </td>
                                        @if (canEdit)
                                        {
                                            <td>
                                                <div class="d-flex gap-1">
                                                    <button class="btn btn-xs btn-outline-secondary"
                                                            onclick="openLocationModal(@loc.LocationId, '@loc.LocationCode.Replace("'", "\\'")', '@loc.LocationName.Replace("'", "\\'")', '@(loc.Zone?.Replace("'", "\\'") ?? "")', '@(loc.Aisle?.Replace("'", "\\'") ?? "")', '@(loc.Rack?.Replace("'", "\\'") ?? "")', '@(loc.Shelf?.Replace("'", "\\'") ?? "")', '@(loc.Bin?.Replace("'", "\\'") ?? "")', '@(loc.MaxCapacity?.ToString() ?? "")')"
                                                            title="Sửa">
                                                        <i class="bi bi-pencil" style="font-size:.75rem;"></i>
                                                    </button>
                                                    <button class="btn btn-xs @(loc.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                                            onclick="toggleLocationActive(@loc.LocationId)"
                                                            title="@(loc.IsActive ? "Vô hiệu hóa" : "Kích hoạt lại")">
                                                        <i class="bi @(loc.IsActive ? "bi-slash-circle" : "bi-check-circle")" style="font-size:.75rem;"></i>
                                                    </button>
                                                </div>
                                            </td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Location Modal -->
<div class="modal fade" id="locationModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title fw-bold" id="locationModalTitle">Thêm vị trí</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="locationModalError" class="alert alert-danger py-2 small" style="display:none;"></div>
                <input type="hidden" id="loc_id" />

                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label small fw-semibold">Mã vị trí <span class="text-danger">*</span></label>
                        <input type="text" id="loc_code" class="form-control form-control-sm"
                               placeholder="VD: A-01-02-03" />
                    </div>
                    <div class="col-md-8">
                        <label class="form-label small fw-semibold">Tên vị trí <span class="text-danger">*</span></label>
                        <input type="text" id="loc_name" class="form-control form-control-sm"
                               placeholder="VD: Khu A > Dãy 1 > Kệ 2 > Tầng 3" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-semibold">Khu vực (Zone)</label>
                        <input type="text" id="loc_zone" class="form-control form-control-sm"
                               placeholder="A, B, Khu Khô..." />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-semibold">Dãy (Aisle)</label>
                        <input type="text" id="loc_aisle" class="form-control form-control-sm"
                               placeholder="01, 02..." />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-semibold">Kệ (Rack)</label>
                        <input type="text" id="loc_rack" class="form-control form-control-sm"
                               placeholder="01, 02..." />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-semibold">Tầng (Shelf)</label>
                        <input type="text" id="loc_shelf" class="form-control form-control-sm"
                               placeholder="01, 02..." />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-semibold">Ô (Bin)</label>
                        <input type="text" id="loc_bin" class="form-control form-control-sm"
                               placeholder="01, 02..." />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-semibold">Sức chứa tối đa</label>
                        <input type="number" id="loc_capacity" class="form-control form-control-sm"
                               placeholder="Số lượng" min="0" step="1" />
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-sm btn-primary" onclick="saveLocation()">
                    <i class="bi bi-check-lg me-1"></i> Lưu
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    .btn-xs { padding: .15rem .35rem; font-size: .75rem; }
    .bg-success-subtle { background-color: #dcfce7 !important; }
    .text-success-emphasis { color: #166534 !important; }
    .bg-secondary-subtle { background-color: #f1f5f9 !important; }
    .text-secondary-emphasis { color: #475569 !important; }
    .bg-info-subtle { background-color: #e0f2fe !important; }
    .text-info-emphasis { color: #075985 !important; }
</style>

<script>
    var warehouseId = @Model.WarehouseId;

    function openLocationModal(id, code, name, zone, aisle, rack, shelf, bin, capacity) {
        document.getElementById('locationModalTitle').textContent = id ? 'Sửa vị trí' : 'Thêm vị trí';
        document.getElementById('loc_id').value = id ?? '';
        document.getElementById('loc_code').value = code ?? '';
        document.getElementById('loc_name').value = name ?? '';
        document.getElementById('loc_zone').value = zone ?? '';
        document.getElementById('loc_aisle').value = aisle ?? '';
        document.getElementById('loc_rack').value = rack ?? '';
        document.getElementById('loc_shelf').value = shelf ?? '';
        document.getElementById('loc_bin').value = bin ?? '';
        document.getElementById('loc_capacity').value = capacity ?? '';
        document.getElementById('locationModalError').style.display = 'none';
        new bootstrap.Modal(document.getElementById('locationModal')).show();
    }

    function saveLocation() {
        var code = document.getElementById('loc_code').value.trim();
        var name = document.getElementById('loc_name').value.trim();
        if (!code || !name) {
            showModalError('Mã vị trí và tên vị trí là bắt buộc');
            return;
        }

        var locIdVal = document.getElementById('loc_id').value;
        var capVal = document.getElementById('loc_capacity').value;
        var payload = {
            LocationId: locIdVal ? parseInt(locIdVal) : null,
            WarehouseId: warehouseId,
            LocationCode: code,
            LocationName: name,
            Zone: document.getElementById('loc_zone').value.trim() || null,
            Aisle: document.getElementById('loc_aisle').value.trim() || null,
            Rack: document.getElementById('loc_rack').value.trim() || null,
            Shelf: document.getElementById('loc_shelf').value.trim() || null,
            Bin: document.getElementById('loc_bin').value.trim() || null,
            MaxCapacity: capVal ? parseFloat(capVal) : null
        };

        fetch('/Warehouse/SaveLocation', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': getAntiForgeryToken()
            },
            body: JSON.stringify(payload)
        })
        .then(r => r.json())
        .then(data => {
            if (data.Success) {
                bootstrap.Modal.getInstance(document.getElementById('locationModal')).hide();
                location.reload();
            } else {
                showModalError(data.Message || 'Lỗi lưu vị trí');
            }
        });
    }

    function toggleLocationActive(id) {
        if (!confirm('Bạn có chắc muốn thay đổi trạng thái vị trí này?')) return;

        var form = new FormData();
        form.append('__RequestVerificationToken', getAntiForgeryToken());

        fetch('/Warehouse/ToggleLocationActive/' + id, { method: 'POST', body: form })
            .then(r => r.json())
            .then(data => {
                if (data.Success) location.reload();
                else alert('Lỗi: ' + data.Message);
            });
    }

    function showModalError(msg) {
        var el = document.getElementById('locationModalError');
        el.textContent = msg;
        el.style.display = 'block';
    }

    function getAntiForgeryToken() {
        return document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
    }
</script>
@Html.AntiForgeryToken()
