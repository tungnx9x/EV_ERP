@model EV_ERP.Models.ViewModels.RFQs.RfqFormViewModel
@{
    var action = Model.IsEditMode ? "Edit" : "Create";
    var title = Model.RfqNo;
    var icon = Model.IsEditMode ? "bi-pencil-square" : "bi-file-earmark-plus";
}

<div class="row">
    <div class="col-lg-8 mx-auto">
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-white border-bottom py-3">
                <div class="d-flex align-items-center gap-2">
                    @* <a href="/Rfq" class="btn btn-sm btn-light border">
                        <i class="bi bi-arrow-left"></i>
                    </a> *@
                    <h5 class="mb-0 fw-semibold">
                        <i class="bi @icon me-2 text-primary"></i>@title
                    </h5>
                </div>
            </div>
            <div class="card-body">
                @if (Model.IsEditMode)
                {
                    <input type="hidden" id="frm_rfqId" value="@Model.RfqId" />
                }

                <div class="row g-3">
                    <!-- Khách hàng -->
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Khách hàng <span class="text-danger">*</span></label>
                        <select id="frm_customerId" class="form-select form-select-sm">
                            <option value="">-- Chọn khách hàng --</option>
                            @foreach (var c in Model.Customers)
                            {
                                <option value="@c.CustomerId" selected="@(Model.CustomerId == c.CustomerId)">
                                    @c.CustomerName (@c.CustomerCode)
                                </option>
                            }
                        </select>
                    </div>

                    <!-- Ưu tiên -->
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Độ ưu tiên</label>
                        <select id="frm_priority" class="form-select form-select-sm">
                            @foreach (var pr in new[] { ("LOW","Thấp"), ("NORMAL","Bình thường"), ("HIGH","Cao"), ("URGENT","Khẩn cấp") })
                            {
                                <option value="@pr.Item1" selected="@(Model.Priority == pr.Item1)">@pr.Item2</option>
                            }
                        </select>
                    </div>

                    <!-- Ngày yêu cầu -->
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Ngày yêu cầu</label>
                        <input type="date" id="frm_requestDate" class="form-control form-control-sm"
                               value="@Model.RequestDate.ToString("yyyy-MM-dd")" />
                    </div>

                    <!-- Hạn xử lý -->
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Hạn xử lý <span class="text-danger">*</span></label>
                        <input type="datetime-local" id="frm_deadline" class="form-control form-control-sm"
                               value="@(Model.Deadline?.ToString("yyyy-MM-ddTHH:mm"))" />
                    </div>

                    <!-- Phân công -->
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Phân công cho</label>
                        <div class="position-relative" id="assignedToWrapper">
                            <input type="hidden" id="frm_assignedTo" value="@Model.AssignedTo" />
                            <input type="text" class="form-control form-control-sm" id="assignedToSearchInput"
                                   placeholder="Tìm nhân viên..."
                                   autocomplete="off"
                                   value="@(Model.AssignedTo.HasValue ? Model.Users.FirstOrDefault(u => u.UserId == Model.AssignedTo)?.FullName : "")" />
                            <div id="assignedToDropdown" class="position-absolute w-100 bg-white border rounded shadow-sm d-none"
                                 style="z-index:1050;max-height:200px;overflow-y:auto;top:100%;left:0;">
                            </div>
                        </div>
                    </div>

                    <!-- Mô tả -->
                    <div class="col-12">
                        <label class="form-label small fw-semibold">Mô tả yêu cầu</label>
                        <div id="frm_description_editor">@Html.Raw(Model.Description)</div>
                    </div>

                    <!-- Ghi chú -->
                    <div class="col-12">
                        <label class="form-label small fw-semibold">Ghi chú</label>
                        <textarea id="frm_notes" class="form-control form-control-sm" rows="2"
                                  placeholder="Ghi chú nội bộ...">@Model.Notes</textarea>
                    </div>
                </div>
            </div>
        </div>

        <!-- Actions -->
        <div class="d-flex gap-2 justify-content-end mb-4">
            <a href="/Rfq" class="btn btn-outline-secondary">Hủy</a>
            <button type="button" class="btn btn-primary" onclick="submitForm()" id="btnSubmit">
                <i class="bi bi-check-lg me-1"></i>
                @(Model.IsEditMode ? "Cập nhật" : "Tạo yêu cầu")
            </button>
        </div>
    </div>
</div>

<script src="https://cdn.ckeditor.com/ckeditor5/41.4.2/classic/ckeditor.js"></script>
<script>
    function RfqImageUploadAdapter(loader) {
        this.loader = loader;
    }
    RfqImageUploadAdapter.prototype.upload = function () {
        var loader = this.loader;
        return loader.file.then(function (file) {
            return new Promise(function (resolve, reject) {
                var data = new FormData();
                data.append('file', file);
                data.append('__RequestVerificationToken',
                    document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '');
                fetch('/Rfq/UploadImage', { method: 'POST', body: data })
                    .then(function (r) { return r.json(); })
                    .then(function (res) {
                        if (res.Success) resolve({ default: res.Data.url });
                        else reject(res.Message);
                    })
                    .catch(reject);
            });
        });
    };
    RfqImageUploadAdapter.prototype.abort = function () {};

    function RfqImageUploadAdapterPlugin(editor) {
        editor.plugins.get('FileRepository').createUploadAdapter = function (loader) {
            return new RfqImageUploadAdapter(loader);
        };
    }

    var descriptionEditor;
    ClassicEditor.create(document.getElementById('frm_description_editor'), {
        extraPlugins: [RfqImageUploadAdapterPlugin],
        toolbar: ['heading', '|', 'bold', 'italic', 'underline', '|',
                  'bulletedList', 'numberedList', '|', 'link', 'imageUpload', 'blockQuote', '|', 'undo', 'redo'],
        placeholder: 'Mô tả chi tiết yêu cầu từ khách hàng...',
        image: {
            toolbar: ['imageStyle:inline', 'imageStyle:block', '|', 'imageTextAlternative']
        }
    }).then(function (editor) {
        descriptionEditor = editor;
    });

    function submitForm() {
        var customerId = parseInt(document.getElementById('frm_customerId').value);
        if (!customerId) {
            alert('Vui lòng chọn khách hàng');
            return;
        }

        var deadlineVal = document.getElementById('frm_deadline').value;
        if (!deadlineVal) {
            alert('Vui lòng chọn hạn xử lý');
            return;
        }

        var rfqIdEl = document.getElementById('frm_rfqId');
        var isEdit = !!rfqIdEl;
        var assignedTo = parseInt(document.getElementById('frm_assignedTo').value) || null;

        var payload = {
            RfqId: isEdit ? parseInt(rfqIdEl.value) : null,
            CustomerId: customerId,
            RequestDate: document.getElementById('frm_requestDate').value,
            Deadline: document.getElementById('frm_deadline').value,
            Priority: document.getElementById('frm_priority').value,
            AssignedTo: assignedTo,
            Description: descriptionEditor ? (descriptionEditor.getData().trim() || null) : null,
            Notes: document.getElementById('frm_notes').value.trim() || null
        };

        var btn = document.getElementById('btnSubmit');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Đang xử lý...';

        var url = isEdit ? '/Rfq/Edit' : '/Rfq/Create';

        fetch(url, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? ''
            },
            body: JSON.stringify(payload)
        })
        .then(function (r) { return r.json(); })
        .then(function (data) {
            if (data.Success) {
                window.location.href = '/Rfq/Detail/' + data.Data.RfqId;
            } else {
                alert(data.Message || 'Có lỗi xảy ra');
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-check-lg me-1"></i>' + (isEdit ? 'Cập nhật' : 'Tạo yêu cầu');
            }
        })
        .catch(function () {
            alert('Lỗi kết nối');
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-check-lg me-1"></i>' + (isEdit ? 'Cập nhật' : 'Tạo yêu cầu');
        });
    }
    // ── Searchable assigned-to dropdown ─────────────────
    (function () {
        var users = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Users.Select(u => new { u.UserId, u.FullName, u.UserCode })));
        var input = document.getElementById('assignedToSearchInput');
        var hidden = document.getElementById('frm_assignedTo');
        var dd = document.getElementById('assignedToDropdown');

        function render(filter) {
            var kw = (filter || '').toLowerCase();
            var items = users.filter(function (u) {
                return !kw || u.FullName.toLowerCase().indexOf(kw) >= 0 || u.UserCode.toLowerCase().indexOf(kw) >= 0;
            });
            var html = '<div class="cs-item" data-id="" style="padding:6px 10px;cursor:pointer;font-size:0.82rem;">-- Chưa phân công --</div>';
            items.forEach(function (u) {
                html += '<div class="cs-item" data-id="' + u.UserId + '" style="padding:6px 10px;cursor:pointer;font-size:0.82rem;">'
                    + u.FullName + ' <span class="text-muted">(' + u.UserCode + ')</span></div>';
            });
            dd.innerHTML = html;
            dd.classList.remove('d-none');
        }

        input.addEventListener('focus', function () { render(input.value); });
        input.addEventListener('input', function () { hidden.value = ''; render(input.value); });

        dd.addEventListener('mouseover', function (e) {
            dd.querySelectorAll('.cs-item').forEach(function (el) { el.style.background = ''; });
            var item = e.target.closest('.cs-item');
            if (item) item.style.background = '#e0f2fe';
        });
        dd.addEventListener('click', function (e) {
            var item = e.target.closest('.cs-item');
            if (!item) return;
            var id = item.getAttribute('data-id');
            hidden.value = id;
            input.value = id ? item.textContent.trim() : '';
            dd.classList.add('d-none');
        });

        document.addEventListener('click', function (e) {
            if (!document.getElementById('assignedToWrapper').contains(e.target))
                dd.classList.add('d-none');
        });
    })();
</script>
@Html.AntiForgeryToken()
