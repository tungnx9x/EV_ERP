<!-- Buying Modal (WAIT → BUYING) — v2.2 per-line -->
<div class="modal fade" id="buyingModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title fw-bold">Bắt đầu mua hàng</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-info py-2 px-3 small mb-3">
                    <i class="bi bi-info-circle me-1"></i>
                    Tích chọn các dòng muốn bắt đầu mua. Có thể đặt <strong>ngày dự kiến về</strong> riêng cho từng dòng.
                    Các dòng chưa tích vẫn lưu giá/nguồn nhưng giữ trạng thái <em>chưa bắt đầu</em>.
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-12">
                        <label class="form-label small fw-semibold">Ghi chú mua hàng (chung)</label>
                        <textarea id="inputBuyingNotes" class="form-control form-control-sm" rows="2"
                                  placeholder="Ghi chú..."></textarea>
                    </div>
                </div>

                <h6 class="fw-semibold small mb-2">Thông tin mua từng dòng</h6>
                <div class="table-responsive">
                    <table class="table table-sm table-bordered align-middle mb-0" style="font-size:0.82rem;">
                        <thead class="table-light">
                            <tr>
                                <th style="width:36px;" class="text-center">
                                    <input type="checkbox" id="buyingCheckAll" checked title="Chọn/bỏ tất cả" />
                                </th>
                                <th>Sản phẩm</th>
                                <th class="text-end" style="width:70px;">SL</th>
                                <th class="text-end" style="width:130px;">Giá mua</th>
                                <th class="text-end" style="width:110px;">Chi phí</th>
                                <th style="width:140px;">Dự kiến về <span class="text-danger">*</span></th>
                                <th style="width:160px;">Nguồn</th>
                            </tr>
                        </thead>
                        <tbody id="buyingItemsBody">
                            @foreach (var item in Model.Items.Where(i => i.EffectiveQty > 0))
                            {
                                <tr data-item-id="@item.SOItemId">
                                    <td class="text-center">
                                        <input type="checkbox" class="buying-include" checked />
                                    </td>
                                    <td>@item.ProductName</td>
                                    <td class="text-end">@item.EffectiveQty.ToString("0.###")</td>
                                    <td class="text-end purchase-price-cell" data-item-id="@item.SOItemId"
