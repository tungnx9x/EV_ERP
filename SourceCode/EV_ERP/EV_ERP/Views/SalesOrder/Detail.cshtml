@model EV_ERP.Models.ViewModels.SalesOrders.SalesOrderDetailViewModel
@{
    ViewData["Title"] = Model.SalesOrderNo;
    ViewData["Breadcrumbs"] = new List<BreadcrumbItem>
    {
        new("Trang chủ", "/"),
        new("Đơn hàng", "/SalesOrder"),
        new(Model.SalesOrderNo)
    };
    bool canEdit = ViewBag.CanEdit == true;
    bool isManager = ViewBag.IsManager == true;
    int currentUserId = (int)(ViewBag.CurrentUserId ?? 0);
    string currentRole = (ViewBag.CurrentRoleCode as string) ?? "";
    bool isWarehouse = currentRole == "WAREHOUSE";
    bool isAccountant = currentRole is "ACCOUNTANT" or "ADMIN";   // settlement approval is an accounting action
    bool showMoney = !isWarehouse;   // pricing / cost / profit / advance — hidden from warehouse role
    bool canManageStatus = isManager || Model.SalesPersonId == currentUserId;
    bool showBuyingInfo = Model.Status is "BUYING" or "RECEIVED" or "DELIVERING" or "DELIVERED" or "RETURNED" or "COMPLETED" or "REPORTED";
    var productForm = ViewBag.ProductForm as EV_ERP.Models.ViewModels.Products.ProductFormViewModel;
}

<!-- Header -->
<div class="d-flex align-items-start justify-content-between mb-3 flex-wrap gap-2">
    <div class="d-flex align-items-center gap-3">
        @* <a href="/SalesOrder" class="btn btn-sm btn-light border">
            <i class="bi bi-arrow-left"></i>
        </a> *@
        <div>
            <div class="d-flex flex-wrap align-items-center gap-3">
                <h5 class="mb-0 fw-bold">@Model.SalesOrderNo</h5>
                @if (showMoney && Model.Status == "DELIVERED")
                {
                    <div class="dropdown">
                        <a class="text-success d-flex align-items-center dropdown-toggle"
                           href="#"
                           role="button"
                           data-bs-toggle="dropdown"
                           aria-expanded="false"
                           style="text-decoration: none;">
                            <i class="bi bi-download me-1"></i>
                            Xuất Excel
                        </a>

                        <ul class="dropdown-menu">
                            <li>
                                <a class="dropdown-item d-flex align-items-center"
                                   href="/SalesOrder/ExportDnhu/@Model.SalesOrderId">
                                    <i class="bi bi-download me-2 text-success"></i>
                                    Xuất DNHU
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item d-flex align-items-center"
                                   href="/SalesOrder/ExportDntt/@Model.SalesOrderId">
                                    <i class="bi bi-download me-2 text-success"></i>
                                    Xuất DNTT
                                </a>
                            </li>
                        </ul>
                    </div>
                }
            </div>
            <div class="text-muted small">
                <span class="badge bg-@(Model.StatusBadge)-subtle text-@(Model.StatusBadge)-emphasis rounded-pill">
                    <i class="bi bi-circle-fill me-1" style="font-size:0.4rem;vertical-align:middle;"></i>
                    @Model.StatusText
                </span>
                @if (Model.QuotationNo != null)
                {
                    <span class="ms-2">
                        <i class="bi bi-file-earmark-text me-1"></i>BG:
                        <a href="/Quotation/Detail/@Model.QuotationId">@Model.QuotationNo</a>
                    </span>
                }
                @if (Model.RfqNo != null)
                {
                    <span class="ms-2">
                        <i class="bi bi-clipboard-check me-1"></i>RFQ:
                        <a href="/Rfq/Detail/@Model.RfqId">@Model.RfqNo</a>
                    </span>
                }
            </div>
        </div>
    </div>

    <!-- Action buttons per status -->
    <div class="d-flex gap-1 flex-wrap">
        @if (canEdit)
        {
            @if (Model.Status == "DRAFT")
            {           
                @if (canManageStatus)
                {
                    <button class="btn btn-sm btn-primary" onclick="showSubmitWaitModal()">
                        <i class="bi bi-send me-1"></i> Gửi DNTU
                    </button>
                    <button class="btn btn-sm btn-outline-danger" onclick="doCancel()">
                        <i class="bi bi-x-circle me-1"></i> Hủy
                    </button>
                }
            }
            @if (Model.Status == "WAIT" && canManageStatus)
            {
                <button class="btn btn-sm btn-info text-white" onclick="showBuyingModal()">
                    <i class="bi bi-cart3 me-1"></i> Bắt đầu mua hàng
                </button>
                <button class="btn btn-sm btn-outline-danger" onclick="doCancel()">
                    <i class="bi bi-x-circle me-1"></i> Hủy
                </button>
            }
            @if (Model.Status is "BUYING" or "RECEIVED" or "DELIVERING" && canManageStatus)
            {
                @* Whole-order action removed — Nhận hàng / Giao hàng nay theo từng dòng (bảng bên dưới).
                   Chỉ giữ "Hủy đơn" và batch shortcut. Trạng thái SO tự roll-up khi xác nhận phiếu kho. *@
                if (Model.Items.Any(i => i.RemainingReceiveQty > 0))
                {
                    <button class="btn btn-sm btn-info text-white" onclick="showReceiveBatchModal()">
                        <i class="bi bi-box-arrow-in-down me-1"></i> Nhận lô (nhiều dòng)
                    </button>
                }
                if (Model.Items.Any(i => i.InStockQty > 0))
                {
                    <button class="btn btn-sm btn-warning" onclick="showDeliverBatchModal()">
                        <i class="bi bi-truck me-1"></i> Giao lô (nhiều dòng)
                    </button>
                }
                <button class="btn btn-sm btn-outline-danger" onclick="doCancel()">
                    <i class="bi bi-x-circle me-1"></i> Hủy đơn
                </button>
            }
            @if (Model.Status == "DELIVERED" && canManageStatus)
            {
                <button class="btn btn-sm btn-warning" onclick="showReturnModal()">
                    <i class="bi bi-arrow-return-left me-1"></i> Trả hàng
                </button>
            }
            @* @if (Model.Status == "COMPLETED" && canManageStatus)
            {
                <button class="btn btn-sm btn-primary" onclick="doSimpleAction('Report', 'Xác nhận nộp báo cáo KQKD?')">
                    <i class="bi bi-file-earmark-bar-graph me-1"></i> Nộp báo cáo KQKD
                </button>
            } *@
        }
        @* Hoàn tất quyết toán — chỉ Kế toán mới được duyệt & chuyển trạng thái (DELIVERED/RETURNED → COMPLETED) *@
        @if (isAccountant && Model.Status is "DELIVERED" or "RETURNED")
        {
            <button class="btn btn-sm btn-success" onclick="openCompleteModal()">
                <i class="bi bi-check-all me-1"></i> Duyệt quyết toán
            </button>
        }
    </div>
</div>

<!-- Unmapped products warning -->
@if (canEdit && Model.Status == "DRAFT" && Model.HasUnmappedProducts)
{
    <div class="alert alert-warning border-0 shadow-sm mb-3 py-2" role="alert">
        <div class="d-flex align-items-center gap-2 mb-2">
            <i class="bi bi-exclamation-triangle-fill fs-5"></i>
            <div class="small">
                <strong>@Model.UnmappedProductCount sản phẩm chưa được nhập vào hệ thống.</strong>
                Tạo từng sản phẩm hoặc import hàng loạt bằng Excel.
            </div>
        </div>
        <div class="d-flex gap-2 flex-wrap ms-4">
            <a href="/SalesOrder/ExportProductTemplate/@Model.SalesOrderId"
               class="btn btn-sm btn-outline-success">
                <i class="bi bi-download me-1"></i> Tải template Excel
            </a>
            <label class="btn btn-sm btn-outline-primary mb-0" for="importProductFile">
                <i class="bi bi-upload me-1"></i> Import từ Excel
            </label>
            <input type="file" id="importProductFile" class="d-none"
                   accept=".xlsx,.xls" onchange="importProducts(this)" />
        </div>
    </div>
}

<!-- Status timeline -->
<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2 px-3">
        <div class="d-flex align-items-center gap-1 flex-wrap" style="font-size:0.78rem;">
            @{
                var steps = new[] {
                    ("DRAFT", "Nháp"), ("WAIT", "Chờ tạm ứng"), ("BUYING", "Đang mua"),
                    ("RECEIVED", "Nhận hàng"), ("DELIVERING", "Đang giao"),
                    ("DELIVERED", "Đã giao"), ("COMPLETED", "Hoàn tất"),
                    ("REPORTED", "Báo cáo KQKD")
                };
                if (Model.Status == "RETURNED" || Model.ReturnedAt.HasValue)
                {
                    var list = steps.ToList();
                    var deliveredIdx = list.FindIndex(s => s.Item1 == "COMPLETED");
                    list.Insert(deliveredIdx, ("RETURNED", "Trả hàng"));
                    steps = list.ToArray();
                }
                var statusOrder = steps.Select(s => s.Item1).ToList();
                var currentIdx = statusOrder.IndexOf(Model.Status);
                bool isCancelled = Model.Status == "CANCELLED";
            }
            @for (int i = 0; i < steps.Length; i++)
            {
                var (code, label) = steps[i];
                var done = !isCancelled && currentIdx >= i;
                var active = !isCancelled && currentIdx == i;
                <div class="d-flex align-items-center gap-1">
                    <span class="badge @(active ? "bg-primary" : done ? "bg-success" : "bg-light text-muted border")">
                        @if (done && !active) { <i class="bi bi-check-lg"></i> }
                        @label
                    </span>
                    @if (i < steps.Length - 1)
                    {
                        <i class="bi bi-chevron-right text-muted" style="font-size:0.6rem;"></i>
                    }
                </div>
            }
            @if (isCancelled)
            {
                <span class="badge bg-danger ms-2">Đã hủy</span>
            }
        </div>
    </div>
</div>
<!-- Info cards -->
@{
    // When a status has no secondary cards to show on the right (e.g. WAIT / "Chờ tạm ứng"),
    // render Order Information full-width instead of leaving the right half empty.
    bool hasSecondaryCards = (canEdit && Model.Status == "DRAFT")
        || showBuyingInfo
        || Model.DeliveringAt.HasValue || Model.DeliveredAt.HasValue || Model.ReturnedAt.HasValue
        || Model.CompletedAt.HasValue || Model.ReportedAt.HasValue
        || (showMoney && Model.Status is "COMPLETED" or "REPORTED" or "RETURNED" && Model.ActualCost.HasValue)
        || Model.Status is "CANCELLED" or "RETURNED"
        || !string.IsNullOrEmpty(Model.Notes)
        || !string.IsNullOrEmpty(Model.InternalNotes);
}
<style>
    /* When Order Information spans the full width, pack its fields 4-per-row on desktop
       so they don't stretch into a sparse 2-per-row layout. */
    @@media (min-width: 768px) {
        .order-info-full .row.g-2.small > [class*="col-"] { flex: 0 0 auto; width: 25%; }
    }
</style>
<div class="row g-3">
    <div class="col-lg-@(hasSecondaryCards ? "6" : "12") @(hasSecondaryCards ? "" : "order-info-full")">
        <!-- Order info -->
        <div class="card border-0 shadow-sm mb-3 border-start border-4 border-info">
            <div class="card-body">
                <h6 class="fw-semibold text-muted text-uppercase mb-3" style="font-size:0.72rem;letter-spacing:.06em;">
                    Thông tin đơn hàng
                </h6>
                <div class="row g-2 small">
                    <div class="col-6">
                        <div class="text-muted">Khách hàng</div>
                        <div class="fw-semibold">@Model.CustomerName</div>
                    </div>
                    <div class="col-6">
                        <div class="text-muted">Ngày tạo</div>
                        <div class="fw-semibold">@Model.OrderDate.ToString("dd/MM/yyyy")</div>
                    </div>
                    <div class="col-6">
                        <div class="text-muted">Phụ trách</div>
                        <div class="fw-semibold">@Model.SalesPersonName</div>
                    </div>
                    @if (Model.Status != "DRAFT" && Model.CustomerPoNo != null)
                    {
                        <div class="col-6">
                            <div class="text-muted">Mã PO KH</div>
                            <div class="fw-semibold">@Model.CustomerPoNo</div>
                        </div>
                    }
                    @if (Model.Status != "DRAFT" && Model.CustomerPoDate.HasValue)
                    {
                        <div class="col-6">
                            <div class="text-muted">Ngày nhận PO</div>
                            <div class="fw-semibold">@Model.CustomerPoDate.Value.ToString("dd/MM/yyyy")</div>
                        </div>
                    }
                    @if (Model.Status != "DRAFT" && Model.CustomerPoFile != null)
                    {
                        <div class="col-6">
                            <div class="text-muted">File PO KH</div>
                            <div><a href="@Model.CustomerPoFile" target="_blank" class="text-primary"><i class="bi bi-file-earmark-arrow-down me-1"></i>Tải xuống</a></div>
                        </div>
                    }
                    @if (Model.ExpectedDeliveryDate.HasValue)
                    {
                        <div class="col-6">
                            <div class="text-muted">Dự kiến giao</div>
                            <div class="fw-semibold">@Model.ExpectedDeliveryDate.Value.ToString("dd/MM/yyyy")</div>
                        </div>
                    }
                    @if (Model.PaymentDueDate.HasValue)
                    {
                        <div class="col-6">
                            <div class="text-muted">Hạn thanh toán</div>
                            <div class="fw-semibold">@Model.PaymentDueDate.Value.ToString("dd/MM/yyyy")</div>
                        </div>
                    }
                </div>
            </div>
        </div>

        @* Advance info — moved to dedicated full-width card below items/totals (v2.2 multi-advance) *@
    </div>
    @if (hasSecondaryCards)
    {
    <div class="col-lg-6">
         <!-- PO KH editable (DRAFT only) -->
         @if (canEdit && Model.Status == "DRAFT")
         {
             <div class="card border-0 shadow-sm mb-3 border-start border-4 border-primary">
                 <div class="card-body">
                     <h6 class="fw-semibold text-muted text-uppercase mb-3" style="font-size:0.72rem;letter-spacing:.06em;">
                         <i class="bi bi-file-earmark-text me-1"></i> PO Khách hàng
                     </h6>
                     <form id="draftInfoForm" enctype="multipart/form-data">
                         <div class="mb-2">
                             <label class="form-label small fw-semibold mb-1">Mã PO khách hàng</label>
                             <input type="text" id="draftCustomerPoNo" class="form-control form-control-sm"
                                    placeholder="Nhập mã PO..." value="@Model.CustomerPoNo" />
                         </div>
                         <div class="row g-2 mb-2">
                             <div class="col-6">
                                 <label class="form-label small fw-semibold mb-1">Ngày nhận PO</label>
                                 <input type="text" id="draftCustomerPoDate" class="form-control form-control-sm js-flatpickr"
                                        value="@(Model.CustomerPoDate?.ToString("yyyy-MM-dd"))" />
                             </div>
                             <div class="col-6">
                                 <label class="form-label small fw-semibold mb-1">Dự kiến giao hàng</label>
                                 <input type="text" id="draftExpectedDeliveryDate" class="form-control form-control-sm js-flatpickr"
                                        value="@(Model.ExpectedDeliveryDate?.ToString("yyyy-MM-dd"))" />
                             </div>
                         </div>
                         <div class="mb-2">
                             <label class="form-label small fw-semibold mb-1">File PO khách hàng</label>
                             @if (Model.CustomerPoFile != null)
                             {
                                 <div class="mb-1">
                                     <a href="@Model.CustomerPoFile" target="_blank" class="text-primary small">
                                         <i class="bi bi-file-earmark-arrow-down me-1"></i>File hiện tại
                                     </a>
                                 </div>
                             }
                             <input type="file" id="draftCustomerPoFile" class="form-control form-control-sm"
                                    accept=".pdf,.jpg,.jpeg,.png,.doc,.docx,.xls,.xlsx" />
                             <div class="form-text" style="font-size:0.7rem;">PDF, ảnh, Word, Excel (tối đa 10MB)</div>
                         </div>
                         <button type="button" class="btn btn-sm btn-primary w-100" onclick="saveDraftInfo()">
                             <i class="bi bi-check-lg me-1"></i> Lưu thông tin PO
                         </button>
                     </form>
                 </div>
             </div>
         }
         <!-- Vendor / Buying info -->
           @if (showBuyingInfo)
           {
               <div class="card border-0 shadow-sm mb-3">
                   <div class="card-body">
                       <h6 class="fw-semibold text-muted text-uppercase mb-3" style="font-size:0.72rem;letter-spacing:.06em;">
                           <i class="bi bi-cart3 me-1"></i> Thông tin mua hàng
                       </h6>
                       <div class="row g-2 small">
                           <div class="col-12">
                               <div class="text-muted">Nhà cung cấp</div>
                               <div class="fw-semibold">@(Model.PurchaseSource ?? "—")</div>
                           </div>
                           @if (Model.ExpectedReceiveDate.HasValue)
                           {
                               <div class="col-6">
                                   <div class="text-muted">Dự kiến về kho</div>
                                   <div class="fw-semibold">@Model.ExpectedReceiveDate.Value.ToString("dd/MM/yyyy")</div>
                               </div>
                           }
                           @if (Model.BuyingAt.HasValue)
                           {
                               <div class="col-6">
                                   <div class="text-muted">Bắt đầu mua</div>
                                   <div class="fw-semibold">@Model.BuyingAt.Value.ToString("dd/MM HH:mm")</div>
                               </div>
                           }
                           @if (Model.ReceivedAt.HasValue)
                           {
                               <div class="col-6">
                                   <div class="text-muted">Nhận hàng</div>
                                   <div class="fw-semibold text-success">@Model.ReceivedAt.Value.ToString("dd/MM HH:mm")</div>
                               </div>
                           }
                           @if (!string.IsNullOrEmpty(Model.BuyingNotes))
                           {
                               <div class="col-12">
                                   <div class="text-muted">Ghi chú mua</div>
                                   <div style="white-space:pre-wrap;">@Model.BuyingNotes</div>
                               </div>
                           }
                       </div>
                   </div>
               </div>
           }

           <!-- Delivery timestamps -->
           @if (Model.DeliveringAt.HasValue || Model.DeliveredAt.HasValue || Model.ReturnedAt.HasValue || Model.CompletedAt.HasValue || Model.ReportedAt.HasValue)
           {
               <div class="card border-0 shadow-sm mb-3">
                   <div class="card-body">
                       <h6 class="fw-semibold text-muted text-uppercase mb-3" style="font-size:0.72rem;letter-spacing:.06em;">
                           <i class="bi bi-clock-history me-1"></i> Tiến trình
                       </h6>
                       <div class="row g-2 small">
                           @if (Model.DeliveringAt.HasValue)
                           {
                               <div class="col-6">
                                   <div class="text-muted">Giao vận chuyển</div>
                                   <div class="fw-semibold">@Model.DeliveringAt.Value.ToString("dd/MM HH:mm")</div>
                               </div>
                           }
                           @if (Model.DeliveredAt.HasValue)
                           {
                               <div class="col-6">
                                   <div class="text-muted">KH nhận hàng</div>
                                   <div class="fw-semibold text-success">@Model.DeliveredAt.Value.ToString("dd/MM HH:mm")</div>
                               </div>
                           }
                           @if (Model.ReturnedAt.HasValue)
                           {
                               <div class="col-6">
                                   <div class="text-muted">Trả hàng</div>
                                   <div class="fw-semibold text-warning">@Model.ReturnedAt.Value.ToString("dd/MM HH:mm")</div>
                               </div>
                           }
                           @if (Model.CompletedAt.HasValue)
                           {
                               <div class="col-6">
                                   <div class="text-muted">Hoàn tất</div>
                                   <div class="fw-semibold text-success">@Model.CompletedAt.Value.ToString("dd/MM HH:mm")</div>
                               </div>
                           }
                           @if (Model.ReportedAt.HasValue)
                           {
                               <div class="col-6">
                                   <div class="text-muted">Báo cáo KQKD</div>
                                   <div class="fw-semibold text-primary">@Model.ReportedAt.Value.ToString("dd/MM HH:mm")</div>
                               </div>
                           }
                       </div>
                   </div>
               </div>
           }

           <!-- Settlement -->
           @if (showMoney && Model.Status is "COMPLETED" or "REPORTED" or "RETURNED" && Model.ActualCost.HasValue)
           {
               <div class="card border-0 shadow-sm mb-3 border-start border-4 border-success">
                   <div class="card-body">
                       <h6 class="fw-semibold text-muted text-uppercase mb-3" style="font-size:0.72rem;letter-spacing:.06em;">
                           <i class="bi bi-calculator me-1"></i> Quyết toán
                       </h6>
                       <div class="row g-2 small">
                           <div class="col-6">
                               <div class="text-muted">Chi phí thực tế</div>
                               <div class="fw-bold">@Model.ActualCost?.ToString("N0") @Model.Currency</div>
                           </div>
                           @if (!string.IsNullOrEmpty(Model.OutputInvoiceNo))
                           {
                               <div class="col-6">
                                   <div class="text-muted">Số hóa đơn đầu ra</div>
                                   <div class="fw-bold">@Model.OutputInvoiceNo</div>
                               </div>
                           }
                           @if (!string.IsNullOrEmpty(Model.SettlementNotes))
                           {
                               <div class="col-12">
                                   <div class="text-muted">Ghi chú</div>
                                   <div>@Model.SettlementNotes</div>
                               </div>
                           }
                       </div>
                   </div>
               </div>
           }

           <!-- Cancel info -->
           @if (Model.Status == "CANCELLED")
           {
               <div class="card border-0 shadow-sm mb-3 border-start border-4 border-danger">
                   <div class="card-body">
                       <h6 class="fw-semibold text-muted text-uppercase mb-3" style="font-size:0.72rem;letter-spacing:.06em;">
                           <i class="bi bi-x-circle me-1"></i> Thông tin hủy
                       </h6>
                       <div class="small">
                           <div class="text-muted">Hủy lúc: @Model.CancelledAt?.ToString("dd/MM/yyyy HH:mm")</div>
                           @if (!string.IsNullOrEmpty(Model.CancelReason))
                           {
                               <div class="mt-1">Lý do: @Model.CancelReason</div>
                           }
                       </div>
                   </div>
               </div>
           }

           <!-- Return info -->
           @if (Model.Status == "RETURNED" || Model.ReturnedAt.HasValue)
           {
               <div class="card border-0 shadow-sm mb-3 border-start border-4 border-warning">
                   <div class="card-body">
                       <h6 class="fw-semibold text-muted text-uppercase mb-3" style="font-size:0.72rem;letter-spacing:.06em;">
                           <i class="bi bi-arrow-return-left me-1"></i> Trả hàng
                       </h6>
                       <div class="small">
                           <div class="text-muted">Trả hàng lúc: @Model.ReturnedAt?.ToString("dd/MM/yyyy HH:mm")</div>
                           @if (!string.IsNullOrEmpty(Model.ReturnReason))
                           {
                               <div class="mt-1">Lý do: @Model.ReturnReason</div>
                           }
                       </div>
                   </div>
               </div>
           }

           <!-- Notes -->
           @if (!string.IsNullOrEmpty(Model.Notes))
           {
               <div class="card border-0 shadow-sm mb-3">
                   <div class="card-body">
                       <h6 class="fw-semibold text-muted text-uppercase mb-2" style="font-size:0.72rem;letter-spacing:.06em;">
                           Ghi chú
                       </h6>
                       <p class="small mb-0" style="white-space:pre-wrap;">@Model.Notes</p>
                   </div>
               </div>
           }
           @if (!string.IsNullOrEmpty(Model.InternalNotes))
           {
               <div class="card border-0 shadow-sm mb-3 border-start border-4 border-warning">
                   <div class="card-body">
                       <h6 class="fw-semibold text-muted text-uppercase mb-2" style="font-size:0.72rem;letter-spacing:.06em;">
                           <i class="bi bi-lock me-1"></i> Ghi chú nội bộ
                       </h6>
                       <p class="small mb-0" style="white-space:pre-wrap;">@Model.InternalNotes</p>
                   </div>
               </div>
           }
        </div>
    }
</div>
<!-- Items + Totals -->
<div class="row g-3">
    <div class="col-lg-12">
        @{
            bool showProgress = Model.Status is "BUYING" or "RECEIVED" or "DELIVERING" or "DELIVERED" or "COMPLETED" or "REPORTED" or "RETURNED";
            bool canAct = canManageStatus && Model.Status is "BUYING" or "RECEIVED" or "DELIVERING";
            bool canCancelEarly = canManageStatus && Model.Status is "DRAFT" or "WAIT";
            bool showActionsCol = canAct || canCancelEarly;
            bool showAdvanceCol = Model.Status is not "DRAFT" and not "CANCELLED";
            int totalLines = Model.Items.Count;
            int doneRecv = Model.Items.Count(i => i.LineStatus is "RECEIVED_FULL" or "PARTIAL_DELIVERED" or "DELIVERED");
            int doneDeliv = Model.Items.Count(i => i.LineStatus == "DELIVERED");
            int partial = Model.Items.Count(i => i.LineStatus is "PARTIAL" or "PARTIAL_DELIVERED");
            int notStarted = Model.Items.Count(i => i.LineStatus is "NOT_STARTED" or "BUYING");
            int cancelledLines = Model.Items.Count(i => i.LineStatus == "CANCELLED");
        }

        @if (showProgress)
        {
            <!-- Per-line progress summary strip -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body py-2 px-3">
                    <div class="d-flex flex-wrap gap-3 align-items-center small">
                        <span class="text-muted">
                            <i class="bi bi-box-arrow-in-down text-info me-1"></i>
                            <strong>Mua/Nhận:</strong>
                            <span class="badge bg-success-subtle text-success-emphasis">@doneRecv / @totalLines đã đủ</span>
                            @if (partial > 0)
                            {
                                <span class="badge bg-warning-subtle text-warning-emphasis ms-1">@partial về 1 phần</span>
                            }
                            @if (notStarted > 0)
                            {
                                <span class="badge bg-light text-muted border ms-1">@notStarted chưa bắt đầu</span>
                            }
                        </span>
                        <span class="text-muted">
                            <i class="bi bi-truck text-warning me-1"></i>
                            <strong>Giao KH:</strong>
                            <span class="badge bg-success-subtle text-success-emphasis">@doneDeliv / @totalLines đã giao đủ</span>
                        </span>
                        @if (cancelledLines > 0)
                        {
                            <span class="text-muted">
                                <i class="bi bi-x-circle text-danger me-1"></i>
                                <span class="badge bg-danger-subtle text-danger-emphasis">@cancelledLines dòng đã hủy</span>
                            </span>
                        }
                    </div>
                </div>
            </div>
        }

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom py-2">
                <h6 class="mb-0 fw-semibold small text-uppercase">
                    <i class="bi bi-box-seam me-1"></i> Chi tiết sản phẩm
                    <span class="badge bg-primary rounded-pill ms-1">@Model.Items.Count</span>
                    @if (Model.Status == "DRAFT" && Model.HasUnmappedProducts)
                    {
                        <span class="badge bg-warning rounded-pill ms-1">
                            <i class="bi bi-exclamation-triangle me-1"></i>@Model.UnmappedProductCount chưa nhập SP
                        </span>
                    }
                </h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-bordered table-hover align-middle mb-0" style="font-size:0.8rem;">
                        <thead class="table-light">
                            <tr>
                                <th style="width:30px;" class="text-center">STT</th>
                                <th>Sản phẩm</th>
                                @if (canEdit && Model.Status == "DRAFT")
                                {
                                    <th style="width:80px;" class="text-center">Đã nhập</th>
                                }
                                <th>DVT</th>
                                <th class="text-end">SL</th>
                                @if (showProgress)
                                {
                                    <th class="text-center bg-info-subtle" style="min-width:140px;">Tiến độ mua/giao</th>
                                    <th class="text-center bg-info-subtle" style="min-width:110px;">Dự kiến</th>
                                }
                                @if (showMoney)
                                {
                                    <th class="text-end" style="background-color:#fff3cd;" title="Giá nhập hiện tại - bấm để nhập lại">Giá nhập hiện tại</th>
                                    <th class="text-end bg-success-subtle">Đơn giá bán</th>
                                    <th class="text-end bg-success-subtle">Phí vận chuyển</th>
                                    <th class="text-end bg-success-subtle">Thành tiền</th>
                                    <th class="text-end bg-success-subtle">Hệ số</th>
                                }
                                @if (showMoney && showBuyingInfo)
                                {
                                    <th class="text-end bg-warning-subtle">Giá mua</th>
                                    <th class="text-end bg-warning-subtle">Chi phí</th>
                                }
                                @if (showMoney && showAdvanceCol)
                                {
                                    <th class="text-end" style="background-color:#fff7e6;min-width:110px;" title="Tổng tạm ứng đã ghi nhận cho dòng này">Đã tạm ứng</th>
                                }

                                @if (showActionsCol)
                                {
                                    <th class="text-center" style="width:130px;">Hành động</th>
                                }
                            </tr>
                        </thead>
                        <tbody id="soItemsTbody">
                            @{ int idx = 1; }
                            @foreach (var item in Model.Items)
                            {
                                <tr class="@(!item.IsProductMapped && Model.Status == "DRAFT" ? "table-warning" : "") @(item.LineStatus == "CANCELLED" ? "text-decoration-line-through text-muted" : "")">
                                    <td class="text-center text-muted">@(idx++)</td>
                                    <td class="fw-semibold">
                                        @item.ProductName
                                        @if (showProgress)
                                        {
                                            <span class="badge @item.LineStatusBadge ms-1" style="font-size:0.65rem;">@item.LineStatusText</span>
                                        }
                                        @if (item.CancelledQty > 0 && item.CancelledQty < item.Quantity)
                                        {
                                            <span class="badge bg-danger-subtle text-danger-emphasis ms-1" style="font-size:0.65rem;">Hủy @item.CancelledQty.ToString("0.###")</span>
                                        }
                                    </td>
                                    @if (canEdit && Model.Status == "DRAFT")
                                    {
                                        <td class="text-center">
                                            @if (item.IsProductMapped)
                                            {
                                                <span class="badge bg-success-subtle text-success-emphasis">
                                                    <i class="bi bi-check-circle-fill me-1"></i>OK
                                                </span>
                                            }
                                            else
                                            {
                                                var matchedUnitId = productForm?.Units.FirstOrDefault(u => u.UnitName == item.UnitName)?.UnitId ?? 0;
                                                <div class="d-flex flex-column gap-1">
                                                    <a href="#" style="text-decoration: none;"
                                                            onclick="openCreateProductModal(@item.SOItemId, '@System.Web.HttpUtility.JavaScriptStringEncode(item.ProductName)', @item.UnitPrice, @(item.PurchasePrice?.ToString() ?? "0"), '@System.Web.HttpUtility.JavaScriptStringEncode(item.SourceUrl ?? "")', '@System.Web.HttpUtility.JavaScriptStringEncode(item.ProductDescription ?? "")', '@System.Web.HttpUtility.JavaScriptStringEncode(item.ImageUrl ?? "")', @matchedUnitId, '@System.Web.HttpUtility.JavaScriptStringEncode(item.UnitName)')">
                                                        <i class="bi bi-plus-circle me-1"></i>Tạo SP
                                                    </a>
                                                    <a href="#" style="text-decoration: none;"
                                                            onclick="openAssignProductModal(@item.SOItemId, '@System.Web.HttpUtility.JavaScriptStringEncode(item.ProductName)')">
                                                        <i class="bi bi-link-45deg me-1"></i>Gán SP
                                                    </a>
                                                </div>
                                            }
                                        </td>
                                    }
                                    <td>@item.UnitName</td>
                                    <td class="text-end">
                                        @if (item.CancelledQty > 0 && item.CancelledQty < item.Quantity)
                                        {
                                            <span class="text-muted text-decoration-line-through">@item.Quantity.ToString("0.###")</span>
                                            <div class="fw-semibold text-danger-emphasis">@item.EffectiveQty.ToString("0.###")</div>
                                        }
                                        else
                                        {
                                            @item.Quantity.ToString("0.###")
                                        }
                                    </td>
                                    @if (showProgress)
                                    {
                                        <td class="text-center small">
                                            <div>
                                                <span class="text-muted">Nhận:</span>
                                                <span class="fw-semibold @(item.RemainingReceiveQty > 0 ? "text-info-emphasis" : "text-success")">
                                                    @item.ReceivedQty.ToString("0.###") / @item.EffectiveQty.ToString("0.###")
                                                </span>
                                            </div>
                                            @if (item.PendingReceiveQty > 0)
                                            {
                                                <div class="badge bg-warning-subtle text-warning-emphasis border" style="font-size:0.65rem;"
                                                     title="Đang chờ Kho xác nhận phiếu nhập đã tạo">
                                                    Chờ nhập kho: @item.PendingReceiveQty.ToString("0.###")
                                                </div>
                                            }
                                            <div>
                                                <span class="text-muted">Giao:</span>
                                                <span class="fw-semibold @(item.RemainingDeliverQty > 0 ? "text-warning-emphasis" : "text-success")">
                                                    @item.DeliveredQty.ToString("0.###") / @item.EffectiveQty.ToString("0.###")
                                                </span>
                                            </div>
                                            @if (item.InStockQty > 0)
                                            {
                                                <div class="badge bg-secondary-subtle text-secondary-emphasis" style="font-size:0.65rem;">
                                                    Trong kho: @item.InStockQty.ToString("0.###")
                                                </div>
                                            }
                                            @if (item.PendingDeliverQty > 0)
                                            {
                                                <div class="badge bg-warning-subtle text-warning-emphasis border" style="font-size:0.65rem;"
                                                     title="Đang chờ Kho xác nhận phiếu xuất đã tạo">
                                                    Chờ xuất kho: @item.PendingDeliverQty.ToString("0.###")
                                                </div>
                                            }
                                        </td>
                                        <td class="text-center small">
                                            @if (item.ExpectedReceiveDate.HasValue)
                                            {
                                                <div title="Dự kiến hàng về">
                                                    <i class="bi bi-box-arrow-in-down text-info"></i> @item.ExpectedReceiveDate.Value.ToString("dd/MM")
                                                </div>
                                            }
                                            @if (item.ExpectedDeliveryDate.HasValue)
                                            {
                                                <div title="Dự kiến giao KH">
                                                    <i class="bi bi-truck text-warning"></i> @item.ExpectedDeliveryDate.Value.ToString("dd/MM")
                                                </div>
                                            }
                                            @if (!item.ExpectedReceiveDate.HasValue && !item.ExpectedDeliveryDate.HasValue)
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                    }
                                    @if (showMoney)
                                    {
                                        <td class="text-end" style="background-color:#fff3cd;">
                                            @if (canManageStatus && item.LineStatus != "CANCELLED")
                                            {
                                                <a href="#" class="fw-semibold"
                                                   onclick="openItemCalcModal(@item.SOItemId); return false;" title="Nhập lại giá nhập">
                                                    @(item.PurchasePrice?.ToString("N0") ?? "—")
                                                    <i class="bi bi-calculator ms-1 small"></i>
                                                </a>
                                            }
                                            else
                                            {
                                                @(item.PurchasePrice?.ToString("N0") ?? "—")
                                            }
                                        </td>
                                        <td class="text-end">@item.UnitPrice.ToString("N0")</td>
                                        <td class="text-end text-muted">
                                            @if (canManageStatus && item.LineStatus != "CANCELLED")
                                            {
                                                <a href="#" class="ship-fee-display" style="cursor:pointer;" title="Bấm để sửa phí vận chuyển" onclick="startEditShipFee(this)">
                                                    @(item.ShippingFee.HasValue && item.ShippingFee.Value > 0 ? item.ShippingFee.Value.ToString("N0") : "—")
                                                    <i class="bi bi-pencil-square small text-primary"></i>
                                                </a>
                                                <input type="number" min="0" step="1" class="form-control form-control-sm text-end ship-fee-input d-none"
                                                       value="@(item.ShippingFee.HasValue && item.ShippingFee.Value > 0 ? item.ShippingFee.Value.ToString("0", System.Globalization.CultureInfo.InvariantCulture) : "")"
                                                       data-so-item-id="@item.SOItemId"
                                                       onblur="saveShipFee(this)" onkeydown="shipFeeKey(event, this)" />
                                            }
                                            else
                                            {
                                                @(item.ShippingFee.HasValue && item.ShippingFee.Value > 0 ? item.ShippingFee.Value.ToString("N0") : "—")
                                            }
                                        </td>
                                        <td class="text-end fw-semibold text-success">
                                            @if (item.CancelledQty > 0 && item.CancelledQty < item.Quantity)
                                            {
                                                var effAmount = item.Quantity > 0 ? Math.Round(item.LineTotal * item.EffectiveQty / item.Quantity) : item.LineTotal;
                                                <span class="text-muted text-decoration-line-through fw-normal small">@item.LineTotal.ToString("N0")</span>
                                                <div>@effAmount.ToString("N0")</div>
                                            }
                                            else
                                            {
                                                @item.LineTotal.ToString("N0")
                                            }
                                        </td>
                                        <td class="text-end" style="background-color:#fffaf0;">
                                            @if (item.PurchasePrice.HasValue && item.PurchasePrice.Value > 0 && item.UnitPrice > 0)
                                            {
                                                @* Hệ số = Giá nhập / (Đơn giá bán − Phí vận chuyển / SL); từ CT: Đơn giá bán = Giá nhập / Hệ số + Phí vận chuyển / SL *@
                                                var perUnitShip = item.EffectiveQty > 0 ? (item.ShippingFee ?? 0) / item.EffectiveQty : 0;
                                                var coefDenom = item.UnitPrice - perUnitShip;
                                                var curCoef = coefDenom > 0 ? item.PurchasePrice.Value / coefDenom : 0;
                                                var quoteCoef = item.Coefficient ?? 0;
                                                <span class="fw-semibold text-warning-emphasis">@curCoef.ToString("0.####")</span>
                                                @if (quoteCoef > 0 && Math.Round(curCoef, 4) > quoteCoef)
                                                {
                                                    <i class="bi bi-exclamation-triangle-fill text-danger ms-1"
                                                       title="Hệ số đã tăng vượt hệ số báo giá - @quoteCoef.ToString("0.####")"></i>
                                                }
                                            }
                                            else
                                            {
                                                <span class="text-muted small">—</span>
                                            }
                                        </td>
                                    }
                                    @if (showMoney && showBuyingInfo)
                                    {
                                        <td class="text-end">@(item.PurchasePrice?.ToString("N0") ?? "—")</td>
                                        <td class="text-end text-warning-emphasis">@(item.LineCost?.ToString("N0") ?? "—")</td>
                                    }
                                    @if (showMoney && showAdvanceCol)
                                    {
                                        <td class="text-end" style="background-color:#fffaf0;">
                                            @if (item.AdvancedAmount > 0)
                                            {
                                                <span class="fw-semibold text-warning-emphasis">@item.AdvancedAmount.ToString("N0")</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">—</span>
                                            }
                                        </td>
                                    }
                                    @if (showActionsCol)
                                    {
                                        <td class="text-center">
                                            @if (item.LineStatus == "CANCELLED")
                                            {
                                                <span class="text-muted small">—</span>
                                            }
                                            else if (canCancelEarly)
                                            {
                                                <button type="button" class="btn btn-sm btn-outline-danger py-0 px-2"
                                                        title="Bỏ sản phẩm này khỏi đơn (khách không mua)"
                                                        onclick="openCancelItemModal(@item.SOItemId)">
                                                    <i class="bi bi-x-circle"></i>
                                                </button>
                                            }
                                            else
                                            {
                                                <div class="btn-group btn-group-sm">
                                                    @if (item.RemainingReceiveQty > 0)
                                                    {
                                                        <button type="button" class="btn btn-outline-info py-0 px-1"
                                                                title="Nhận hàng cho dòng này"
                                                                onclick="openReceiveItemModal(@item.SOItemId)">
                                                            <i class="bi bi-box-arrow-in-down"></i>
                                                        </button>
                                                    }
                                                    @if (item.InStockQty > 0)
                                                    {
                                                        <button type="button" class="btn btn-outline-warning py-0 px-1"
                                                                title="Giao hàng dòng này"
                                                                onclick="openDeliverItemModal(@item.SOItemId)">
                                                            <i class="bi bi-truck"></i>
                                                        </button>
                                                    }
                                                    <button type="button" class="btn btn-outline-secondary py-0 px-1 dropdown-toggle"
                                                            data-bs-toggle="dropdown" aria-expanded="false"
                                                            data-portal="fixed" title="Khác">
                                                    </button>
                                                    <ul class="dropdown-menu dropdown-menu-end">
                                                        <li>
                                                            <a class="dropdown-item small" href="#"
                                                               onclick="openEditItemModal(@item.SOItemId); return false;">
                                                                <i class="bi bi-pencil me-1"></i> Sửa ngày dự kiến
                                                            </a>
                                                        </li>
                                                        @if (item.RemainingReceiveQty > 0)
                                                        {
                                                            <li>
                                                                <a class="dropdown-item small text-danger" href="#"
                                                                   onclick="openCancelItemModal(@item.SOItemId); return false;">
                                                                    <i class="bi bi-x-circle me-1"></i> Hủy dòng
                                                                </a>
                                                            </li>
                                                        }
                                                    </ul>
                                                </div>
                                            }
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <!-- Pager (client-side) -->
                <div id="soItemsPager" class="d-flex justify-content-between align-items-center px-3 py-2 border-top small" style="display:none !important;">
                    <div class="d-flex align-items-center gap-2">
                        <span class="text-muted">Hiển thị</span>
                        <select id="soItemsPageSize" class="form-select form-select-sm" style="width:auto;">
                            <option value="10" selected>10</option>
                            <option value="20">20</option>
                            <option value="50">50</option>
                            <option value="9999">Tất cả</option>
                        </select>
                        <span class="text-muted">/ tổng @Model.Items.Count dòng</span>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <button type="button" id="soItemsPrev" class="btn btn-sm btn-outline-secondary py-0 px-2" title="Trang trước">
                            <i class="bi bi-chevron-left"></i>
                        </button>
                        <span class="text-muted" id="soItemsPageInfo"></span>
                        <button type="button" id="soItemsNext" class="btn btn-sm btn-outline-secondary py-0 px-2" title="Trang sau">
                            <i class="bi bi-chevron-right"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Financial summary (hidden for WAREHOUSE role) -->
        @if (showMoney)
        {
        <div class="card border-0 shadow-sm mt-3">
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <h6 class="fw-semibold text-muted text-uppercase mb-3" style="font-size:0.72rem;letter-spacing:.06em;">
                            <i class="bi bi-cash me-1"></i> Giá trị bán
                        </h6>
                        <table class="table table-sm table-borderless mb-0" style="font-size:0.85rem;">
                            <tr>
                                <td class="text-muted">Tạm tính</td>
                                <td class="text-end">@Model.SubTotal.ToString("N0")</td>
                            </tr>
                            @if (Model.DiscountAmount > 0)
                            {
                                <tr>
                                    <td class="text-muted">Chiết khấu</td>
                                    <td class="text-end text-danger">-@Model.DiscountAmount.ToString("N0")</td>
                                </tr>
                            }
                            <tr>
                                <td class="text-muted">Thuế (@Model.TaxRate%)</td>
                                <td class="text-end">@Model.TaxAmount.ToString("N0")</td>
                            </tr>
                            <tr class="fw-bold border-top">
                                <td>Tổng bán</td>
                                <td class="text-end text-primary fs-6">@Model.TotalAmount.ToString("N0") @Model.Currency</td>
                            </tr>
                        </table>
                    </div>
                    @if (showBuyingInfo || Model.Status == "DRAFT")
                    {
                        <div class="col-md-6">
                            <h6 class="fw-semibold text-muted text-uppercase mb-3" style="font-size:0.72rem;letter-spacing:.06em;">
                                <i class="bi bi-calculator me-1"></i> Chi phí & Lợi nhuận
                            </h6>
                            <table class="table table-sm table-borderless mb-0" style="font-size:0.85rem;">
                                <tr>
                                    <td class="text-muted">Chi phí mua</td>
                                    <td class="text-end">@(Model.Status == "DRAFT" ? Model.AdvanceSummary?.PurchaseCost.ToString("N0") : Model.PurchaseCost?.ToString("N0") ?? "—")</td>
                                </tr>
                                <tr class="fw-bold border-top">
                                    <td>Lợi nhuận</td>
                                    <td class="text-end @(Model.ProfitAmount >= 0 ? "text-success" : "text-danger")">
                                        @* @Model.ProfitAmount.ToString("N0") @Model.Currency *@
                                        @((Model.TotalAmount - (Model.Status == "DRAFT" ? Model.AdvanceSummary?.PurchaseCost : Model.PurchaseCost))?.ToString("N0") + @Model.Currency)
                                    </td>
                                </tr>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
        }

        @* ── Ảnh hóa đơn theo từng sản phẩm (lazy-load, ẩn với WAREHOUSE) ── *@
        @if (showMoney)
        {
            var totalBills = Model.Items.Sum(i => i.BillImageCount);
            <div class="card border-0 shadow-sm mt-3" id="billSection">
                <div class="card-header bg-white border-bottom d-flex flex-wrap align-items-center gap-2">
                    <h6 class="mb-0 fw-semibold">
                        <i class="bi bi-receipt me-1"></i> Ảnh hóa đơn theo sản phẩm
                        <span class="badge bg-secondary-subtle text-secondary-emphasis ms-1" id="billTotalBadge">@totalBills</span>
                    </h6>
                    <div class="ms-auto d-flex align-items-center gap-2">
                        <input type="text" id="billFilter" class="form-control form-control-sm" style="width:200px;"
                               placeholder="Tìm sản phẩm..." oninput="filterBillCards()" />
                        <button type="button" class="btn btn-sm btn-outline-secondary py-0 px-2" onclick="toggleAllBills(true)" title="Mở tất cả">
                            <i class="bi bi-arrows-expand"></i>
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-secondary py-0 px-2" onclick="toggleAllBills(false)" title="Thu gọn tất cả">
                            <i class="bi bi-arrows-collapse"></i>
                        </button>
                    </div>
                </div>
                <div class="card-body">
                    @if (Model.Items.Any())
                    {
                        <div class="row g-2" id="billCardGrid">
                            @{ int bidx = 1; }
                            @foreach (var item in Model.Items)
                            {
                                var collapseId = $"billCollapse-{item.SOItemId}";
                                <div class="col-12 col-md-6 col-xl-4 bill-card" data-name="@item.ProductName.ToLowerInvariant()">
                                    <div class="border rounded h-100">
                                        <button type="button" class="btn btn-link text-decoration-none text-start w-100 d-flex align-items-center gap-2 px-2 py-2 text-body collapsed"
                                                data-bs-toggle="collapse" data-bs-target="#@collapseId"
                                                onclick="onBillToggle(@item.SOItemId)">
                                            <span class="text-muted small">@(bidx++).</span>
                                            <span class="fw-semibold small text-truncate flex-grow-1" title="@item.ProductName">@item.ProductName</span>
                                            <span class="badge bg-primary-subtle text-primary-emphasis" id="billCount-@item.SOItemId">@item.BillImageCount</span>
                                            <i class="bi bi-chevron-down small"></i>
                                        </button>
                                        <div class="collapse" id="@collapseId" data-loaded="false">
                                            <div class="border-top p-2">
                                                <div class="d-flex flex-wrap gap-2 mb-2" id="billGrid-@item.SOItemId"></div>
                                                @if (canManageStatus)
                                                {
                                                    <input type="file" accept="image/*" multiple class="d-none"
                                                           id="billFile-@item.SOItemId" onchange="uploadItemBills(@item.SOItemId, this)" />
                                                    <button type="button" class="btn btn-sm btn-outline-primary py-0 px-2"
                                                            onclick="document.getElementById('billFile-@item.SOItemId').click()">
                                                        <i class="bi bi-upload me-1"></i> Thêm ảnh hóa đơn
                                                    </button>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                        <div id="billNoMatch" class="text-center py-3 text-muted small d-none">Không tìm thấy sản phẩm phù hợp</div>
                    }
                    else
                    {
                        <div class="text-center py-3 text-muted small">Đơn chưa có sản phẩm</div>
                    }
                </div>
            </div>
        }
    </div>
</div>

@{
    // v2.5 — advance entry now starts at DRAFT step (sales enters data before sending DNTU)
    bool showAdvanceSection = Model.Status != "CANCELLED";
    bool canManageAdvance = canManageStatus && Model.Status is not "CANCELLED" and not "REPORTED";
    // ── Quyền theo vai trò trong quy trình duyệt tạm ứng (strict + ADMIN override) ──
    bool canAccountantAct = currentRole is "ADMIN" or "ACCOUNTANT";   // bước 1→2, 3→4
    bool canDirectorAct = currentRole is "ADMIN" or "MANAGER";        // bước 2→3
    bool canRejectAdvance = currentRole is "ADMIN" or "MANAGER" or "ACCOUNTANT";
    var adv = Model.AdvanceSummary;
}
@if (showMoney && showAdvanceSection && adv != null)
{
    <div class="card border-0 shadow-sm mt-3 border-start border-4 border-warning">
        <div class="card-header bg-white border-bottom py-2 d-flex align-items-center justify-content-between flex-wrap gap-2">
            <h6 class="mb-0 fw-semibold small text-uppercase">
                <i class="bi bi-cash-stack text-warning me-1"></i> Tạm ứng
                <span class="badge bg-warning text-dark rounded-pill ms-1">@adv.Requests.Count</span>
            </h6>
            @if (canManageAdvance)
            {
                <button type="button" class="btn btn-sm btn-warning" onclick="openCreateAdvanceModal()">
                    <i class="bi bi-plus-circle me-1"></i> Tạm ứng mới
                </button>
            }
        </div>
        <div class="card-body">
            <!-- Summary strip -->
            <div class="row g-2 mb-3 small">
                <div class="col-6 col-md">
                    <div class="border rounded p-2 text-center bg-light h-100">
                        <div class="text-muted" style="font-size:0.72rem;">Chi phí mua dự kiến</div>
                        <div class="fw-bold">@adv.PurchaseCost.ToString("N0") <span class="text-muted small">@adv.Currency</span></div>
                    </div>
                </div>
                <div class="col-6 col-md">
                    <div class="border rounded p-2 text-center bg-light h-100">
                        <div class="text-muted" style="font-size:0.72rem;">Chi phí vận chuyển dự kiến</div>
                        <div class="fw-bold">@adv.CustomerShippingCost.ToString("N0") <span class="text-muted small">@adv.Currency</span></div>
                    </div>
                </div>
                <div class="col-6 col-md">
                    <div class="border rounded p-2 text-center bg-info-subtle h-100">
                        <div class="text-muted" style="font-size:0.72rem;">Tổng đã yêu cầu</div>
                        <div class="fw-bold text-info-emphasis">@adv.TotalRequested.ToString("N0")</div>
                    </div>
                </div>
                <div class="col-6 col-md">
                    <div class="border rounded p-2 text-center bg-success-subtle h-100">
                        <div class="text-muted" style="font-size:0.72rem;">Đã chi tiền</div>
                        <div class="fw-bold text-success-emphasis">@adv.TotalReceived.ToString("N0")</div>
                    </div>
                </div>
                <div class="col-6 col-md">
                    <div class="border rounded p-2 @((adv.RemainingVsCost > 0 || adv.RemainingVsCustomerShipping > 0) ? "bg-warning-subtle" : "bg-success-subtle") h-100">
                        <div class="text-muted text-center" style="font-size:0.72rem;">Còn lại</div>
                        <div class="d-flex justify-content-between"><span class="text-muted">Mua:</span> <span class="fw-bold @(adv.RemainingVsCost > 0 ? "text-warning-emphasis" : "text-success-emphasis")">@adv.RemainingVsCost.ToString("N0")</span></div>
                        <div class="d-flex justify-content-between"><span class="text-muted">VC khách:</span> <span class="fw-bold @(adv.RemainingVsCustomerShipping > 0 ? "text-warning-emphasis" : "text-success-emphasis")">@adv.RemainingVsCustomerShipping.ToString("N0")</span></div>
                    </div>
                </div>
            </div>

            @if (adv.Requests.Count == 0)
            {
                <div class="text-center py-4 text-muted small">
                    <i class="bi bi-inboxes" style="font-size:1.8rem;opacity:.3;"></i>
                    <div class="mt-1">Chưa có đề nghị tạm ứng nào</div>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-bordered align-middle mb-0" style="font-size:0.825rem;">
                        <thead class="table-light">
                            <tr>
                                <th style="width:40px;">#</th>
                                <th>Số phiếu</th>
                                <th>Ngày</th>
                                <th>Mục đích</th>
                                <th>Phân bổ</th>
                                <th class="text-end">Số tiền</th>
                                <th>Trạng thái</th>
                                <th class="d-none d-md-table-cell">Người tạo</th>
                                <th class="text-center" style="min-width:160px;">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ int aIdx = 1; }
                            @foreach (var r in adv.Requests)
                            {
                                <tr>
                                    <td class="text-muted small">@(aIdx++)</td>
                                    <td class="fw-semibold">@r.RequestNo</td>
                                    <td>@r.RequestDate.ToString("dd/MM/yyyy")</td>
                                    <td class="small">@r.Purpose</td>
                                    <td class="small">
                                        @foreach (var li in r.Items)
                                        {
                                            <div>
                                                <span class="@(li.SOItemId.HasValue ? "" : "text-muted fst-italic")">@li.ProductName</span>
                                                <span class="text-muted">— @li.Amount.ToString("N0")</span>
                                            </div>
                                        }
                                    </td>
                                    <td class="text-end fw-semibold text-warning-emphasis">@r.RequestedAmount.ToString("N0")</td>
                                    <td><span class="badge @r.StatusBadge">@r.StatusText</span></td>
                                    <td class="d-none d-md-table-cell small text-muted">@r.CreatedByName</td>
                                    <td class="text-center">
                                        <div class="d-flex gap-1 justify-content-center flex-wrap">
                                            <a href="/AdvanceRequest/ExportDntu/@r.AdvanceRequestId"
                                               class="btn btn-sm btn-outline-success py-0 px-1" title="Xuất DNTU">
                                                <i class="bi bi-download"></i>
                                            </a>
                                            @if (canManageAdvance && r.Status == "WAIT_ACCOUNTANT")
                                            {
                                                <button type="button" class="btn btn-sm btn-outline-primary py-0 px-1" title="Sửa"
                                                        onclick="editAdvance(@r.AdvanceRequestId)">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                            }
                                            @* Bước 1→2: Kế toán duyệt *@
                                            @if (canAccountantAct && r.Status == "WAIT_ACCOUNTANT")
                                            {
                                                <button type="button" class="btn btn-sm btn-outline-info py-0 px-1" title="Kế toán duyệt"
                                                        onclick="accountantReview(@r.AdvanceRequestId, '@r.RequestNo')">
                                                    <i class="bi bi-check2"></i> KT duyệt
                                                </button>
                                            }
                                            @* Bước 2→3: Giám đốc duyệt *@
                                            @if (canDirectorAct && r.Status == "WAIT_DIRECTOR")
                                            {
                                                <button type="button" class="btn btn-sm btn-outline-primary py-0 px-1" title="Giám đốc duyệt"
                                                        onclick="directorApprove(@r.AdvanceRequestId, '@r.RequestNo')">
                                                    <i class="bi bi-check2-circle"></i> GĐ duyệt
                                                </button>
                                            }
                                            @* Bước 3→4: Kế toán xác nhận chi tiền *@
                                            @if (canAccountantAct && r.Status == "WAIT_DISBURSE")
                                            {
                                                <button type="button" class="btn btn-sm btn-outline-success py-0 px-1" title="Xác nhận chi tiền"
                                                        onclick="disburseAdvance(@r.AdvanceRequestId, '@r.RequestNo')">
                                                    <i class="bi bi-cash-coin"></i> Chi tiền
                                                </button>
                                            }
                                            @* Từ chối: trong các bước chờ duyệt *@
                                            @if (canRejectAdvance && r.Status is "WAIT_ACCOUNTANT" or "WAIT_DIRECTOR" or "WAIT_DISBURSE")
                                            {
                                                <button type="button" class="btn btn-sm btn-outline-warning py-0 px-1" title="Từ chối"
                                                        onclick="rejectAdvance(@r.AdvanceRequestId, '@r.RequestNo')">
                                                    <i class="bi bi-x-octagon"></i>
                                                </button>
                                            }
                                            @if (canManageAdvance && r.Status is not "SETTLING" and not "SETTLED")
                                            {
                                                <button type="button" class="btn btn-sm btn-outline-danger py-0 px-1" title="Xóa"
                                                        onclick="deleteAdvance(@r.AdvanceRequestId, '@r.RequestNo')">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

<!-- Comment Panel -->
@await Html.PartialAsync("_TaskComments", new ViewDataDictionary(ViewData) {
