@model EV_ERP.Models.ViewModels.Quotations.QuotationFormViewModel
@{
    var action = Model.IsEditMode ? "Edit" : "Create";
    var title = Model.IsEditMode
        ? $"{Model.QuotationNo}"
        : (!string.IsNullOrEmpty(Model.QuotationNo) ? Model.QuotationNo : "Tạo báo giá mới");
    var icon = Model.IsEditMode ? "bi-pencil-square" : "bi-file-earmark-plus";
}

<div class="row">
    <!-- Form header -->
    <div class="col-lg-12">
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-white border-bottom py-3">
                <div class="d-flex align-items-center gap-2">
                    @* <a href="/Quotation" class="btn btn-sm btn-light border">
                        <i class="bi bi-arrow-left"></i>
                    </a> *@
                    <h5 class="mb-0 fw-semibold">
                        <i class="bi @icon me-2 text-primary"></i>@title
                    </h5>
                </div>
            </div>
            <div class="card-body">
                @if (Model.IsEditMode)
                {
                    <input type="hidden" id="frm_quotationId" value="@Model.QuotationId" />
                }
                @if (Model.RfqId.HasValue)
                {
                    <input type="hidden" id="frm_rfqId" value="@Model.RfqId" />
                }
                <input type="hidden" id="frm_salesPersonId" value="@Model.SalesPersonId" />
                <div class="row">
                    <div class="col-lg-3">
                        <label class="form-label small fw-semibold">Khách hàng <span class="text-danger">*</span></label>
                        <div class="position-relative" id="customerWrapper">
                            <input type="hidden" id="frm_customerId" value="@Model.CustomerId" />
                            <input type="text" class="form-control form-control-sm" id="customerSearchInput"
                                   placeholder="Tìm khách hàng..."
                                   autocomplete="off"
                                   value="@(Model.CustomerId > 0 ? Model.Customers.FirstOrDefault(c => c.CustomerId == Model.CustomerId)?.CustomerName : "")" />
                            <div id="customerDropdown" class="position-absolute w-100 bg-white border rounded shadow-sm d-none"
                                 style="z-index:1050;max-height:240px;overflow-y:auto;top:100%;left:0;">
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-3">
                        <label class="form-label small fw-semibold">Hạn xử lý nội bộ <span class="text-danger">*</span></label>
                        <input type="datetime-local" id="frm_deadline" class="form-control form-control-sm"
                               value="@(Model.Deadline?.ToString("yyyy-MM-ddTHH:mm"))"
                               @(Model.RfqId.HasValue ? "readonly" : "") />
                    </div>
                    <div class="col-lg-2">
                        <label class="form-label small fw-semibold">Hệ số chung</label>
                        <input type="number" id="frm_coefficient" class="form-control form-control-sm" min="0.01" step="any" placeholder="Nhập để áp dụng chung" />
                        <div class="form-text" style="font-size:0.72rem;">Đơn giá = Giá nhập × Tỷ giá / Hệ số + Vận chuyển / Số lượng</div>
                    </div>
                    <div class="col-lg-4">
                        <label class="form-label small fw-semibold">Ghi chú chung</label>
                        <textarea id="frm_notesforall" class="form-control form-control-sm" rows="1" placeholder="Nhập để áp dụng chung"></textarea>
                    </div>                   
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-12">
        <!-- Items header -->
        <div class="d-flex align-items-center justify-content-between mb-2">
            <h6 class="mb-0 fw-semibold small text-uppercase">
                <i class="bi bi-box-seam me-1"></i> Sản phẩm
                <span class="badge bg-primary rounded-pill ms-1" id="itemCountBadge">0</span>
            </h6>
        </div>

        <!-- Items container -->
        <div id="itemsContainer"></div>

        <div id="itemsEmpty" class="card border-0 shadow-sm mb-3">
            <div class="card-body text-center py-5 text-muted">
                <i class="bi bi-inbox" style="font-size:2.5rem;opacity:.25;"></i>
                <p class="small mt-2 mb-0">Chưa có sản phẩm — nhấn <strong>"Thêm sản phẩm"</strong> để bắt đầu</p>
            </div>
        </div>

        <!-- Inline action bar: add product + quick save (no redirect) -->
        <div class="d-flex justify-content-end gap-2 mb-3">
            <button type="button" class="btn btn-sm btn-outline-primary" onclick="addEmptyRow()">
                <i class="bi bi-plus-lg me-1"></i> Thêm sản phẩm
            </button>
            <button type="button" class="btn btn-sm btn-success" onclick="submitForm(true)" id="btnQuickSave">
                <i class="bi bi-save me-1"></i> Lưu báo giá
            </button>
        </div>

        <!-- Totals -->
        <div id="totalsCard" class="card border-0 shadow-sm mb-3" style="display:none;">
            <div class="card-body py-2">
                <div class="d-flex justify-content-end gap-4">
                    <div class="text-end">
                        <div class="text-muted small">Tổng trước VAT</div>
                        <div class="fw-semibold" id="sumExclVat">0</div>
                    </div>
                    <div class="text-end">
                        <div class="text-muted small">Tổng sau VAT</div>
                        <div class="fw-bold text-primary fs-5" id="sumInclVat">0</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Actions -->
        <div class="d-flex gap-2 justify-content-end mb-4">
            <a href="/Quotation" class="btn btn-outline-secondary">Hủy</a>
            <button type="button" class="btn btn-primary" onclick="submitForm()" id="btnSubmit">
                <i class="bi bi-check-lg me-1"></i>
                @* @(Model.IsEditMode ? "Cập nhật" : "Tạo báo giá") *@
                Hoàn tất
            </button>
        </div>
    </div>
</div>

<!-- Inline search dropdown (shared, repositioned per input) -->
<div id="inlineSearchDropdown" class="position-fixed bg-white border rounded shadow-sm"
     style="z-index:2000; display:none; max-height:240px; overflow-y:auto; min-width:320px;">
</div>

<style>
    .qi-card {
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        background: #fff;
        margin-bottom: 10px;
        box-shadow: 0 1px 3px rgba(0,0,0,.04);
        transition: box-shadow .15s;
    }
    .qi-card:hover { box-shadow: 0 2px 8px rgba(0,0,0,.08); }

    .qi-header {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 14px 6px;
    }
    .qi-num {
        width: 26px; height: 26px;
        display: flex; align-items: center; justify-content: center;
        background: #f1f5f9; border-radius: 6px;
        font-size: 0.72rem; font-weight: 600; color: #64748b;
        flex-shrink: 0;
    }
    .qi-search {
        flex: 1;
        border: 1px solid #dee2e6;
        border-radius: 6px;
        padding: 6px 10px;
        font-size: 0.82rem;
        outline: none;
        transition: border-color .15s, box-shadow .15s;
    }
    .qi-search:focus {
        border-color: #86b7fe;
        box-shadow: 0 0 0 2px rgba(13,110,253,.12);
    }
    .qi-search::placeholder { color: #94a3b8; }

    .qi-body { padding: 0 14px 10px; }

    .qi-grid {
        display: grid;
        gap: 6px 12px;
        align-items: end;
    }
    .qi-grid-row1 { grid-template-columns: 1fr 80px 1fr 1fr; }
    .qi-grid-row2 { grid-template-columns: 1fr 1fr 1fr 1fr 80px 1fr 1fr 60px 1fr; margin-top: 8px; padding-top: 8px; border-top: 1px solid #f1f5f9; }

    .qi-label {
        font-size: 0.68rem;
        color: #64748b;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .03em;
        margin-bottom: 2px;
    }
    .qi-val {
        font-size: 0.82rem;
        font-weight: 600;
        padding: 4px 0;
        white-space: nowrap;
    }
    .qi-val-primary { color: #2563eb; font-weight: 700; }

    .qi-card input.form-control,
    .qi-card select.form-select {
        font-size: 0.8rem;
        padding: 4px 8px;
        height: auto;
    }

    .qi-img-row {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 8px 0;
        margin: 4px 0;
        border-top: 1px solid #f1f5f9;
        /* border-bottom: 1px solid #f1f5f9; */
    }
    .qi-img-preview {
        width: 80px; height: 80px;
        object-fit: contain;
        border-radius: 8px;
        border: 1px solid #e2e8f0;
        background: #f8fafc;
        flex-shrink: 0;
    }
    .qi-img-empty-lg {
        width: 80px; height: 80px;
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        background: #f8fafc; border-radius: 8px;
        border: 2px dashed #cbd5e1;
        color: #94a3b8; font-size: 0.72rem;
        cursor: pointer; transition: all .15s;
        flex-shrink: 0;
    }
    .qi-img-empty-lg:not(.qi-img-readonly):hover {
        border-color: #93c5fd; background: #eff6ff; color: #3b82f6;
    }
    .qi-img-readonly { cursor: default; }
    .qi-img-actions {
        display: flex; flex-direction: column;
        gap: 4px;
    }
    .qi-img-upload-btn {
        font-size: 0.72rem; padding: 3px 10px;
        border: 1px solid #cbd5e1; border-radius: 5px;
        background: #fff; color: #475569;
        cursor: pointer; transition: all .12s;
        display: inline-flex; align-items: center; gap: 4px;
    }
    .qi-img-upload-btn:hover { border-color: #3b82f6; color: #2563eb; background: #eff6ff; }
    .qi-img-remove-btn {
        font-size: 0.68rem; padding: 2px 8px;
        border: none; border-radius: 4px;
        background: none; color: #94a3b8;
        cursor: pointer;
    }
    .qi-img-remove-btn:hover { color: #dc2626; }
    .qi-img-paste-target { box-shadow: 0 0 0 2px #3b82f6; border-radius: 6px; }

    .qi-badge-mapped {
        font-size: 0.6rem; padding: 2px 6px; border-radius: 4px;
        font-weight: 600; flex-shrink: 0;
    }
    .qi-badge-ht { background: #dcfce7; color: #166534; }
    .qi-badge-tmp { background: #fef9c3; color: #854d0e; }

    .qi-delete {
        width: 28px; height: 28px;
        display: flex; align-items: center; justify-content: center;
        border-radius: 6px; border: none;
        background: #fff; color: #94a3b8;
        cursor: pointer; flex-shrink: 0;
        transition: all .15s;
    }
    .qi-delete:hover { background: #fef2f2; color: #dc2626; }

    .qi-calc-symbol {
        font-size: 0.78rem; color: #94a3b8; font-weight: 500;
        display: flex; align-items: end; padding-bottom: 5px;
    }

    .product-result-item {
        padding: 10px 14px;
        cursor: pointer;
        border-bottom: 1px solid #f1f5f9;
        transition: background .1s;
    }
    .product-result-item:hover { background: #f8fafc; }
    .product-result-item:last-child { border-bottom: none; }

    @@media (max-width: 768px) {
        .qi-grid-row1 { grid-template-columns: 1fr 60px; }
        .qi-grid-row2 { grid-template-columns: 1fr 1fr 1fr; }
    }
</style>

<script>
    // ══════════════════════════════════════════════
    // STATE
    // ══════════════════════════════════════════════
    var items = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Items));
    var searchTimeout = null;
    var isEditMode = @(Model.IsEditMode ? "true" : "false");
    var activeSearchIdx = -1;

    // ══════════════════════════════════════════════
    // INIT
    // ══════════════════════════════════════════════
    document.addEventListener('DOMContentLoaded', function () {
        // New quotation with no pre-loaded items → seed one empty row so the user can start typing.
        if (!isEditMode && items.length === 0) {
            addEmptyRow();
        } else {
            renderItems();
            recalcTotals();
        }

        document.getElementById('frm_coefficient').addEventListener('input', function () {
            var globalCoeff = parseFloat(this.value) || 1;
            items.forEach(function (item, idx) {
                item.Coefficient = globalCoeff;
                recalcUnitPriceFromImport(idx);
                recalcItemLine(idx);
            });
            renderItems();
            recalcTotals();
        });

        document.getElementById('frm_notesforall').addEventListener('input', function () {
            var globalNotes = this.value;
            items.forEach(function (item, idx) {
                item.Notes = globalNotes;
            });
            renderItems();
        });

        document.addEventListener('click', function (e) {
            var dd = document.getElementById('inlineSearchDropdown');
            if (!dd.contains(e.target) && !e.target.classList.contains('qi-search')) {
                dd.style.display = 'none';
                activeSearchIdx = -1;
            }
        });
    });

    // ══════════════════════════════════════════════
    // ADD EMPTY ROW
    // ══════════════════════════════════════════════
    function addEmptyRow() {
        var globalCoeff = parseFloat(document.getElementById('frm_coefficient').value) || 1;
        var globalNotes = document.getElementById('frm_notesforall').value || null;
        items.push({
            QuotationItemId: null,
            ProductId: 0,
            ProductName: '',
            Proposal: '',
            ImageUrl: '',
            UnitName: '',
            Quantity: 1,
            UnitPrice: 0,
            AmountExclVat: 0,
            VatRate: 8,
            AmountInclVat: 0,
            Supplier: '',
            SourceUrl: '',
            ImportPrice: 0,
            ExchangeRate: 0,
            Shipping: 0,
            Coefficient: globalCoeff,
            DiscountType: null,
            DiscountValue: null,
            DiscountAmount: 0,
            LineTotal: 0,
            SortOrder: items.length,
            Notes: globalNotes,
            IsProductMapped: false
        });
        renderItems();
        recalcTotals();
        setTimeout(function () {
            var input = document.getElementById('req_' + (items.length - 1));
            if (input) input.focus();
        }, 50);
    }

    // ══════════════════════════════════════════════
    // INLINE PRODUCT SEARCH
    // ══════════════════════════════════════════════
    function onRequestInput(idx, inputEl) {
        var kw = inputEl.value.trim();
        items[idx].ProductName = inputEl.value;
        if (items[idx].IsProductMapped) {
            items[idx].ProductId = 0;
            items[idx].IsProductMapped = false;
            // Update badge inline without full re-render
            var badge = document.getElementById('badge_' + idx);
            if (badge) {
                badge.className = 'qi-badge-mapped qi-badge-tmp';
                badge.textContent = 'Tam';
                badge.title = 'SP nhap tay (chua co trong he thong)';
            }
        }
        activeSearchIdx = idx;

        clearTimeout(searchTimeout);
        var dd = document.getElementById('inlineSearchDropdown');

        if (kw.length < 2) {
            dd.style.display = 'none';
            return;
        }

        searchTimeout = setTimeout(function () {
            fetch('/Quotation/SearchProducts?keyword=' + encodeURIComponent(kw))
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    if (activeSearchIdx !== idx) return;

                    if (!data || data.length === 0) {
                        dd.innerHTML = '<div class="p-3 text-muted small text-center">Khong tim thay san pham — nhap tay thong tin</div>';
                    } else {
                        dd.innerHTML = data.map(function (p) {
                            var imgHtml = p.ImageUrl
                                ? '<img src="' + escapeHtml(p.ImageUrl) + '" style="width:32px;height:32px;object-fit:cover;border-radius:4px;margin-right:8px;" />'
                                : '';
                            return '<div class="product-result-item d-flex align-items-center" onmousedown="selectProduct(' + idx + ', ' + JSON.stringify(p).replace(/"/g, '&quot;') + ')">' +
                                imgHtml +
                                '<div>' +
                                '<div class="fw-semibold small">' + escapeHtml(p.ProductName) + '</div>' +
                                '<div class="text-muted" style="font-size:0.72rem;">' +
                                escapeHtml(p.ProductCode) + ' &bull; ' + escapeHtml(p.UnitName) +
                                (p.DefaultPurchasePrice ? ' &bull; Nhap: ' + formatNumber(p.DefaultPurchasePrice) : '') +
                                '</div></div></div>';
                        }).join('');
                    }

                    var rect = inputEl.getBoundingClientRect();
                    dd.style.left = rect.left + 'px';
                    dd.style.top = (rect.bottom + 2) + 'px';
                    dd.style.width = Math.max(rect.width, 320) + 'px';
                    dd.style.display = 'block';
                });
        }, 300);
    }

    function onRequestBlur(idx) {
        setTimeout(function () {
            if (activeSearchIdx === idx) {
                document.getElementById('inlineSearchDropdown').style.display = 'none';
                activeSearchIdx = -1;
            }
        }, 200);
    }

    function selectProduct(idx, product) {
        var globalCoeff = parseFloat(document.getElementById('frm_coefficient').value) || 1;
        var importPrice = product.DefaultPurchasePrice || 0;
        var coeff = items[idx].Coefficient || globalCoeff;
        var unitPrice = coeff > 0 ? Math.round(importPrice / coeff) : importPrice;

        items[idx].ProductId = product.ProductId;
        items[idx].ProductName = product.ProductName;
        items[idx].Proposal = product.Description || '';
        items[idx].ImageUrl = product.ImageUrl || '';
        items[idx].UnitName = product.UnitName || '';
        items[idx].ImportPrice = importPrice;
        items[idx].UnitPrice = unitPrice;
        items[idx].IsProductMapped = true;

        recalcItemLine(idx);

        document.getElementById('inlineSearchDropdown').style.display = 'none';
        activeSearchIdx = -1;

        renderItems();
        recalcTotals();
    }

    // ══════════════════════════════════════════════
    // RENDER ITEMS
    // ══════════════════════════════════════════════
    function renderItems() {
        var container = document.getElementById('itemsContainer');
        var empty = document.getElementById('itemsEmpty');
        var totals = document.getElementById('totalsCard');
        document.getElementById('itemCountBadge').textContent = items.length;

        if (items.length === 0) {
            container.innerHTML = '';
            empty.style.display = 'block';
            totals.style.display = 'none';
            return;
        }
        empty.style.display = 'none';
        totals.style.display = 'block';

        container.innerHTML = items.map(function (item, idx) {
            var badgeClass = item.IsProductMapped ? 'qi-badge-ht' : 'qi-badge-tmp';
            var badgeText = item.IsProductMapped ? 'HT' : 'Tam';
            var badgeTitle = item.IsProductMapped ? 'SP trong he thong' : 'SP nhap tay (chua co trong he thong)';
            var showBadge = item.IsProductMapped || item.ProductName;

            return '<div class="qi-card">' +
                // ── HEADER: Number + Search + Badge + Delete ──
                '<div class="qi-header">' +
                    '<div class="qi-num">' + (idx + 1) + '</div>' +
                    '<input type="text" class="qi-search" id="req_' + idx + '" ' +
                        'value="' + escapeHtml(item.ProductName) + '" ' +
                        'oninput="onRequestInput(' + idx + ', this)" ' +
                        'onblur="onRequestBlur(' + idx + ')" ' +
                        'placeholder="Tim san pham hoac nhap ten truc tiep..." autocomplete="off" />' +
                    (showBadge ? '<span class="qi-badge-mapped ' + badgeClass + '" id="badge_' + idx + '" title="' + badgeTitle + '">' + badgeText + '</span>' : '') +
                    '<button class="qi-delete" onclick="removeItem(' + idx + ')" title="Xoa dong nay">' +
                        '<i class="bi bi-trash3" style="font-size:0.8rem;"></i>' +
                    '</button>' +
                '</div>' +

                '<div class="qi-body">' +
                    // ── ROW 1: Image + Description + Unit + Purchase Link ──
                    '<div class="qi-img-row" data-paste-idx="' + idx + '">' +
                        (item.IsProductMapped
                            ? (item.ImageUrl
                                ? '<img src="' + escapeHtml(item.ImageUrl) + '" class="qi-img-preview" alt="" />'
                                : '<div class="qi-img-empty-lg qi-img-readonly"><i class="bi bi-image" style="font-size:1.5rem;"></i><span>Khong co anh</span></div>') +
                              '<div class="qi-img-actions">' +
                                  '<div class="text-muted" style="font-size:0.68rem;"><i class="bi bi-lock me-1"></i>Anh tu he thong</div>' +
                              '</div>'
                            : (item.ImageUrl
                                ? '<img src="' + escapeHtml(item.ImageUrl) + '" class="qi-img-preview" alt="" />'
                                : '<div class="qi-img-empty-lg" title="Click vao day roi Ctrl+V de paste anh">' +
                                    '<i class="bi bi-clipboard-plus" style="font-size:1.5rem;"></i>' +
                                    '<span>Click + Ctrl+V</span>' +
                                    '<span style="font-size:0.62rem; color:#94a3b8; margin-top:2px;">paste anh</span>' +
                                  '</div>') +
                              '<div class="qi-img-actions">' +
                                  '<input type="file" id="imgFile_' + idx + '" accept="image/*" style="display:none;" onchange="uploadItemImage(' + idx + ', this)" />' +
                                  '<button type="button" class="qi-img-upload-btn" onclick="triggerUpload(' + idx + ')">' +
                                      '<i class="bi bi-upload"></i> ' + (item.ImageUrl ? 'Doi anh' : 'Chon anh') +
                                  '</button>' +
                                  (item.ImageUrl ? '<button type="button" class="qi-img-remove-btn" onclick="removeImage(' + idx + ')"><i class="bi bi-x-lg"></i> Xoa anh</button>' : '') +
                                  '<div class="text-muted" style="font-size:0.65rem; margin-top:2px;">JPG, PNG — toi da 5MB</div>' +
                              '</div>'
                        ) +
                        '<div class="qi-grid qi-grid-row1" style="flex:1;">' +
                            '<div>' +
                                '<div class="qi-label">Mo ta / De xuat</div>' +
                                '<textarea rows="1" class="form-control form-control-sm"' +
                                    'onchange="updateField(' + idx + ', \'Proposal\', this.value)" placeholder="Mo ta san pham...">' + escapeHtml(item.Proposal || '') + '</textarea>' +
                            '</div>' +
                            '<div>' +
                                '<div class="qi-label">DVT</div>' +
                                '<input type="text" class="form-control form-control-sm" value="' + escapeHtml(item.UnitName) + '" ' +
                                    'onchange="updateField(' + idx + ', \'UnitName\', this.value)" placeholder="Cai, Bo..." />' +
                            '</div>' +
                            '<div>' +
                                '<div class="qi-label">Link mua hang</div>' +
                                '<input type="url" class="form-control form-control-sm" value="' + escapeHtml(item.SourceUrl || '') + '" ' +
                                    'onchange="updateField(' + idx + ', \'SourceUrl\', this.value)" placeholder="https://..." />' +
                            '</div>' +
                            '<div>' +
                                '<div class="qi-label">Ghi chu</div>' +
                                 '<textarea rows="1" class="form-control form-control-sm"' +
                                    'onchange="updateField(' + idx + ', \'Notes\', this.value)" placeholder="5-7 days...">' + escapeHtml(item.Notes || '') + '</textarea>' +
                            '</div>' +
                        '</div>' +
                    '</div>' +

                    // ── ROW 2: Cost Price + Exchange Rate + Shipping + Coefficient + Qty + Unit Price + Before VAT + VAT% + After VAT ──
                    '<div class="qi-grid qi-grid-row2">' +
                        '<div>' +
                            '<div class="qi-label">Gia nhap</div>' +
                            '<input type="text" inputmode="decimal" class="form-control form-control-sm text-end" ' +
                                'value="' + formatNumber(item.ImportPrice) + '" oninput="formatMoneyInput(this)" onchange="updateImportPrice(' + idx + ', this.value)" onfocus="this.select()" />' +
                        '</div>' +
                        '<div>' +
                            '<div class="qi-label">Ty gia</div>' +
                            '<input type="text" inputmode="decimal" class="form-control form-control-sm text-end" ' +
                                'value="' + (item.ExchangeRate ? formatNumber(item.ExchangeRate) : '') + '" ' +
                                'oninput="formatMoneyInput(this)" onchange="updateExchangeRate(' + idx + ', this.value)" onfocus="this.select()" placeholder="De trong = 1" />' +
                        '</div>' +
                        '<div>' +
                            '<div class="qi-label">Van chuyen</div>' +
                            '<input type="text" inputmode="decimal" class="form-control form-control-sm text-end" ' +
                                'value="' + formatNumber(item.Shipping) + '" oninput="formatMoneyInput(this)" onchange="updateShipping(' + idx + ', this.value)" onfocus="this.select()" />' +
                        '</div>' +
                        '<div>' +
                            '<div class="qi-label">He so</div>' +
                            '<input type="text" inputmode="decimal" class="form-control form-control-sm text-end" ' +
                                'value="' + item.Coefficient + '" onchange="updateCoefficient(' + idx + ', this.value)" onfocus="this.select()" />' +
                        '</div>' +
                        '<div>' +
                            '<div class="qi-label">So luong</div>' +
                            '<input type="text" inputmode="decimal" class="form-control form-control-sm text-end" id="qty_' + idx + '" ' +
                                'value="' + item.Quantity + '" onchange="updateQtyOrPrice(' + idx + ')" onfocus="this.select()" />' +
                        '</div>' +
                        '<div>' +
                            '<div class="qi-label">Don gia</div>' +
                            '<input type="text" inputmode="decimal" class="form-control form-control-sm text-end" ' +
                                'value="' + formatNumber(item.UnitPrice) + '" oninput="formatMoneyInput(this)" onchange="updateUnitPrice(' + idx + ', this.value)" onfocus="this.select()" />' +
                        '</div>' +
                        '<div>' +
                            '<div class="qi-label">Truoc VAT</div>' +
                            '<div class="qi-val">' + formatNumber(item.AmountExclVat) + '</div>' +
                        '</div>' +
                        '<div>' +
                            '<div class="qi-label">VAT %</div>' +
                            '<input type="text" inputmode="decimal" class="form-control form-control-sm text-end" ' +
                                'value="' + item.VatRate + '" onchange="updateVat(' + idx + ', this.value)" onfocus="this.select()" />' +
                        '</div>' +
                        '<div>' +
                            '<div class="qi-label">Sau VAT</div>' +
                            '<div class="qi-val qi-val-primary">' + formatNumber(item.AmountInclVat) + '</div>' +
                        '</div>' +
                    '</div>' +
                '</div>' +
            '</div>';
        }).join('');
    }

    // ══════════════════════════════════════════════
    // ITEM UPDATES
    // ══════════════════════════════════════════════
    function updateField(idx, field, val) {
        items[idx][field] = val;
    }

    function updateQtyOrPrice(idx) {
        var qty = parseDecimal(document.getElementById('qty_' + idx).value);
        items[idx].Quantity = qty;
        recalcUnitPriceFromImport(idx);
        recalcItemLine(idx);
        renderItems();
        recalcTotals();
    }

    function updateUnitPrice(idx, val) {
        items[idx].UnitPrice = parseMoney(val);
        recalcItemLine(idx);
        renderItems();
        recalcTotals();
    }

    function updateVat(idx, val) {
        items[idx].VatRate = parseDecimal(val);
        recalcItemLine(idx);
        renderItems();
        recalcTotals();
    }

    function updateImportPrice(idx, val) {
        items[idx].ImportPrice = parseMoney(val);
        recalcUnitPriceFromImport(idx);
        recalcItemLine(idx);
        renderItems();
        recalcTotals();
    }

    function updateExchangeRate(idx, val) {
        items[idx].ExchangeRate = parseMoney(val);
        recalcUnitPriceFromImport(idx);
        recalcItemLine(idx);
        renderItems();
        recalcTotals();
    }

    function updateShipping(idx, val) {
        items[idx].Shipping = parseMoney(val);
        recalcUnitPriceFromImport(idx);
        recalcItemLine(idx);
        renderItems();
        recalcTotals();
    }

    function updateCoefficient(idx, val) {
        var c = parseDecimal(val);
        items[idx].Coefficient = c > 0 ? c : 1;
        recalcUnitPriceFromImport(idx);
        recalcItemLine(idx);
        renderItems();
        recalcTotals();
    }

    function removeItem(idx) {
        items.splice(idx, 1);
        renderItems();
        recalcTotals();
    }

    // ══════════════════════════════════════════════
    // IMAGE UPLOAD
    // ══════════════════════════════════════════════
    var activePasteIdx = null;

    function triggerUpload(idx) {
        document.getElementById('imgFile_' + idx).click();
    }

    function uploadItemImage(idx, inputEl) {
        var file = inputEl.files[0];
        if (!file) return;
        _doUploadItemImage(idx, file);
    }

    function _doUploadItemImage(idx, file) {
        if (!file) return;
        if (!/^image\//i.test(file.type)) { alert('File khong phai la anh'); return; }

        var formData = new FormData();
        formData.append('file', file, file.name || ('paste-' + Date.now() + '.png'));

        // Show loading state on the image cell of this row
        var rowEl = document.querySelector('.qi-img-row[data-paste-idx="' + idx + '"]');
        var firstChild = rowEl ? rowEl.firstElementChild : null;
        if (firstChild) firstChild.style.opacity = '0.5';

        fetch('/Quotation/UploadItemImage', {
            method: 'POST',
            headers: { 'RequestVerificationToken': getAntiForgeryToken() },
            body: formData
        })
        .then(function (r) { return r.json(); })
        .then(function (res) {
            if (res.Success && res.Data && res.Data.url) {
                items[idx].ImageUrl = res.Data.url;
                renderItems();
            } else {
                alert(res.Message || 'Upload that bai');
                if (firstChild) firstChild.style.opacity = '1';
            }
        })
        .catch(function () {
            alert('Loi ket noi khi upload');
            if (firstChild) firstChild.style.opacity = '1';
        });
    }

    // Track which image cell is the paste target — set on click, drawn with a blue ring.
    document.addEventListener('click', function (e) {
        var row = e.target.closest('.qi-img-row[data-paste-idx]');
        // Clear any previous ring
        document.querySelectorAll('.qi-img-paste-target').forEach(function (el) {
            el.classList.remove('qi-img-paste-target');
        });
        if (!row) { activePasteIdx = null; return; }

        var idx = parseInt(row.dataset.pasteIdx, 10);
        var item = items[idx];
        // Mapped items can't change image (system avatar) — skip activation.
        if (!item || item.IsProductMapped) { activePasteIdx = null; return; }

        activePasteIdx = idx;
        row.classList.add('qi-img-paste-target');
    });

    // Document-level paste handler — fires when the user presses Ctrl+V anywhere.
    document.addEventListener('paste', function (e) {
        if (activePasteIdx === null || activePasteIdx === undefined) return;
        if (!items[activePasteIdx] || items[activePasteIdx].IsProductMapped) return;

        var cd = e.clipboardData || window.clipboardData;
        if (!cd || !cd.items) return;

        for (var i = 0; i < cd.items.length; i++) {
            var it = cd.items[i];
            if (it.kind === 'file' && /^image\//i.test(it.type)) {
                var file = it.getAsFile();
                if (file) {
                    e.preventDefault();
                    _doUploadItemImage(activePasteIdx, file);
                    return;
                }
            }
        }
    });

    function removeImage(idx) {
        items[idx].ImageUrl = '';
        renderItems();
    }

    function recalcUnitPriceFromImport(idx) {
        var item = items[idx];
        var rate = item.ExchangeRate > 0 ? item.ExchangeRate : 1;
        var importVnd = item.ImportPrice * rate;
        var coeff = item.Coefficient > 0 ? item.Coefficient : 1;
        var qty = item.Quantity > 0 ? item.Quantity : 1;
        item.UnitPrice = Math.round(importVnd / coeff + (item.Shipping || 0) / qty);
    }

    function recalcItemLine(idx) {
        var item = items[idx];
        item.AmountExclVat = Math.round(item.UnitPrice * item.Quantity);
        item.AmountInclVat = Math.round(item.AmountExclVat * (1 + item.VatRate / 100));
        item.LineTotal = item.AmountInclVat;
    }

    // ══════════════════════════════════════════════
    // TOTALS
    // ══════════════════════════════════════════════
    function recalcTotals() {
        var totalExcl = 0;
        var totalIncl = 0;
        items.forEach(function (item) {
            totalExcl += item.AmountExclVat;
            totalIncl += item.AmountInclVat;
        });
        document.getElementById('sumExclVat').textContent = formatNumber(totalExcl);
        document.getElementById('sumInclVat').textContent = formatNumber(totalIncl);
    }

    // ══════════════════════════════════════════════
    // EXPORT EXCEL
    // ══════════════════════════════════════════════
    function exportExcel() {
        if (items.length === 0) { alert('Chua co san pham de xuat'); return; }

        var customerId = parseInt(document.getElementById('frm_customerId').value);
        if (!customerId) { alert('Vui long lua chon khach hang'); return; }

        var btn = document.getElementById('btnExport');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Dang xuat...';

        var payload = {
            CustomerId: customerId,
            Coefficient: parseFloat(document.getElementById('frm_coefficient').value) || 1,
            Notes: null,
            Items: items
        };

        fetch('/Quotation/ExportExcel', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': getAntiForgeryToken()
            },
            body: JSON.stringify(payload)
        })
        .then(function (r) {
            if (!r.ok) throw new Error('Export failed');
            var disposition = r.headers.get('Content-Disposition');
            var filename = 'quotation.xlsx';
            if (disposition) {
                var match = disposition.match(/filename\*?=(?:UTF-8''|")([^";]+)/i);
                if (match) filename = decodeURIComponent(match[1].replace(/"/g, ''));
            }
            return r.blob().then(function (blob) { return { blob: blob, filename: filename }; });
        })
        .then(function (result) {
            var url = window.URL.createObjectURL(result.blob);
            var a = document.createElement('a');
            a.href = url;
            a.download = result.filename;
            document.body.appendChild(a);
            a.click();
            a.remove();
            window.URL.revokeObjectURL(url);
        })
        .catch(function (err) {
            alert('Loi xuat file: ' + err.message);
        })
        .finally(function () {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-file-earmark-excel me-1"></i> Xuat file bao gia';
        });
    }

    // ══════════════════════════════════════════════
    // SUBMIT
    // ══════════════════════════════════════════════
    // stayOnPage = true → quick save (no redirect, inline toast, switches to Edit mode after Create)
    // stayOnPage = false (default) → existing behavior: redirect to Detail on success
    function submitForm(stayOnPage) {
        var customerId = parseInt(document.getElementById('frm_customerId').value);
        var deadlineVal = document.getElementById('frm_deadline')?.value;
        if (!deadlineVal) { alert('Vui long chon han xu ly noi bo'); return; }
        if (!customerId) { alert('Vui long chon khach hang'); return; }
        if (items.length === 0) { alert('Vui long them it nhat 1 san pham'); return; }

        for (var vi = 0; vi < items.length; vi++) {
            if (!items[vi].ProductName || !items[vi].ProductName.trim()) {
                alert('Dong ' + (vi + 1) + ': Vui long nhap ten san pham');
                var inp = document.getElementById('req_' + vi);
                if (inp) inp.focus();
                return;
            }
        }

        var primaryBtn = document.getElementById('btnSubmit');
        var quickBtn = document.getElementById('btnQuickSave');
        var activeBtn = stayOnPage ? quickBtn : primaryBtn;
        var primaryLabel = '<i class="bi bi-check-lg me-1"></i> ' + 'Hoàn tất';
        var quickLabel = '<i class="bi bi-save me-1"></i> Lưu báo giá';

        function setBusy(busy) {
            [primaryBtn, quickBtn].forEach(function (b) { if (b) b.disabled = busy; });
            if (busy) {
                activeBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Đang lưu...';
            } else {
                if (primaryBtn) primaryBtn.innerHTML = primaryLabel;
                if (quickBtn) quickBtn.innerHTML = quickLabel;
            }
        }

        setBusy(true);

        var payload = {
            QuotationId: isEditMode ? parseInt(document.getElementById('frm_quotationId')?.value) : null,
            RfqId: document.getElementById('frm_rfqId')?.value ? parseInt(document.getElementById('frm_rfqId').value) : null,
            CustomerId: customerId,
            QuotationDate: new Date().toISOString().split('T')[0],
            ExpiryDate: null,
            Deadline: document.getElementById('frm_deadline')?.value || null,
            SalesPersonId: parseInt(document.getElementById('frm_salesPersonId').value) || 0,
            PaymentTerms: null,
            TaxRate: 8,
            Coefficient: parseFloat(document.getElementById('frm_coefficient').value) || 1,
            DiscountType: null,
            DiscountValue: null,
            Items: items
        };

        var url = isEditMode ? '/Quotation/Edit' : '/Quotation/Create';
        fetch(url, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': getAntiForgeryToken()
            },
            body: JSON.stringify(payload)
        })
        .then(r => r.json())
        .then(data => {
            if (data.Success && data.Data) {
                if (stayOnPage) {
                    var savedId = data.Data.QuotationId;
                    // Promote Create → Edit so subsequent quick-saves update the same quotation.
                    if (!isEditMode && savedId) {
                        isEditMode = true;
                        var hid = document.getElementById('frm_quotationId');
                        if (!hid) {
                            hid = document.createElement('input');
                            hid.type = 'hidden';
                            hid.id = 'frm_quotationId';
                            document.body.appendChild(hid);
                        }
                        hid.value = savedId;
                        try { history.replaceState(null, '', '/Quotation/Edit/' + savedId); } catch (e) {}
                    }
                    setBusy(false);
                    showQuickSaveToast(data.Message || 'Da luu bao gia');
                } else {
                    window.location.href = '/Quotation/Detail/' + data.Data.QuotationId;
                }
            } else {
                alert(data.Message || 'Loi luu bao gia');
                setBusy(false);
            }
        })
        .catch(function () {
            alert('Loi ket noi');
            setBusy(false);
        });
    }

    function showQuickSaveToast(msg) {
        var html = '<div class="alert alert-success alert-dismissible fade show alert-fixed" role="alert" style="z-index:10000;">' +
            '<i class="bi bi-check-circle me-2"></i>' + escapeHtml(msg) +
            '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>' +
            '</div>';
        document.body.insertAdjacentHTML('beforeend', html);
        var el = document.body.lastElementChild;
        setTimeout(function () {
            try { bootstrap.Alert.getOrCreateInstance(el).close(); } catch (e) { el.remove(); }
        }, 3000);
    }

    // ══════════════════════════════════════════════
    // HELPERS
    // ══════════════════════════════════════════════
    function formatNumber(n) {
        return Math.round(n).toLocaleString('vi-VN');
    }

    // Whitelist-evaluator: returns NaN if the string contains anything other
    // than digits, dots, and the four operators / parentheses / spaces.
    function evalArithmetic(str) {
        if (!/^[\d.+\-*/()\s]+$/.test(str)) return NaN;
        try {
            var r = Function('"use strict"; return (' + str + ')')();
            return isFinite(r) ? r : NaN;
        } catch (e) { return NaN; }
    }

    // Money parser — strips vi-VN thousand-separator dots, evaluates
    // arithmetic expressions, returns an integer.
    function parseMoney(s) {
        if (s === null || s === undefined || s === '') return 0;
        if (typeof s === 'number') return s;
        var str = String(s).trim().replace(/\s/g, '');
        if (str === '') return 0;
        var hasOp = /[+\-*/()]/.test(str);
        // For integer money fields, dots are thousand separators — strip them.
        str = str.replace(/\./g, '');
        if (!hasOp) {
            var n = parseInt(str, 10);
            return isNaN(n) ? 0 : n;
        }
        var r = evalArithmetic(str);
        return isNaN(r) ? 0 : Math.round(r);
    }

    // Decimal parser — keeps dots as decimal points, evaluates expressions,
    // returns a float. Used by Quantity / Coefficient / VAT %.
    function parseDecimal(s) {
        if (s === null || s === undefined || s === '') return 0;
        if (typeof s === 'number') return s;
        var str = String(s).trim().replace(/\s/g, '');
        if (str === '') return 0;
        if (!/[+\-*/()]/.test(str)) {
            var n = parseFloat(str);
            return isNaN(n) ? 0 : n;
        }
        var r = evalArithmetic(str);
        return isNaN(r) ? 0 : r;
    }

    // Live-format a money input while preserving caret position.
    function formatMoneyInput(input) {
        var oldVal = input.value;
        // Skip formatting while an arithmetic expression is being typed —
        // we don't want to strip operators / parens. parseMoney will eval on blur.
        if (/[+\-*/()]/.test(oldVal)) return;
        var caret = input.selectionStart;
        if (caret === null || caret === undefined) caret = oldVal.length;

        // Count digits left of caret in the old (mid-edit) value.
        var digitsLeft = 0;
        for (var i = 0; i < caret; i++) {
            var c = oldVal.charCodeAt(i);
            if (c >= 48 && c <= 57) digitsLeft++;
        }

        var rawDigits = oldVal.replace(/\D/g, '');
        if (rawDigits === '') { input.value = ''; return; }

        var formatted = parseInt(rawDigits, 10).toLocaleString('vi-VN');
        input.value = formatted;

        // Place caret after the same number of digits in the new string.
        var newPos = 0, seen = 0;
        if (digitsLeft > 0) {
            for (newPos = 0; newPos < formatted.length; newPos++) {
                var c2 = formatted.charCodeAt(newPos);
                if (c2 >= 48 && c2 <= 57) {
                    seen++;
                    if (seen === digitsLeft) { newPos++; break; }
                }
            }
        }
        try { input.setSelectionRange(newPos, newPos); } catch (e) { /* IE/non-text inputs */ }
    }

    function escapeHtml(str) {
        if (!str) return '';
        var d = document.createElement('div');
        d.appendChild(document.createTextNode(str));
        return d.innerHTML;
    }

    function getAntiForgeryToken() {
        return document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
    }

    // ── Searchable customer dropdown ────────────────────
    (function () {
        var customers = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Customers.Select(c => new { c.CustomerId, c.CustomerName, c.CustomerCode })));
        var input = document.getElementById('customerSearchInput');
        var hidden = document.getElementById('frm_customerId');
        var dd = document.getElementById('customerDropdown');

        function render(filter) {
            var kw = (filter || '').toLowerCase();
            var matches = customers.filter(function (c) {
                return !kw || c.CustomerName.toLowerCase().indexOf(kw) >= 0 || c.CustomerCode.toLowerCase().indexOf(kw) >= 0;
            });
            var html = '';
            if (matches.length === 0) {
                html = '<div class="text-muted small text-center py-2">Khong tim thay khach hang</div>';
            } else {
                matches.forEach(function (c) {
                    html += '<div class="cs-item" data-id="' + c.CustomerId + '" style="padding:6px 10px;cursor:pointer;font-size:0.82rem;">'
                        + escapeHtml(c.CustomerName) + ' <span class="text-muted">(' + escapeHtml(c.CustomerCode) + ')</span></div>';
                });
            }
            dd.innerHTML = html;
            dd.classList.remove('d-none');
        }

        input.addEventListener('focus', function () { render(input.value); });
        input.addEventListener('input', function () { hidden.value = ''; render(input.value); });

        dd.addEventListener('mouseover', function (e) {
            dd.querySelectorAll('.cs-item').forEach(function (el) { el.style.background = ''; });
            var item = e.target.closest('.cs-item');
            if (item) item.style.background = '#e0f2fe';
        });
        dd.addEventListener('click', function (e) {
            var item = e.target.closest('.cs-item');
            if (!item) return;
            hidden.value = item.getAttribute('data-id');
            input.value = item.textContent.trim();
            dd.classList.add('d-none');
        });

        document.addEventListener('click', function (e) {
            if (!document.getElementById('customerWrapper').contains(e.target))
                dd.classList.add('d-none');
        });
    })();
</script>
@Html.AntiForgeryToken()
