@model EV_ERP.Models.ViewModels.Quotations.QuotationListViewModel
@{
    ViewData["Title"] = "Báo giá";
    ViewData["Breadcrumbs"] = new List<BreadcrumbItem>
    {
        new("Trang chủ", "/"),
        new("Báo giá")
    };
    bool canEdit = ViewBag.CanEdit == true;
    bool isManager = ViewBag.IsManager == true;
    int currentUserId = (int)(ViewBag.CurrentUserId ?? 0);
    var p = Model.Paged;
}

<div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
    <div>
        <p class="text-muted small mb-0">Tổng cộng @p.TotalCount báo giá</p>
    </div>
    @if (canEdit)
    {
        <div class="d-flex gap-2">
            <a href="/Quotation/Create" class="btn btn-primary">
                <i class="bi bi-file-earmark-plus me-1"></i> Tạo báo giá
            </a>
            <button type="button" class="btn btn-outline-success" data-bs-toggle="modal" data-bs-target="#importModal">
                <i class="bi bi-file-earmark-arrow-up me-1"></i> Import báo giá
            </button>
        </div>
    }
</div>

<!-- Filter bar -->
<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-3">
        <form method="get" asp-action="Index" class="row g-2 align-items-end">
            <div class="col-12 col-sm-4 col-lg-3">
                <label class="form-label small fw-semibold mb-1">Tìm kiếm</label>
                <div class="input-group input-group-sm">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" name="keyword" class="form-control"
                           placeholder="Mã BG, tên KH..."
                           value="@Model.SearchKeyword" />
                </div>
            </div>
            <div class="col-6 col-sm-3 col-lg-2">
                <label class="form-label small fw-semibold mb-1">Trạng thái</label>
                <select name="status" class="form-select form-select-sm">
                    <option value="">Tất cả</option>
                    @foreach (var s in new[] { ("DRAFT","Nháp"), ("SENT","Đã gửi"), ("APPROVED","Đã duyệt"),
                        ("REJECTED","Từ chối"), ("AMEND","Chỉnh sửa"), ("EXPIRED","Hết hạn") })
                    {
                        <option value="@s.Item1" selected="@(Model.FilterStatus == s.Item1)">@s.Item2</option>
                    }
                </select>
            </div>
            <div class="col-6 col-sm-3 col-lg-2">
                <label class="form-label small fw-semibold mb-1">Khách hàng</label>
                <div class="position-relative" id="customerFilterWrapper">
                    <input type="hidden" name="customerId" id="filterCustomerId" value="@Model.FilterCustomerId" />
                    <input type="text" class="form-control form-control-sm" id="customerSearchInput"
                           placeholder="Tìm khách hàng..."
                           autocomplete="off"
                           value="@(Model.FilterCustomerId.HasValue ? Model.Customers.FirstOrDefault(c => c.CustomerId == Model.FilterCustomerId)?.CustomerName : "")" />
                    <div id="customerDropdown" class="position-absolute w-100 bg-white border rounded shadow-sm d-none"
                         style="z-index:1050;max-height:200px;overflow-y:auto;top:100%;left:0;">
                    </div>
                </div>
            </div>
            <div class="col-6 col-sm-3 col-lg-2">
                <label class="form-label small fw-semibold mb-1">Người tạo</label>
                <select name="createdBy" class="form-select form-select-sm">
                    <option value="">Tất cả</option>
                    @foreach (var u in Model.Users)
                    {
                        <option value="@u.UserId" selected="@(Model.FilterCreatedBy == u.UserId)">@u.FullName</option>
                    }
                </select>
            </div>
            <div class="col-6 col-sm-3 col-lg-2">
                <label class="form-label small fw-semibold mb-1">Phụ trách</label>
                <select name="salesPersonId" class="form-select form-select-sm">
                    <option value="">Tất cả</option>
                    @foreach (var u in Model.Users)
                    {
                        <option value="@u.UserId" selected="@(Model.FilterSalesPersonId == u.UserId)">@u.FullName</option>
                    }
                </select>
            </div>
            <div class="col-12 col-sm-2 col-lg-1 d-flex gap-1">
                <button type="submit" class="btn btn-primary btn-sm flex-fill">
                    <i class="bi bi-funnel me-1"></i>
                </button>
                <a href="/Quotation" class="btn btn-outline-secondary btn-sm" title="Reset (mặc định: do tôi tạo)">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Table -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (!p.Items.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-file-earmark-text" style="font-size: 3rem; opacity: 0.3;"></i>
                <p class="mt-2 mb-0">Không tìm thấy báo giá nào</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" style="font-size:0.875rem;">
                    <thead class="table-light">
                        <tr>
                            <th style="width:40px;">#</th>
                            <th>Mã báo giá</th>
                            <th>Khách hàng</th>
                            <th class="d-none d-md-table-cell">Ngày BG</th>
                            <th class="d-none d-lg-table-cell">SP</th>
                            <th class="d-none d-md-table-cell">Phụ trách</th>
                            <th>Trạng thái</th>
                            <th class="text-end">Tổng tiền</th>
                            <th style="width:90px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int idx = (p.PageIndex - 1) * p.PageSize + 1; }
                        @foreach (var q in p.Items)
                        {
                            <tr>
                                <td class="text-muted small">@(idx++)</td>
                                <td>
                                    <a href="/Quotation/Detail/@q.QuotationId"
                                       class="fw-semibold text-decoration-none text-dark link-hover">
                                        @q.QuotationNo
                                    </a>
                                </td>
                                <td>
                                    <div>@q.CustomerName</div>
                                    <div class="text-muted small">@q.CustomerCode</div>
                                </td>
                                <td class="d-none d-md-table-cell text-muted small">
                                    @q.QuotationDate.ToString("dd/MM/yyyy")
                                    @if (q.ExpiryDate.HasValue)
                                    {
                                        <div class="@(q.ExpiryDate < DateTime.Today ? "text-danger" : "")">
                                            HH: @q.ExpiryDate.Value.ToString("dd/MM/yyyy")
                                        </div>
                                    }
                                </td>
                                <td class="d-none d-lg-table-cell text-muted small">@q.ItemCount</td>                              
                                <td class="d-none d-md-table-cell text-muted small">@q.SalesPersonName</td>
                                <td>
                                    <span class="badge bg-@(q.StatusBadge)-subtle text-@(q.StatusBadge)-emphasis rounded-pill">
                                        <i class="bi bi-circle-fill me-1" style="font-size:0.4rem;vertical-align:middle;"></i>
                                        @q.StatusText
                                    </span>
                                </td>
                                <td class="text-end fw-semibold">
                                    @q.TotalAmount.ToString("N0")
                                    <span class="text-muted small">@q.Currency</span>
                                </td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a href="/Quotation/Detail/@q.QuotationId"
                                           class="btn btn-sm btn-outline-secondary" title="Xem">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (canEdit && q.Status == "DRAFT" && (q.CreatedBy == currentUserId || isManager))
                                        {
                                            <a href="/Quotation/Edit/@q.QuotationId"
                                               class="btn btn-sm btn-outline-primary" title="Sửa">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (p.TotalPages > 1)
            {
                <nav class="d-flex justify-content-center py-3">
                    <ul class="pagination pagination-sm mb-0">
                        @if (p.HasPrevious)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@BuildPageUrl(p.PageIndex - 1)">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                            </li>
                        }
                        @for (int pg = 1; pg <= p.TotalPages; pg++)
                        {
                            <li class="page-item @(pg == p.PageIndex ? "active" : "")">
                                <a class="page-link" href="@BuildPageUrl(pg)">@pg</a>
                            </li>
                        }
                        @if (p.HasNext)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@BuildPageUrl(p.PageIndex + 1)">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        }
    </div>
</div>

@functions {
    string BuildPageUrl(int page)
    {
        // Always emit createdBy (even when empty) so the controller's "no querystring → default to me"
        // logic doesn't re-apply on pagination after the user clears the creator filter.
        var qs = new Dictionary<string, string?> {
            ["keyword"] = Model.SearchKeyword,
            ["status"] = Model.FilterStatus,
            ["customerId"] = Model.FilterCustomerId?.ToString(),
            ["salesPersonId"] = Model.FilterSalesPersonId?.ToString(),
            ["createdBy"] = Model.FilterCreatedBy?.ToString() ?? "",
            ["page"] = page.ToString()
        };
        return "/Quotation?" + string.Join("&", qs.Where(kv => kv.Value != null).Select(kv => $"{kv.Key}={kv.Value}"));
    }
}

@if (canEdit)
{
    <!-- Import Modal -->
    <div class="modal fade" id="importModal" tabindex="-1" aria-labelledby="importModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="importModalLabel">
                        <i class="bi bi-file-earmark-arrow-up me-2"></i>Import báo giá từ Excel
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="importForm">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Khách hàng <span class="text-danger">*</span></label>
                            <div class="position-relative" id="importCustomerWrapper">
                                <input type="hidden" id="importCustomerId" />
                                <input type="text" class="form-control" id="importCustomerSearchInput"
                                       placeholder="Tìm khách hàng..." autocomplete="off" required />
                                <div id="importCustomerDropdown" class="position-absolute w-100 bg-white border rounded shadow-sm d-none"
                                     style="z-index:1060;max-height:240px;overflow-y:auto;top:100%;left:0;">
                                </div>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Nhân viên phụ trách <span class="text-danger">*</span></label>
                            <select id="importSalesPersonId" class="form-select" required>
                                <option value="">-- Chọn nhân viên --</option>
                                @foreach (var s in Model.SalesPersons)
                                {
                                    <option value="@s.UserId">@s.FullName (@s.UserCode)</option>
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Hạn xử lý nội bộ <span class="text-danger">*</span></label>
                            <input type="datetime-local" id="importDeadline" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">File Excel <span class="text-danger">*</span></label>
                            <input type="file" id="importFile" class="form-control" accept=".xlsx,.xls" required />
                            <div class="form-text">File Excel cùng định dạng với file xuất báo giá (Export)</div>
                        </div>
                    </form>
                    <div id="importResult" class="d-none mt-3"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                    <button type="button" class="btn btn-success" id="btnDoImport" onclick="doImport()">
                        <i class="bi bi-upload me-1"></i> Import
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<script>
    function doImport() {
        var customerId = document.getElementById('importCustomerId').value;
        var salesPersonId = document.getElementById('importSalesPersonId').value;
        var deadline = document.getElementById('importDeadline').value;
        var fileInput = document.getElementById('importFile');
        var resultDiv = document.getElementById('importResult');

        if (!customerId) { alert('Vui lòng chọn khách hàng'); return; }
        if (!salesPersonId) { alert('Vui lòng chọn nhân viên phụ trách'); return; }
        if (!deadline) { alert('Vui lòng chọn hạn xử lý'); return; }
        if (!fileInput.files.length) { alert('Vui lòng chọn file Excel'); return; }

        var formData = new FormData();
        formData.append('file', fileInput.files[0]);
        formData.append('customerId', customerId);
        formData.append('salesPersonId', salesPersonId);
        formData.append('deadline', deadline);

        var btn = document.getElementById('btnDoImport');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Đang xử lý...';
        resultDiv.classList.add('d-none');

        var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
        if (!token) {
            // Find token in cookie or meta
            var cookieToken = document.cookie.split(';').find(c => c.trim().startsWith('.AspNetCore.Antiforgery'));
        }

        fetch('/Quotation/ImportFromExcel', {
            method: 'POST',
            headers: {
                'RequestVerificationToken': token || ''
            },
            body: formData
        })
        .then(function(r) { return r.json(); })
        .then(function(res) {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-upload me-1"></i> Import';

            resultDiv.classList.remove('d-none');
            if (res.Success) {
                var msg = (res.Message || 'Import thành công').replace(/\n/g, '<br/>');
                resultDiv.className = 'alert alert-success mt-3';
                resultDiv.innerHTML = msg + '<br/><a href="/Quotation/Detail/' + res.Data.QuotationId +
                    '" class="btn btn-sm btn-primary mt-2"><i class="bi bi-eye me-1"></i>Xem báo giá</a>';
            } else {
                var msg = (res.Message || 'Import thất bại').replace(/\n/g, '<br/>');
                resultDiv.className = 'alert alert-danger mt-3';
                resultDiv.innerHTML = msg;
            }
        })
        .catch(function(err) {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-upload me-1"></i> Import';
            resultDiv.classList.remove('d-none');
            resultDiv.className = 'alert alert-danger mt-3';
            resultDiv.innerHTML = 'Lỗi: ' + err.message;
        });
    }

    // ── Searchable customer filter dropdown ─────────────
    (function () {
        var customers = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Customers.Select(c => new { c.CustomerId, c.CustomerName, c.CustomerCode })));
        var input = document.getElementById('customerSearchInput');
        var hidden = document.getElementById('filterCustomerId');
        var dd = document.getElementById('customerDropdown');

        function render(filter) {
            var kw = (filter || '').toLowerCase();
            var items = customers.filter(function (c) {
                return !kw || c.CustomerName.toLowerCase().indexOf(kw) >= 0 || c.CustomerCode.toLowerCase().indexOf(kw) >= 0;
            });
            var html = '<div class="cs-item" data-id="">Tất cả KH</div>';
            items.forEach(function (c) {
                html += '<div class="cs-item" data-id="' + c.CustomerId + '">' + c.CustomerName + ' <span class="text-muted">(' + c.CustomerCode + ')</span></div>';
            });
            dd.innerHTML = html;
            dd.classList.remove('d-none');
        }

        input.addEventListener('focus', function () { render(input.value); });
        input.addEventListener('input', function () { hidden.value = ''; render(input.value); });

        dd.addEventListener('click', function (e) {
            var item = e.target.closest('.cs-item');
            if (!item) return;
            var id = item.getAttribute('data-id');
            hidden.value = id;
            input.value = id ? item.textContent.trim() : '';
            dd.classList.add('d-none');
        });

        document.addEventListener('click', function (e) {
            if (!document.getElementById('customerFilterWrapper').contains(e.target))
                dd.classList.add('d-none');
        });
    })();

    // ── Searchable customer in import modal ─────────────
    (function () {
        var wrapper = document.getElementById('importCustomerWrapper');
        if (!wrapper) return; // import modal only rendered for canEdit

        var customers = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Customers.Select(c => new { c.CustomerId, c.CustomerName, c.CustomerCode })));
        var input = document.getElementById('importCustomerSearchInput');
        var hidden = document.getElementById('importCustomerId');
        var dd = document.getElementById('importCustomerDropdown');

        function render(filter) {
            var kw = (filter || '').toLowerCase();
            var items = customers.filter(function (c) {
                return !kw || c.CustomerName.toLowerCase().indexOf(kw) >= 0 || c.CustomerCode.toLowerCase().indexOf(kw) >= 0;
            });
            var html = '';
            if (items.length === 0) {
                html = '<div class="text-muted small text-center py-2">Không tìm thấy khách hàng</div>';
            } else {
                items.forEach(function (c) {
                    html += '<div class="cs-item" data-id="' + c.CustomerId + '">' + c.CustomerName + ' <span class="text-muted">(' + c.CustomerCode + ')</span></div>';
                });
            }
            dd.innerHTML = html;
            dd.classList.remove('d-none');
        }

        input.addEventListener('focus', function () { render(input.value); });
        input.addEventListener('input', function () { hidden.value = ''; render(input.value); });

        dd.addEventListener('click', function (e) {
            var item = e.target.closest('.cs-item');
            if (!item) return;
            var id = item.getAttribute('data-id');
            hidden.value = id;
            input.value = item.textContent.trim();
            dd.classList.add('d-none');
        });

        document.addEventListener('click', function (e) {
            if (!wrapper.contains(e.target)) dd.classList.add('d-none');
        });
    })();
</script>

@Html.AntiForgeryToken()

<style>
    .link-hover:hover { color: #2563eb !important; }
    .bg-secondary-subtle { background-color: #f1f5f9 !important; }
    .text-secondary-emphasis { color: #475569 !important; }
    .bg-info-subtle { background-color: #e0f2fe !important; }
    .text-info-emphasis { color: #0369a1 !important; }
    .bg-success-subtle { background-color: #dcfce7 !important; }
    .text-success-emphasis { color: #166534 !important; }
    .bg-danger-subtle { background-color: #fee2e2 !important; }
    .text-danger-emphasis { color: #991b1b !important; }
    .bg-warning-subtle { background-color: #fef9c3 !important; }
    .text-warning-emphasis { color: #854d0e !important; }
    .bg-dark-subtle { background-color: #e2e8f0 !important; }
    .text-dark-emphasis { color: #1e293b !important; }
    .cs-item { padding: 6px 10px; cursor: pointer; font-size: 0.82rem; }
    .cs-item:hover, .cs-item.active { background: #e0f2fe; }
</style>
