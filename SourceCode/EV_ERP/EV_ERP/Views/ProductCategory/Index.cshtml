@model EV_ERP.Models.ViewModels.Products.ProductCategoryListViewModel
@{
    ViewData["Title"] = "Danh mục sản phẩm";
    ViewData["Breadcrumbs"] = new List<BreadcrumbItem>
    {
        new("Trang chủ", "/"),
        new("Sản phẩm", "/Product"),
        new("Danh mục")
    };
}

<!-- Header -->
<div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
    <div>
        <h5 class="mb-0 fw-bold">Danh mục sản phẩm</h5>
        <div class="text-muted small">@Model.TotalCount danh mục</div>
    </div>
    <a href="/ProductCategory/Create" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i> Thêm danh mục
    </a>
</div>

<!-- Filter bar -->
<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-center">
            <div class="col-12 col-sm-5 col-md-4">
                <div class="input-group input-group-sm">
                    <span class="input-group-text bg-white border-end-0">
                        <i class="bi bi-search text-muted"></i>
                    </span>
                    <input name="keyword" value="@Model.SearchKeyword" type="text"
                           class="form-control border-start-0 ps-0"
                           placeholder="Tìm tên, mã danh mục..." />
                </div>
            </div>
            <div class="col-6 col-sm-4 col-md-3">
                <select name="status" class="form-select form-select-sm">
                    <option value="" selected="@(string.IsNullOrEmpty(Model.FilterStatus))">Tất cả</option>
                    <option value="active" selected="@(Model.FilterStatus == "active")">Đang hoạt động</option>
                    <option value="inactive" selected="@(Model.FilterStatus == "inactive")">Vô hiệu</option>
                </select>
            </div>
            <div class="col-6 col-sm-3 col-md-2 d-flex gap-1">
                <button type="submit" class="btn btn-sm btn-primary flex-grow-1">Lọc</button>
                <a href="/ProductCategory" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>
            @if (Model.RootNodes.Any())
            {
                <div class="col-auto ms-auto d-none d-md-block">
                    <button type="button" class="btn btn-sm btn-outline-secondary" onclick="expandAll()">
                        <i class="bi bi-arrows-expand me-1"></i> Mở rộng
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-secondary ms-1" onclick="collapseAll()">
                        <i class="bi bi-arrows-collapse me-1"></i> Thu gọn
                    </button>
                </div>
            }
        </form>
    </div>
</div>

<!-- Tree table -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (!Model.RootNodes.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-tags" style="font-size:2.5rem;opacity:.25;"></i>
                <p class="mt-3 mb-0">Không tìm thấy danh mục nào</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" style="font-size:0.875rem;">
                    <thead class="table-light">
                        <tr>
                            <th>Danh mục</th>
                            <th class="text-center d-none d-sm-table-cell" style="width:90px;">Sản phẩm</th>
                            <th class="text-center" style="width:110px;">Trạng thái</th>
                            <th style="width:60px;"></th>
                        </tr>
                    </thead>
                    <tbody id="category-tree">
                        @foreach (var root in Model.RootNodes)
                        {
                            @await Html.PartialAsync("_CategoryNode", root)
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<style>
    .bg-success-subtle { background-color: #dcfce7 !important; }
    .text-success-emphasis { color: #166534 !important; }
    .bg-secondary-subtle { background-color: #f1f5f9 !important; }
    .text-secondary-emphasis { color: #475569 !important; }
    .btn-xs { padding: .2rem .45rem; font-size: .8rem; }
    #category-tree tr { transition: opacity .1s; }
    #category-tree tr.tree-collapsed { display: none; }
    .tree-toggle:hover { color: #2563eb !important; }
</style>

@section Scripts {
    <script>
        var collapsedNodes = new Set();

        function toggleNode(id) {
            if (collapsedNodes.has(id)) expandNode(id);
            else collapseNode(id);
        }

        function collapseNode(id) {
            collapsedNodes.add(id);
            var icon = document.getElementById('icon-' + id);
            if (icon) icon.style.transform = 'rotate(-90deg)';

            // Hide all rows that are descendants of this node
            getDescendantRows(id).forEach(row => row.classList.add('tree-collapsed'));
        }

        function expandNode(id) {
            collapsedNodes.delete(id);
            var icon = document.getElementById('icon-' + id);
            if (icon) icon.style.transform = '';

            // Show direct children; leave collapsed grandchildren hidden
            getDirectChildRows(id).forEach(row => {
                row.classList.remove('tree-collapsed');
                // If this child itself was collapsed, keep its children hidden
                var childId = parseInt(row.dataset.nodeId);
                if (collapsedNodes.has(childId)) {
                    getDescendantRows(childId).forEach(r => r.classList.add('tree-collapsed'));
                }
            });
        }

        function getDirectChildRows(parentId) {
            return Array.from(document.querySelectorAll(
                '#category-tree tr[data-parent-id="' + parentId + '"]'));
        }

        function getDescendantRows(ancestorId) {
            // Collect all rows in the subtree using BFS
            var result = [];
            var queue = [ancestorId];
            while (queue.length > 0) {
                var current = queue.shift();
                var children = getDirectChildRows(current);
                children.forEach(row => {
                    result.push(row);
                    queue.push(parseInt(row.dataset.nodeId));
                });
            }
            return result;
        }

        function expandAll() {
            collapsedNodes.clear();
            document.querySelectorAll('#category-tree tr').forEach(r => r.classList.remove('tree-collapsed'));
            document.querySelectorAll('[id^="icon-"]').forEach(i => i.style.transform = '');
        }

        function collapseAll() {
            // Collapse all nodes that have children (depth 0 roots)
            document.querySelectorAll('#category-tree tr[data-depth="0"]').forEach(row => {
                var id = parseInt(row.dataset.nodeId);
                collapseNode(id);
            });
        }

        function toggleActive(id) {
            var form = new FormData();
            form.append('__RequestVerificationToken',
                document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '');

            fetch('/ProductCategory/ToggleActive/' + id, { method: 'POST', body: form })
                .then(r => r.json())
                .then(data => {
                    if (!data.Success) { alert(data.Message); return; }
                    var badge = document.querySelector('.status-badge-' + id);
                    if (!badge) return;
                    var wasActive = badge.textContent.trim() === 'Hoạt động';
                    badge.textContent = wasActive ? 'Vô hiệu' : 'Hoạt động';
                    badge.classList.remove(
                        'bg-success-subtle', 'text-success-emphasis',
                        'bg-secondary-subtle', 'text-secondary-emphasis');
                    if (wasActive) {
                        badge.classList.add('bg-secondary-subtle', 'text-secondary-emphasis');
                    } else {
                        badge.classList.add('bg-success-subtle', 'text-success-emphasis');
                    }
                });
        }
    </script>
    @Html.AntiForgeryToken()
}
