    // ══════════════════════════════════════════════════
    // ADVANCE REQUEST (v2.2 multi-advance, v2.5 % input + accountant flow)
    // ══════════════════════════════════════════════════
    var soPurchaseCost = @((Model.AdvanceSummary?.PurchaseCost ?? Model.PurchaseCost ?? 0).ToString(System.Globalization.CultureInfo.InvariantCulture));

    function resetAdvanceModalToCreate() {
        document.getElementById('advEditId').value = '';
        document.getElementById('advModalTitle').textContent = 'Tạm ứng mới';
        document.getElementById('advSubmitBtnLabel').textContent = 'Tạo phiếu tạm ứng';
        document.getElementById('advDate').value = new Date().toISOString().slice(0, 10);
        document.getElementById('advPurpose').value = '';
        document.getElementById('advNotes').value = '';
        var spw = document.getElementById('advSelfPaidWrap');
        if (spw) spw.classList.remove('d-none');
        var sp = document.getElementById('advSelfPaid');
        if (sp) sp.checked = false;
        document.querySelectorAll('.adv-line-amount').forEach(function (el) { el.value = ''; });
        document.querySelectorAll('.adv-line-percent').forEach(function (el) { el.value = ''; });
        updateAdvTotal();
        updateAggregatePercent();
    }

    function openCreateAdvanceModal() {
        var modal = document.getElementById('createAdvanceModal');
        if (!modal) return;
        resetAdvanceModalToCreate();
        new bootstrap.Modal(modal).show();
    }

    function editAdvance(advId) {
        var modal = document.getElementById('createAdvanceModal');
        if (!modal) return;
        fetch('/AdvanceRequest/GetForEdit?id=' + advId, { credentials: 'same-origin' })
            .then(function (r) { return r.json(); })
            .then(function (res) {
                if (!res.Success || !res.Data) { appAlert(res.Message || 'Không tải được dữ liệu'); return; }
                var d = res.Data;

                // Switch modal to edit mode
                resetAdvanceModalToCreate();
                document.getElementById('advEditId').value = d.AdvanceRequestId;
                document.getElementById('advModalTitle').textContent = 'Sửa tạm ứng ' + (d.RequestNo || '');
                document.getElementById('advSubmitBtnLabel').textContent = 'Lưu thay đổi';
                // "Tự thanh toán" chỉ áp dụng khi tạo mới — ẩn khi sửa.
                var spwEdit = document.getElementById('advSelfPaidWrap');
                if (spwEdit) spwEdit.classList.add('d-none');

                // Populate header
                if (d.RequestDate) {
                    document.getElementById('advDate').value = d.RequestDate.substring(0, 10);
                }
                document.getElementById('advPurpose').value = d.Purpose || '';
                document.getElementById('advNotes').value = d.Notes || '';

                // Populate per-line amounts
                (d.Items || []).forEach(function (it) {
                    if (!it.SOItemId) return;
                    var pn = (it.Purpose || '').trim().normalize('NFC');
                    var kind = (pn === 'Vận chuyển KH'.normalize('NFC')) ? 'customer_shipping' : ((pn === 'Vận chuyển'.normalize('NFC')) ? 'shipping' : 'product');
                    var input = document.querySelector('.adv-line-amount[data-so-item-id="' + it.SOItemId + '"][data-adv-kind="' + kind + '"]');
                    if (input) input.value = it.Amount;
                });
                // Derive each product's % from its amount, then refresh totals.
                recomputeAllPercents();
                updateAdvTotal();
                updateAggregatePercent();

                new bootstrap.Modal(modal).show();
            })
            .catch(function (err) { appAlert('Lỗi tải dữ liệu: ' + err); });
    }

    // Find the amount input on the same row as a given percent/amount input.
    function advRowAmountInput(el) {
        var tr = el.closest('tr');
        return tr ? tr.querySelector('.adv-line-amount') : null;
    }
    function advRowPercentInput(el) {
        var tr = el.closest('tr');
        return tr ? tr.querySelector('.adv-line-percent') : null;
    }

    // % nhập ở dòng SP → tính số tiền = chi phí dòng × % / 100
    function syncLineFromPercent(percentEl) {
        var cost = parseFloat(percentEl.getAttribute('data-line-cost')) || 0;
        var pct = parseFloat(percentEl.value);
        // Giới hạn % tạm ứng tối đa 100% (không vượt quá chi phí).
        if (!isNaN(pct) && pct > 100) {
            pct = 100;
            percentEl.value = 100;
            if (typeof appToast === 'function') appToast('% tạm ứng tối đa là 100%', 'warning');
        }
        var amountEl = advRowAmountInput(percentEl);
        if (!amountEl) return;
        if (cost > 0 && !isNaN(pct) && pct > 0) {
            amountEl.value = Math.round(cost * pct / 100);
        } else if (percentEl.value === '' || isNaN(pct) || pct <= 0) {
            amountEl.value = '';
        }
        updateAdvTotal();
        updateAggregatePercent();
    }

    // Số tiền nhập tay ở dòng SP → tính ngược lại % = số tiền / chi phí dòng × 100
    function syncLineFromAmount(amountEl) {
        var cost = parseFloat(amountEl.getAttribute('data-line-cost')) || 0;
        var amt = parseFloat(amountEl.value);
        // Không cho nhập số tiền tạm ứng vượt quá chi phí (100%).
        if (cost > 0 && !isNaN(amt) && amt > cost) {
            amt = Math.round(cost);
            amountEl.value = amt;
            if (typeof appToast === 'function') appToast('Số tiền tạm ứng không được vượt quá chi phí dòng', 'warning');
        }
        var percentEl = advRowPercentInput(amountEl);
        if (percentEl && cost > 0) {
            percentEl.value = (!isNaN(amt) && amt > 0)
                ? +(amt / cost * 100).toFixed(2)
                : '';
        }
        updateAdvTotal();
        updateAggregatePercent();
    }

    // Tính lại % của mọi dòng SP từ số tiền hiện có (dùng khi mở chế độ sửa).
    function recomputeAllPercents() {
        document.querySelectorAll('.adv-line-amount').forEach(function (amountEl) {
            var cost = parseFloat(amountEl.getAttribute('data-line-cost')) || 0;
            var amt = parseFloat(amountEl.value);
            var percentEl = advRowPercentInput(amountEl);
            if (percentEl && cost > 0) {
                percentEl.value = (!isNaN(amt) && amt > 0) ? +(amt / cost * 100).toFixed(2) : '';
            }
        });
    }

    // % tổng hợp (chỉ hiển thị) = Σ tạm ứng SP / Σ chi phí mua SP × 100
    function updateAggregatePercent() {
        var totalAmt = 0, totalCost = 0;
        document.querySelectorAll('.adv-line-amount').forEach(function (amountEl) {
            var cost = parseFloat(amountEl.getAttribute('data-line-cost')) || 0;
            var amt = parseFloat(amountEl.value);
            if (cost > 0) {
                totalCost += cost;
                if (!isNaN(amt) && amt > 0) totalAmt += amt;
            }
        });
        var pct = totalCost > 0 ? (totalAmt / totalCost * 100) : 0;
        var el = document.getElementById('advPercent');
        if (el) el.value = (Math.round(pct * 100) / 100).toLocaleString('vi-VN');
    }

    function updateAdvTotal() {
        var total = 0;
        document.querySelectorAll('.adv-line-amount').forEach(function (el) {
            var v = parseFloat(el.value);
            if (!isNaN(v) && v > 0) total += v;
        });
        document.getElementById('advTotalDisplay').value = total.toLocaleString('vi-VN');
    }

    // Wire up inputs: product % drives amount; manual amount edit drives % back.
    document.querySelectorAll('.adv-line-percent').forEach(function (el) {
        el.addEventListener('input', function () { syncLineFromPercent(el); });
    });
    document.querySelectorAll('.adv-line-amount').forEach(function (el) {
        el.addEventListener('input', function () { syncLineFromAmount(el); });
    });

    function confirmCreateAdvance() {
        var items = [];
        // Guard: không cho số tiền tạm ứng vượt quá chi phí dòng (>100%).
        var overLimitEl = null;
        document.querySelectorAll('.adv-line-amount').forEach(function (el) {
            var v = parseFloat(el.value);
            var cost = parseFloat(el.getAttribute('data-line-cost')) || 0;
            if (!isNaN(v) && v > 0 && cost > 0 && v > cost) overLimitEl = el;
        });
        if (overLimitEl) {
            appAlert('Số tiền tạm ứng không được vượt quá chi phí dòng (tối đa 100%).');
            overLimitEl.focus();
            return;
        }
        document.querySelectorAll('.adv-line-amount').forEach(function (el) {
            var v = parseFloat(el.value);
            if (!isNaN(v) && v > 0) {
                var raw = el.getAttribute('data-so-item-id');
                // Mark the shipping allocation row so it can be told apart from the general one.
                var advKind = el.getAttribute('data-adv-kind');
                var purpose = advKind === 'shipping' ? 'Vận chuyển' : (advKind === 'customer_shipping' ? 'Vận chuyển KH' : null);
                items.push({
                    SOItemId: raw ? parseInt(raw) : null,
                    Amount: v,
                    Purpose: purpose
                });
            }
        });

        if (items.length === 0) {
            appAlert('Nhập ít nhất 1 dòng có số tiền > 0');
            return;
        }
        var purpose = document.getElementById('advPurpose').value.trim();
        if (!purpose) {
            appAlert('Vui lòng nhập Mục đích');
            return;
        }

        var selfPaidEl = document.getElementById('advSelfPaid');
        var body = {
            RequestDate: document.getElementById('advDate').value || null,
            Purpose: purpose,
            Notes: document.getElementById('advNotes').value.trim(),
            SelfPaid: !!(selfPaidEl && selfPaidEl.checked),
            Items: items
        };

        var editId = document.getElementById('advEditId').value;
        var url = editId
            ? '/AdvanceRequest/Update?id=' + editId + '&salesOrderId=' + soId
            : '/AdvanceRequest/Create?salesOrderId=' + soId;

        postAction(url, body, function (data) {
            if (data.Success) {
                bootstrap.Modal.getInstance(document.getElementById('createAdvanceModal')).hide();
                location.reload();
            } else {
                appAlert(data.Message || 'Lỗi');
            }
        });
    }

    async function deleteAdvance(advId, advNo) {
        if (!await appConfirm('Xóa đề nghị tạm ứng ' + advNo + '?')) return;
        postAction('/AdvanceRequest/Delete?id=' + advId + '&salesOrderId=' + soId, null, function (data) {
            if (data.Success) location.reload();
            else appAlert(data.Message || 'Lỗi');
        });
