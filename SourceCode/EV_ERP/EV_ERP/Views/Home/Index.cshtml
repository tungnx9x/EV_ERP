@model EV_ERP.Models.ViewModels.Dashboard.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<!-- Welcome banner -->
<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm"
             style="background: linear-gradient(135deg, #1a2d4e, #2563eb); color:#fff;">
            <div class="card-body py-4 px-4">
                <div class="d-flex align-items-center gap-3">
                    <div style="width:52px;height:52px;border-radius:50%;
                                background:rgba(255,255,255,0.2);
                                display:flex;align-items:center;justify-content:center;
                                font-size:1.5rem;font-weight:700;flex-shrink:0;">
                        @Model.CurrentUser.FullName[0].ToString().ToUpper()
                    </div>
                    <div>
                        <h5 class="mb-0 fw-bold">Xin chào, @Model.CurrentUser.FullName!</h5>
                        <small style="opacity:.8;">
                            @Model.CurrentUser.RoleName &bull; @Model.CurrentUser.UserCode
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@{
    var dashboardPartial = Model.CurrentUser.RoleCode switch
    {
        "MANAGER" => "_ManagerDashboard",
        "ADMIN"   => "_ManagerDashboard",
        "SALES"   => "_ManagerDashboard",
        _         => "_ManagerDashboard"
    };
}
<partial name="@dashboardPartial" model="Model" />

<style>
    .stat-icon {
        width: 46px; height: 46px; border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }
    .stat-icon i { font-size: 1.3rem; }
    .stat-value { font-size: 1.5rem; font-weight: 700; color: #1e293b; line-height: 1.2; }
    .bg-primary-subtle { background-color: #dbeafe !important; }
    .text-primary { color: #2563eb !important; }
    .bg-secondary-subtle { background-color: #f1f5f9 !important; }
    .text-secondary { color: #64748b !important; }
</style>
